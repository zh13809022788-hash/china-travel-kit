# Cloudflare Pages _headers — KEEP MINIMAL
#
# DO NOT add Content-Type rules! Cloudflare Pages auto-detects MIME
# types perfectly by file extension. Every time someone added
# Content-Type here, it broke the site. See MEMORY.md for war stories.

/*
  Cache-Control: public, max-age=300, s-maxage=3600
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()

/sitemap*.xml
  Cache-Control: public, max-age=3600, s-maxage=3600

/rss.xml
  Cache-Control: public, max-age=3600, s-maxage=3600
