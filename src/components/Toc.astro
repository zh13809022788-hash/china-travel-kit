---
// Simple in-page table of contents. Anchors to H2 ids the page sets itself.
// Renders nothing when there are no items.
export interface TocItem {
  id: string;
  label: string;
}

export interface Props {
  items: TocItem[];
  title?: string;
}

const { items = [], title = 'On this page' } = Astro.props;
---

{
  items.length > 0 && (
    <nav
      aria-label="Table of contents"
      class="my-8 rounded-xl border border-gray-200 bg-gray-50 p-5"
    >
      <p class="text-sm font-semibold uppercase tracking-wide text-gray-500">{title}</p>
      <ul class="mt-3 space-y-2">
        {items.map((item) => (
          <li>
            <a
              href={`#${item.id}`}
              class="text-sm text-brand-600 hover:underline"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  )
}
