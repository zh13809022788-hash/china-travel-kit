---
// Compact inline newsletter CTA — one line, sits below article title
// Appears at top of blog posts for maximum visibility

const { locale = 'en' } = Astro.props;
const t = (key: string) => {
  const i18n: Record<string, Record<string, string>> = {
    en: {
      cta: 'Get weekly China travel tips',
      desc: 'Free newsletter. No spam.',
      placeholder: 'your@email.com',
      btn: 'Subscribe',
      subscribing: '...',
      success: 'Thanks! Check your email.',
      already: 'Already subscribed!',
      error: 'Try again',
    },
    'zh-tw': {
      cta: '每週獲取中國旅遊資訊',
      desc: '免費電子報，無垃圾郵件',
      placeholder: 'your@email.com',
      btn: '訂閱',
      subscribing: '...',
      success: '感謝訂閱！請查收確認郵件。',
      already: '您已訂閱！',
      error: '請重試',
    },
    ja: {
      cta: '中国旅行情報を毎週受信',
      desc: '無料ニュースレター',
      placeholder: 'your@email.com',
      btn: '購読',
      subscribing: '...',
      success: 'ご購読ありがとうございます！',
      already: '既に購読済みです！',
      error: 'もう一度お試しください',
    },
    ko: {
      cta: '주간 중국 여행 정보 받기',
      desc: '무료 뉴스레터',
      placeholder: 'your@email.com',
      btn: '구독',
      subscribing: '...',
      success: '구독해 주셔서 감사합니다!',
      already: '이미 구독 중입니다!',
      error: '다시 시도해 주세요',
    },
    ru: {
      cta: 'Еженедельные советы по Китаю',
      desc: 'Бесплатная рассылка',
      placeholder: 'your@email.com',
      btn: 'Подписаться',
      subscribing: '...',
      success: 'Спасибо за подписку!',
      already: 'Вы уже подписаны!',
      error: 'Попробуйте ещё раз',
    },
    fr: {
      cta: 'Conseils Chine chaque semaine',
      desc: 'Newsletter gratuite',
      placeholder: 'votre@email.com',
      btn: "S'abonner",
      subscribing: '...',
      success: 'Merci pour votre abonnement !',
      already: 'Déjà abonné !',
      error: 'Réessayez',
    },
    de: {
      cta: 'Wöchentliche China-Tipps',
      desc: 'Kostenloser Newsletter',
      placeholder: 'ihre@email.com',
      btn: 'Abonnieren',
      subscribing: '...',
      success: 'Danke fürs Abonnieren!',
      already: 'Bereits angemeldet!',
      error: 'Erneut versuchen',
    },
    es: {
      cta: 'Consejos de China semanales',
      desc: 'Boletín gratuito',
      placeholder: 'tu@email.com',
      btn: 'Suscribirse',
      subscribing: '...',
      success: '¡Gracias por suscribirte!',
      already: '¡Ya está suscrito!',
      error: 'Inténtalo de nuevo',
    },
  };
  const lang = i18n[locale as string] || i18n['en'];
  return lang[key] || (i18n['en'])[key] || '';
};
---

<div class="my-6 flex items-center gap-3 rounded-lg border border-brand-100 bg-brand-50/60 p-4 sm:flex-row flex-col" data-newsletter-inline>
  <div class="min-w-0 flex-1">
    <p class="text-sm font-semibold text-gray-900">{t('cta')}</p>
    <p class="text-xs text-gray-500">{t('desc')}</p>
  </div>
  <form class="flex w-full gap-2 sm:w-auto" data-newsletter-inline-form>
    <input
      type="email"
      name="email"
      placeholder={t('placeholder')}
      required
      autocomplete="email"
      class="min-w-0 flex-1 rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 placeholder-gray-400 focus:border-brand-400 focus:outline-none focus:ring-1 focus:ring-brand-200 sm:w-48"
    />
    <button type="submit" class="shrink-0 rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white transition-colors hover:bg-brand-700 disabled:opacity-60" data-newsletter-inline-btn>
      {t('btn')}
    </button>
  </form>
  <span class="hidden text-xs" data-newsletter-inline-msg></span>
</div>

<script is:inline define:vars={{
  texts: {
    subscribing: t('subscribing'),
    success: t('success'),
    already: t('already'),
    error: t('error'),
    btn: t('btn'),
  }
}}>
  (function() {
    const I18N = texts;
    document.querySelectorAll('[data-newsletter-inline]').forEach(function(el) {
      const form = el.querySelector('[data-newsletter-inline-form]');
      const btn = el.querySelector('[data-newsletter-inline-btn]');
      const msg = el.querySelector('[data-newsletter-inline-msg]');
      const input = el.querySelector('input[name="email"]');
      if (!form || !btn || !msg || !input) return;

      let done = false;
      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        if (done) return;
        const email = input.value.trim();
        if (!email) return;

        done = true;
        btn.disabled = true;
        btn.textContent = I18N.subscribing;

        try {
          const res = await fetch('/api/subscribe', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
          });
          const data = await res.json();
          if (data.message === 'subscribed' || data.message === 'already_subscribed') {
            form.style.display = 'none';
            msg.className = 'mt-1 text-sm font-medium text-green-600 block';
            msg.textContent = data.message === 'already_subscribed' ? I18N.already : I18N.success;
          } else {
            msg.className = 'mt-1 text-sm text-red-600 block';
            msg.textContent = data.error || I18N.error;
            done = false;
            btn.disabled = false;
            btn.textContent = I18N.btn;
          }
        } catch {
          msg.className = 'mt-1 text-sm text-red-600 block';
          msg.textContent = I18N.error;
          done = false;
          btn.disabled = false;
          btn.textContent = I18N.btn;
        }
      });
    });
  })();
</script>
