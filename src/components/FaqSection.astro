---
export interface FaqItem {
  question: string;
  answer: string;
}

export interface Props {
  items: FaqItem[];
  title?: string;
  locale?: string;
}

const { items = [], title: propTitle, locale = 'en' } = Astro.props;
const normalizedLocale = (locale as string).toLowerCase();

const FAQ_TITLES: Record<string, string> = {
  en: 'Frequently Asked Questions',
  'zh-tw': '常見問題',
  ja: 'よくある質問',
  ko: '자주 묻는 질문',
  ru: 'Часто задаваемые вопросы',
  fr: 'Questions fréquemment posées',
  de: 'Häufig gestellte Fragen',
  es: 'Preguntas frecuentes',
};

const title = propTitle || (FAQ_TITLES[normalizedLocale] ?? FAQ_TITLES['en']);
---

{items.length > 0 && (
  <section class="my-10" aria-labelledby="faq-heading">
    <h2 id="faq-heading" class="text-2xl font-bold text-gray-900">{title}</h2>
    <div class="mt-6 divide-y divide-gray-200 rounded-xl border border-gray-200">
      {items.map((item) => (
        <details class="group px-5 py-4">
          <summary class="flex cursor-pointer list-none items-center justify-between text-base font-semibold text-gray-900">
            <span>{item.question}</span>
            <svg
              class="h-5 w-5 shrink-0 text-gray-400 transition-transform group-open:rotate-180"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </summary>
          <p class="mt-3 text-sm leading-relaxed text-gray-600">{item.answer}</p>
        </details>
      ))}
    </div>
  </section>
)}
