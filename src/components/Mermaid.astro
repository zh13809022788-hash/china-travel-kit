---
/**
 * Mermaid.astro — Client-side Mermaid diagram renderer.
 * 
 * After page load, finds all <code class="language-mermaid"> blocks
 * rendered from ```mermaid fenced code in markdown articles,
 * and replaces each with a rendered SVG diagram.
 * 
 * Loads Mermaid library from CDN only if a mermaid block is detected.
 */
---

{
  /* Render a zero-width marker so the client script knows to scan the page */
}
<div class="mermaid-marker" style="display:none" aria-hidden="true"></div>

<script>
  (async function initMermaid() {
    const blocks = document.querySelectorAll('code.language-mermaid');
    if (!blocks.length) return;

    // Load Mermaid library
    const script = document.createElement('script');
    script.src = 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js';
    script.onload = async () => {
      // Initialize with a light theme matching the site
      window.mermaid.initialize({
        startOnLoad: false,
        theme: 'default',
        themeVariables: {
          primaryColor: '#e8f0fe',
          primaryBorderColor: '#1a73e8',
          lineColor: '#5f6368',
          fontSize: '14px',
          fontFamily: 'system-ui, -apple-system, sans-serif',
        },
      });

      for (const code of blocks) {
        const pre = code.parentElement;
        if (!pre || pre.tagName !== 'PRE') continue;

        const source = code.textContent || '';
        if (!source.trim()) continue;

        try {
          // Render to SVG
          const id = 'mermaid-' + Math.random().toString(36).slice(2, 9);
          const { svg } = await window.mermaid.render(id, source);
          
          // Replace the <pre> with rendered SVG
          const wrapper = document.createElement('div');
          wrapper.className = 'mermaid-wrapper my-6 overflow-x-auto rounded-lg border border-gray-200 bg-white p-4';
          wrapper.innerHTML = svg;
          pre.parentElement?.replaceChild(wrapper, pre);
        } catch (err) {
          console.warn('Mermaid render error:', err);
          // Keep the raw source as fallback
          pre.className = 'mermaid-error rounded-lg border border-red-200 bg-red-50 p-4 text-xs text-red-700';
        }
      }
    };

    document.head.appendChild(script);
  })();
</script>
