---
import LanguageSwitcher from './LanguageSwitcher.astro';

type LocaleCode = 'en' | 'zh-TW' | 'ja' | 'ko' | 'ru' | 'fr' | 'de' | 'es';

export interface Props {
  locale?: LocaleCode;
  alternates?: Partial<Record<LocaleCode, string>>;
}

const { locale = 'en', alternates } = Astro.props;

// Multilingual nav label map
const navLabels: Record<string, Record<string, string>> = {
  'Home':           { en:'Home', 'zh-TW':'首頁', ja:'ホーム', ko:'홈', ru:'Главная', fr:'Accueil', de:'Start', es:'Inicio' },
  'Plan Your Trip': { en:'Plan Your Trip', 'zh-TW':'行程規劃', ja:'旅行計画', ko:'여행 계획', ru:'План поездки', fr:'Planifier', de:'Reise planen', es:'Planificar' },
  'Apps & Setup':   { en:'Apps & Setup', 'zh-TW':'App 與設定', ja:'アプリ設定', ko:'앱 설정', ru:'Приложения', fr:'Applications', de:'Apps', es:'Apps' },
  'Payments':       { en:'Payments', 'zh-TW':'付款', ja:'決済', ko:'결제', ru:'Оплата', fr:'Paiement', de:'Bezahlung', es:'Pagos' },
  'Internet':       { en:'Internet', 'zh-TW':'網路', ja:'通信', ko:'인터넷', ru:'Интернет', fr:'Internet', de:'Internet', es:'Internet' },
  'Transport':      { en:'Transport', 'zh-TW':'交通', ja:'交通', ko:'교통', ru:'Транспорт', fr:'Transport', de:'Verkehr', es:'Transporte' },
  'Cities':         { en:'Cities', 'zh-TW':'城市', ja:'都市', ko:'도시', ru:'Города', fr:'Villes', de:'Städte', es:'Ciudades' },
  'Food':           { en:'Food', 'zh-TW':'美食', ja:'グルメ', ko:'음식', ru:'Еда', fr:'Gastronomie', de:'Essen', es:'Comida' },
  'Trip Planning':  { en:'Trip Planning', 'zh-TW':'行前準備', ja:'旅行準備', ko:'여행 준비', ru:'Планирование', fr:'Préparation', de:'Reiseplanung', es:'Planificación' },
  'Trip Planner':   { en:'Trip Planner', 'zh-TW':'行程工具', ja:'旅行プランナー', ko:'여행 플래너', ru:'Планировщик', fr:'Planificateur', de:'Reiseplaner', es:'Planificador' },
  'Tools':          { en:'Tools', 'zh-TW':'工具', ja:'ツール', ko:'도구', ru:'Инструменты', fr:'Outils', de:'Werkzeuge', es:'Herramientas' },
  'Series':         { en:'Series', 'zh-TW':'系列', ja:'シリーズ', ko:'시리즈', ru:'Серии', fr:'Séries', de:'Serien', es:'Series' },
  'Long Stay':      { en:'Long Stay', 'zh-TW':'長住', ja:'長期滞在', ko:'장기 체류', ru:'Долгое проживание', fr:'Long séjour', de:'Langzeitaufenthalt', es:'Estancia larga' },
  'Digital Nomads': { en:'Digital Nomads', 'zh-TW':'數位遊民', ja:'デジタルノマド', ko:'디지털 노마드', ru:'Цифровые кочевники', fr:'Nomades digitaux', de:'Digitale Nomaden', es:'Nómadas digitales' },
  'Help':           { en:'Help', 'zh-TW':'幫助', ja:'ヘルプ', ko:'도움말', ru:'Помощь', fr:'Aide', de:'Hilfe', es:'Ayuda' },
  'About':          { en:'About', 'zh-TW':'關於', ja:'概要', ko:'소개', ru:'О нас', fr:'À propos', de:'Über uns', es:'Acerca de' },
};
const t = (key: string) => navLabels[key]?.[locale] ?? key;

const localePrefixes: Record<string, string> = { en: '/', 'zh-TW': '/zh-tw/', ja: '/ja/', ko: '/ko/', ru: '/ru/', fr: '/fr/', de: '/de/', es: '/es/' };

const navLinks = [
  { href: '/', label: t('Home') },
  { href: '/resources/', label: t('Plan Your Trip') },
  { href: '/apps/', label: t('Apps & Setup') },
  { href: '/payment/', label: t('Payments') },
  { href: '/esim/', label: t('Internet') },
  { href: '/transport/', label: t('Transport') },
  { href: '/cities/', label: t('Cities') },
  { href: '/food/', label: t('Food') },
];
const secondaryLinks = [
  { href: '/essentials/', label: t('Trip Planning') },
  { href: '/trip-planner/', label: t('Trip Planner') },
  { href: '/tools/', label: t('Tools') },
  { href: '/series/', label: t('Series') },
  { href: '/long-stay/', label: t('Long Stay') },
  { href: '/digital-nomads/', label: t('Digital Nomads') },
  { href: '/travel-help/', label: t('Help') },
  { href: '/about/', label: t('About') },
];
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const isHome = pathname === '/' || Object.values(localePrefixes).includes(pathname);
const homePath = localePrefixes[locale] ?? '/';

const getPath = (key: LocaleCode) => {
  // Preferred: exact translation exists for this page
  const alt = alternates?.[key];
  if (alt) return alt;
  // Fallback: link to the language homepage so the switcher always has valid options
  const homeFallback: Record<LocaleCode, string> = { en: '/', 'zh-TW': '/zh-tw/', ja: '/ja/', ko: '/ko/', ru: '/ru/', fr: '/fr/', de: '/de/', es: '/es/' };
  return homeFallback[key];
};
---

<header class="sticky top-0 z-40 border-b border-gray-200 bg-white/95 backdrop-blur">
  <nav class="container-page flex h-16 items-center justify-between gap-3">
    <a href={homePath} class="flex shrink-0 items-center gap-2 font-bold text-gray-900 hover:no-underline">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-brand-600 text-white">CT</span>
      <span class="hidden text-lg sm:inline">ChinaTripBox</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-3 lg:flex xl:gap-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium whitespace-nowrap transition-colors hover:text-brand-600 hover:no-underline',
              isActive(link.href) ? 'text-brand-600' : 'text-gray-700',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right side: language + hamburger -->
    <div class="flex items-center gap-2">
      <LanguageSwitcher
        currentLocale={locale}
        enPath={getPath('en')}
        zhTwPath={getPath('zh-TW')}
        jaPath={getPath('ja')}
        koPath={getPath('ko')}
        ruPath={getPath('ru')}
        frPath={getPath('fr')}
        dePath={getPath('de')}
        esPath={getPath('es')}
      />

      <!-- Mobile hamburger -->
      <button
        id="menu-toggle"
        class="inline-flex items-center justify-center rounded-md p-2 text-gray-700 lg:hidden"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-gray-200 lg:hidden">
    <div class="container-page py-2">
    <ul class="flex flex-col">
      {[...navLinks, ...secondaryLinks].map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'block py-2.5 text-sm font-medium hover:no-underline',
              isActive(link.href) ? 'text-brand-600' : 'text-gray-700',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(open === false));
  });
</script>
