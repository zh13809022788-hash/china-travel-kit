---
import LanguageSwitcher from './LanguageSwitcher.astro';

type LocaleCode = 'en' | 'zh-TW' | 'ja' | 'ko' | 'ru' | 'fr' | 'de' | 'es';

export interface Props {
  locale?: LocaleCode;
  alternates?: Partial<Record<LocaleCode, string>>;
}

const { locale = 'en', alternates } = Astro.props;
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/resources/', label: 'Start Here' },
  { href: '/essentials/', label: 'Essentials' },
  { href: '/payment/', label: 'Payments' },
  { href: '/esim/', label: 'Internet' },
  { href: '/transport/', label: 'Transport' },
  { href: '/cities/', label: 'Cities' },
  { href: '/food/', label: 'Food' },
  { href: '/series/', label: 'Series' },
  { href: '/tools/', label: 'Tools' },
];
const secondaryLinks = [
  { href: '/trip-planner/', label: 'Trip Planner' },
  { href: '/long-stay/', label: 'Long Stay' },
  { href: '/digital-nomads/', label: 'Digital Nomads' },
  { href: '/travel-help/', label: 'Help' },
  { href: '/about/', label: 'About' },
];
const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);

const localePrefixes: Record<string, string> = { en: '/', 'zh-TW': '/zh-tw/', ja: '/ja/', ko: '/ko/', ru: '/ru/', fr: '/fr/', de: '/de/', es: '/es/' };
const isHome = pathname === '/' || Object.values(localePrefixes).includes(pathname);
const homePath = localePrefixes[locale] ?? '/';

const getPath = (key: LocaleCode) => {
  if (key === 'en') { const a = alternates?.en; return a ?? (isHome ? '/' : undefined); }
  if (key === 'zh-TW') { const a = alternates?.['zh-TW']; return a ?? (isHome ? '/zh-tw/' : undefined); }
  if (key === 'ja') { const a = alternates?.ja; return a ?? (isHome ? '/ja/' : undefined); }
  if (key === 'ko') { const a = alternates?.ko; return a ?? (isHome ? '/ko/' : undefined); }
  if (key === 'ru') { const a = alternates?.ru; return a ?? (isHome ? '/ru/' : undefined); }
  if (key === 'fr') { const a = alternates?.fr; return a ?? (isHome ? '/fr/' : undefined); }
  if (key === 'de') { const a = alternates?.de; return a ?? (isHome ? '/de/' : undefined); }
  if (key === 'es') { const a = alternates?.es; return a ?? (isHome ? '/es/' : undefined); }
  return undefined;
};
---

<header class="sticky top-0 z-40 border-b border-gray-200 bg-white/95 backdrop-blur">
  <nav class="container-page flex h-16 items-center justify-between gap-3">
    <a href={homePath} class="flex shrink-0 items-center gap-2 font-bold text-gray-900 hover:no-underline">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-lg bg-brand-600 text-white">CT</span>
      <span class="hidden text-lg sm:inline">ChinaTripBox</span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden items-center gap-3 lg:flex xl:gap-4">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'text-sm font-medium whitespace-nowrap transition-colors hover:text-brand-600 hover:no-underline',
              isActive(link.href) ? 'text-brand-600' : 'text-gray-700',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right side: language + hamburger -->
    <div class="flex items-center gap-2">
      <LanguageSwitcher
        currentLocale={locale}
        enPath={getPath('en')}
        zhTwPath={getPath('zh-TW')}
        jaPath={getPath('ja')}
        koPath={getPath('ko')}
        ruPath={getPath('ru')}
        frPath={getPath('fr')}
        dePath={getPath('de')}
        esPath={getPath('es')}
      />

      <!-- Mobile hamburger -->
      <button
        id="menu-toggle"
        class="inline-flex items-center justify-center rounded-md p-2 text-gray-700 lg:hidden"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-gray-200 lg:hidden">
    <div class="container-page py-2">
    <ul class="flex flex-col">
      {[...navLinks, ...secondaryLinks].map((link) => (
        <li>
          <a
            href={link.href}
            class:list={[
              'block py-2.5 text-sm font-medium hover:no-underline',
              isActive(link.href) ? 'text-brand-600' : 'text-gray-700',
            ]}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => {
    const open = menu?.classList.toggle('hidden');
    toggle.setAttribute('aria-expanded', String(open === false));
  });
</script>
