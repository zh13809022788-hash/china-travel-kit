---
// Breadcrumb navigation + BreadcrumbList JSON-LD (site-wide first use).
// Pass items in order from root to current page. The last item is the
// current page and is rendered without a link.
export interface Crumb {
  label: string;
  href?: string;
}

export interface Props {
  items: Crumb[];
}

const { items = [] } = Astro.props;

// Build absolute URLs for the structured data (Google prefers absolute).
const toAbs = (href?: string) =>
  href ? new URL(href, Astro.site).toString() : undefined;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: item.label,
    ...(toAbs(item.href) ? { item: toAbs(item.href) } : {}),
  })),
};
---

{
  items.length > 0 && (
    <nav aria-label="Breadcrumb" class="mb-6 text-sm text-gray-500">
      <ol class="flex flex-wrap items-center gap-1.5">
        {items.map((item, i) => (
          <li class="flex items-center gap-1.5">
            {item.href && i < items.length - 1 ? (
              <a href={item.href} class="hover:text-brand-600 hover:no-underline">
                {item.label}
              </a>
            ) : (
              <span class="text-gray-700" aria-current="page">
                {item.label}
              </span>
            )}
            {i < items.length - 1 && <span class="text-gray-300">/</span>}
          </li>
        ))}
      </ol>
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    </nav>
  )
}
