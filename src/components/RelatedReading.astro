---
// "Related Reading" block — internal links to strengthen site structure.
// Renders nothing when empty.
export interface RelatedItem {
  title: string;
  description: string;
  href: string;
}

export interface Props {
  items: RelatedItem[];
  title?: string;
  readMore?: string;
}

const { items = [], title = 'Related Reading', readMore = 'Read more →' } = Astro.props;
---

{
  items.length > 0 && (
    <section class="my-10" aria-labelledby="related-heading">
      <h2 id="related-heading" class="text-2xl font-bold text-gray-900">{title}</h2>
      <div class="mt-6 grid gap-6 md:grid-cols-2">
        {items.map((item) => (
          <a href={item.href} class="card block hover:no-underline">
            <h3 class="text-lg font-bold text-gray-900">{item.title}</h3>
            <p class="mt-1.5 text-sm text-gray-600">{item.description}</p>
            <span class="mt-3 inline-block text-sm font-semibold text-brand-600">
              {readMore}
            </span>
          </a>
        ))}
      </div>
    </section>
  )
}
