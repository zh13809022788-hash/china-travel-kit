---
interface Props {
  themeId: string;
  steps: string[];
  locale?: string;
}

const { themeId, steps, locale = 'en' } = Astro.props;

const UI = {
  en: { kicker: 'Interactive checklist', heading: 'Get ready step by step', desc: 'Progress is saved on this device with localStorage.', done: 'Ready for your trip. Your checklist is complete.', label: 'complete' },
  de: { kicker: 'Interaktive Checkliste', heading: 'Schritt für Schritt vorbereiten', desc: 'Dein Fortschritt wird im Browser gespeichert.', done: 'Bereit für deine Reise. Deine Checkliste ist vollständig.', label: 'erledigt' },
  es: { kicker: 'Lista interactiva', heading: 'Prepárate paso a paso', desc: 'El progreso se guarda en el navegador.', done: 'Listo para tu viaje. Tu lista está completa.', label: 'completado' },
  fr: { kicker: 'Liste interactive', heading: 'Préparez-vous étape par étape', desc: 'La progression est sauvegardée dans le navigateur.', done: 'Prêt pour votre voyage. Votre liste est complète.', label: 'terminé' },
  ru: { kicker: 'Интерактивный чек-лист', heading: 'Готовьтесь шаг за шагом', desc: 'Прогресс сохраняется в браузере.', done: 'Готово к поездке. Ваш чек-лист завершён.', label: 'завершено' },
  ja: { kicker: 'インタラクティブチェックリスト', heading: 'ステップごとに準備', desc: '進捗はブラウザに保存されます。', done: '旅行の準備完了。チェックリストが完成しました。', label: '完了' },
  ko: { kicker: '인터랙티브 체크리스트', heading: '단계별로 준비하기', desc: '진행 상황은 브라우저에 저장됩니다.', done: '여행 준비 완료. 체크리스트가 모두 완료되었습니다.', label: '완료' },
  'zh-tw': { kicker: '互動式檢查清單', heading: '一步步做好準備', desc: '進度會儲存在瀏覽器中。', done: '旅行準備就緒。你的檢查清單已全部完成。', label: '完成' },
};
const t = UI[locale] ?? UI.en;
---

<section class="survival-checklist rounded-lg border border-gray-200 bg-white p-5 shadow-sm" data-checklist-id={themeId}>
  <div class="flex flex-col gap-3 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <p class="section-kicker">{t.kicker}</p>
      <h2 class="mt-1 text-2xl font-bold text-gray-950">{t.heading}</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">{t.desc}</p>
    </div>
    <p class="checklist-count text-sm font-semibold text-gray-700" data-label={t.label}>0/{steps.length} {t.label}</p>
  </div>

  <div class="mt-4 h-2 overflow-hidden rounded-full bg-gray-100">
    <div class="checklist-bar h-full w-0 rounded-full bg-brand-600 transition-all"></div>
  </div>

  <div class="mt-5 grid gap-3">
    {steps.map((step, index) => (
      <label class="flex cursor-pointer items-start gap-3 rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-700 hover:border-brand-200 hover:bg-brand-50">
        <input class="checklist-item mt-1 h-4 w-4 rounded border-gray-300 text-brand-600" type="checkbox" value={index} data-clarity-click={`checklist-${themeId}-${index}`} />
        <span>{step}</span>
      </label>
    ))}
  </div>

  <div class="checklist-done mt-5 hidden rounded-lg border border-green-200 bg-green-50 p-4 text-sm font-semibold text-green-800" data-done-label={t.done}>
    {t.done}
  </div>
</section>

<script>
  document.querySelectorAll<HTMLElement>('.survival-checklist').forEach((section) => {
    const id = section.dataset.checklistId ?? 'survival';
    const key = `chinatripbox-checklist-${id}`;
    const boxes = Array.from(section.querySelectorAll<HTMLInputElement>('.checklist-item'));
    const bar = section.querySelector<HTMLElement>('.checklist-bar');
    const count = section.querySelector<HTMLElement>('.checklist-count');
    const done = section.querySelector<HTMLElement>('.checklist-done');
    const label = count?.dataset.label ?? 'complete';
    const doneLabel = done?.dataset.doneLabel ?? 'Ready for your trip. Your checklist is complete.';

    const saved = new Set<number>(JSON.parse(localStorage.getItem(key) || '[]'));

    function render() {
      const checked = boxes.filter((box) => box.checked).length;
      const total = boxes.length;
      if (bar) bar.style.width = `${total ? (checked / total) * 100 : 0}%`;
      if (count) count.textContent = `${checked}/${total} ${label}`;
      if (done) {
        done.textContent = doneLabel;
        done.classList.toggle('hidden', checked !== total || total === 0);
        done.classList.toggle('animate-pulse', checked === total && total > 0);
      }
      const values = boxes.filter((box) => box.checked).map((box) => Number(box.value));
      localStorage.setItem(key, JSON.stringify(values));
    }

    boxes.forEach((box) => {
      box.checked = saved.has(Number(box.value));
      box.addEventListener('change', render);
    });

    render();
  });
</script>
