---
export interface Props {
  currentLocale: 'en' | 'zh-TW';
  enPath?: string;
  zhTwPath?: string;
}

const { currentLocale, enPath, zhTwPath } = Astro.props;
const options = [
  { locale: 'en', label: 'English', path: enPath },
  { locale: 'zh-TW', label: '繁體中文', path: zhTwPath },
] as const;

const visibleOptions = options.filter((option) => option.path);
---

{
  visibleOptions.length > 1 && (
    <div class="flex items-center rounded-full border border-gray-200 bg-white p-0.5 text-xs font-medium text-gray-600">
      {visibleOptions.map((option) =>
        option.locale === currentLocale ? (
          <span class="rounded-full bg-brand-600 px-2.5 py-1 text-white">{option.label}</span>
        ) : (
          <a
            href={option.path}
            data-lang-switch={option.locale}
            class="rounded-full px-2.5 py-1 text-gray-600 transition-colors hover:bg-gray-100 hover:text-brand-600 hover:no-underline"
          >
            {option.label}
          </a>
        )
      )}
    </div>
  )
}

<script>
  document.querySelectorAll('[data-lang-switch]').forEach(function(link) {
    link.addEventListener('click', function() {
      try { localStorage.setItem('ctb-lang-pref', this.getAttribute('data-lang-switch')); } catch(e) {}
    });
  });
</script>
