---
type LocaleCode = 'en' | 'zh-TW' | 'ja' | 'ko' | 'ru' | 'fr' | 'de' | 'es';

interface Props {
  defaultPrompt?: string;
  locale?: LocaleCode;
}

const { defaultPrompt = 'Help me plan my China trip.', locale = 'en' } = Astro.props;

// ---- i18n translations ----
const i18n = {
  button: {
    en: 'Ask', 'zh-TW': '提問', ja: '質問', ko: '질문', ru: 'Спросить', fr: 'Demander', de: 'Fragen', es: 'Preguntar',
  },
  title: {
    en: 'ChinaTripBox Help', 'zh-TW': 'ChinaTripBox 幫助', ja: 'ChinaTripBox ヘルプ', ko: 'ChinaTripBox 도움말',
    ru: 'ChinaTripBox Помощь', fr: 'ChinaTripBox Aide', de: 'ChinaTripBox Hilfe', es: 'ChinaTripBox Ayuda',
  },
  welcome: {
    en: 'Ask about China travel — I\'ll search our guides first. If I can\'t find anything, I\'ll bring in the AI expert.',
    'zh-TW': '詢問中國旅行問題 — 我會先搜尋我們的文章。如果找不到，我會請 AI 專家來幫忙。',
    ja: '中国旅行について質問してください — まず記事を検索します。見つからない場合はAI専門家に相談します。',
    ko: '중국 여행에 대해 물어보세요 — 먼저 가이드를 검색합니다. 찾지 못하면 AI 전문가에게 문의합니다.',
    ru: 'Спросите о поездке в Китай — сначала поищу в наших путеводителях. Если не найду, привлеку ИИ-эксперта.',
    fr: 'Posez une question sur la Chine — je cherche d\'abord dans nos guides. Si je ne trouve rien, je fais appel à l\'expert IA.',
    de: 'Fragen Sie zu Ihrer China-Reise — ich durchsuche zuerst unsere Ratgeber. Falls nichts dabei ist, hole ich den KI-Experten.',
    es: 'Pregunte sobre viajar a China — primero buscaré en nuestras guías. Si no encuentro nada, recurriré al experto en IA.',
  },
  line1: {
    en: 'Search 300+ articles', 'zh-TW': '搜尋 300+ 篇文章', ja: '300+ 記事を検索', ko: '300+ 문서 검색',
    ru: 'Поиск по 300+ статьям', fr: 'Recherche dans 300+ articles', de: '300+ Artikel durchsuchen', es: 'Buscar en 300+ artículos',
  },
  line2: {
    en: 'AI expert (if needed)', 'zh-TW': 'AI 專家（如有需要）', ja: 'AI専門家（必要に応じて）', ko: 'AI 전문가 (필요시)',
    ru: 'ИИ-эксперт (при необходимости)', fr: 'Expert IA (si nécessaire)', de: 'KI-Experte (bei Bedarf)', es: 'Experto IA (si es necesario)',
  },
  quick1: {
    en: 'eSIM or SIM?', 'zh-TW': 'eSIM 或 SIM？', ja: 'eSIM か SIM？', ko: 'eSIM 또는 SIM？',
    ru: 'eSIM или SIM？', fr: 'eSIM ou SIM ?', de: 'eSIM oder SIM？', es: '¿eSIM o SIM?',
  },
  quick2: {
    en: 'Alipay setup', 'zh-TW': 'Alipay 設定', ja: 'Alipay 設定', ko: 'Alipay 설정',
    ru: 'Настройка Alipay', fr: 'Configurer Alipay', de: 'Alipay einrichten', es: 'Configurar Alipay',
  },
  quick3: {
    en: 'Lost passport', 'zh-TW': '護照遺失', ja: 'パスポート紛失', ko: '여권 분실',
    ru: 'Потеря паспорта', fr: 'Passeport perdu', de: 'Pass verloren', es: 'Pasaporte perdido',
  },
  quick4: {
    en: 'Cash vs card', 'zh-TW': '現金還是刷卡？', ja: '現金 vs カード', ko: '현금 vs 카드',
    ru: 'Наличные или карта？', fr: 'Espèces ou carte ?', de: 'Bargeld oder Karte？', es: '¿Efectivo o tarjeta?',
  },
  placeholder: {
    en: 'Ask a China travel question...', 'zh-TW': '輸入中國旅行問題...', ja: '中国旅行の質問を入力...', ko: '중국 여행 질문 입력...',
    ru: 'Задайте вопрос о поездке в Китай...', fr: 'Posez une question sur la Chine...', de: 'Fragen Sie zu Ihrer China-Reise...', es: 'Haga una pregunta sobre China...',
  },
  search: {
    en: 'Search', 'zh-TW': '搜尋', ja: '検索', ko: '검색',
    ru: 'Поиск', fr: 'Rechercher', de: 'Suchen', es: 'Buscar',
  },
  hint: {
    en: 'Try: "How do I pay in China?"', 'zh-TW': '例如：「如何在中國付款？」', ja: '例：「中国での支払い方法は？」',
    ko: '예시: 「중국에서 어떻게 결제하나요？」', ru: 'Например: «Как платить в Китае?»',
    fr: 'Ex: «Comment payer en Chine ?»', de: 'Z.B.: «Wie bezahle ich in China?»',
    es: 'Ej: «¿Cómo pago en China?»',
  },
};

const t = (key: keyof typeof i18n): string =>
  (i18n[key] as Record<string, string>)[locale] || (i18n[key] as Record<string, string>)['en'] || '';
---

<!-- Floating AI assistant — article search first, DeepSeek fallback -->
<aside id="ctb-chat-bubble" class="fixed bottom-4 right-4 z-50 flex flex-col items-end">
  <!-- Minimized toggle button -->
  <button
    id="ctb-toggle"
    class="flex items-center gap-2 rounded-full bg-brand-600 px-4 py-3 text-sm font-bold text-white shadow-lg hover:bg-brand-700 transition-shadow hover:shadow-xl"
    type="button"
    aria-label={t('button')}
  >
    <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg>
    <span>{t('button')}</span>
  </button>

  <!-- Chat panel -->
  <div id="ctb-panel" class="mt-3 hidden w-[min(380px,calc(100vw-2rem))] flex-col overflow-hidden rounded-xl border border-gray-200 bg-white shadow-2xl">
    <!-- Header -->
    <div class="flex items-center justify-between border-b border-gray-200 bg-brand-600 px-4 py-3 text-white">
      <div class="flex items-center gap-2">
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z"/></svg>
        <span class="text-sm font-bold">{t('title')}</span>
      </div>
      <button id="ctb-close" class="text-sm font-semibold text-white/80 hover:text-white" type="button">✕</button>
    </div>

    <!-- Messages area -->
    <div id="ctb-messages" class="flex max-h-[420px] min-h-[200px] flex-col gap-3 overflow-y-auto px-4 py-4 text-sm leading-relaxed">
      <div class="max-w-[90%] rounded-lg bg-gray-50 px-4 py-3 text-gray-700">
        {t('welcome')}
        <ul class="mt-2 space-y-1">
          <li class="flex items-start gap-1.5 text-xs text-gray-500"><span class="mt-0.5 text-brand-600">✓</span> {t('line1')}</li>
          <li class="flex items-start gap-1.5 text-xs text-gray-500"><span class="mt-0.5 text-amber-500">⚡</span> {t('line2')}</li>
        </ul>
      </div>
    </div>

    <!-- Quick prompts -->
    <div id="ctb-quick" class="flex gap-2 overflow-x-auto border-t border-gray-100 px-4 py-2">
      <button class="ctb-quick-btn shrink-0 rounded-full border border-gray-200 bg-gray-50 px-3 py-1 text-xs text-gray-600 hover:border-brand-300 hover:text-brand-700">{t('quick1')}</button>
      <button class="ctb-quick-btn shrink-0 rounded-full border border-gray-200 bg-gray-50 px-3 py-1 text-xs text-gray-600 hover:border-brand-300 hover:text-brand-700">{t('quick2')}</button>
      <button class="ctb-quick-btn shrink-0 rounded-full border border-gray-200 bg-gray-50 px-3 py-1 text-xs text-gray-600 hover:border-brand-300 hover:text-brand-700">{t('quick3')}</button>
      <button class="ctb-quick-btn shrink-0 rounded-full border border-gray-200 bg-gray-50 px-3 py-1 text-xs text-gray-600 hover:border-brand-300 hover:text-brand-700">{t('quick4')}</button>
    </div>

    <!-- Input area -->
    <div class="border-t border-gray-200 px-4 py-3">
      <form id="ctb-form" class="flex gap-2">
        <input
          id="ctb-input"
          type="text"
          class="min-w-0 flex-1 rounded-lg border border-gray-300 px-3 py-2 text-sm outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
          placeholder={t('placeholder')}
          autocomplete="off"
        />
        <button id="ctb-submit" type="submit" class="shrink-0 rounded-lg bg-brand-600 px-4 py-2 text-sm font-semibold text-white hover:bg-brand-700 disabled:opacity-50" disabled>
          {t('search')}
        </button>
      </form>
      <p id="ctb-status" class="mt-1 text-xs text-gray-400">{t('hint')}</p>
    </div>
  </div>
</aside>

<script>
// ---- Simple keyword matcher ----
interface SearchEntry {
  slug: string;
  url: string;
  title: string;
  description: string;
  category: string;
  tags: string[];
  pubDate: string;
}

interface SearchIndex {
  [lang: string]: SearchEntry[];
}

// Detect current page language from URL
function detectLang(): string {
  const p = window.location.pathname.toLowerCase();
  for (const lang of ['zh-tw', 'ja', 'ko', 'ru', 'fr', 'de', 'es']) {
    if (p.startsWith('/' + lang + '/')) return lang;
  }
  return 'en';
}

function escapeHtml(text: string): string {
  const div = document.createElement('div');
  div.appendChild(document.createTextNode(text));
  return div.innerHTML;
}

// ---- DOM refs ----
const toggle = document.getElementById('ctb-toggle') as HTMLButtonElement | null;
const panel = document.getElementById('ctb-panel') as HTMLElement | null;
const closeBtn = document.getElementById('ctb-close') as HTMLButtonElement | null;
const messages = document.getElementById('ctb-messages') as HTMLElement | null;
const form = document.getElementById('ctb-form') as HTMLFormElement | null;
const input = document.getElementById('ctb-input') as HTMLInputElement | null;
const submit = document.getElementById('ctb-submit') as HTMLButtonElement | null;
const status = document.getElementById('ctb-status') as HTMLElement | null;
const quickBtns = document.querySelectorAll<HTMLButtonElement>('.ctb-quick-btn');

// ---- State ----
let index: SearchIndex | null = null;
const currentLang = detectLang();

// ---- Load search index once ----
async function loadIndex(): Promise<SearchIndex | null> {
  if (index) return index;
  try {
    const res = await fetch('/search-index.json');
    if (!res.ok) throw new Error('HTTP ' + res.status);
    index = await res.json() as SearchIndex;
    return index;
  } catch (e) {
    console.warn('Search index unavailable:', e);
    return null;
  }
}

// ---- Keyword scoring ----
function scoreArticle(entry: SearchEntry, keywords: string[]): number {
  let score = 0;
  const searchText = [entry.title, entry.description, ...entry.tags, entry.category].join(' ').toLowerCase();

  for (const kw of keywords) {
    if (entry.title.toLowerCase().includes(kw)) score += 10;
    if (entry.description.toLowerCase().includes(kw)) score += 5;
    if (entry.tags.some(t => t.toLowerCase().includes(kw))) score += 8;
    if (entry.category.toLowerCase().includes(kw)) score += 6;
    // Generic match in full text
    const count = (searchText.match(new RegExp(kw.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'), 'g')) || []).length;
    score += count;
  }
  return score;
}

// ---- Search (current language only — no English fallback to avoid language mixing) ----
function searchIndex(query: string, lang: string, idx: SearchIndex): SearchEntry[] {
  const keywords = query.toLowerCase()
    .replace(/[.,!?;:"]/g, '')
    .split(/\s+/)
    .filter(w => w.length > 1 && !['the', 'a', 'an', 'in', 'on', 'at', 'to', 'for', 'of', 'is', 'it', 'my', 'i', 'do', 'how', 'what', 'can', 'with', 'and', 'or', 'me', 'need', 'get', 'have'].includes(w));

  if (keywords.length === 0) return [];

  // Only search current language — no English fallback to prevent language mixing
  const candidates = idx[lang] || [];

  const scored = candidates
    .map(entry => ({ entry, score: scoreArticle(entry, keywords) }))
    .filter(item => item.score > 0)
    .sort((a, b) => b.score - a.score)
    .slice(0, 5);

  return scored.map(item => item.entry);
}

// ---- Add message bubble ----
function addBubble(html: string, isUser = false): void {
  if (!messages) return;
  const div = document.createElement('div');
  div.className = isUser
    ? 'ml-auto max-w-[90%] rounded-lg bg-brand-600 px-4 py-2.5 text-sm text-white'
    : 'max-w-[90%] rounded-lg bg-gray-50 px-4 py-2.5 text-sm leading-relaxed text-gray-700';
  div.innerHTML = html;
  messages.appendChild(div);
  messages.scrollTop = messages.scrollHeight;
}

// ---- Add article link cards ----
function addArticleCards(entries: SearchEntry[]): void {
  if (!messages || entries.length === 0) return;
  const wrapper = document.createElement('div');
  wrapper.className = 'max-w-full rounded-lg bg-gray-50 px-4 py-3 text-sm leading-relaxed text-gray-700';

  let html = `<div class="mb-2 font-semibold text-gray-900 text-xs uppercase tracking-wide">📖 Related guides</div>`;
  for (const entry of entries) {
    html += `<a href="${entry.url}"
      class="mb-2 block rounded-md border border-gray-200 bg-white px-3 py-2.5 transition hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
      <div class="text-sm font-semibold text-gray-900">${escapeHtml(entry.title || entry.slug)}</div>
      <div class="mt-0.5 text-xs text-gray-500 line-clamp-2">${escapeHtml((entry.description || '').slice(0, 120))}</div>
    </a>`;
  }

  wrapper.innerHTML = html;
  messages.appendChild(wrapper);
  messages.scrollTop = messages.scrollHeight;
}

// ---- PayPal CTA card (shown after AI answer) ----
const PAYPAL_EMAIL = 'zh13809022788@gmail.com';
const GUIDES: Array<{ id: string; name: string; price: string; file: string }> = [
  { id: 'arrival-checklist', name: 'China Arrival Checklist', price: '9.90', file: 'China-Arrival-Checklist.pdf' },
  { id: 'payment-setup', name: 'China Payment Setup Guide', price: '12.90', file: 'China-Payment-Setup-Guide.pdf' },
  { id: '7-day-trip', name: '7-Day China Trip Plan', price: '14.90', file: '7-Day-China-Trip-Plan.pdf' },
];

function addCtaCard(lang: string): void {
  if (!messages) return;
  const wrapper = document.createElement('div');
  wrapper.className = 'max-w-full rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm leading-relaxed';

  if (lang === 'en') {
    let html = '<div class="mb-2 font-semibold text-amber-900">📖 Get the Complete Guide</div>';
    for (const guide of GUIDES) {
      const paypalUrl = `https://www.paypal.com/cgi-bin/webscr?cmd=_xclick&business=${PAYPAL_EMAIL}&item_name=${encodeURIComponent(guide.name)}&amount=${guide.price}&currency_code=USD&return=${encodeURIComponent('https://www.chinatripbox.com/guides/' + guide.file)}`;
      html += `<a href="${paypalUrl}" target="_blank" rel="noopener"
        class="mb-2 flex items-center justify-between rounded-md border border-amber-200 bg-white px-3 py-2.5 transition hover:border-amber-400 hover:bg-amber-100 hover:no-underline">
        <span class="text-sm font-semibold text-gray-900">${guide.name}</span>
        <span class="shrink-0 rounded-full bg-amber-100 px-2.5 py-0.5 text-xs font-bold text-amber-800">$${guide.price}</span>
      </a>`;
    }
    html += '<div class="mt-1 text-[10px] text-gray-400">Secure payment via PayPal — instant download after purchase</div>';
    wrapper.innerHTML = html;
  } else {
    wrapper.innerHTML = '<div class="font-semibold text-amber-900">📖 Guides in your language — coming soon</div>' +
      '<div class="mt-1 text-xs text-gray-500">We\'re translating our detailed guides. Check back or <a href="mailto:zh13809022788@gmail.com" class="font-semibold text-brand-700">email us</a> to get notified.</div>';
  }

  messages.appendChild(wrapper);
  messages.scrollTop = messages.scrollHeight;
}

// ---- DeepSeek primary call (with article context) ----
async function callDeepSeek(query: string, articles: SearchEntry[]): Promise<void> {
  const thinking = addBubble('Thinking...');
  if (submit) submit.disabled = true;
  if (status) status.textContent = 'Getting AI answer...';

  const langKey = currentLang === 'zh-tw' ? 'zh-TW' : currentLang;

  try {
    const res = await fetch('/api/travel-help', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({
        message: query,
        stage: 'General inquiry',
        topic: 'General trip setup',
        location: '',
        language: langKey,
        articles: JSON.stringify(articles.slice(0, 5)),
      }),
    });

    const data = await res.json() as { answer?: string; error?: string };
    const bubble = messages?.lastElementChild;
    if (bubble && data.answer) {
      bubble.innerHTML = `<div class="font-semibold text-gray-900 mb-1">${escapeHtml(data.answer.split('\n')[0])}</div>
        <div>${escapeHtml(data.answer).replace(/\n/g, '<br>')}</div>
        <div class="mt-2 text-[10px] text-gray-400">DeepSeek · ChinaTripBox guides</div>`;
      // Show purchase CTA after AI answer
      addCtaCard(langKey);
    } else if (bubble) {
      bubble.innerHTML = `<div class="font-semibold text-amber-900">Temporarily unavailable</div>
        <div>Please try again later or email us at <a href="mailto:zh13809022788@gmail.com" class="font-semibold text-brand-700">zh13809022788@gmail.com</a>.</div>`;
    }
    if (status) status.textContent = 'AI answer ready.';
  } catch {
    const bubble = messages?.lastElementChild;
    if (bubble) {
      bubble.innerHTML = `<div class="font-semibold text-amber-900">Temporarily unavailable</div>
        <div>Please try again later or <a href="mailto:zh13809022788@gmail.com" class="font-semibold text-brand-700">email us</a>.</div>`;
    }
    if (status) status.textContent = 'AI expert unavailable.';
  } finally {
    if (submit) submit.disabled = false;
  }
}

// ---- Main flow: search + DeepSeek ----
async function handleQuery(query: string): Promise<void> {
  const trimmed = query.trim();
  if (!trimmed) return;

  if (input) input.value = '';
  if (status) status.textContent = 'Searching guides...';

  // Show user message
  addBubble(escapeHtml(trimmed), true);

  // Search local index (current language only)
  const idx = await loadIndex();
  let results: SearchEntry[] = [];
  if (idx) {
    results = searchIndex(trimmed, currentLang, idx);
  }

  // Show relevant article links if found
  if (results.length > 0) {
    addArticleCards(results);
  }

  // Call DeepSeek with article context
  callDeepSeek(trimmed, results);
}

// ---- Event wiring ----
toggle?.addEventListener('click', () => {
  panel?.classList.remove('hidden');
  panel?.classList.add('flex');
  toggle?.classList.add('hidden');
  // Preload index
  loadIndex();
  input?.focus();
});

closeBtn?.addEventListener('click', () => {
  panel?.classList.add('hidden');
  panel?.classList.remove('flex');
  toggle?.classList.remove('hidden');
});

input?.addEventListener('input', () => {
  if (submit) submit.disabled = !(input.value.trim().length > 0);
});

input?.addEventListener('keydown', (e) => {
  if (e.key === 'Enter') {
    e.preventDefault();
    form?.requestSubmit();
  }
});

form?.addEventListener('submit', (e) => {
  e.preventDefault();
  const val = input?.value?.trim();
  if (val && val.length > 0) {
    handleQuery(val);
  }
});

quickBtns.forEach(btn => {
  btn.addEventListener('click', () => {
    handleQuery(btn.textContent?.trim() || '');
  });
});

// ---- Auto-open on first visit hint (only on desktop, not if user has seen it) ----
(function() {
  const SEEN = 'ctb-seen';
  try {
    if (!sessionStorage.getItem(SEEN) && window.innerWidth >= 768) {
      // Don't auto-open, just preload
      loadIndex();
      sessionStorage.setItem(SEEN, '1');
    }
  } catch {}
})();
</script>
