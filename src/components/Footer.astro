---
import LanguageSwitcher from './LanguageSwitcher.astro';

type LocaleCode = 'en' | 'zh-TW' | 'ja' | 'ko' | 'ru' | 'fr' | 'de' | 'es';

const year = new Date().getFullYear();
const pathname = Astro.url.pathname;

const localePrefixMap: Record<LocaleCode, string> = {
  en: '/',
  'zh-TW': '/zh-tw/',
  ja: '/ja/',
  ko: '/ko/',
  ru: '/ru/',
  fr: '/fr/',
  de: '/de/',
  es: '/es/',
};

const currentLocale: LocaleCode = pathname.startsWith('/zh-tw/')
  ? 'zh-TW'
  : pathname.startsWith('/ja/')
    ? 'ja'
    : pathname.startsWith('/ko/')
      ? 'ko'
      : pathname.startsWith('/ru/')
        ? 'ru'
        : pathname.startsWith('/fr/')
          ? 'fr'
          : pathname.startsWith('/de/')
            ? 'de'
            : pathname.startsWith('/es/')
              ? 'es'
              : 'en';

const footerLabels: Record<string, Record<LocaleCode, string>> = {
  'Travel Help': { en: 'Travel Help', 'zh-TW': '旅行幫助', ja: '旅行ヘルプ', ko: '여행 도움말', ru: 'Помощь в поездке', fr: 'Aide voyage', de: 'Reisehilfe', es: 'Ayuda de viaje' },
  Resources: { en: 'Resources', 'zh-TW': '資源', ja: 'リソース', ko: '자료', ru: 'Ресурсы', fr: 'Ressources', de: 'Ressourcen', es: 'Recursos' },
  About: { en: 'About', 'zh-TW': '關於', ja: '概要', ko: '소개', ru: 'О нас', fr: 'À propos', de: 'Über uns', es: 'Acerca de' },
  Contact: { en: 'Contact', 'zh-TW': '聯絡', ja: 'お問い合わせ', ko: '문의', ru: 'Контакты', fr: 'Contact', de: 'Kontakt', es: 'Contacto' },
  'Editorial Policy': { en: 'Editorial Policy', 'zh-TW': '編輯政策', ja: '編集方針', ko: '편집 정책', ru: 'Редакционная политика', fr: 'Politique éditoriale', de: 'Redaktionsrichtlinie', es: 'Política editorial' },
  'Affiliate Disclosure': { en: 'Affiliate Disclosure', 'zh-TW': '聯盟揭露', ja: 'アフィリエイト開示', ko: '제휴 고지', ru: 'Партнёрское раскрытие', fr: 'Divulgation affiliation', de: 'Partner-Offenlegung', es: 'Divulgación de afiliados' },
  'Privacy Policy': { en: 'Privacy Policy', 'zh-TW': '隱私政策', ja: 'プライバシーポリシー', ko: '개인정보 처리방침', ru: 'Политика конфиденциальности', fr: 'Politique de confidentialité', de: 'Datenschutz', es: 'Política de privacidad' },
  Terms: { en: 'Terms', 'zh-TW': '條款', ja: '利用規約', ko: '이용약관', ru: 'Условия', fr: 'Conditions', de: 'AGB', es: 'Términos' },
  'All rights reserved': { en: 'All rights reserved.', 'zh-TW': '版權所有。', ja: '無断転載を禁じます。', ko: '모든 권리 보유.', ru: 'Все права защищены.', fr: 'Tous droits réservés.', de: 'Alle Rechte vorbehalten.', es: 'Todos los derechos reservados.' },
};

const footerDesc: Record<LocaleCode, string> = {
  en: 'ChinaTripBox is an independent China travel planning site for foreign visitors. We publish practical guides, tools, and optional human-reviewed trip help. Some links may earn us a commission.',
  'zh-TW': 'ChinaTripBox 是面向外國旅客的獨立中國旅行規劃網站，提供實用指南、工具，以及可選的人工作業協助。部分連結可能為我們帶來佣金。',
  ja: 'ChinaTripBox は外国人旅行者向けの独立した中国旅行計画サイトです。実用的なガイド、ツール、必要に応じた人による旅行サポートを提供しています。一部のリンクから手数料を得る場合があります。',
  ko: 'ChinaTripBox는 외국인 방문객을 위한 독립 중국 여행 계획 사이트입니다. 실용 가이드, 도구, 선택형 여행 지원을 제공합니다. 일부 링크를 통해 수수료를 받을 수 있습니다.',
  ru: 'ChinaTripBox — независимый сайт планирования поездок в Китай для иностранных гостей. Мы публикуем практические гиды, инструменты и дополнительную помощь по поездке. Некоторые ссылки могут приносить нам комиссию.',
  fr: 'ChinaTripBox est un site indépendant de planification de voyages en Chine pour les visiteurs étrangers. Nous publions des guides pratiques, des outils et une aide optionnelle. Certains liens peuvent nous rapporter une commission.',
  de: 'ChinaTripBox ist eine unabhängige China-Reiseplanungsseite für ausländische Besucher. Wir veröffentlichen praktische Reiseführer, Werkzeuge und optionale Reisehilfe. Einige Links können Provisionen enthalten.',
  es: 'ChinaTripBox es un sitio independiente de planificación de viajes a China para visitantes extranjeros. Publicamos guías prácticas, herramientas y ayuda opcional. Algunos enlaces pueden generarnos una comisión.',
};

const disclaimer: Record<LocaleCode, string> = {
  en: 'We provide general travel information only, not legal, immigration, medical, banking, emergency, or official government advice.',
  'zh-TW': '我們僅提供一般旅行資訊，不構成法律、移民、醫療、銀行、緊急或官方政府建議。',
  ja: '当サイトは一般的な旅行情報のみを提供し、法律、入国管理、医療、銀行、緊急対応、政府公式の助言ではありません。',
  ko: '본 사이트는 일반 여행 정보만 제공하며 법률, 출입국, 의료, 금융, 긴급 상황 또는 정부 공식 조언이 아닙니다.',
  ru: 'Мы предоставляем только общую туристическую информацию, а не юридические, иммиграционные, медицинские, банковские, экстренные или официальные государственные консультации.',
  fr: 'Nous fournissons uniquement des informations générales de voyage, pas des conseils juridiques, d’immigration, médicaux, bancaires, d’urgence ou officiels.',
  de: 'Wir bieten nur allgemeine Reiseinformationen, keine rechtliche, einwanderungsbezogene, medizinische, bankbezogene, Notfall- oder amtliche Beratung.',
  es: 'Proporcionamos solo información general de viajes, no asesoramiento legal, migratorio, médico, bancario, de emergencia ni gubernamental oficial.',
};

const ft = (key: string) => footerLabels[key]?.[currentLocale] ?? key;

const footerLocalePath = (href: string) => {
  if (currentLocale === 'en') return href;
  const prefix = localePrefixMap[currentLocale];
  if (href === '/') return prefix;
  return prefix + href.replace(/^\//, '');
};

const legalLinks = [
  { href: footerLocalePath('/travel-help/'), label: ft('Travel Help') },
  { href: footerLocalePath('/resources/'), label: ft('Resources') },
  { href: footerLocalePath('/about/'), label: ft('About') },
  { href: footerLocalePath('/contact/'), label: ft('Contact') },
  { href: footerLocalePath('/editorial-policy/'), label: ft('Editorial Policy') },
  { href: footerLocalePath('/affiliate-disclosure/'), label: ft('Affiliate Disclosure') },
  { href: footerLocalePath('/privacy/'), label: ft('Privacy Policy') },
  { href: footerLocalePath('/terms/'), label: ft('Terms') },
];

const swapLocale = (path: string, to: LocaleCode) => {
  let base = path;
  for (const prefix of Object.values(localePrefixMap).filter((p) => p !== '/')) {
    if (base.startsWith(prefix)) {
      base = base.slice(prefix.length - 1);
      break;
    }
  }
  if (to === 'en') return base || '/';
  const prefix = localePrefixMap[to].replace(/\/$/, '');
  return base === '/' ? `${prefix}/` : `${prefix}${base}`;
};

const paths = {
  en: currentLocale === 'en' ? undefined : swapLocale(pathname, 'en'),
  'zh-TW': currentLocale === 'zh-TW' ? undefined : swapLocale(pathname, 'zh-TW'),
  ja: currentLocale === 'ja' ? undefined : swapLocale(pathname, 'ja'),
  ko: currentLocale === 'ko' ? undefined : swapLocale(pathname, 'ko'),
  ru: currentLocale === 'ru' ? undefined : swapLocale(pathname, 'ru'),
  fr: currentLocale === 'fr' ? undefined : swapLocale(pathname, 'fr'),
  de: currentLocale === 'de' ? undefined : swapLocale(pathname, 'de'),
  es: currentLocale === 'es' ? undefined : swapLocale(pathname, 'es'),
};
---

<footer class="mt-auto border-t border-gray-200 bg-gray-50">
  <div class="container-page py-10">
    <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
      <div>
        <div class="flex items-center gap-2 font-bold text-gray-900">
          <span class="flex items-baseline gap-0.5 text-base font-extrabold leading-none">
            <span class="text-[#085041]">China</span><span class="text-[#E7292F]">TripBox</span>
          </span>
        </div>
        <p class="mt-2 max-w-xl text-sm leading-6 text-gray-500">{footerDesc[currentLocale]}</p>
        <p class="mt-2 max-w-xl text-xs leading-5 text-gray-500">{disclaimer[currentLocale]}</p>
      </div>
      <ul class="flex flex-wrap gap-5">
        {legalLinks.map((link) => (
          <li>
            <a href={link.href} class="text-sm text-gray-600 hover:text-brand-600">{link.label}</a>
          </li>
        ))}
      </ul>
    </div>
    <div class="mt-8 flex flex-col gap-4 border-t border-gray-200 pt-6 sm:flex-row sm:items-center sm:justify-between">
      <span class="text-sm text-gray-500">&copy; {year} ChinaTripBox. {ft('All rights reserved')}</span>
      <LanguageSwitcher
        currentLocale={currentLocale}
        enPath={paths.en}
        zhTwPath={paths['zh-TW']}
        jaPath={paths.ja}
        koPath={paths.ko}
        ruPath={paths.ru}
        frPath={paths.fr}
        dePath={paths.de}
        esPath={paths.es}
      />
    </div>
  </div>
</footer>
