---
// China city location map — no borders, no political boundaries.
// Cities shown at real geographic positions (equirectangular projection).
// Each marker is clickable and links to its city guide page.

export interface CityMarker {
  name: string;
  x: number;  // SVG x coordinate (equirectangular projection)
  y: number;  // SVG y coordinate (equirectangular projection)
  href: string;
}

export interface Props {
  cities: CityMarker[];
}

const { cities } = Astro.props;
---

<figure class="my-8 overflow-hidden rounded-xl border border-gray-200 bg-white">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 680 540" width="100%" height="auto" role="img" aria-label="China city map showing geographic positions of major travel destinations">
    <defs>
      <filter id="dot-shadow" x="-20%" y="-20%" width="140%" height="140%">
        <feDropShadow dx="0" dy="1" stdDeviation="1.5" flood-color="#000" flood-opacity="0.15" />
      </filter>
    </defs>

    <!-- Background -->
    <rect x="0" y="0" width="680" height="540" rx="12" fill="#faf9f7" />

    <!-- Very subtle latitude reference lines -->
    <line x1="80" y1="130" x2="640" y2="130" stroke="#e8e4dd" stroke-width="0.5" stroke-dasharray="3,5" />
    <line x1="80" y1="230" x2="640" y2="230" stroke="#e8e4dd" stroke-width="0.5" stroke-dasharray="3,5" />
    <line x1="80" y1="330" x2="640" y2="330" stroke="#e8e4dd" stroke-width="0.5" stroke-dasharray="3,5" />
    <line x1="80" y1="430" x2="640" y2="430" stroke="#e8e4dd" stroke-width="0.5" stroke-dasharray="3,5" />

    <!-- City markers and labels -->
    {cities.map((city) => (
      <g>
        {city.href ? (
          <a href={city.href} class="cursor-pointer">
            <!-- Hover glow ring -->
            <circle cx={city.x} cy={city.y} r="16" fill="none" stroke="#534AB7" stroke-width="0.4" opacity="0.15">
              <animate attributeName="r" values="16;22;16" dur="3s" repeatCount="indefinite" />
              <animate attributeName="opacity" values="0.15;0;0.15" dur="3s" repeatCount="indefinite" />
            </circle>
            <!-- Marker dot -->
            <circle cx={city.x} cy={city.y} r="5" fill="#534AB7" stroke="#fff" stroke-width="2" filter="url(#dot-shadow)" />
            <!-- City label -->
            <text x={city.x} y={city.y - 14} text-anchor="middle" style="font:500 12px/1.2 sans-serif;fill:#2C2C2A">
              {city.name}
            </text>
          </a>
        ) : (
          <g opacity="0.4">
            <circle cx={city.x} cy={city.y} r="4" fill="#b0a898" stroke="#fff" stroke-width="1.5" />
            <text x={city.x} y={city.y - 12} text-anchor="middle" style="font:400 11px sans-serif;fill:#888780">
              {city.name}
            </text>
          </g>
        )}
      </g>
    ))}

    <!-- Compass rose (minimal) -->
    <g transform="translate(50, 45)" opacity="0.35">
      <line x1="0" y1="-12" x2="0" y2="12" stroke="#666" stroke-width="1" />
      <line x1="-12" y1="0" x2="12" y2="0" stroke="#666" stroke-width="0.5" />
      <polygon points="0,-12 -3,-5 3,-5" fill="#666" />
      <text x="0" y="-16" text-anchor="middle" style="font:500 10px sans-serif;fill:#888">N</text>
    </g>
  </svg>
  <figcaption class="border-t border-gray-200 px-5 py-2.5 text-xs text-gray-500">
    Click a city marker to open its travel guide. Positions shown at approximate geographic coordinates.
  </figcaption>
</figure>
