---
export interface Props {
  title: string;
  description: string;
  buttonText?: string;
  placeholder?: string;
}

const {
  title,
  description,
  buttonText = 'Learn More',
  placeholder = '#AFFILIATE_LINK',
} = Astro.props;

// Only render the CTA once a real affiliate URL is provided. While the link is
// still a placeholder (e.g. "#AFFILIATE_ESIM"), render nothing so no dead link
// appears on the page — the correct state before affiliate programs are joined.
const isRealLink = /^https?:\/\//.test(placeholder);
---

{isRealLink && (
<div class="my-8 overflow-hidden rounded-xl border border-brand-200 bg-brand-50">
  <div class="flex flex-col gap-4 p-6 sm:flex-row sm:items-center sm:justify-between">
    <div>
      <h3 class="text-lg font-bold text-brand-800">{title}</h3>
      <p class="mt-1 text-sm text-brand-700/90">{description}</p>
    </div>
    <a
      href={placeholder}
      class="btn-primary whitespace-nowrap"
      rel="sponsored nofollow"
      target="_blank"
    >
      {buttonText}
    </a>
  </div>
</div>
)}
