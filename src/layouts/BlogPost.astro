---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import AffiliateCta from '../components/AffiliateCta.astro';
import FaqSection from '../components/FaqSection.astro';
import type { FaqItem } from '../components/FaqSection.astro';
import CoverImage from '../components/CoverImage.astro';
import RelatedReading from '../components/RelatedReading.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import Mermaid from '../components/Mermaid.astro';
import type { RelatedItem } from '../components/RelatedReading.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

type LocaleCode = 'en' | 'zh-TW' | 'ja' | 'ko' | 'ru' | 'fr' | 'de' | 'es';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  tags?: string[];
  faqs?: FaqItem[];
  cover?: string;
  coverAlt?: string;
  related?: RelatedItem[];
  locale?: LocaleCode;
  alternates?: Partial<Record<LocaleCode, string>>;
  affiliate?: {
    title: string;
    description: string;
    buttonText?: string;
    placeholder?: string;
  };
}

const {
  title,
  description,
  pubDate,
  category,
  tags = [],
  faqs = [],
  cover,
  coverAlt,
  related = [],
  locale = 'en',
  alternates,
  affiliate,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteURL = new URL('/', Astro.site).toString();
const author = {
  name: 'ChinaTripBox Editorial Team',
  url: new URL('/authors/chinatripbox-editorial-team/', Astro.site).toString(),
};

const categoryLabels: Record<string, Record<string, string>> = {
  payment:    { en:'Payment', 'zh-TW':'付款', ja:'決済', ko:'결제', ru:'Оплата', fr:'Paiement', de:'Bezahlung', es:'Pagos' },
  esim:       { en:'eSIM', 'zh-TW':'eSIM 與網路', ja:'eSIM・通信', ko:'eSIM・인터넷', ru:'eSIM', fr:'eSIM', de:'eSIM', es:'eSIM' },
  transport:  { en:'Transport', 'zh-TW':'交通', ja:'交通', ko:'교통', ru:'Транспорт', fr:'Transport', de:'Verkehr', es:'Transporte' },
  essentials: { en:'Trip Planning', 'zh-TW':'行前準備', ja:'旅行準備', ko:'여행 준비', ru:'Планирование', fr:'Préparation', de:'Reiseplanung', es:'Planificación' },
  food:       { en:'Food & Dining', 'zh-TW':'美食與用餐', ja:'グルメ', ko:'음식', ru:'Еда', fr:'Gastronomie', de:'Essen', es:'Comida' },
};

const categoryPaths: Record<string, string> = {
  payment: '/payment/',
  esim: '/esim/',
  transport: '/transport/',
  essentials: '/essentials/',
  food: '/food/',
};

const catLabel = categoryLabels[category]?.[locale] ?? category;

const faqItems = faqs.map((item) => ({
  '@type': 'Question',
  name: item.question,
  acceptedAnswer: {
    '@type': 'Answer',
    text: item.answer,
  },
}));

// Use cover image for OG meta when available
const ogImage = cover
  ? new URL('/og-default.svg', Astro.site).toString()  // placeholder until we can resolve cover URL
  : new URL('/og-default.svg', Astro.site).toString();

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  image: [ogImage],
  datePublished: pubDate.toISOString(),
  dateModified: pubDate.toISOString(),
  mainEntityOfPage: canonicalURL.toString(),
  author: {
    '@type': 'Person',
    name: author.name,
    url: author.url,
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${siteURL}#organization`,
    name: 'ChinaTripBox',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/favicon.svg', Astro.site).toString(),
    },
  },
};

const faqJsonLd =
  faqItems.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqItems,
      }
    : null;

function localeContact(lc: string): string {
  if (lc === 'en') return '/contact/';
  const map: Record<string, string> = { 'zh-TW':'zh-tw', ja:'ja', ko:'ko', ru:'ru', fr:'fr', de:'de', es:'es' };
  return `/${map[lc] ?? ''}/contact/`;
}

const jsonLd = faqJsonLd ? [articleJsonLd, faqJsonLd] : articleJsonLd;

const dateLocaleMap: Record<string, string> = { en:'en-US', 'zh-TW':'zh-TW', ja:'ja-JP', ko:'ko-KR', ru:'ru-RU', fr:'fr-FR', de:'de-DE', es:'es-ES' };
const formattedDate = pubDate.toLocaleDateString(dateLocaleMap[locale] ?? 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const ui = {
  home: { en:'Home', 'zh-TW':'首頁', ja:'ホーム', ko:'홈', ru:'Главная', fr:'Accueil', de:'Start', es:'Inicio' },
  by: { en:'By ', 'zh-TW':'作者：', ja:'著者：', ko:'작성자: ', ru:'Автор: ', fr:'Par ', de:'Von ', es:'Por ' },
  relatedTitle: { en:'Recommended next steps', 'zh-TW':'下一步推薦閱讀', ja:'おすすめの関連記事', ko:'추천 다음 읽을거리', ru:'Рекомендуемые материалы', fr:'Articles recommandés', de:'Empfohlene nächste Schritte', es:'Próximos pasos recomendados' },
  correctionPrefix: { en:'Found something outdated or incorrect? Please ', 'zh-TW':'發現內容過時或有誤？請附上頁面網址 ', ja:'情報が古い、または誤りがありましたら、ページURLとともに ', ko:'내용이 오래되었거나 잘못된 부분이 있으면 페이지 URL과 함께 ', ru:'Нашли устаревшую или неверную информацию? ', fr:'Vous avez trouvé une information obsolète ou incorrecte ? ', de:'Veraltete oder falsche Informationen gefunden? ', es:'¿Encontraste algo desactualizado o incorrecto? ' },
  correctionLink: { en:'send a correction', 'zh-TW':'回報修正', ja:'お知らせください', ko:'알려주세요', ru:'отправьте исправление', fr:'envoyez une correction', de:'Korrektur senden', es:'envía una corrección' },
  correctionSuffix: { en:' with the page URL so we can review it.', 'zh-TW':'，我們會盡快檢查。', ja:' をお送りください。確認いたします。', ko:'. 확인 후 수정하겠습니다.', ru:' с URL страницы, и мы проверим.', fr:' avec l\'URL de la page pour que nous puissions la vérifier.', de:' mit der Seiten-URL, damit wir sie überprüfen können.', es:' con la URL de la página para que podamos revisarlo.' },
  ctaTitle: { en:"Don't forget the essentials", 'zh-TW':'不要忘記必需品', ja:'必需品をお忘れなく', ko:'필수품을 잊지 마세요', ru:'Не забудьте самое необходимое', fr:'N\'oubliez pas l\'essentiel', de:'Vergessen Sie nicht das Wichtigste', es:'No olvides lo esencial' },
  ctaDesc: { en:'Get our complete pre-departure checklist — what to install, what to bring, and what to set up before your China trip.', 'zh-TW':'查看我們的行前準備清單——安裝什麼、帶什麼、出發前要設定什麼。', ja:'出発前の準備リストをご確認ください。インストールすべきアプリ、持ち物、設定すべきことをまとめました。', ko:'출발 전 준비 체크리스트를 확인하세요. 설치할 앱, 챙길 물건, 설정할 사항을 정리했습니다.', ru:'Получите полный предотъездный чек-лист: что установить, что взять и что настроить перед поездкой в Китай.', fr:'Obtenez notre checklist complète avant le départ : quoi installer, quoi apporter, quoi configurer avant votre voyage en Chine.', de:'Holen Sie sich unsere vollständige Checkliste für die Abreise: was Sie installieren, mitbringen und vor Ihrer China-Reise einrichten sollten.', es:'Obtén nuestra lista de verificación completa antes de la salida: qué instalar, qué traer y qué configurar antes de tu viaje a China.' },
  ctaButton: { en:'View pre-departure checklist →', 'zh-TW':'查看行前準備清單 →', ja:'出発前チェックリストを見る →', ko:'출발 전 체크리스트 보기 →', ru:'Посмотреть предотъездный чек-лист →', fr:'Voir la checklist avant départ →', de:'Vorab-Checkliste ansehen →', es:'Ver lista de verificación previa →' },
  readMore: { en:'Read more →', 'zh-TW':'閱讀更多 →', ja:'続きを読む →', ko:'더 읽기 →', ru:'Читать далее →', fr:'Lire la suite →', de:'Weiterlesen →', es:'Seguir leyendo →' },
};

const homeHref = locale === 'en' ? '/' : '/' + localePrefix(locale) + '/';
function localePrefix(lc: string) {
  const map: Record<string, string> = { 'zh-TW':'zh-tw', ja:'ja', ko:'ko', ru:'ru', fr:'fr', de:'de', es:'es' };
  return map[lc] ?? '';
}
const homeLabel = ui.home[locale] ?? 'Home';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} image={ogImage} type="article" locale={locale} alternates={alternates}>
  <Header locale={locale} alternates={alternates} />
  <main class="container-page py-8">
    <article class="prose-content">
      <AdSlot format="banner" />
      <header class="mb-8">
        <Breadcrumbs
          items={[
            { label: homeLabel, href: homeHref },
            { label: catLabel, href: categoryPaths[category] ?? '/' },
            { label: title },
          ]}
        />
        <a href={`/${category}/`} class="text-sm font-semibold uppercase tracking-wide text-brand-600">
          {catLabel}
        </a>
        <h1 class="mt-2 text-3xl font-bold leading-tight text-gray-900 md:text-4xl">{title}</h1>
        <p class="mt-3 text-lg text-gray-600">{description}</p>
        <div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-gray-500">
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          <span class="inline-flex items-center gap-1 rounded-full bg-green-50 px-2 py-0.5 text-xs font-medium text-green-700">
            <svg width="10" height="10" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
            Updated Jul 2026
          <span>{ui.by[locale] ?? 'By '}<a href="/authors/chinatripbox-editorial-team/" class="font-medium text-gray-700 hover:text-brand-600">ChinaTripBox Editorial Team</a></span>
          {tags.length > 0 && (
            <span class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="rounded-full bg-gray-100 px-2.5 py-0.5 text-xs text-gray-600">#{tag}</span>
              ))}
            </span>
          )}
        </div>
      </header>

      {cover && <CoverImage name={cover} alt={coverAlt ?? title} />}
      <div class="article-body max-w-none">
        <slot />
        <Mermaid />
      </div>

      <!-- Bottom CTA: Travel Checklist -->
      <div class="mt-8 rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h3 class="text-lg font-bold text-gray-900">{ui.ctaTitle[locale] ?? "Don't forget the essentials"}</h3>
        <p class="mt-2 text-sm leading-6 text-gray-700">{ui.ctaDesc[locale] ?? "Get our complete pre-departure checklist — what to install, what to bring, and what to set up before your China trip."}</p>
        <a href={locale === 'en' ? '/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/' : `/${locale.toLowerCase()}/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/`}
           class="mt-4 inline-block rounded-md bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white transition-colors hover:bg-brand-700 hover:no-underline">
          {ui.ctaButton[locale] ?? "View pre-departure checklist →"}
        </a>
      </div>

      <AdSlot format="in-article" />
      <FaqSection items={faqs} locale={locale} />
      <RelatedReading items={related} title={ui.relatedTitle[locale] ?? 'Recommended next steps'} readMore={ui.readMore[locale] ?? 'Read more →'} />

      <p class="mt-8 rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-600">
        {ui.correctionPrefix[locale] ?? 'Found something outdated or incorrect? Please '}
        <a href={localeContact(locale)} class="font-semibold">{ui.correctionLink[locale] ?? 'send a correction'}</a>
        {ui.correctionSuffix[locale] ?? ' with the page URL so we can review it.'}
      </p>

      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

      <div class="mt-8">
        <NewsletterSignup locale={locale} />
      </div>

      {affiliate && (
        <AffiliateCta
          title={affiliate.title}
          description={affiliate.description}
          buttonText={affiliate.buttonText}
          placeholder={affiliate.placeholder}
        />
      )}

      <AdSlot format="banner" />
    </article>
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  .article-body h2 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.6rem;
  }
  .article-body h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
  }
  .article-body {
    text-align: justify;
    hyphens: auto;
  }
  .article-body p {
    margin-bottom: 1.1rem;
    color: #374151;
  }
  .article-body ul,
  .article-body ol {
    margin-bottom: 1.1rem;
    padding-left: 1.5rem;
  }
  .article-body ul { list-style: disc; }
  .article-body ol { list-style: decimal; }
  .article-body li { margin-bottom: 0.4rem; }
  .article-body strong { color: #111827; }
  .article-body blockquote {
    border-left: 4px solid theme('colors.brand.400');
    padding-left: 1rem;
    color: #4b5563;
    font-style: italic;
    margin: 1.25rem 0;
  }
</style>
