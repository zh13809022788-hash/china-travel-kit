---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import AffiliateCta from '../components/AffiliateCta.astro';
import FaqSection from '../components/FaqSection.astro';
import type { FaqItem } from '../components/FaqSection.astro';
import CoverImage from '../components/CoverImage.astro';
import RelatedReading from '../components/RelatedReading.astro';
import type { RelatedItem } from '../components/RelatedReading.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';

export interface Props {
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  tags?: string[];
  faqs?: FaqItem[];
  cover?: string;
  coverAlt?: string;
  related?: RelatedItem[];
  locale?: 'en' | 'zh-TW';
  alternates?: {
    en?: string;
    'zh-TW'?: string;
  };
  affiliate?: {
    title: string;
    description: string;
    buttonText?: string;
    placeholder?: string;
  };
}

const {
  title,
  description,
  pubDate,
  category,
  tags = [],
  faqs = [],
  cover,
  coverAlt,
  related = [],
  locale = 'en',
  alternates,
  affiliate,
} = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteURL = new URL('/', Astro.site).toString();
const author = {
  name: 'ChinaTripBox Editorial Team',
  url: new URL('/authors/chinatripbox-editorial-team/', Astro.site).toString(),
};

const categoryLabels: Record<string, string> = {
  payment: locale === 'zh-TW' ? '付款' : 'Payment',
  esim: 'eSIM',
  transport: locale === 'zh-TW' ? '交通' : 'Transport',
  essentials: locale === 'zh-TW' ? '行前準備' : 'Trip Planning',
  food: locale === 'zh-TW' ? '美食與用餐' : 'Food & Dining',
};

const categoryPaths: Record<string, string> = {
  payment: '/payment/',
  esim: '/esim/',
  transport: '/transport/',
  essentials: '/essentials/',
  food: '/food/',
};

const faqItems = faqs.map((item) => ({
  '@type': 'Question',
  name: item.question,
  acceptedAnswer: {
    '@type': 'Answer',
    text: item.answer,
  },
}));

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  image: [new URL('/og-default.svg', Astro.site).toString()],
  datePublished: pubDate.toISOString(),
  dateModified: pubDate.toISOString(),
  mainEntityOfPage: canonicalURL.toString(),
  author: {
    '@type': 'Person',
    name: author.name,
    url: author.url,
  },
  publisher: {
    '@type': 'Organization',
    '@id': `${siteURL}#organization`,
    name: 'ChinaTripBox',
    logo: {
      '@type': 'ImageObject',
      url: new URL('/favicon.svg', Astro.site).toString(),
    },
  },
};

const faqJsonLd =
  faqItems.length > 0
    ? {
        '@context': 'https://schema.org',
        '@type': 'FAQPage',
        mainEntity: faqItems,
      }
    : null;

const jsonLd = faqJsonLd ? [articleJsonLd, faqJsonLd] : articleJsonLd;

const formattedDate = pubDate.toLocaleDateString(locale === 'zh-TW' ? 'zh-TW' : 'en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} type="article" locale={locale} alternates={alternates}>
  <Header locale={locale} alternates={alternates} />
  <main class="container-page py-8">
    <article class="prose-content">
      {/* 1. Top ad slot */}
      <AdSlot format="banner" />

      {/* 2. Title & meta */}
      <header class="mb-8">
        <Breadcrumbs
          items={[
            { label: locale === 'zh-TW' ? '首頁' : 'Home', href: locale === 'zh-TW' ? '/zh-tw/' : '/' },
            { label: categoryLabels[category] ?? category, href: categoryPaths[category] ?? '/' },
            { label: title },
          ]}
        />
        <a href={`/${category}/`} class="text-sm font-semibold uppercase tracking-wide text-brand-600">
          {categoryLabels[category] ?? category}
        </a>
        <h1 class="mt-2 text-3xl font-bold leading-tight text-gray-900 md:text-4xl">{title}</h1>
        <p class="mt-3 text-lg text-gray-600">{description}</p>
        <div class="mt-4 flex flex-wrap items-center gap-3 text-sm text-gray-500">
          <time datetime={pubDate.toISOString()}>{formattedDate}</time>
          <span>{locale === 'zh-TW' ? '作者：' : 'By '}<a href="/authors/chinatripbox-editorial-team/" class="font-medium text-gray-700 hover:text-brand-600">ChinaTripBox Editorial Team</a></span>
          {tags.length > 0 && (
            <span class="flex flex-wrap gap-2">
              {tags.map((tag) => (
                <span class="rounded-full bg-gray-100 px-2.5 py-0.5 text-xs text-gray-600">#{tag}</span>
              ))}
            </span>
          )}
        </div>
      </header>

      {/* 3. Cover image */}
      {cover && <CoverImage name={cover} alt={coverAlt ?? title} />}
      <div class="article-body max-w-none">
        <slot />
      </div>

      {/* 4. In-article ad slot */}
      <AdSlot format="in-article" />

      {/* 5. FAQ module */}
      <FaqSection items={faqs} />

      <RelatedReading items={related} title={locale === 'zh-TW' ? '下一步推薦閱讀' : 'Recommended next steps'} />

      <p class="mt-8 rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-600">
        {locale === 'zh-TW'
          ? '發現內容過時或有誤？請附上頁面網址 '
          : 'Found something outdated or incorrect? Please '}
        <a href="/contact/" class="font-semibold">{locale === 'zh-TW' ? '回報修正' : 'send a correction'}</a>
        {locale === 'zh-TW' ? '，我們會盡快檢查。' : ' with the page URL so we can review it.'}
      </p>

      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

      {/* 6. Affiliate CTA card */}
      {affiliate && (
        <AffiliateCta
          title={affiliate.title}
          description={affiliate.description}
          buttonText={affiliate.buttonText}
          placeholder={affiliate.placeholder}
        />
      )}

      {/* 7. Bottom ad slot */}
      <AdSlot format="banner" />
    </article>
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  .article-body h2 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.6rem;
  }
  .article-body h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
  }
  .article-body p {
    margin-bottom: 1.1rem;
    color: #374151;
  }
  .article-body ul,
  .article-body ol {
    margin-bottom: 1.1rem;
    padding-left: 1.5rem;
  }
  .article-body ul { list-style: disc; }
  .article-body ol { list-style: decimal; }
  .article-body li { margin-bottom: 0.4rem; }
  .article-body strong { color: #111827; }
  .article-body blockquote {
    border-left: 4px solid theme('colors.brand.400');
    padding-left: 1rem;
    color: #4b5563;
    font-style: italic;
    margin: 1.25rem 0;
  }
</style>
