---
// Thin layout for the new vertical guide pages (long-stay, digital-nomads,
// ai-opc). Reuses BaseLayout for SEO/head, adds Header/Footer, and wires in
// Breadcrumbs, TOC, FAQ, Related Reading, and Article JSON-LD so the pages
// themselves only supply content.
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import type { Crumb } from '../components/Breadcrumbs.astro';
import Toc from '../components/Toc.astro';
import type { TocItem } from '../components/Toc.astro';
import FaqSection from '../components/FaqSection.astro';
import type { FaqItem } from '../components/FaqSection.astro';
import RelatedReading from '../components/RelatedReading.astro';
import type { RelatedItem } from '../components/RelatedReading.astro';
import ArticleSchema from '../components/ArticleSchema.astro';
import CoverImage from '../components/CoverImage.astro';

export interface Props {
  title: string; // <h1> and SEO title base
  description: string; // meta description + lead paragraph
  url: string; // canonical path, e.g. "/digital-nomads/visa/"
  datePublished: string; // ISO "YYYY-MM-DD"
  breadcrumbs: Crumb[];
  toc?: TocItem[];
  faqs?: FaqItem[];
  related?: RelatedItem[];
  cover?: string; // image name in src/assets/images/ (e.g. "cover-visa")
  coverAlt?: string;
  image?: string; // OG image path override
  locale?: string;
}

const {
  title,
  description,
  url,
  datePublished,
  breadcrumbs,
  toc = [],
  faqs = [],
  related = [],
  cover,
  coverAlt = '',
  image,
  locale = 'en',
} = Astro.props;

const formattedDate = new Date(datePublished).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const ui = {
  relatedTitle: { en:'Related Reading', 'zh-TW':'相關閱讀', ja:'関連記事', ko:'관련 읽을거리', ru:'Рекомендуемые', fr:'Lecture connexe', de:'Weiterführende Lektüre', es:'Lectura relacionada' },
  readMore: { en:'Read more →', 'zh-TW':'閱讀更多 →', ja:'続きを読む →', ko:'더 읽기 →', ru:'Читать далее →', fr:'Lire la suite →', de:'Weiterlesen →', es:'Seguir leyendo →' },
};
const relatedTitle = ui.relatedTitle[locale] ?? 'Related Reading';
const readMore = ui.readMore[locale] ?? 'Read more →';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} type="article" image={image} locale={locale}>
  <Header locale={locale} />
  <main class="container-page py-8">
    <article class="prose-content">
      <Breadcrumbs items={breadcrumbs} />

      <header class="mb-6">
        <h1 class="text-3xl font-bold leading-tight text-gray-900 md:text-4xl">{title}</h1>
        <p class="mt-3 text-lg text-gray-600">{description}</p>
        <div class="mt-4 text-sm text-gray-500">
          <time datetime={datePublished}>{formattedDate}</time>
        </div>
      </header>

      {cover && <CoverImage name={cover} alt={coverAlt || title} loading="eager" />}

      <Toc items={toc} />

      <div class="article-body max-w-none">
        <slot />
      </div>

      <FaqSection items={faqs} locale={locale} />

      <RelatedReading items={related} />

      <ArticleSchema
        title={title}
        description={description}
        url={url}
        datePublished={datePublished}
      />
    </article>
  </main>
  <Footer />
</BaseLayout>

<style is:global>
  .article-body h2 {
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    font-size: 1.6rem;
    scroll-margin-top: 5rem;
  }
  .article-body h3 {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    font-size: 1.25rem;
  }
  .article-body p {
    margin-bottom: 1.1rem;
    color: #374151;
  }
  .article-body ul,
  .article-body ol {
    margin-bottom: 1.1rem;
    padding-left: 1.5rem;
  }
  .article-body ul { list-style: disc; }
  .article-body ol { list-style: decimal; }
  .article-body li { margin-bottom: 0.4rem; }
  .article-body strong { color: #111827; }
  .article-body table {
    width: 100%;
    border-collapse: collapse;
    margin: 1.25rem 0;
    font-size: 0.95rem;
  }
  .article-body th,
  .article-body td {
    border: 1px solid #e5e7eb;
    padding: 0.5rem 0.75rem;
    text-align: left;
  }
  .article-body th { background: #f9fafb; font-weight: 600; color: #111827; }
  .article-body blockquote {
    border-left: 4px solid theme('colors.brand.400');
    padding-left: 1rem;
    color: #4b5563;
    font-style: italic;
    margin: 1.25rem 0;
  }
</style>
