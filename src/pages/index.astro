---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import { TOOLS } from '../config';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/city-shanghai.jpg';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featuredPosts = sortedPosts.filter((post) => post.data.featured);
const latestPosts = sortedPosts.slice(0, 8);
const planningTools = TOOLS.slice(0, 6);

const categoryLabels: Record<string, string> = {
  payment: 'Payment',
  esim: 'eSIM & Internet',
  transport: 'Transport',
  essentials: 'Trip Planning',
  food: 'Food & Dining',
};

const topicHubs = [
  {
    href: '/resources/',
    label: 'Start here',
    title: 'Find the right guide',
    desc: 'A guided index for first timers, including visas, payments, internet, transport, food, cities, and tools.',
    accent: 'bg-indigo-50 text-indigo-700 ring-indigo-100',
  },
  {
    href: '/payment/',
    label: 'Payment',
    title: 'Pay in China',
    desc: 'Alipay, WeChat Pay, foreign cards, cash backup, and everyday payment problems.',
    accent: 'bg-rose-50 text-rose-700 ring-rose-100',
  },
  {
    href: '/esim/',
    label: 'Internet',
    title: 'Stay Connected',
    desc: 'eSIM choices, roaming costs, app access, VPN expectations, and mobile setup.',
    accent: 'bg-sky-50 text-sky-700 ring-sky-100',
  },
  {
    href: '/transport/',
    label: 'Transport',
    title: 'Move Around',
    desc: 'High-speed rail, airport transfers, DiDi, metro systems, tickets, and QR codes.',
    accent: 'bg-emerald-50 text-emerald-700 ring-emerald-100',
  },
  {
    href: '/cities/',
    label: 'Cities',
    title: 'Choose your base',
    desc: 'City guides for Beijing, Shanghai, Chengdu, Hangzhou, and Sanya, with arrival and neighborhood context.',
    accent: 'bg-violet-50 text-violet-700 ring-violet-100',
  },
  {
    href: '/food/',
    label: 'Food',
    title: 'Eat with confidence',
    desc: 'Food delivery, street-food safety, spice levels, tipping, and restaurant etiquette for visitors.',
    accent: 'bg-orange-50 text-orange-700 ring-orange-100',
  },
  {
    href: '/essentials/',
    label: 'Essentials',
    title: 'Plan the Basics',
    desc: 'Packing, seasons, cash, tipping, food safety, and practical first-trip decisions.',
    accent: 'bg-amber-50 text-amber-700 ring-amber-100',
  },
];

const quickPaths = [
  { href: '/resources/', title: 'I need the best starting point', desc: 'Use the resource hub to jump into the right guide, tool, or city pathway.' },
  { href: '/trip-planner/', title: 'Build my China plan', desc: 'Create a practical payment, eSIM, transport, and first-day setup plan.' },
  { href: '/tools/payment-checker/', title: 'Can I pay with my card?', desc: 'Check Alipay, WeChat Pay, card limits, and cash backup before you land.' },
  { href: '/tools/visa-free-checker/', title: 'Do I need a visa?', desc: 'Check visa-free entry and transit options by passport and route.' },
];

const arrivalTasks = [
  {
    href: '/payment/',
    title: 'Set up payments',
    desc: 'Choose Alipay, WeChat Pay, foreign cards, and a small cash backup.',
    action: 'Start payment setup',
  },
  {
    href: '/esim/',
    title: 'Get online on arrival',
    desc: 'Pick between eSIM, roaming, pocket Wi-Fi, and apps that may need a workaround.',
    action: 'Compare internet options',
  },
  {
    href: '/transport/',
    title: 'Plan the first ride',
    desc: 'Prepare airport transfers, metro QR codes, DiDi, and train tickets.',
    action: 'Plan transport',
  },
];

const mainPages = [
  {
    title: 'China Trip Planner',
    description: 'Create a practical first-pass plan for payments, eSIMs, transport, apps, cash, and daily pacing.',
    href: '/trip-planner/',
    category: 'Planning',
    tags: ['trip planner', 'china itinerary', 'arrival setup', 'payment', 'esim'],
  },
  {
    title: 'China Travel Help',
    description: 'Ask a practical China travel question and learn when to upgrade to human help.',
    href: '/travel-help/',
    category: 'Help',
    tags: ['travel help', 'ai question', 'human help', 'china support'],
  },
  {
    title: 'Long Stay in China',
    description: 'Practical setup for visitors staying longer than a short tourist trip.',
    href: '/long-stay/',
    category: 'Planning',
    tags: ['long stay', 'china setup', 'travel planning'],
  },
  {
    title: 'Digital Nomads in China',
    description: 'Connectivity, payments, visas, work setup, and practical tools for remote workers.',
    href: '/digital-nomads/',
    category: 'Digital Nomads',
    tags: ['digital nomad', 'remote work', 'china'],
  },
  {
    title: 'China Travel Tools',
    description: 'Free calculators and checkers for visas, eSIMs, payments, budgets, plugs, and phrases.',
    href: '/tools/',
    category: 'Tools',
    tags: ['tools', 'calculator', 'checker'],
  },
  {
    title: 'China City Guides',
    description: 'Choose where to land and how to plan Beijing, Shanghai, Chengdu, Hangzhou, and Sanya.',
    href: '/cities/',
    category: 'Cities',
    tags: ['cities', 'beijing', 'shanghai', 'chengdu', 'hangzhou', 'sanya'],
  },
  {
    title: 'China Food and Dining Guides',
    description: 'Order food, handle spice levels, understand tipping, and avoid common dining mistakes.',
    href: '/food/',
    category: 'Food',
    tags: ['food', 'dining', 'meituan', 'chengdu', 'tipping'],
  },
];

const searchItems = [
  ...sortedPosts.map((post) => ({
    type: 'Guide',
    title: post.data.title,
    description: post.data.description,
    href: `/posts/${post.slug}/`,
    category: categoryLabels[post.data.category] ?? post.data.category,
    tags: post.data.tags,
  })),
  ...TOOLS.map((tool) => ({
    type: 'Tool',
    title: tool.title,
    description: tool.desc,
    href: tool.href,
    category: 'Tool',
    tags: [tool.title, tool.desc],
  })),
  ...mainPages.map((page) => ({
    type: 'Page',
    title: page.title,
    description: page.description,
    href: page.href,
    category: page.category,
    tags: page.tags,
  })),
];
---

<BaseLayout>
  <Header />
  <main>
    <section class="border-b border-gray-200 bg-[radial-gradient(circle_at_top_left,#fff1f2,transparent_30%),linear-gradient(180deg,#f8fafc_0%,#ffffff_80%)]">
      <div class="container-page grid gap-10 py-12 lg:grid-cols-[1fr_360px] lg:items-center lg:py-16">
        <div>
          <p class="text-sm font-semibold uppercase tracking-wide text-brand-700">ChinaTripBox travel toolkit</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Sort out payments, internet, visas, and transport before you land in China
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Use practical checkers and step-by-step guides for the decisions foreign visitors usually need to solve first: how to pay, how to get online, whether visa-free transit applies, and how to move around.
          </p>

          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/tools/payment-checker/" class="btn-primary">Check payment setup</a>
            <a href="/tools/visa-free-checker/" class="btn-outline">Check visa-free entry</a>
          </div>

          <section class="mt-8" aria-label="Site search">
            <div class="search-shell">
              <label for="site-search" class="sr-only">Search all ChinaTripBox content</label>
              <div class="flex items-center gap-3 border-b border-gray-200 px-4 py-3">
                <span aria-hidden="true" class="text-lg text-gray-400">⌕</span>
                <input
                  id="site-search"
                  class="min-w-0 flex-1 border-0 bg-transparent text-base text-gray-950 outline-none placeholder:text-gray-400"
                  type="search"
                  autocomplete="off"
                  placeholder="Search payments, eSIM, visa-free transit, trains, cash..."
                />
              </div>
              <div id="search-results" class="hidden max-h-[420px] overflow-y-auto p-2"></div>
              <div id="search-empty" class="hidden px-4 py-5 text-sm text-gray-500">
                No matching guide or tool found. Try a shorter term like "Alipay", "train", "eSIM", or "visa".
              </div>
            </div>
            <div class="mt-3 flex flex-wrap gap-2 text-sm">
              {['Alipay', 'WeChat Pay', 'eSIM', 'visa-free', 'train tickets', 'cash'].map((term) => (
                <button class="search-chip" type="button" data-search-term={term}>{term}</button>
              ))}
            </div>
          </section>
        </div>

        <aside class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
          <Image
            src={heroImage}
            alt="Shanghai skyline from the Bund, representing China city travel planning"
            widths={[360, 720]}
            sizes="(max-width: 1024px) 100vw, 360px"
            quality={65}
            loading="eager"
            class="h-48 w-full object-cover"
          />
          <div class="border-b border-gray-100 px-5 py-4">
            <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">First-trip shortcuts</p>
            <h2 class="mt-1 text-base font-bold text-gray-950">Start here</h2>
          </div>
          <div class="grid gap-3 p-5">
            {quickPaths.map((item) => (
              <a href={item.href} class="group rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950 group-hover:text-brand-700">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <AdSlot format="banner" />

      <section class="py-8" aria-labelledby="arrival-tasks-heading">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Before you fly</p>
            <h2 id="arrival-tasks-heading">Solve the three arrival problems first</h2>
          </div>
          <a href="/tools/" class="text-sm font-semibold text-brand-700 hover:text-brand-800">Open all tools</a>
        </div>
        <div class="mt-6 grid gap-4 md:grid-cols-3">
          {arrivalTasks.map((task) => (
            <a href={task.href} class="card group block hover:no-underline">
              <h3 class="text-lg font-bold text-gray-950 group-hover:text-brand-700">{task.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{task.desc}</p>
              <span class="mt-4 inline-flex text-sm font-semibold text-brand-700">{task.action}</span>
            </a>
          ))}
        </div>
      </section>

      <section class="py-8">
        <div class="rounded-lg border border-brand-100 bg-brand-50 p-6 md:p-7">
          <div class="grid gap-6 md:grid-cols-[1fr_auto] md:items-center">
            <div>
              <p class="section-kicker">Plan first, ask later</p>
              <h2 class="mt-2 text-2xl font-bold text-gray-950">Start with a free China trip plan</h2>
              <p class="mt-3 max-w-2xl text-sm leading-6 text-gray-700">
                Build a practical arrival checklist for payments, eSIMs, transport, app setup,
                cash backup, and daily pacing. Complex issues can move to human one-on-one help later.
              </p>
            </div>
            <a href="/trip-planner/" class="btn-primary">Open Trip Planner</a>
          </div>
        </div>
      </section>

      <section class="py-8">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Browse by need</p>
            <h2>Choose a travel problem</h2>
          </div>
          <a href="/tools/" class="text-sm font-semibold text-brand-700 hover:text-brand-800">View all tools</a>
        </div>
        <div class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-3">
          {topicHubs.map((topic) => (
            <a href={topic.href} class="card group block hover:no-underline">
              <span class:list={['inline-flex rounded-full px-2.5 py-1 text-xs font-semibold ring-1', topic.accent]}>{topic.label}</span>
              <h3 class="mt-4 text-lg font-bold text-gray-950 group-hover:text-brand-700">{topic.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{topic.desc}</p>
              <span class="mt-4 inline-flex text-sm font-semibold text-brand-700">Explore guides</span>
            </a>
          ))}
        </div>
      </section>

      <section class="grid gap-8 py-8 lg:grid-cols-[1fr_340px]">
        <div>
          <div class="section-heading">
            <div>
              <p class="section-kicker">Latest guides</p>
              <h2>Recently updated travel answers</h2>
            </div>
          </div>
          <div class="mt-6 divide-y divide-gray-200 rounded-lg border border-gray-200 bg-white">
            {latestPosts.map((post) => (
              <a href={`/posts/${post.slug}/`} class="group block p-5 hover:bg-gray-50 hover:no-underline">
                <div class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-wide text-brand-700">
                  <span>{categoryLabels[post.data.category] ?? post.data.category}</span>
                  <span class="text-gray-300">/</span>
                  <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</time>
                </div>
                <h3 class="mt-2 text-lg font-bold text-gray-950 group-hover:text-brand-700">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        </div>

        <aside>
          <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
            <p class="section-kicker">Interactive planning</p>
            <h2 class="mt-1 text-xl font-bold text-gray-950">Useful tools</h2>
            <div class="mt-5 grid gap-3">
              {planningTools.map((tool) => (
                <a href={tool.href} class="group rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                  <h3 class="text-sm font-semibold text-gray-950 group-hover:text-brand-700">{tool.title}</h3>
                  <p class="mt-1 text-sm leading-6 text-gray-600">{tool.desc}</p>
                </a>
              ))}
            </div>
          </div>
        </aside>
      </section>

      {featuredPosts.length > 0 && (
        <section class="py-8">
          <div class="section-heading">
            <div>
              <p class="section-kicker">Editor picks</p>
              <h2>Core guides for first-time visitors</h2>
            </div>
          </div>
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {featuredPosts.slice(0, 4).map((post) => (
              <a href={`/posts/${post.slug}/`} class="card group block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{categoryLabels[post.data.category] ?? post.data.category}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950 group-hover:text-brand-700">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        </section>
      )}

      <AdSlot format="banner" />
    </div>
  </main>
  <Footer />
</BaseLayout>

<script type="application/json" id="site-search-data" set:html={JSON.stringify(searchItems)} />

<script>
  const input = document.getElementById('site-search') as HTMLInputElement | null;
  const results = document.getElementById('search-results');
  const empty = document.getElementById('search-empty');
  const dataScript = document.getElementById('site-search-data');
  const items = dataScript?.textContent ? JSON.parse(dataScript.textContent) : [];
  const normalize = (value: string) => value.toLowerCase().trim();
  const searchable = items.map((item: any) => ({
    ...item,
    haystack: normalize([item.title, item.description, item.category, ...(item.tags ?? [])].join(' ')),
  }));

  function renderSearch(query: string) {
    if (!results || !empty) return;
    const term = normalize(query);
    results.innerHTML = '';
    if (term.length < 2) {
      results.classList.add('hidden');
      empty.classList.add('hidden');
      return;
    }

    const matches = searchable
      .filter((item: any) => item.haystack.includes(term))
      .slice(0, 10);

    if (matches.length === 0) {
      results.classList.add('hidden');
      empty.classList.remove('hidden');
      return;
    }

    empty.classList.add('hidden');
    results.classList.remove('hidden');
    results.innerHTML = matches
      .map((item: any) => `
        <a class="block rounded-lg p-3 hover:bg-gray-50 hover:no-underline" href="${item.href}">
          <div class="flex items-center gap-2 text-xs font-semibold uppercase tracking-wide text-brand-700">
            <span>${item.type}</span>
            <span class="text-gray-300">/</span>
            <span>${item.category}</span>
          </div>
          <div class="mt-1 font-semibold text-gray-950">${item.title}</div>
          <p class="mt-1 text-sm leading-6 text-gray-600">${item.description}</p>
        </a>
      `)
      .join('');
  }

  function setSearch(value: string, updateUrl = false) {
    if (!input) return;
    input.value = value;
    renderSearch(value);
    if (updateUrl && value.trim().length >= 2) {
      const url = new URL(window.location.href);
      url.searchParams.set('q', value);
      window.history.replaceState({}, '', url);
    }
  }

  const initialQuery = new URLSearchParams(window.location.search).get('q');
  if (initialQuery) {
    setSearch(initialQuery);
  }

  input?.addEventListener('input', () => setSearch(input.value, true));
  document.querySelectorAll<HTMLButtonElement>('[data-search-term]').forEach((button) => {
    button.addEventListener('click', () => {
      if (!input) return;
      setSearch(button.dataset.searchTerm ?? '', true);
      input.focus();
    });
  });
</script>
