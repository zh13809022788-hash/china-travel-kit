---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';

const posts = await getCollection('posts');
const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const featured = sorted.filter((p) => p.data.featured).slice(0, 3);
const popular = (featured.length > 0 ? featured : sorted).slice(0, 6);

const categories = [
  {
    href: '/payment/',
    title: 'Payment',
    desc: 'Set up Alipay & WeChat Pay, link foreign cards, and pay like a local.',
    icon: '💳',
  },
  {
    href: '/esim/',
    title: 'eSIM & Data',
    desc: 'Stay online the moment you land with the best eSIM plans for China.',
    icon: '📶',
  },
  {
    href: '/transport/',
    title: 'Transport',
    desc: 'Book high-speed trains, use ride-hailing, and get around with ease.',
    icon: '🚄',
  },
];
---

<BaseLayout>
  <Header />
  <main>
    <!-- Hero -->
    <section class="border-b border-gray-100 bg-gradient-to-b from-brand-50 to-white">
      <div class="container-page py-16 text-center md:py-24">
        <h1 class="mx-auto max-w-3xl text-4xl font-bold leading-tight text-gray-900 md:text-5xl">
          Everything You Need to Travel China Smoothly
        </h1>
        <p class="mx-auto mt-5 max-w-2xl text-lg text-gray-600">
          Practical, up-to-date guides for foreign visitors — mobile payments, eSIM data,
          trains, and ride-hailing. No guesswork, just what works.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href="/payment/" class="btn-primary">Start with Payments</a>
          <a href="/tools/" class="btn-outline">Try Our Tools</a>
        </div>
      </div>
    </section>

    <div class="container-page py-12">
      <AdSlot format="banner" />

      <!-- Core categories -->
      <section class="py-8">
        <h2 class="text-2xl font-bold text-gray-900">Explore by Topic</h2>
        <div class="mt-6 grid gap-6 md:grid-cols-3">
          {categories.map((cat) => (
            <a href={cat.href} class="card block hover:no-underline">
              <div class="text-3xl">{cat.icon}</div>
              <h3 class="mt-3 text-lg font-bold text-gray-900">{cat.title}</h3>
              <p class="mt-1.5 text-sm text-gray-600">{cat.desc}</p>
              <span class="mt-3 inline-block text-sm font-semibold text-brand-600">Read guides →</span>
            </a>
          ))}
        </div>
      </section>

      <!-- Popular guides -->
      <section class="py-8">
        <h2 class="text-2xl font-bold text-gray-900">Popular Guides</h2>
        <div class="mt-6 grid gap-6 md:grid-cols-2">
          {popular.map((post) => (
            <a href={`/posts/${post.slug}/`} class="card block hover:no-underline">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{post.data.category}</span>
              <h3 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h3>
              <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>

      <!-- Tools entry -->
      <section class="py-8">
        <div class="rounded-2xl bg-gray-900 px-8 py-10 text-center">
          <h2 class="text-2xl font-bold text-white">Free Interactive Tools</h2>
          <p class="mx-auto mt-2 max-w-xl text-gray-300">
            Compare eSIM plans and check whether your card works in China — in seconds.
          </p>
          <a href="/tools/" class="btn-primary mt-6">Open Tool Center</a>
        </div>
      </section>

      <AdSlot format="banner" />
    </div>
  </main>
  <Footer />
</BaseLayout>
