---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import { TOOLS } from '../config';

const featuredTools = TOOLS.filter((t) => t.featured).slice(0, 6);

const posts = await getCollection('posts');
const sorted = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
// Featured guides surface first, then every remaining guide by date, so all
// articles are reachable directly from the homepage (better for SEO & AdSense).
const featuredPosts = sorted.filter((p) => p.data.featured);
const restPosts = sorted.filter((p) => !p.data.featured);
const popular = [...featuredPosts, ...restPosts];

const categories = [
  {
    href: '/payment/',
    title: 'Payment',
    desc: 'Set up Alipay & WeChat Pay, link foreign cards, and pay like a local.',
    icon: '💳',
  },
  {
    href: '/esim/',
    title: 'eSIM & Data',
    desc: 'Stay online the moment you land with the best eSIM plans for China.',
    icon: '📶',
  },
  {
    href: '/transport/',
    title: 'Transport',
    desc: 'Book high-speed trains, use ride-hailing, and get around with ease.',
    icon: '🚄',
  },
];
---

<BaseLayout>
  <Header />
  <main>
    <!-- Hero -->
    <section class="border-b border-gray-100 bg-gradient-to-b from-brand-50 to-white">
      <div class="container-page py-16 text-center md:py-24">
        <h1 class="mx-auto max-w-3xl text-4xl font-bold leading-tight text-gray-900 md:text-5xl">
          Everything You Need to Travel China Smoothly
        </h1>
        <p class="mx-auto mt-5 max-w-2xl text-lg text-gray-600">
          Practical, up-to-date guides for foreign visitors — mobile payments, eSIM data,
          trains, and ride-hailing. No guesswork, just what works.
        </p>
        <div class="mt-8 flex flex-wrap justify-center gap-3">
          <a href="/payment/" class="btn-primary">Start with Payments</a>
          <a href="/tools/" class="btn-outline">Try Our Tools</a>
        </div>
      </div>
    </section>

    <div class="container-page py-12">
      <AdSlot format="banner" />

      <!-- Core categories -->
      <section class="py-8">
        <h2 class="text-2xl font-bold text-gray-900">Explore by Topic</h2>
        <div class="mt-6 grid gap-6 md:grid-cols-3">
          {categories.map((cat) => (
            <a href={cat.href} class="card block hover:no-underline">
              <div class="text-3xl">{cat.icon}</div>
              <h3 class="mt-3 text-lg font-bold text-gray-900">{cat.title}</h3>
              <p class="mt-1.5 text-sm text-gray-600">{cat.desc}</p>
              <span class="mt-3 inline-block text-sm font-semibold text-brand-600">Read guides →</span>
            </a>
          ))}
        </div>
      </section>

      <!-- All guides -->
      <section class="py-8">
        <h2 class="text-2xl font-bold text-gray-900">All Guides</h2>
        <p class="mt-1 text-gray-600">Every practical guide for your China trip, updated for 2026.</p>
        <div class="mt-6 grid gap-6 md:grid-cols-2">
          {popular.map((post) => (
            <a href={`/posts/${post.slug}/`} class="card block hover:no-underline">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{post.data.category}</span>
              <h3 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h3>
              <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>

      <!-- Tools entry -->
      <section class="py-8">
        <div class="flex items-end justify-between gap-4">
          <div>
            <h2 class="text-2xl font-bold text-gray-900">Free Interactive Tools</h2>
            <p class="mt-1 text-gray-600">Plan the practical side of your trip in seconds — no sign-up needed.</p>
          </div>
          <a href="/tools/" class="hidden shrink-0 text-sm font-semibold text-brand-600 hover:text-brand-700 sm:inline">
            View all tools →
          </a>
        </div>
        <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {featuredTools.map((tool) => (
            <a href={tool.href} class="card block hover:no-underline">
              <div class="text-3xl">{tool.icon}</div>
              <h3 class="mt-3 text-base font-bold text-gray-900">{tool.title}</h3>
              <p class="mt-1.5 text-sm text-gray-600">{tool.desc}</p>
              <span class="mt-3 inline-block text-sm font-semibold text-brand-600">Open tool →</span>
            </a>
          ))}
        </div>
        <div class="mt-6 text-center sm:hidden">
          <a href="/tools/" class="btn-outline">View all tools</a>
        </div>
      </section>

      <AdSlot format="banner" />
    </div>
  </main>
  <Footer />
</BaseLayout>
