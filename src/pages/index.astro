---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/city-shanghai.jpg';
import { TOOLS } from '../config';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 12);
const featuredTools = TOOLS.filter((t) => t.featured).slice(0, 4);

import { getCategoryLabel } from '../i18n/categories';
const locale = 'en';
---

<BaseLayout
  title="ChinaTripBox - Payment, eSIM & Transport Guides for China Travel"
  description="Practical China travel guides for foreign visitors: payments, eSIMs, high-speed rail, DiDi, visa-free transit, and what to set up before you land."
  alternates={{ en: '/', 'zh-TW': '/zh-tw/', ja: '/ja/', ko: '/ko/', ru: '/ru/', fr: '/fr/', de: '/de/', es: '/es/' }}
>
  <Header />
  <main>
    <section class="border-b border-gray-200 bg-gray-50">
      <div class="container-page grid gap-8 py-12 lg:grid-cols-[1fr_360px] lg:items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-wide text-brand-700">ChinaTripBox travel toolkit</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Sort out payments, internet, visas, and transport before you land in China
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Practical guides and tools for foreign visitors. Set up Alipay, WeChat Pay, eSIM, high-speed rail, DiDi, and visa-free transit — solve the logistics first, then enjoy the trip.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/posts/how-to-pay-in-china-tourist-guide/" class="btn-primary">Start with payments</a>
            <a href="/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-outline">Pre-departure checklist</a>
          </div>
        </div>

        <aside class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
          <Image
            src={heroImage}
            alt="Shanghai skyline representing China city travel planning"
            widths={[360, 720]}
            sizes="(max-width: 1024px) 100vw, 360px"
            quality={65}
            loading="eager"
            class="h-52 w-full object-cover"
          />
          <div class="p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Suggested reading order</p>
            <h2 class="mt-2 text-lg font-bold text-gray-950">Solve arrival-day problems first</h2>
            <p class="mt-2 text-sm leading-6 text-gray-600">
              Payments, internet, ride-hailing, and train tickets are the four things worth setting up before you land.
            </p>
          </div>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <!-- Tools section: essential planning tools before articles -->
      <section class="mb-8">
        <div class="section-heading">
          <div>
            <p class="section-kicker">start here</p>
            <h2>Essential planning tools</h2>
          </div>
        </div>
        <div class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
          {featuredTools.map((tool) => (
            <a
              href={tool.href}
              class="group block rounded-lg border border-gray-200 bg-white p-5 transition hover:border-brand-200 hover:shadow-sm hover:no-underline"
            >
              <div class="text-2xl">{tool.icon}</div>
              <h3 class="mt-3 text-sm font-bold text-gray-950 group-hover:text-brand-700">{tool.title}</h3>
              <p class="mt-1 text-xs leading-5 text-gray-500">{tool.desc}</p>
            </a>
          ))}
        </div>
      </section>

      <section class="py-8">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Latest guides</p>
            <h2>Practical China travel articles</h2>
          </div>
        </div>

        <div class="mt-6 divide-y divide-gray-200 rounded-lg border border-gray-200 bg-white">
          {sortedPosts.map((post) => (
            <a href={`/posts/${post.slug}/`} class="group block p-5 hover:bg-gray-50 hover:no-underline">
              <div class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-wide text-brand-700">
                <span>{getCategoryLabel(post.data.category, locale)}</span>
                <span class="text-gray-300">/</span>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </div>
              <h3 class="mt-2 text-lg font-bold text-gray-950 group-hover:text-brand-700">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>

      <!-- Guides section -->

      <section class="py-8">
        <NewsletterSignup locale="en" />
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>
