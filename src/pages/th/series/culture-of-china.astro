---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';

const seriesSlug = 'culture-of-china';
const posts = (await getCollection('posts-zh-tw'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = '中國文化：旅客須知的傳統與習俗';
const description = '以外國旅客的角度探索中華文化：茶道、春節、面子與關係、書法、功夫、生肖，以及形塑中國日常生活的傳統。';

const relatedTools = [
  { href: '/zh-tw/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/', title: '小費與禮儀', desc: '什麼時候該給小費、什麼時候不用，以及背後的原因' },
  { href: '/zh-tw/posts/what-to-pack-for-china-a-season-by-season-checklist/', title: '節慶行李準備', desc: '假期期間應攜帶的物品' },
  { href: '/zh-tw/posts/how-to-pay-in-china-tourist-guide/', title: '在中國如何付款', desc: '節慶期間的付款方式' },
];

const relatedCities = [
  { href: '/zh-tw/posts/beijing-city-guide-for-foreigners/', title: '北京', desc: '皇家文化與胡同生活' },
  { href: '/zh-tw/posts/hangzhou-city-guide-for-foreigners/', title: '杭州', desc: '茶文化與西湖遺產' },
  { href: '/zh-tw/posts/chengdu-city-guide-for-foreigners/', title: '成都', desc: '茶館文化與慢活步調' },
];

const otherSeries = [
  { href: '/zh-tw/series/food-of-china/', title: '中國美食' },
  { href: '/zh-tw/series/history-of-china/', title: '中國歷史' },
  { href: '/zh-tw/series/modern-china/', title: '現代中國' },
];
import { getCategoryLabel } from '../../../i18n/categories';
const locale = 'zh-tw';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="zh-TW">
  <Header locale="zh-TW" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">內容系列</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">文章</p>
            <h2>中國文化系列</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/zh-tw/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">本系列文章正在準備中，請稍後再回來查看。</p>
        )}
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">實用工具</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">帶著文化理解去旅行</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">城市指南</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">文化名城</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">更多系列</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>
