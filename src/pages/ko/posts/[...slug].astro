---
import { getCollection } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts-ko');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { data } = post;

const affiliateByCategory: Record<string, { title: string; description: string; buttonText: string }> = {
  payment: {
    title: '사전 결제 설정',
    description: 'Alipay와 WeChat Pay에서 사용 가능한 여행용 카드를 준비하면 중국 도착 후 안심할 수 있습니다.',
    buttonText: '설정 시작',
  },
  esim: {
    title: '추천 중국 eSIM',
    description: '공항에서 줄 서지 마세요. 출발 전 고속 데이터 통신을 활성화하세요.',
    buttonText: '요금제 보기',
  },
  transport: {
    title: '기차·픽업 간편 예약',
    description: '영어로 고속철도 티켓과 공항 픽업을 예약하면 소통 부담을 줄일 수 있습니다.',
    buttonText: '예약하기',
  },
};

const affiliate = affiliateByCategory[data.category];
const allPosts = await getCollection('posts-ko');
const related = allPosts
  .filter((candidate) => candidate.slug !== post.slug)
  .map((candidate) => {
    const sharedTags = candidate.data.tags.filter((tag) => data.tags.includes(tag)).length;
    const categoryMatch = candidate.data.category === data.category ? 2 : 0;
    const cityMatch =
      ['beijing', 'shanghai', 'chengdu', 'hangzhou', 'sanya'].some(
        (city) => post.slug.includes(city) && candidate.slug.includes(city)
      )
        ? 3
        : 0;
    return { candidate, score: sharedTags + categoryMatch + cityMatch };
  })
  .filter((item) => item.score > 0)
  .sort((a, b) => b.score - a.score || b.candidate.data.pubDate.valueOf() - a.candidate.data.pubDate.valueOf())
  .slice(0, 4)
  .map(({ candidate }) => ({
    title: candidate.data.title,
    description: candidate.data.description,
    href: `/ko/posts/${candidate.slug}/`,
  }));
---

<BlogPost
  title={data.title}
  description={data.description}
  pubDate={data.pubDate}
  category={data.category}
  tags={data.tags}
  faqs={data.faqs}
  cover={data.cover}
  coverAlt={data.coverAlt}
  related={related}
  locale="ko"
  alternates={{ en: `/posts/${post.slug}/`, ko: `/ko/posts/${post.slug}/` }}
  affiliate={affiliate}
>
  <Content />
</BlogPost>
