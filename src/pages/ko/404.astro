---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = '페이지를 찾을 수 없습니다';
const description = '요청하신 ChinaTripBox 페이지를 찾을 수 없습니다.';
---
<!-- AI 지원으로 생성된 콘텐츠, 원어민 검토 완료 -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description} noindex>
  <Header />
  <main class="container-page py-16">
    <section class="mx-auto max-w-2xl">
      <p class="section-kicker">404</p>
      <h1 class="mt-2 text-4xl font-bold text-gray-950">페이지를 찾을 수 없습니다</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">
        페이지가 이동되었거나 주소가 올바르지 않을 수 있습니다. 가이드 허브에서 다시 시작하거나 아래의
        계획 도구를 사용하세요.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/" class="btn-primary">홈으로 이동</a>
        <a href="/resources/" class="btn-outline">여기서 시작하기</a>
        <a href="/tools/" class="btn-outline">도구 열기</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>