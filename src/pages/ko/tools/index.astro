---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import { TOOLS as tools } from '../../../config';

const title = '무료 중국 여행 도구: 비자, 결제, eSIM, 예산, 기사 카드, 필수 표현';
const description =
  '중국 여행을 준비할 때 유용한 무료 인터랙티브 도구를 한곳에 모았어요. 무비자 입국 가능 여부, 결제 카드 호환성, eSIM 옵션, 여행 예산, 현금 예비금, 전원 플러그, 중국어 필수 표현, 택시 기사님용 주소 카드를 확인해 보세요.';

const toolUseCases = [
  {
    title: '항공권 예약 전에',
    text: '날짜와 도시를 확정하기 전에 무비자 확인기, 최적 여행 시기 플래너, 예산 계산기를 먼저 활용해 보세요.',
    links: [
      { href: '/ko/tools/visa-free-checker/', label: '무비자 확인기' },
      { href: '/ko/tools/best-time-to-visit/', label: '여행 최적 시기' },
      { href: '/ko/tools/budget-cash-estimator/', label: '예산 계산기' },
    ],
  },
  {
    title: '출발 전에',
    text: '집에서 아직 설정을 바로잡을 시간이 있을 때 결제, eSIM, 앱, 플러그, 표현 도구를 확인해 보세요.',
    links: [
      { href: '/ko/tools/payment-checker/', label: '결제 확인기' },
      { href: '/ko/tools/esim-comparison/', label: 'eSIM 비교기' },
      { href: '/ko/tools/app-availability-checker/', label: '앱 확인기' },
    ],
  },
  {
    title: '중국 현지에서',
    text: '앱, 택시, 메뉴, 프런트 데스크 이용이 헷갈릴 때 기사 카드, 환율 변환, 필수 표현 도구를 활용해 보세요.',
    links: [
      { href: '/ko/tools/survival-kit/', label: '생존 키트' },
      { href: '/ko/tools/show-to-driver/', label: '기사님께 보여주기' },
      { href: '/ko/tools/currency-converter/', label: 'RMB 변환기' },
      { href: '/ko/tools/essential-phrases/', label: '필수 표현' },
    ],
  },
];

const toolsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  hasPart: tools.map((tool) => ({
    '@type': 'WebApplication',
    name: tool.title,
    description: tool.desc,
    applicationCategory: 'TravelApplication',
    url: new URL(tool.href, 'https://www.chinatripbox.com').toString(),
  })),
};
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(toolsJsonLd)} />
  <Header locale="ko" />
  <main class="container-page py-12">
    <header class="max-w-2xl">
      <p class="section-kicker">도구 센터</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">무료 중국 여행 도구</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="/ko/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-primary">출발 전 체크리스트 보기</a>
        <a href="/ko/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">처음 가는 분용 가이드 읽기</a>
      </div>
    </header>

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 lg:grid-cols-3" aria-labelledby="tool-use-cases-heading">
      <div class="lg:col-span-3">
        <h2 id="tool-use-cases-heading" class="text-2xl font-bold text-gray-950">어떤 도구부터 써보면 좋을까요?</h2>
      </div>
      {toolUseCases.map((useCase) => (
        <article class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <h3 class="text-lg font-bold text-gray-950">{useCase.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{useCase.text}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {useCase.links.map((link) => (
              <a href={link.href} class="rounded-full border border-gray-200 px-3 py-1.5 text-xs font-semibold text-brand-700 hover:border-brand-300 hover:bg-brand-50 hover:no-underline">{link.label}</a>
            ))}
          </div>
        </article>
      ))}
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {tools.map((tool) => (
        <a href={tool.href} class="card block hover:no-underline">
          <div class="text-3xl">{tool.icon}</div>
          <h2 class="mt-3 text-lg font-bold text-gray-900">{tool.title}</h2>
          <p class="mt-1.5 text-sm text-gray-600">{tool.desc}</p>
          <span class="mt-3 inline-block text-sm font-semibold text-brand-600">도구 열기 →</span>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>