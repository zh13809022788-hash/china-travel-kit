---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = '중국 여행용 eSIM 요금제 비교기';
const description =
  '데이터 용량, 사용 기간, 가격, 네트워크를 기준으로 중국 여행용 대표 eSIM 요금제를 비교해 보세요. 필터와 정렬로 여행에 가장 잘 맞는 요금제를 찾을 수 있습니다.';

// 중국 여행용 eSIM 상품 8종 예시 데이터
const plans = [
  { id: 1, name: '중국 익스플로러 5GB', data: 5, dataLabel: '5GB', days: 7, price: 9.5, network: 'China Unicom', note: '현지 앱 제한을 우회할 수 있음' },
  { id: 2, name: '중국 익스플로러 10GB', data: 10, dataLabel: '10GB', days: 15, price: 16, network: 'China Unicom', note: '현지 앱 제한을 우회할 수 있음' },
  { id: 3, name: '중국 본토 라이트 3GB', data: 3, dataLabel: '3GB', days: 7, price: 6.5, network: 'China Mobile', note: '현지 네트워크 사용, VPN 경유 없음' },
  { id: 4, name: '중화권 8GB', data: 8, dataLabel: '8GB', days: 30, price: 18.9, network: 'China Unicom', note: '중국 본토, 홍콩, 마카오, 대만 지원' },
  { id: 5, name: '일일 무제한', data: 9999, dataLabel: '무제한*', days: 10, price: 29, network: 'China Unicom', note: '하루 2GB 사용 후 공정 사용 제한 적용' },
  { id: 6, name: '비즈니스 20GB', data: 20, dataLabel: '20GB', days: 30, price: 32, network: 'China Unicom', note: '현지 앱 제한을 우회할 수 있음' },
  { id: 7, name: '단기 여행 1GB', data: 1, dataLabel: '1GB', days: 3, price: 3.2, network: 'China Mobile', note: '짧은 경유 일정에 적합' },
  { id: 8, name: '가족용 30GB', data: 30, dataLabel: '30GB', days: 30, price: 45, network: 'China Unicom', note: '핫스팟으로 공유 가능' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">도구</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">eSIM 요금제 비교기</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- 필터 및 정렬 -->
    <div class="mt-6 flex flex-wrap items-end gap-4 rounded-xl border border-gray-200 bg-gray-50 p-4">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">정렬 기준</span>
        <select id="sort-by" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="가격오름차순">가격: 낮은 순</option>
          <option value="가격내림차순">가격: 높은 순</option>
          <option value="데이터내림차순">데이터: 많은 순</option>
          <option value="기간내림차순">사용 기간: 긴 순</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">네트워크</span>
        <select id="filter-network" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="전체">전체 네트워크</option>
          <option value="China Unicom">China Unicom</option>
          <option value="China Mobile">China Mobile</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">최소 데이터(GB)</span>
        <select id="filter-data" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="0">상관없음</option>
          <option value="5">5GB 이상</option>
          <option value="10">10GB 이상</option>
          <option value="20">20GB 이상</option>
        </select>
      </label>
    </div>

    <!-- 비교 표 -->
    <div class="mt-6 overflow-x-auto">
      <table class="w-full min-w-[720px] border-collapse text-sm">
        <thead>
          <tr class="border-b-2 border-gray-200 text-left text-gray-500">
            <th class="py-3 pr-4 font-semibold">요금제</th>
            <th class="py-3 pr-4 font-semibold">데이터</th>
            <th class="py-3 pr-4 font-semibold">사용 기간</th>
            <th class="py-3 pr-4 font-semibold">가격(USD)</th>
            <th class="py-3 pr-4 font-semibold">네트워크</th>
            <th class="py-3 pr-4 font-semibold">비고</th>
          </tr>
        </thead>
        <tbody id="plan-rows"></tbody>
      </table>
      <p id="no-results" class="hidden py-8 text-center text-gray-500">선택한 조건에 맞는 요금제가 없습니다.</p>
    </div>

    <AffiliateCta
      title="바로 연결할 준비 되셨나요?"
      description="추천 중국 eSIM을 개통하고 도착하자마자 바로 인터넷을 이용하세요."
      buttonText="eSIM 구매하기"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ plans }}>
  const rowsEl = document.getElementById('plan-rows');
  const noResults = document.getElementById('no-results');
  const sortBy = document.getElementById('sort-by');
  const filterNetwork = document.getElementById('filter-network');
  const filterData = document.getElementById('filter-data');

  function render() {
    let list = [...plans];
    const net = filterNetwork.value;
    const minData = Number(filterData.value);

    if (net !== '전체') list = list.filter((p) => p.network === net);
    if (minData > 0) list = list.filter((p) => p.data >= minData);

    switch (sortBy.value) {
      case '가격오름차순': list.sort((a, b) => a.price - b.price); break;
      case '가격내림차순': list.sort((a, b) => b.price - a.price); break;
      case '데이터내림차순': list.sort((a, b) => b.data - a.data); break;
      case '기간내림차순': list.sort((a, b) => b.days - a.days); break;
    }

    rowsEl.innerHTML = list
      .map(
        (p) => `
      <tr class="border-b border-gray-100">
        <td class="py-3 pr-4 font-semibold text-gray-900">${p.name}</td>
        <td class="py-3 pr-4">${p.dataLabel}</td>
        <td class="py-3 pr-4">${p.days}일</td>
        <td class="py-3 pr-4 font-semibold">$${p.price.toFixed(2)}</td>
        <td class="py-3 pr-4">${p.network}</td>
        <td class="py-3 pr-4 text-gray-500">${p.note}</td>
      </tr>`
      )
      .join('');

    noResults.classList.toggle('hidden', list.length > 0);
  }

  [sortBy, filterNetwork, filterData].forEach((el) => el.addEventListener('change', render));
  render();
</script>
