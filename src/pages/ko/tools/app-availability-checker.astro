---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = '내 앱이 중국에서 작동할까? 앱 사용 가능 여부 확인기';
const description =
  'Google, WhatsApp, Instagram 등 다양한 앱이 VPN 없이 중국에서 작동하는지 확인하고, 차단된 서비스별 현지 대안도 함께 살펴보세요.';

interface AppInfo {
  name: string;
  category: string;
  status: 'works' | 'blocked' | 'partial';
  note: string;
  alt?: string;
}

const apps: AppInfo[] = [
  { name: 'Google Search', category: 'Google', status: 'blocked', note: 'VPN 없이는 차단됩니다.', alt: 'Bing(사용 가능) 또는 Baidu' },
  { name: 'Google Maps', category: 'Google', status: 'partial', note: '열리기는 하지만 중국 본토에서는 데이터가 부정확하거나 위치가 어긋날 수 있습니다.', alt: 'Apple Maps, Amap 또는 Baidu Maps' },
  { name: 'Gmail', category: 'Google', status: 'blocked', note: 'VPN 없이는 차단됩니다.', alt: 'Outlook / Google이 아닌 이메일 서비스' },
  { name: 'YouTube', category: 'Google', status: 'blocked', note: 'VPN 없이는 차단됩니다.', alt: 'Bilibili(현지 서비스)' },
  { name: 'WhatsApp', category: '메신저', status: 'blocked', note: 'VPN 없이는 차단됩니다.', alt: 'WeChat' },
  { name: 'Facebook', category: '소셜', status: 'blocked', note: 'VPN 없이는 차단됩니다.', alt: 'WeChat Moments / RED' },
  { name: 'Instagram', category: '소셜', status: 'blocked', note: 'VPN 없이는 차단됩니다.', alt: 'RED (Xiaohongshu)' },
  { name: 'X (Twitter)', category: '소셜', status: 'blocked', note: 'VPN 없이는 차단됩니다.', alt: 'Weibo' },
  { name: 'Telegram', category: '메신저', status: 'blocked', note: 'VPN 없이는 차단됩니다.', alt: 'WeChat' },
  { name: 'WeChat', category: '메신저', status: 'works', note: '완전히 정상 작동합니다. 중국에서 기본적으로 가장 많이 쓰는 앱입니다.' },
  { name: 'Apple services (iMessage, App Store)', category: 'Apple', status: 'works', note: '정상적으로 작동합니다.' },
  { name: 'Microsoft / Bing / Outlook', category: 'Microsoft', status: 'works', note: '정상적으로 작동합니다.' },
  { name: 'Booking.com', category: '여행', status: 'works', note: '정상적으로 작동합니다.' },
  { name: 'Airbnb', category: '여행', status: 'works', note: '정상적으로 작동합니다.' },
  { name: 'Trip.com', category: '여행', status: 'works', note: '완전히 정상 작동하며 기차와 호텔 예약에 특히 유용합니다.' },
  { name: 'Alipay', category: '결제', status: 'works', note: '완전히 정상 작동하며 해외 카드도 지원합니다.' },
  { name: 'Uber', category: '교통', status: 'blocked', note: '중국 본토에서는 운영되지 않습니다.', alt: 'DiDi' },
  { name: 'Netflix', category: '미디어', status: 'blocked', note: '중국 본토에서는 이용할 수 없습니다.', alt: '현지 스트리밍 서비스 이용 또는 미리 다운로드' },
  { name: 'Spotify', category: '미디어', status: 'blocked', note: '중국 본토에서는 이용할 수 없습니다.', alt: 'QQ Music / 미리 오프라인 다운로드' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">도구</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">내 앱이 중국에서 작동할까?</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-4">
      <label class="flex flex-col text-sm sm:max-w-sm">
        <span class="mb-1 font-medium text-gray-700">앱 검색 또는 필터</span>
        <input id="search" type="text" placeholder="예: WhatsApp, Google, Netflix"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <div class="mt-3 flex flex-wrap gap-2 text-sm">
        <button data-status="all" class="status-filter btn-primary px-3 py-1">전체</button>
        <button data-status="works" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">✅ 사용 가능</button>
        <button data-status="partial" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">⚠️ 일부만 가능</button>
        <button data-status="blocked" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">🚫 차단됨</button>
      </div>
    </div>

    <div id="app-list" class="mt-6 grid gap-3 sm:grid-cols-2"></div>
    <p id="no-results" class="hidden py-8 text-center text-gray-500">검색 조건과 일치하는 앱이 없습니다.</p>

    <AffiliateCta
      title="여행용 eSIM으로 평소 앱 계속 사용하기"
      description="중국 여행용 eSIM을 사용해 현지 제한을 우회하면 평소 쓰던 앱을 계속 온라인 상태로 유지할 수 있습니다. 별도의 VPN 설정도 필요 없습니다."
      buttonText="eSIM 옵션 보기"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ apps }}>
  const listEl = document.getElementById('app-list');
  const noResults = document.getElementById('no-results');
  const searchEl = document.getElementById('search');
  const filters = document.querySelectorAll('.status-filter');
  let activeStatus = 'all';

  const badge = {
    works: { cls: 'bg-green-100 text-green-800', label: '✅ 사용 가능' },
    partial: { cls: 'bg-amber-100 text-amber-800', label: '⚠️ 일부만 가능' },
    blocked: { cls: 'bg-red-100 text-red-800', label: '🚫 차단됨' },
  };

  function render() {
    const q = searchEl.value.trim().toLowerCase();
    const list = apps.filter((a) => {
      const matchStatus = activeStatus === 'all' || a.status === activeStatus;
      const matchQuery = !q || a.name.toLowerCase().includes(q) || a.category.toLowerCase().includes(q);
      return matchStatus && matchQuery;
    });

    listEl.innerHTML = list
      .map((a) => `
        <div class="card">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="font-bold text-gray-900">${a.name}</h3>
              <span class="text-xs text-gray-400">${a.category}</span>
            </div>
            <span class="whitespace-nowrap rounded-full px-2.5 py-0.5 text-xs font-semibold ${badge[a.status].cls}">${badge[a.status].label}</span>
          </div>
          <p class="mt-2 text-sm text-gray-600">${a.note}</p>
          ${a.alt ? `<p class="mt-1.5 text-sm"><span class="text-gray-500">대신 사용:</span> <span class="font-medium text-brand-600">${a.alt}</span></p>` : ''}
        </div>`)
      .join('');

    noResults.classList.toggle('hidden', list.length > 0);
  }

  searchEl.addEventListener('input', render);
  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeStatus = btn.dataset.status;
      filters.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('btn-primary', on);
        ['rounded-lg', 'border', 'border-gray-300', 'font-medium', 'text-gray-700'].forEach((c) => b.classList.toggle(c, !on));
      });
      render();
    });
  });

  render();
</script>
