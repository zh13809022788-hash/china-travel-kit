```astro
---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = '중국 여행 필수 중국어 표현집';
const description =
  '중국을 여행할 때 바로 써먹기 좋은 핵심 중국어 표현을 한곳에 모았습니다. 병음과 한국어 뜻을 함께 제공해 인사, 결제, 교통, 식사, 비상 상황까지 손쉽게 확인할 수 있습니다.';

interface Phrase {
  ko: string;
  zh: string;
  pinyin: string;
}
interface Group {
  id: string;
  label: string;
  icon: string;
  phrases: Phrase[];
}

const groups: Group[] = [
  {
    id: '기본',
    label: '인사와 기본 표현',
    icon: '👋',
    phrases: [
      { ko: '안녕하세요', zh: '你好', pinyin: 'nǐ hǎo' },
      { ko: '감사합니다', zh: '谢谢', pinyin: 'xièxie' },
      { ko: '괜찮아요 / 천만에요', zh: '不客气', pinyin: 'bú kèqi' },
      { ko: '죄송합니다 / 실례합니다', zh: '对不起', pinyin: 'duìbuqǐ' },
      { ko: '네 / 맞아요', zh: '对', pinyin: 'duì' },
      { ko: '아니요 / 아니에요', zh: '不是', pinyin: 'bú shì' },
      { ko: '이해가 안 돼요', zh: '我不明白', pinyin: 'wǒ bù míngbái' },
      { ko: '영어 하실 줄 아세요?', zh: '你会说英语吗？', pinyin: 'nǐ huì shuō yīngyǔ ma?' },
    ],
  },
  {
    id: '결제',
    label: '돈과 결제',
    icon: '💳',
    phrases: [
      { ko: '얼마예요?', zh: '多少钱？', pinyin: 'duōshao qián?' },
      { ko: 'Alipay로 결제할 수 있나요?', zh: '可以用支付宝吗？', pinyin: 'kěyǐ yòng zhīfùbǎo ma?' },
      { ko: 'WeChat Pay로 결제할 수 있나요?', zh: '可以用微信支付吗？', pinyin: 'kěyǐ yòng wēixìn zhīfù ma?' },
      { ko: '너무 비싸요', zh: '太贵了', pinyin: 'tài guì le' },
      { ko: '카드 결제 되나요?', zh: '可以刷卡吗？', pinyin: 'kěyǐ shuākǎ ma?' },
      { ko: '제가 QR코드를 스캔할게요', zh: '我扫你的码', pinyin: 'wǒ sǎo nǐ de mǎ' },
    ],
  },
  {
    id: '교통',
    label: '이동과 교통',
    icon: '🚕',
    phrases: [
      { ko: '지하철역이 어디에 있나요?', zh: '地铁站在哪里？', pinyin: 'dìtiě zhàn zài nǎlǐ?' },
      { ko: '이 주소로 가 주세요', zh: '请带我去这个地址', pinyin: 'qǐng dài wǒ qù zhège dìzhǐ' },
      { ko: '여기 세워 주세요', zh: '请在这里停', pinyin: 'qǐng zài zhèlǐ tíng' },
      { ko: '기차역', zh: '火车站', pinyin: 'huǒchē zhàn' },
      { ko: '공항', zh: '机场', pinyin: 'jīchǎng' },
      { ko: '...에는 어떻게 가나요?', zh: '怎么去...？', pinyin: 'zěnme qù...?' },
    ],
  },
  {
    id: '식사',
    label: '음식과 식사',
    icon: '🍜',
    phrases: [
      { ko: '메뉴판 주세요', zh: '请给我菜单', pinyin: 'qǐng gěi wǒ càidān' },
      { ko: '저는 채식해요', zh: '我吃素', pinyin: 'wǒ chī sù' },
      { ko: '맵지 않게 해 주세요', zh: '请不要辣', pinyin: 'qǐng búyào là' },
      { ko: '물 주세요', zh: '请给我水', pinyin: 'qǐng gěi wǒ shuǐ' },
      { ko: '계산해 주세요', zh: '买单', pinyin: 'mǎidān' },
      { ko: '정말 맛있어요', zh: '很好吃', pinyin: 'hěn hǎochī' },
    ],
  },
  {
    id: '도움',
    label: '도움과 비상 상황',
    icon: '🆘',
    phrases: [
      { ko: '도와주세요!', zh: '救命！', pinyin: 'jiùmìng!' },
      { ko: '화장실이 어디에 있나요?', zh: '洗手间在哪里？', pinyin: 'xǐshǒujiān zài nǎlǐ?' },
      { ko: '의사가 필요해요', zh: '我需要看医生', pinyin: 'wǒ xūyào kàn yīshēng' },
      { ko: '경찰을 불러 주세요', zh: '请报警', pinyin: 'qǐng bàojǐng' },
      { ko: '길을 잃었어요', zh: '我迷路了', pinyin: 'wǒ mílù le' },
      { ko: '적어 주세요', zh: '请写下来', pinyin: 'qǐng xiě xiàlái' },
    ],
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">도구</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">중국 여행 필수 중국어 표현</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- 필터와 인쇄 버튼 -->
    <div class="mt-6 flex flex-wrap items-center gap-3 print:hidden">
      <button data-filter="전체" class="phrase-filter btn-primary text-sm">전체 보기</button>
      {groups.map((g) => (
        <button data-filter={g.id} class="phrase-filter rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:border-brand-400">
          {g.icon} {g.label}
        </button>
      ))}
      <button id="print-btn" class="ml-auto rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:border-brand-400">
        🖨️ 인쇄하기 / PDF로 저장하기
      </button>
    </div>

    <!-- 표현 묶음 -->
    <div class="mt-6 space-y-8">
      {groups.map((g) => (
        <section class="phrase-group" data-group={g.id}>
          <h2 class="mb-3 text-xl font-bold text-gray-900">{g.icon} {g.label}</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            {g.phrases.map((p) => (
              <div class="card flex flex-col">
                <span class="text-sm text-gray-500">{p.ko}</span>
                <span class="mt-1 text-2xl font-bold text-gray-900">{p.zh}</span>
                <span class="mt-0.5 text-sm italic text-brand-600">{p.pinyin}</span>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>

    <AffiliateCta
      title="이동 중에도 바로 번역하려면 인터넷 연결을 유지하세요"
      description="중국 여행용 eSIM이 있으면 도착하자마자 번역 앱과 지도를 바로 사용할 수 있습니다."
      buttonText="연결하러 가기"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.phrase-filter');
  const sections = document.querySelectorAll<HTMLElement>('.phrase-group');
  const printBtn = document.getElementById('print-btn');

  const activeCls = ['btn-primary'];
  const idleCls = ['rounded-lg', 'border', 'border-gray-300', 'px-3', 'py-1.5', 'text-sm', 'font-medium', 'text-gray-700', 'hover:border-brand-400'];

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      sections.forEach((s) => {
        s.classList.toggle('hidden', filter !== '전체' && s.dataset.group !== filter);
      });
      buttons.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('btn-primary', on);
        idleCls.forEach((c) => b.classList.toggle(c, !on));
      });
    });
  });

  printBtn?.addEventListener('click', () => window.print());
</script>
```
