```astro
---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = '중국 의류·신발 사이즈 변환표';
const description =
  '미국, 영국, 유럽 의류·신발 사이즈를 중국 사이즈와 비교해 보고, 중국에서도 더 수월하게 쇼핑할 수 있도록 도와드립니다. 여성·남성 의류와 신발 사이즈를 한눈에 확인해 보세요.';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">도구</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">중국 의류·신발 사이즈 변환표</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 flex flex-wrap gap-2 text-sm">
      <button data-tab="여성-의류" class="size-tab btn-primary px-3 py-1.5">여성 의류</button>
      <button data-tab="남성-의류" class="size-tab rounded-lg border border-gray-300 px-3 py-1.5 font-medium text-gray-700">남성 의류</button>
      <button data-tab="여성-신발" class="size-tab rounded-lg border border-gray-300 px-3 py-1.5 font-medium text-gray-700">여성 신발</button>
      <button data-tab="남성-신발" class="size-tab rounded-lg border border-gray-300 px-3 py-1.5 font-medium text-gray-700">남성 신발</button>
    </div>

    <div class="mt-6 overflow-x-auto">
      <table class="w-full min-w-[560px] border-collapse text-sm">
        <thead>
          <tr class="border-b-2 border-gray-200 text-left text-gray-500">
            <th class="py-3 pr-4 font-semibold">중국</th>
            <th class="py-3 pr-4 font-semibold">미국</th>
            <th class="py-3 pr-4 font-semibold">영국</th>
            <th class="py-3 pr-4 font-semibold">유럽</th>
          </tr>
        </thead>
        <tbody id="size-rows"></tbody>
      </table>
    </div>

    <p class="mt-4 text-xs text-gray-400">
      브랜드와 핏에 따라 실제 착용감은 달라질 수 있습니다. 중국 의류는 서구권 사이즈보다 작게 나오는 경우가 많으므로,
      사이즈가 애매하다면 한 치수 크게 고르거나 구매 전에 직접 입어 보는 편이 좋습니다. 이 표는 일반적인 참고용입니다.
    </p>

    <AffiliateCta
      title="여행 중 쇼핑도 더 편하게 준비하세요"
      description="중국에서 오프라인 매장이나 앱으로 불편 없이 결제하고 연결할 수 있도록, 결제 수단과 인터넷 환경을 미리 준비해 두세요."
      buttonText="여행 준비물 보기"
      placeholder={AFFILIATE_LINKS.transport}
    />
  </main>
  <Footer />
</BaseLayout>

<script>
  // 참고용 변환표입니다. 중국 의류는 키/가슴둘레(cm) 표기를 사용하며,
  // 대체로 숫자 사이즈로도 함께 표시됩니다. 신발은 유럽식 기준에 가까운 표기를 사용합니다.
  const charts: Record<string, { 중국: string; 미국: string; 영국: string; 유럽: string }[]> = {
    '여성-의류': [
      { 중국: '155/80A (매우 작음)', 미국: '0–2', 영국: '4–6', 유럽: '32–34' },
      { 중국: '160/84A (작음)', 미국: '4', 영국: '8', 유럽: '36' },
      { 중국: '165/88A (보통)', 미국: '6–8', 영국: '10–12', 유럽: '38–40' },
      { 중국: '170/92A (큼)', 미국: '10–12', 영국: '14–16', 유럽: '42–44' },
      { 중국: '175/96A (매우 큼)', 미국: '14', 영국: '18', 유럽: '46' },
    ],
    '남성-의류': [
      { 중국: '165/88A (작음)', 미국: '34–36', 영국: '34–36', 유럽: '44–46' },
      { 중국: '170/92A (보통)', 미국: '38', 영국: '38', 유럽: '48' },
      { 중국: '175/96A (큼)', 미국: '40', 영국: '40', 유럽: '50' },
      { 중국: '180/100A (매우 큼)', 미국: '42–44', 영국: '42–44', 유럽: '52–54' },
      { 중국: '185/104A (아주 큼)', 미국: '46', 영국: '46', 유럽: '56' },
    ],
    '여성-신발': [
      { 중국: '35', 미국: '5', 영국: '2.5', 유럽: '35' },
      { 중국: '36', 미국: '6', 영국: '3.5', 유럽: '36' },
      { 중국: '37', 미국: '6.5', 영국: '4.5', 유럽: '37' },
      { 중국: '38', 미국: '7.5', 영국: '5.5', 유럽: '38' },
      { 중국: '39', 미국: '8.5', 영국: '6.5', 유럽: '39' },
      { 중국: '40', 미국: '9', 영국: '7', 유럽: '40' },
    ],
    '남성-신발': [
      { 중국: '39', 미국: '6.5', 영국: '6', 유럽: '39' },
      { 중국: '40', 미국: '7', 영국: '6.5', 유럽: '40' },
      { 중국: '41', 미국: '8', 영국: '7.5', 유럽: '41' },
      { 중국: '42', 미국: '8.5', 영국: '8', 유럽: '42' },
      { 중국: '43', 미국: '9.5', 영국: '9', 유럽: '43' },
      { 중국: '44', 미국: '10.5', 영국: '10', 유럽: '44' },
      { 중국: '45', 미국: '11', 영국: '10.5', 유럽: '45' },
    ],
  };

  const rowsEl = document.getElementById('size-rows');
  const tabs = document.querySelectorAll<HTMLButtonElement>('.size-tab');

  function render(key: string) {
    if (!rowsEl) return;
    rowsEl.innerHTML = charts[key]
      .map((r) => `
        <tr class="border-b border-gray-100">
          <td class="py-3 pr-4 font-semibold text-gray-900">${r.중국}</td>
          <td class="py-3 pr-4">${r.미국}</td>
          <td class="py-3 pr-4">${r.영국}</td>
          <td class="py-3 pr-4">${r.유럽}</td>
        </tr>`)
      .join('');
  }

  tabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      tabs.forEach((t) => {
        const on = t === tab;
        t.classList.toggle('btn-primary', on);
        ['rounded-lg', 'border', 'border-gray-300', 'font-medium', 'text-gray-700'].forEach((c) => t.classList.toggle(c, !on));
      });
      render(tab.dataset.tab!);
    });
  });

  render('여성-의류');
</script>
```
