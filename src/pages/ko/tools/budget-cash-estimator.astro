---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = '중국 여행 예산·현금 계산기';
const description =
  '여행 기간, 여행 스타일, 도시 물가 수준에 맞춰 중국 여행의 하루 예산과 준비할 현금 액수를 계산해 보세요. 위안화와 미국 달러 기준으로 한눈에 확인할 수 있습니다.';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">도구</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">중국 여행 예산·현금 계산기</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">여행 기간(박 수)</span>
        <input
          id="nights"
          type="number"
          min="1"
          max="60"
          value="7"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm"
        />
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">여행 인원</span>
        <input
          id="travelers"
          type="number"
          min="1"
          max="10"
          value="1"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm"
        />
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">여행 스타일</span>
        <select id="style" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="절약형">절약형(호스텔, 길거리 음식, 지하철 위주)</option>
          <option value="보통형" selected>보통형(3~4성급 호텔, 일반 식당)</option>
          <option value="여유형">여유형(4~5성급 호텔, 택시, 외식 중심)</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">도시 물가 수준</span>
        <select id="tier" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="1선도시">1선 도시(베이징, 상하이, 선전)</option>
          <option value="2선도시" selected>2선 도시(청두, 시안, 항저우)</option>
          <option value="중소도시">중소 도시</option>
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="calc-btn" class="btn-primary w-full sm:w-auto">예산 계산하기</button>
      </div>
    </div>

    <div id="result" class="mt-6 hidden">
      <div class="grid gap-5 md:grid-cols-2">
        <div class="card" id="budget-card"></div>
        <div class="card" id="cash-card"></div>
      </div>
      <div class="card mt-5" id="breakdown-card"></div>
      <p class="mt-3 text-xs text-gray-400">
        예상 금액은 참고용이며 국제선 항공권은 포함되지 않습니다. 실제 비용은 여행 시기, 환율, 개인 소비 방식에 따라 달라질 수 있습니다. 환율은 1달러당 약 7.2위안으로 가정했습니다.
      </p>

      <AffiliateCta
        title="현지처럼 결제하고 수수료를 줄이세요"
        description="여행 전에 바로 쓸 수 있는 결제 수단을 준비해 두면 대부분의 지출을 현금 없이 해결할 수 있습니다."
        buttonText="결제 수단 확인하기"
        placeholder={AFFILIATE_LINKS.payment}
      />
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  type StyleKey = '절약형' | '보통형' | '여유형';
  type TierKey = '1선도시' | '2선도시' | '중소도시';

  const USD_RATE = 7.2;

  const dailySpend: Record<StyleKey, { food: number; transport: number; activities: number; misc: number }> = {
    절약형: { food: 80, transport: 30, activities: 40, misc: 30 },
    보통형: { food: 180, transport: 70, activities: 100, misc: 60 },
    여유형: { food: 400, transport: 200, activities: 220, misc: 130 },
  };

  const lodging: Record<StyleKey, number> = {
    절약형: 150,
    보통형: 450,
    여유형: 1100,
  };

  const tierMult: Record<TierKey, number> = {
    '1선도시': 1.25,
    '2선도시': 1.0,
    중소도시: 0.8,
  };

  const rmb = (n: number) => `¥${Math.round(n).toLocaleString()}`;
  const usd = (n: number) => `$${Math.round(n / USD_RATE).toLocaleString()}`;

  const btn = document.getElementById('calc-btn');
  const result = document.getElementById('result');
  const budgetCard = document.getElementById('budget-card');
  const cashCard = document.getElementById('cash-card');
  const breakdownCard = document.getElementById('breakdown-card');

  const nightsEl = document.getElementById('nights') as HTMLInputElement;
  const travelersEl = document.getElementById('travelers') as HTMLInputElement;
  const styleEl = document.getElementById('style') as HTMLSelectElement;
  const tierEl = document.getElementById('tier') as HTMLSelectElement;

  function calc() {
    if (!budgetCard || !cashCard || !breakdownCard || !result) return;

    const nights = Math.max(1, Math.min(60, Number(nightsEl.value) || 1));
    const travelers = Math.max(1, Math.min(10, Number(travelersEl.value) || 1));
    const style = styleEl.value as StyleKey;
    const tier = tierEl.value as TierKey;
    const mult = tierMult[tier];

    const spend = dailySpend[style];
    const perPersonDaily = (spend.food + spend.transport + spend.activities + spend.misc) * mult;

    const rooms = Math.ceil(travelers / 2);
    const lodgingTotal = lodging[style] * mult * rooms * nights;

    const spendTotal = perPersonDaily * travelers * nights;
    const grandTotal = spendTotal + lodgingTotal;

    const dailyCashFloat = Math.min(perPersonDaily * 0.15 * travelers, 200 * travelers);
    const cashRecommended = Math.min(dailyCashFloat * nights, 2000 + 100 * travelers);

    budgetCard.innerHTML = `
      <h3 class="text-lg font-bold text-gray-900">예상 총예산</h3>
      <p class="mt-2 text-3xl font-bold text-brand-600">${rmb(grandTotal)}</p>
      <p class="text-sm text-gray-500">약 ${usd(grandTotal)} / ${travelers}명, ${nights}박 기준</p>
      <dl class="mt-4 space-y-2 text-sm">
        <div class="flex justify-between gap-4"><dt class="text-gray-500">숙박비</dt><dd class="font-medium text-gray-900">${rmb(lodgingTotal)}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">현지 지출</dt><dd class="font-medium text-gray-900">${rmb(spendTotal)}</dd></div>
        <div class="flex justify-between gap-4 border-t border-gray-100 pt-2"><dt class="text-gray-700 font-semibold">1인당 예상 비용</dt><dd class="font-semibold text-gray-900">${rmb(grandTotal / travelers)}</dd></div>
      </dl>`;

    cashCard.innerHTML = `
      <h3 class="text-lg font-bold text-gray-900">권장 현금 준비액</h3>
      <p class="mt-2 text-3xl font-bold text-gray-900">${rmb(cashRecommended)}</p>
      <p class="text-sm text-gray-500">약 ${usd(cashRecommended)} 상당의 실물 위안화</p>
      <p class="mt-4 text-sm text-gray-600">
        중국은 모바일 결제가 중심이라 외국 카드가 연결된 Alipay 또는 WeChat Pay로 대부분 결제할 수 있습니다. 이 현금은 QR 결제가 어려운 택시, 소규모 지방 상점, 현금만 받는 기계 등에 대비한 예비 자금입니다. 10위안, 20위안, 50위안처럼 소액권 위주로 준비하는 것이 좋습니다.
      </p>`;

    breakdownCard.innerHTML = `
      <h3 class="text-lg font-bold text-gray-900">하루 지출 내역 <span class="text-sm font-normal text-gray-500">(1인 기준)</span></h3>
      <dl class="mt-4 grid gap-3 sm:grid-cols-4 text-sm">
        <div><dt class="text-gray-500">식비</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.food * mult)}</dd></div>
        <div><dt class="text-gray-500">현지 교통비</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.transport * mult)}</dd></div>
        <div><dt class="text-gray-500">관광·체험비</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.activities * mult)}</dd></div>
        <div><dt class="text-gray-500">기타 비용</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.misc * mult)}</dd></div>
      </dl>`;

    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  btn?.addEventListener('click', calc);
</script>
```
