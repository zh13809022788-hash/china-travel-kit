---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ShowToLocal from '../../../components/ShowToLocal.astro';
import SurvivalChecklist from '../../../components/SurvivalChecklist.astro';
import ContextAiBubble from '../../../components/ContextAiBubble.astro';
import survivalKits from '../../../data/survival-kits-ko.json';

const title = '중국 여행 생존 키트: 번역 카드와 여행 체크리스트';
const description =
  '해외 여행자를 위한 인터랙티브 중국 여행 생존 키트입니다. 전체 화면 번역 카드, 도착 후 준비 체크리스트, 음식 알레르기 카드, 현지 소통 도구를 한곳에서 이용할 수 있습니다.';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">생존 키트</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-950 md:text-4xl">중국 여행 생존 키트</h1>
      <p class="mt-3 text-lg leading-8 text-gray-600">
        긴 안내문을 읽을 시간이 없을 때, 전체 화면 번역 카드와 저장되는 체크리스트를 바로 활용해 보세요.
        공항 도착, 호텔 체크인, 택시 이용, 식당 주문, 알레르기 안내, 첫날 준비까지 빠르게 도와줍니다.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="#arrival" class="btn-primary">도착 준비부터 시작하기</a>
        <a href="#food" class="btn-outline">음식 안내 카드 보기</a>
      </div>
    </header>

    <section class="mt-8 grid gap-4 md:grid-cols-3">
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">전체 화면 번역 카드</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">카드를 눌러 기사님, 호텔 직원, 식당 직원에게 큰 중국어 문구를 바로 보여줄 수 있습니다.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">자동 저장 체크리스트</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">체크리스트 진행 상태가 브라우저에 저장되므로, 페이지를 닫아도 나중에 이어서 확인할 수 있습니다.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">상황별 AI 도우미</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">떠 있는 도우미를 눌러 상황에 맞는 프롬프트로 ChinaTripBox 여행 도움말을 바로 열 수 있습니다.</p>
      </div>
    </section>

    <div class="mt-10 grid gap-8">
      {survivalKits.map((kit) => (
        <section id={kit.slug} class="grid gap-5 rounded-xl border border-gray-200 bg-gray-50 p-5">
          <div class="max-w-3xl">
            <p class="section-kicker">{kit.slug} 키트</p>
            <h2 class="mt-1 text-2xl font-bold text-gray-950">{kit.title}</h2>
            <p class="mt-2 text-sm leading-6 text-gray-600">{kit.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {kit.related_paths.map((path) => (
                <a href={path} class="rounded-full border border-gray-200 bg-white px-3 py-1.5 text-xs font-semibold text-brand-700 hover:border-brand-300 hover:no-underline">
                  관련 가이드 보기
                </a>
              ))}
            </div>
          </div>
          <div class="grid gap-5 lg:grid-cols-[1fr_0.85fr]">
            <ShowToLocal themeId={kit.theme_id} tools={kit.tools} locale="ko" />
            <SurvivalChecklist themeId={kit.theme_id} steps={kit.checklist_steps} locale="ko" />
          </div>
        </section>
      ))}
    </div>
  </main>
  <ContextAiBubble defaultPrompt="도착 준비, 식당 이용, 번역 카드 확인, 체크리스트 준비를 위해 중국 여행 생존 키트를 잘 활용할 수 있도록 도와줘." />
  <Footer />
</BaseLayout>