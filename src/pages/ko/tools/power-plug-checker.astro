---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = '중국 전원 플러그 및 전압 확인기';
const description =
  '출발 국가를 기준으로 중국에서 플러그 어댑터나 전압 변환기가 필요한지 확인해 보세요. 중국은 220V를 사용하며 플러그 유형은 A, C, I입니다.';

const countries = [
  '미국', '영국', '캐나다', '호주', '독일',
  '프랑스', '이탈리아', '스페인', '네덜란드', '일본', '대한민국',
  '싱가포르', '인도', '브라질', '뉴질랜드', '스위스',
  '남아프리카공화국', '아랍에미리트', '기타',
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">도구</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">전원 플러그 및 전압 확인기</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-6">
      <label class="flex flex-col text-sm sm:max-w-sm">
        <span class="mb-1 font-medium text-gray-700">출발 국가</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <button id="check-btn" class="btn-primary mt-4 w-full sm:w-auto">필요한 것 확인하기</button>
    </div>

    <!-- 참고: 중국의 전기 표준 -->
    <div class="mt-6 grid gap-4 sm:grid-cols-3">
      <div class="card"><dt class="text-sm text-gray-500">전압</dt><dd class="text-2xl font-bold text-gray-900">220 V</dd></div>
      <div class="card"><dt class="text-sm text-gray-500">주파수</dt><dd class="text-2xl font-bold text-gray-900">50 Hz</dd></div>
      <div class="card"><dt class="text-sm text-gray-500">플러그 유형</dt><dd class="text-2xl font-bold text-gray-900">A · C · I</dd></div>
    </div>

    <!-- 결과 -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>

      <AffiliateCta
        title="범용 중국 어댑터 준비하기"
        description="중국 콘센트에 맞고 여러 기기를 동시에 충전할 수 있는 콤팩트한 올인원 여행용 어댑터입니다."
        buttonText="추천 어댑터 보기"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  // 각 국가의 가정용 전압과 사용하는 플러그 유형
  const data: Record<string, { volts: number; plugs: string[] }> = {
    '미국': { volts: 120, plugs: ['A', 'B'] },
    '캐나다': { volts: 120, plugs: ['A', 'B'] },
    '일본': { volts: 100, plugs: ['A', 'B'] },
    '브라질': { volts: 127, plugs: ['C', 'N'] },
    '영국': { volts: 230, plugs: ['G'] },
    '호주': { volts: 230, plugs: ['I'] },
    '뉴질랜드': { volts: 230, plugs: ['I'] },
    '독일': { volts: 230, plugs: ['C', 'F'] },
    '프랑스': { volts: 230, plugs: ['C', 'E'] },
    '이탈리아': { volts: 230, plugs: ['C', 'F', 'L'] },
    '스페인': { volts: 230, plugs: ['C', 'F'] },
    '네덜란드': { volts: 230, plugs: ['C', 'F'] },
    '스위스': { volts: 230, plugs: ['C', 'J'] },
    '대한민국': { volts: 220, plugs: ['C', 'F'] },
    '싱가포르': { volts: 230, plugs: ['G'] },
    '인도': { volts: 230, plugs: ['C', 'D', 'M'] },
    '남아프리카공화국': { volts: 230, plugs: ['C', 'D', 'M', 'N'] },
    '아랍에미리트': { volts: 230, plugs: ['C', 'D', 'G'] },
    '기타': { volts: 0, plugs: [] },
  };

  // 중국에서 사용하는 플러그 유형은 A, C, I입니다.
  const CHINA_PLUGS = ['A', 'C', 'I'];
  const CHINA_VOLTS = 220;

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const country = countryEl.value;
    const info = data[country];

    let heading: string, body: string, tone: 'good' | 'warn' | 'info';
    const points: string[] = [];

    if (!info || info.volts === 0) {
      tone = 'info';
      heading = '사용 중인 플러그와 전압을 직접 확인하세요';
      body = '선택한 국가에 대한 데이터가 없습니다. 충전기 라벨에 "100–240V"라고 적혀 있다면 전압 변환기는 필요 없고, 중국의 A, C, I형 콘센트에 맞는 플러그 어댑터만 있으면 됩니다.';
      points.push('중국은 220V, 50Hz를 사용하며 플러그 유형은 A, C, I입니다.');
      points.push('대부분의 휴대폰과 노트북 충전기는 프리볼트(100–240V)라서 플러그 어댑터만 있으면 됩니다.');
    } else {
      const plugMatch = info.plugs.some((p) => CHINA_PLUGS.includes(p));
      const voltMatch = Math.abs(info.volts - CHINA_VOLTS) <= 20;

      if (plugMatch && voltMatch) {
        tone = 'good';
        heading = '어댑터가 필요 없을 가능성이 높습니다';
        body = `${country}에서는 호환되는 플러그 유형(${info.plugs.join(', ')})과 비슷한 전압(${info.volts}V)을 사용합니다. 사용 중인 플러그가 중국 콘센트에 바로 맞을 가능성이 큽니다.`;
        points.push('플러그 모양은 기기마다 다를 수 있으니, 혹시 모를 상황에 대비해 어댑터 하나는 챙기는 것이 좋습니다.');
      } else if (!plugMatch && voltMatch) {
        tone = 'warn';
        heading = '플러그 어댑터는 필요하지만 전압 변환기는 필요 없습니다';
        body = `${country}의 전압은 ${info.volts}V로 중국과 비슷해 기기는 안전하게 사용할 수 있습니다. 다만 플러그 유형(${info.plugs.join(', ')})이 중국 콘센트와 맞지 않으므로 플러그 어댑터를 준비해야 합니다.`;
        points.push('A/C/I형용 간단한 플러그 어댑터만 있으면 충분합니다.');
        points.push('크고 무거운 전압 변환기는 필요하지 않습니다.');
      } else if (plugMatch && !voltMatch) {
        tone = 'warn';
        heading = '단일 전압 기기는 전압을 꼭 확인하세요';
        body = `플러그(${info.plugs.join(', ')})는 맞을 수 있지만, ${country}의 전압(${info.volts}V)은 중국의 220V와 다릅니다.`;
        points.push('100–240V로 표시된 휴대폰, 노트북, 카메라 충전기는 어디서든 사용 가능합니다.');
        points.push('단일 전압 기기(일부 헤어드라이어, 고데기 등)는 전압 변환기가 필요하거나 집에 두고 오는 편이 좋습니다.');
      } else {
        tone = 'warn';
        heading = '플러그 어댑터가 필요하며 전압도 확인해야 합니다';
        body = `${country}는 중국의 220V와 비교해 플러그 유형(${info.plugs.join(', ')})도 다르고 전압(${info.volts}V)도 다릅니다. A/C/I형용 플러그 어댑터를 준비하세요.`;
        points.push('프리볼트 충전기(100–240V)는 플러그 어댑터만 있으면 됩니다.');
        points.push('고출력 단일 전압 기기는 전압 변환기도 필요하므로, 현지 제품을 구매하는 편이 더 나을 수 있습니다.');
      }
    }

    const toneStyles = {
      good: 'border-green-200 bg-green-50',
      warn: 'border-amber-200 bg-amber-50',
      info: 'border-blue-200 bg-blue-50',
    } as const;
    const toneBadge = {
      good: 'bg-green-600 text-white',
      warn: 'bg-amber-500 text-white',
      info: 'bg-blue-600 text-white',
    } as const;
    const toneLabel = { good: '어댑터 불필요', warn: '어댑터 필요', info: '충전기 확인 필요' } as const;

    card.className = `card border ${toneStyles[tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[tone]}">${toneLabel[tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${heading}</h2>
      <p class="mt-2 text-gray-700">${body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
