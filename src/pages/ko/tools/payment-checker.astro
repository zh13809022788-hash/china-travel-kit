---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';
import FaqSection from '../../../components/FaqSection.astro';

const title = '중국 결제 카드 호환성 확인기';
const description =
  '내 신용카드가 중국에서 Alipay와 WeChat Pay에서 작동하는지 확인하세요. 국적과 카드 네트워크별 지원 여부, 한도, 수수료, 설정 방법을 확인할 수 있습니다.';

const nationalities = [
  '미국', '영국', '캐나다', '호주',
  '독일', '프랑스', '일본', '싱가포르', '기타',
];
const cardNetworks = ['Visa', 'Mastercard', 'Amex', 'Discover'];

const nextSteps = [
  { href: '/ko/posts/alipay-foreign-credit-card-step-by-step/', title: '해외 카드로 Alipay 설정하기' },
  { href: '/ko/posts/link-a-foreign-visa-or-mastercard-to-wechat-pay-in-china/', title: 'Visa 또는 Mastercard를 WeChat Pay에 연결하기' },
  { href: '/ko/posts/can-you-still-use-cash-in-china-as-a-foreigner-in-2026/', title: '현금이 아직 유용한 상황 알아보기' },
  { href: '/ko/payment/', title: '중국 결제 가이드 전체 보기' },
];

const faqItems = [
  {
    question: '해외에서 발급한 Visa나 Mastercard는 중국에서 모두 사용할 수 있나요?',
    answer:
      '아니요. Visa와 Mastercard는 Alipay와 WeChat Pay에 등록할 때 가장 무난한 선택이지만, 개별 은행이 본인 확인을 막거나 온라인 지갑 연동을 거부하거나 중국 결제를 위험 거래로 판단할 수 있습니다. 두 번째 카드와 소액 현금을 함께 준비하세요.',
  },
  {
    question: '관광객도 Alipay와 WeChat Pay를 둘 다 설정하는 것이 좋나요?',
    answer:
      '가능하다면 그렇습니다. 방문객에게는 Alipay가 더 쉽게 설정되는 경우가 많고, WeChat Pay는 미니 프로그램, 식당, 지역 서비스에서 유용할 수 있습니다. 둘 다 준비하면 가맹점에서 결제가 막힐 가능성을 줄일 수 있습니다.',
  },
  {
    question: '모바일 결제가 된다면 현금은 얼마나 가져가야 하나요?',
    answer:
      '공항 이동, 비상용 식사, 소규모 상점에 쓸 수 있도록 잔돈 위주로 조금 준비하되, 현금만 믿지는 마세요. 많은 곳이 QR 결제를 선호하고, 직원이 거스름돈을 바로 준비하지 못한 경우도 있습니다.',
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">도구</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">결제 카드 호환성 확인기</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <section class="mt-6 grid gap-4 md:grid-cols-3" aria-label="이 결제 확인기로 알 수 있는 내용">
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">지갑 지원 여부 확인</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">내 카드 네트워크가 Alipay와 WeChat Pay에 잘 맞는지 확인하세요.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">한도에 맞춰 계획 세우기</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">큰 금액을 결제하기 전에 일반적인 거래 한도와 수수료를 미리 확인하세요.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">백업 결제 수단 준비</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">언제 현금을 챙기고, 카드를 바꾸고, 두 결제 앱을 모두 준비해야 하는지 알아두세요.</p>
      </div>
    </section>

    <AdSlot format="banner" />

    <!-- 입력 영역 -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">국적</span>
        <select id="nationality" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {nationalities.map((n) => <option value={n}>{n}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">카드 네트워크</span>
        <select id="network" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {cardNetworks.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="check-btn" class="btn-primary w-full sm:w-auto">호환성 확인하기</button>
      </div>
    </div>

    <!-- 결과 -->
    <div id="result" class="mt-6 hidden">
      <div class="grid gap-5 md:grid-cols-2">
        <div class="card" id="alipay-card"></div>
        <div class="card" id="wechat-card"></div>
      </div>

      <AffiliateCta
        title="여행 준비용 카드 설정하기"
        description="중국 여행에서 Alipay와 WeChat Pay에 안정적으로 연결되는 선불 여행 카드를 확인해 보세요."
        buttonText="추천 카드 보기"
        placeholder={AFFILIATE_LINKS.payment}
      />
    </div>

    <section class="mt-12 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">이 확인기 사용 방법</h2>
        <ol class="mt-4 space-y-3 text-sm leading-6 text-gray-600">
          <li><strong class="text-gray-900">1. 여권 국가 또는 거주 국가를 선택하세요.</strong> 자주 발생하는 은행 문제와 본인 확인 이슈를 가늠하는 데 도움이 됩니다.</li>
          <li><strong class="text-gray-900">2. 카드 네트워크를 선택하세요.</strong> 중국 여행용 결제 지갑에는 보통 Visa와 Mastercard가 가장 무난한 첫 선택입니다.</li>
          <li><strong class="text-gray-900">3. 최소 한 가지 백업 수단을 준비하세요.</strong> 두 번째 카드와 두 결제 앱을 준비하고, 예외 상황에 대비해 소액 현금도 챙기세요.</li>
        </ol>
        <p class="mt-4 text-sm leading-6 text-gray-600">
          결제 규정, 지갑 본인 확인, 카드사 위험 심사는 바뀔 수 있습니다. 이 결과는 실용적인 여행 준비 가이드로 참고하고, 큰 금액의 결제 한도는 출발 전에 Alipay, WeChat Pay, 카드 발급사에서 직접 다시 확인하세요.
        </p>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">다음 결제 준비 단계</h2>
        <div class="mt-4 grid gap-3">
          {nextSteps.map((item) => (
            <a href={item.href} class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">
              {item.title}
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6" aria-labelledby="payment-checker-seo">
      <h2 id="payment-checker-seo" class="text-2xl font-bold text-gray-900">이 확인기로 알 수 있는 것과 알 수 없는 것</h2>
      <p class="mt-3 text-sm leading-6 text-gray-600">
        이 도구는 출발 전 준비를 위해 만들어졌습니다. 중국 매장 계산대 앞에 서기 전에 카드 네트워크,
        지갑 지원 여부, 예상 수수료 구간, 백업 결제 수단을 미리 점검하는 데 도움이 됩니다.
        다만 개별 은행이 모든 결제를 승인할 것이라고 보장할 수는 없습니다.
      </p>
      <div class="mt-5 overflow-x-auto rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200 text-sm">
          <thead class="bg-gray-50 text-left text-gray-700">
            <tr>
              <th class="px-4 py-3 font-semibold">위험 상황</th>
              <th class="px-4 py-3 font-semibold">발생 이유</th>
              <th class="px-4 py-3 font-semibold">가장 좋은 백업 방법</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 bg-white text-gray-600">
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">카드 연동 실패</td>
              <td class="px-4 py-3">발급사가 지갑 본인 확인을 막거나 3-D Secure 인증이 실패합니다.</td>
              <td class="px-4 py-3">다른 은행의 Visa 또는 Mastercard를 다시 시도하세요.</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">고액 결제 거절</td>
              <td class="px-4 py-3">지갑, 가맹점 또는 카드사 한도에 걸려 추가 심사가 발생합니다.</td>
              <td class="px-4 py-3">결제를 나누거나 실물 카드를 쓰거나 호텔 또는 가맹점에 다른 방법을 문의하세요.</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">계산 시 네트워크 불안정</td>
              <td class="px-4 py-3">모바일 데이터가 약하거나 로밍이 없거나 앱이 열리지 않습니다.</td>
              <td class="px-4 py-3">다른 지갑, 매장 Wi‑Fi, 또는 소액 현금을 사용하세요.</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-sm leading-6 text-gray-600">
        가장 탄탄하게 준비하려면 <a href="/ko/posts/how-to-pay-in-china-tourist-guide/" class="font-semibold">중국 여행자 결제 가이드</a>를 읽고,
        <a href="/ko/posts/alipay-vs-wechat-pay-foreigners/" class="font-semibold">Alipay와 WeChat Pay 비교</a>도 확인하고,
        <a href="/ko/posts/how-much-cash-to-bring-to-china/" class="font-semibold">현금 가이드</a>를 참고해 소액의 위안화도 함께 준비하세요.
      </p>
    </section>

    <FaqSection items={faqItems} title="결제 카드 호환성 확인기 자주 묻는 질문" />
  </main>
  <Footer />
</BaseLayout>

<script>
  type NetworkKey = 'Visa' | 'Mastercard' | 'Amex' | 'Discover';

  // 정적 호환성 표(대표적인 안내용 정보)
  const matrix: Record<NetworkKey, {
    alipay: { status: string; single: string; daily: string; fee: string; how: string };
    wechat: { status: string; single: string; daily: string; fee: string; how: string };
  }> = {
    Visa: {
      alipay: { status: '지원됨', single: '약 6,000위안', daily: '약 50,000위안', fee: '200위안 초과 시 약 3%', how: 'Alipay 앱에서 카드를 추가하고 여권 인증을 진행하세요' },
      wechat: { status: '지원됨', single: '약 6,000위안', daily: '약 50,000위안', fee: '200위안 초과 시 약 3%', how: 'WeChat Pay에서 카드를 추가하고 여권 인증을 진행하세요' },
    },
    Mastercard: {
      alipay: { status: '지원됨', single: '약 6,000위안', daily: '약 50,000위안', fee: '200위안 초과 시 약 3%', how: 'Alipay 앱에서 카드를 추가하고 여권 인증을 진행하세요' },
      wechat: { status: '지원됨', single: '약 6,000위안', daily: '약 50,000위안', fee: '200위안 초과 시 약 3%', how: 'WeChat Pay에서 카드를 추가하고 여권 인증을 진행하세요' },
    },
    Amex: {
      alipay: { status: '부분 지원', single: '약 6,000위안', daily: '약 50,000위안', fee: '200위안 초과 시 약 3%', how: '대부분의 경우 Alipay에서 Amex를 사용할 수 있지만, Visa 또는 Mastercard를 백업으로 준비하세요' },
      wechat: { status: '제한적', single: '상황에 따라 다름', daily: '상황에 따라 다름', fee: '200위안 초과 시 약 3%', how: '지원이 일정하지 않으므로 WeChat Pay에서는 Visa 또는 Mastercard를 우선 권장합니다' },
    },
    Discover: {
      alipay: { status: '제한적', single: '상황에 따라 다름', daily: '상황에 따라 다름', fee: '상황에 따라 다름', how: '가맹점 수용 범위가 제한적이므로 Visa 또는 Mastercard를 강력히 권장합니다' },
      wechat: { status: '권장하지 않음', single: '—', daily: '—', fee: '—', how: '대신 Visa 또는 Mastercard를 사용하세요' },
    },
  };

  const statusColor = (status: string) => {
    if (/^지원됨/i.test(status)) return 'text-green-700 bg-green-50 border-green-200';
    if (/부분|제한/i.test(status)) return 'text-amber-700 bg-amber-50 border-amber-200';
    return 'text-red-700 bg-red-50 border-red-200';
  };

  function cardHtml(wallet: string, d: { status: string; single: string; daily: string; fee: string; how: string }) {
    return `
      <h3 class="text-lg font-bold text-gray-900">${wallet}</h3>
      <span class="mt-2 inline-block rounded-full border px-3 py-0.5 text-xs font-semibold ${statusColor(d.status)}">${d.status}</span>
      <dl class="mt-4 space-y-2 text-sm">
        <div class="flex justify-between gap-4"><dt class="text-gray-500">1회 결제 한도</dt><dd class="font-medium text-gray-900">${d.single}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">일일 한도</dt><dd class="font-medium text-gray-900">${d.daily}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">처리 수수료</dt><dd class="font-medium text-gray-900">${d.fee}</dd></div>
        <div class="pt-2 text-gray-600"><dt class="text-gray-500">설정 방법</dt><dd class="mt-1">${d.how}</dd></div>
      </dl>`;
  }

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const networkEl = document.getElementById('network') as HTMLSelectElement;
  const alipayCard = document.getElementById('alipay-card');
  const wechatCard = document.getElementById('wechat-card');

  btn?.addEventListener('click', () => {
    const net = networkEl.value as NetworkKey;
    const data = matrix[net];
    if (!data || !alipayCard || !wechatCard || !result) return;
    alipayCard.innerHTML = cardHtml('Alipay', data.alipay);
    wechatCard.innerHTML = cardHtml('WeChat Pay', data.wechat);
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>