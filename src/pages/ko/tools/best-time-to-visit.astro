---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = '중국 여행 최적기 가이드 - 도시별·월별 플래너';
const description =
  '주요 중국 도시의 월별 날씨, 혼잡도, 준비물을 한눈에 확인하세요. 베이징, 상하이, 시안, 청두, 광저우, 하얼빈 여행 최적기를 계획할 수 있습니다.';

const cities = ['베이징', '상하이', '시안', '청두', '광저우', '하얼빈'];
const months = ['1월', '2월', '3월', '4월', '5월', '6월', '7월', '8월', '9월', '10월', '11월', '12월'];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">도구</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">중국 여행 최적기</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">도시</span>
        <select id="city" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {cities.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">여행 월</span>
        <select id="month" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {months.map((m, i) => <option value={i}>{m}</option>)}
        </select>
      </label>
    </div>

    <div id="result" class="mt-6">
      <div class="card" id="result-card"></div>
    </div>

    <!-- 여행 성수기 주의 안내 -->
    <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
      <strong>혼잡을 피하세요:</strong> 중국의 공휴일, 특히 춘절(1월 말~2월), 노동절(5월 초),
      국경절 및 골든위크(10월 첫째 주)에는 국내 여행 수요가 폭증합니다. 기차표와 호텔이 빠르게
      매진되고 가격도 크게 오르므로, 미리 예약하거나 이 시기를 피해 일정을 잡는 것이 좋습니다.
    </div>

    <AffiliateCta
      title="기차와 호텔은 미리 예약하세요"
      description="성수기에는 인기 노선이 빠르게 매진됩니다. 고속철도와 숙소를 서둘러 확보하세요."
      buttonText="예약 옵션 보기"
      placeholder={AFFILIATE_LINKS.transport}
    />
  </main>
  <Footer />
</BaseLayout>

<script>
