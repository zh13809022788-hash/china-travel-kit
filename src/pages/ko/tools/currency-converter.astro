```astro
---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = '중국 여행자를 위한 위안화 환율 계산기';
const description =
  '내 통화를 중국 위안화(RMB)로, 다시 위안화에서 내 통화로 손쉽게 환산하고, 중국에서 자주 사는 물건 가격까지 함께 살펴보며 현지 물가 감각을 빠르게 잡아보세요.';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">도구</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">위안화 환율 계산기</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-6">
      <div class="grid gap-4 sm:grid-cols-[1fr_auto_1fr] sm:items-end">
        <label class="flex flex-col text-sm">
          <span class="mb-1 font-medium text-gray-700">내 통화</span>
          <div class="flex gap-2">
            <select id="currency" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
              <option value="USD">미국 달러 (USD, $)</option>
              <option value="EUR">유로 (EUR, €)</option>
              <option value="GBP">영국 파운드 (GBP, £)</option>
              <option value="AUD">호주 달러 (AUD, A$)</option>
              <option value="CAD">캐나다 달러 (CAD, C$)</option>
              <option value="JPY">일본 엔 (JPY, ¥)</option>
              <option value="SGD">싱가포르 달러 (SGD, S$)</option>
            </select>
            <input
              id="foreign-amount"
              type="number"
              min="0"
              value="100"
              class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"
            />
          </div>
        </label>
        <div class="hidden pb-2 text-center text-gray-400 sm:block">⇄</div>
        <label class="flex flex-col text-sm">
          <span class="mb-1 font-medium text-gray-700">중국 위안화 (RMB)</span>
          <input
            id="rmb-amount"
            type="number"
            min="0"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"
          />
        </label>
      </div>
      <p id="rate-line" class="mt-3 text-sm text-gray-500"></p>
      <p class="mt-1 text-xs text-gray-400">
        이 환율은 여행 예산을 가늠하기 위한 참고값이며, 실시간 시장 환율이 아닙니다. 실제 결제 시 적용되는 정확한 환율은
        이용 중인 은행 또는 실시간 환율 서비스에서 확인하세요.
      </p>
    </div>

    <section class="mt-8">
      <h2 class="text-xl font-bold text-gray-900">중국에서는 이 정도 가격이에요</h2>
      <p class="mt-1 text-sm text-gray-500">
        대표적인 물가를 RMB 기준으로 보여드리며, 선택한 통화로 환산한 대략적인 금액도 함께 안내합니다.
      </p>
      <div id="cost-grid" class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3"></div>
    </section>

    <AffiliateCta
      title="환전소는 꼭 들르지 않아도 됩니다"
      description="해외 결제 수수료가 없는 카드를 Alipay 또는 WeChat Pay에 연결하면, 현금을 바꾸는 수수료 부담 없이 실제 환율에 가까운 금액으로 결제할 수 있습니다."
      buttonText="결제 설정 방법 보기"
      placeholder={AFFILIATE_LINKS.payment}
    />
  </main>
  <Footer />
</BaseLayout>

<script>
  // 대략적인 참고 환율: 각 통화 1단위가 몇 RMB인지
  const ratesToRmb: Record<string, number> = {
    USD: 7.2,
    EUR: 7.8,
    GBP: 9.1,
    AUD: 4.7,
    CAD: 5.2,
    JPY: 0.048,
    SGD: 5.3,
  };
  const symbols: Record<string, string> = {
    USD: '$', EUR: '€', GBP: '£', AUD: 'A$', CAD: 'C$', JPY: '¥', SGD: 'S$',
  };

  const commonCosts: { label: string; rmb: number }[] = [
    { label: '생수 한 병', rmb: 2 },
    { label: '지하철 1회 이용', rmb: 4 },
    { label: '길거리 간식', rmb: 10 },
    { label: '카페 커피 한 잔', rmb: 30 },
    { label: '간단한 식사 한 끼', rmb: 45 },
    { label: '가까운 거리 DiDi / 택시', rmb: 25 },
    { label: '고속철도 요금(1~2시간)', rmb: 250 },
    { label: '박물관 / 관광지 입장권', rmb: 60 },
    { label: '중급 호텔 1박', rmb: 450 },
  ];

  const currencyEl = document.getElementById('currency') as HTMLSelectElement;
  const foreignEl = document.getElementById('foreign-amount') as HTMLInputElement;
  const rmbEl = document.getElementById('rmb-amount') as HTMLInputElement;
  const rateLine = document.getElementById('rate-line');
  const costGrid = document.getElementById('cost-grid');

  function rate() {
    return ratesToRmb[currencyEl.value];
  }
  function sym() {
    return symbols[currencyEl.value];
  }

  function fromForeign() {
    const v = Number(foreignEl.value) || 0;
    rmbEl.value = (v * rate()).toFixed(2);
    updateMeta();
  }
  function fromRmb() {
    const v = Number(rmbEl.value) || 0;
    foreignEl.value = (v / rate()).toFixed(2);
    updateMeta();
  }

  function updateMeta() {
    if (rateLine) {
      rateLine.textContent = `참고 환율: ${currencyEl.value} 1단위 ≈ ¥${rate().toFixed(2)} RMB`;
    }
    if (costGrid) {
      costGrid.innerHTML = commonCosts
        .map((c) => `
          <div class="card">
            <span class="text-sm text-gray-500">${c.label}</span>
            <div class="mt-1 flex items-baseline gap-2">
              <span class="text-xl font-bold text-gray-900">¥${c.rmb}</span>
              <span class="text-sm text-brand-600">약 ${sym()}${(c.rmb / rate()).toFixed(2)}</span>
            </div>
          </div>`)
        .join('');
    }
  }

  foreignEl.addEventListener('input', fromForeign);
  rmbEl.addEventListener('input', fromRmb);
  currencyEl.addEventListener('change', fromForeign);

  fromForeign();
</script>
```
