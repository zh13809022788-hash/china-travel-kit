---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = '중국 무비자·경유 가능 여부 확인기';
const description =
  '여권 국적과 여행 유형에 따라 중국에 무비자로 입국할 수 있는지, 240시간 무비자 경유가 가능한지, 또는 비자를 신청해야 하는지 확인해보세요.';

const lastReviewed = '2026년 7월 13일';

// 2026년 기준 대표 정책 데이터입니다. 법률 자문이 아니며,
// 여행자는 예약 전에 반드시 대사관에서 직접 확인해야 합니다.
const countries = [
  { value: 'United States', label: '미국' },
  { value: 'United Kingdom', label: '영국' },
  { value: 'Canada', label: '캐나다' },
  { value: 'Australia', label: '호주' },
  { value: 'Germany', label: '독일' },
  { value: 'France', label: '프랑스' },
  { value: 'Italy', label: '이탈리아' },
  { value: 'Spain', label: '스페인' },
  { value: 'Netherlands', label: '네덜란드' },
  { value: 'Japan', label: '일본' },
  { value: 'South Korea', label: '대한민국' },
  { value: 'Singapore', label: '싱가포르' },
  { value: 'Malaysia', label: '말레이시아' },
  { value: 'Thailand', label: '태국' },
  { value: 'Brazil', label: '브라질' },
  { value: 'New Zealand', label: '뉴질랜드' },
  { value: 'Switzerland', label: '스위스' },
  { value: 'Ireland', label: '아일랜드' },
  { value: 'Norway', label: '노르웨이' },
  { value: 'Other', label: '기타' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">도구</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">무비자·경유 가능 여부 확인기</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <p class="mt-3 text-sm text-gray-500">
        최종 검토일: {lastReviewed}. 이 확인기는 여행 계획을 돕기 위한 참고용이며, 공식적인 입국 자격 판정이 아닙니다.
      </p>
    </header>

    <AdSlot format="banner" />

    <!-- 입력 항목 -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">여권 국적</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c.value}>{c.label}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">여행 유형</span>
        <select id="trip" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="tourism">관광 / 방문</option>
          <option value="business">출장 / 비즈니스</option>
          <option value="transit">제3국으로 가는 경유만 해당</option>
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="check-btn" class="btn-primary w-full sm:w-auto">입국 가능 여부 확인하기</button>
      </div>
    </div>

    <!-- 결과 -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>
      <p class="mt-3 text-xs text-gray-400">
        정책은 자주 변경되며, 개인별 상황에 따라 적용 내용이 달라질 수 있습니다. 여행 예약 전에 반드시
        중국 대사관 또는 영사관에 확인하세요. 이 도구는 일반적인 참고 정보만 제공합니다.
      </p>

      <AffiliateCta
        title="나머지 여행 준비도 함께 해보세요"
        description="중국 도착 전에 인터넷 연결, 결제, 이동 준비까지 미리 정리해두세요."
        buttonText="여행 필수 정보 보기"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6" aria-labelledby="official-sources">
      <h2 id="official-sources" class="text-xl font-bold text-gray-950">예약 전에 꼭 확인할 공식 정보</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        무비자 대상 국가, 입국 가능 항구, 허용 이동 지역, 항공사 탑승 심사 기준은 변경될 수 있습니다.
        최종 기준은 반드시 정부 공식 안내와 항공사 규정을 따르세요.
      </p>
      <ul class="mt-4 grid gap-2 text-sm leading-6 text-gray-700">
        <li><a href="https://en.nia.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">National Immigration Administration</a>에서 출입국 심사 및 경유 면제 최신 정보를 확인하세요.</li>
        <li><a href="https://english.www.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">State Council information portal</a>에서 영문 정책 공지를 확인하세요.</li>
        <li><a href="https://www.mfa.gov.cn/eng/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">Ministry of Foreign Affairs</a> 및 중국 대사관·영사관 홈페이지에서 여권별 적용 규정을 확인하세요.</li>
      </ul>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">무비자 이용 시 실수 줄이는 방법</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          가장 흔한 실수는 일반 무비자 입국과 무비자 경유를 혼동하는 것입니다. 단순 왕복 여행과
          제3국으로 가는 경유 일정은 같은 조건이 아닙니다. 항공사는 탑승 전에 서류를 확인하므로,
          규정을 잘못 이해하면 중국에 도착하기도 전에 여행이 막힐 수 있습니다.
        </p>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-gray-600">
          <li><strong class="text-gray-900">먼저 여권 국적을 확인하세요.</strong> 거주 국가나 카드 결제 국가로 무비자 대상 여부가 결정되지는 않습니다.</li>
          <li><strong class="text-gray-900">입국과 경유를 구분하세요.</strong> 경유는 보통 제3국 또는 제3지역으로 가는 확정된 후속 항공권이 필요합니다.</li>
          <li><strong class="text-gray-900">입국 가능한 항구를 확인하세요.</strong> 경유 정책은 지정된 입국 항구와 허용 이동 지역에 따라 달라집니다.</li>
          <li><strong class="text-gray-900">증빙 서류를 준비하세요.</strong> 항공사나 출입국 심사관이 후속 항공권, 호텔 예약, 일정표, 초청장 등을 요구할 수 있습니다.</li>
        </ul>
      </div>
      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">도착 후 준비도 이어서 확인해보세요</h2>
        <div class="mt-4 grid gap-3">
          <a href="/ko/posts/china-visa-free-entry-transit-guide-2026/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">무비자 가이드 전체 보기</a>
          <a href="/ko/posts/first-24-hours-in-china-arrival-checklist/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">도착 체크리스트 확인하기</a>
          <a href="/ko/posts/airport-to-city-transport-beijing-shanghai-guangzhou/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">공항 이동 계획 세우기</a>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  type TripKey = 'tourism' | 'business' | 'transit';

  // 30일 단독 무비자 입국 대상 국적(2026년 프로그램)입니다.
  const visaFree30 = new Set([
    'Germany', 'France', 'Italy', 'Spain', 'Netherlands', 'Switzerland',
    'Ireland', 'Norway', 'Japan', 'South Korea', 'Brazil', 'New Zealand',
    'Malaysia', 'Thailand', 'Australia',
  ]);

  // 제3국/지역으로 이동할 때 지정 항구를 통해 이용 가능한
  // 240시간(10일) 무비자 경유 대상 국적입니다.
  const transit240 = new Set([
    'United States', 'United Kingdom', 'Canada', 'Australia', 'Germany',
    'France', 'Italy', 'Spain', 'Netherlands', 'Japan', 'South Korea',
    'Singapore', 'Switzerland', 'Ireland', 'Norway', 'Brazil', 'New Zealand',
  ]);

  interface Verdict {
    tone: 'good' | 'warn' | 'info';
    heading: string;
    body: string;
    points: string[];
  }

  function evaluate(country: string, trip: TripKey): Verdict {
    const has30 = visaFree30.has(country);
    const hasTransit = transit240.has(country);

    if (trip === 'transit') {
      if (hasTransit) {
        return {
          tone: 'good',
          heading: '240시간 무비자 경유 대상일 가능성이 높아요',
          body: `${country} 여권 소지자가 중국을 거쳐 제3국으로 이동하는 경우, 일반적으로 지정된 입국 항구를 통해 입국하면 최대 240시간(10일)까지 비자 없이 체류할 수 있어요.`,
          points: [
            '240시간 이내에 제3국 또는 제3지역으로 출국하는 확정된 항공권이 있어야 해요.',
            '입국과 출국 모두 지정된 경유 항구를 이용해야 해요. 보통 주요 국제공항이 포함돼요.',
            '대체로 입국한 성이나 지역 내에서만 이동이 제한될 수 있으니, 해당 항구 규정을 꼭 확인하세요.',
          ],
        };
      }
      return {
        tone: 'warn',
        heading: '해당 국적에는 경유 비자 면제가 적용되지 않을 수 있어요',
        body: `현재 데이터 기준으로 ${country}은(는) 일반적인 240시간 무비자 경유 대상 목록에 포함되어 있지 않아요. 다만 무비자 입국 대상일 수는 있으며, 그렇지 않다면 경유 비자(G)를 신청해야 할 수 있어요.`,
        points: [
          '먼저 해당 국적이 일반 무비자 입국 대상인지 확인해보세요.',
          '대상이 아니라면 여행 전에 적절한 비자를 미리 신청하세요.',
        ],
      };
    }

    // 관광 또는 비즈니스
    if (has30) {
      return {
        tone: 'good',
        heading: '30일 무비자 입국 대상일 가능성이 높아요',
        body: `${country} 여권 소지자는 현재 단독 무비자 정책에 따라 일반적으로 관광, 비즈니스, 가족 방문 또는 경유 목적으로 최대 30일 동안 중국에 비자 없이 입국할 수 있어요.`,
        points: [
          '여권은 보통 6개월 이상 유효해야 하고 빈 비자 페이지가 있어야 해요.',
          '입국 심사를 위해 귀국 또는 출국 항공권과 숙소 증빙을 준비해두세요.',
          '30일 체류 기준은 1회 입국당 적용되므로 예약 전에 최신 기준을 다시 확인하세요.',
        ],
      };
    }
    if (hasTransit) {
      return {
        tone: 'info',
        heading: '비자가 필요할 가능성이 높지만 경유 면제가 도움이 될 수 있어요',
        body: `${country}은(는) 현재 관광/비즈니스용 30일 무비자 목록에는 포함되어 있지 않아 보통 비자가 필요해요. 다만 제3국으로 이동하는 경유 일정이라면 240시간 무비자 경유를 이용할 수 있어요.`,
        points: [
          '중국 방문 자체가 목적이라면 L(관광) 또는 M(비즈니스) 비자를 미리 신청하세요.',
          '다른 나라로 가는 중간 경유라면 240시간 경유 대상일 수 있으니 "여행 유형"을 경유로 바꿔 확인해보세요.',
        ],
      };
    }
    return {
      tone: 'warn',
      heading: '비자가 필요할 가능성이 높아요',
      body: `현재 데이터 기준으로 ${country} 여권 소지자는 이 여행 유형으로 중국에 입국할 때 일반적으로 비자가 필요해요. 여행 전에 중국 대사관, 영사관 또는 지정 비자센터를 통해 신청하세요.`,
      points: [
        '여행 일정에 맞춰 L(관광) 또는 M(비즈니스) 비자를 충분한 여유를 두고 준비하세요.',
        '보통 초청장 또는 일정표, 호텔 예약, 왕복 항공권 등의 서류가 필요해요.',
      ],
    };
  }

  const toneStyles: Record<Verdict['tone'], string> = {
    good: 'border-green-200 bg-green-50',
    warn: 'border-amber-200 bg-amber-50',
    info: 'border-blue-200 bg-blue-50',
  };
  const toneBadge: Record<Verdict['tone'], string> = {
    good: 'bg-green-600 text-white',
    warn: 'bg-amber-500 text-white',
    info: 'bg-blue-600 text-white',
  };
  const toneLabel: Record<Verdict['tone'], string> = {
    good: '대상일 가능성 높음',
    warn: '비자 필요 가능성 높음',
    info: '여행 일정에 따라 달라져요',
  };

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;
  const tripEl = document.getElementById('trip') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const v = evaluate(countryEl.value, tripEl.value as TripKey);
    card.className = `card border ${toneStyles[v.tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[v.tone]}">${toneLabel[v.tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${v.heading}</h2>
      <p class="mt-2 text-gray-700">${v.body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${v.points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>