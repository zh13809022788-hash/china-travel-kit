---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = '중국 여행 도움';
const description =
  '결제, eSIM, 교통, 앱, 첫날 준비에 관한 중국 여행 질문을 1:1로 물어보세요. AI가 먼저 분류해 도와주고, 필요하면 사람의 도움도 받을 수 있습니다.';

const quickPrompts = [
  'Alipay 또는 WeChat Pay에 카드가 연결되지 않습니다.',
  '여행에 맞는 eSIM과 앱 사용 계획이 필요합니다.',
  '공항에서 호텔까지 가는 방법이 필요합니다.',
  '현금을 얼마나 가져가야 할지 잘 모르겠습니다.',
];

const supportAreas = [
  '결제 준비: Alipay, WeChat Pay, 카드, 수수료, 현금 백업',
  '연결성: eSIM, 로밍, VPN에 민감한 앱, 공항 도착 직후 데이터 사용',
  '교통: 공항 이동 경로, 지하철, DiDi, 택시, 고속철도 기본',
  '앱 사용: 번역, 음식 배달, 지도, 차량 호출, 스크린샷 활용',
  '여행 준비: 첫날 체크리스트, 도시별 준비 사항, 실용적인 다음 단계',
  '사람 상담 연계: 여러 차례 맥락 확인이 필요한 복잡한 사례',
];

const safetyRules = [
  '여권 사진, 카드 전체 번호, 비밀번호, PIN, 일회용 인증 코드는 보내지 마세요.',
  '누군가에게 당신의 계정에 로그인하게 하거나 본인 확인을 대신 진행해 달라고 하지 마세요.',
  '법률, 출입국, 의료, 은행, 응급 상황 조언 용도로는 사용하지 마세요.',
  '중요한 규정은 공식 출처, 항공사, 은행, 통신사, 앱 운영사에서 다시 확인하세요.',
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko"
  title="중국 여행 도움말 | 여행 질문에 답변해 드립니다"
  description="중국 여행 질문에 전문가 답변: 비자, 결제, eSIM, 교통, 숙소, 문화에 대한 맞춤형 여행 지원.">
  <Header locale="ko" />
  <main>
    <section class="border-b border-gray-200 bg-white">
      <div class="container-page grid gap-8 py-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <div>
          <p class="section-kicker">1:1 여행 지원</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            막히기 전에 중국 여행 질문을 바로 해결해 보세요
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            중국 여행에서 생기는 실질적인 문제를 먼저 무료 AI 도움으로 시작하세요. 질문에
            사람의 판단, 스크린샷 확인, 추가 대화가 필요하면 검토 요청으로 이어갈 수 있습니다.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#travel-help-chat" class="btn-primary">요청 시작하기</a>
            <a href="/ko/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-outline">출국 전 체크리스트 보기</a>
            <a href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Travel%20Help%20Request" class="btn-outline">
              바로 이메일 보내기
            </a>
          </div>
        </div>

        <aside class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">시범 운영 상태</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">먼저 AI, 이후 사람 검토</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            무료 답변은 AI가 생성합니다. 사람의 검토가 필요한 여행 도움은 현재 워크플로를 시험하는
            단계라 이메일로 안내됩니다.
          </p>
          <dl class="mt-5 grid gap-3 text-sm">
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">적합한 용도</dt>
              <dd class="font-semibold text-gray-900">실용적인 여행 준비</dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">응답 방식</dt>
              <dd class="font-semibold text-gray-900">AI + 이메일 후속 안내</dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">결제</dt>
              <dd class="font-semibold text-gray-900">아직 비활성화됨</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <section id="travel-help-chat" class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
          <div class="border-b border-gray-200 bg-gray-50 px-5 py-4">
          <p class="section-kicker">무료 AI 여행 도움</p>
            <h2 class="mt-1 text-2xl font-bold text-gray-950">여행 도움 데스크</h2>
          </div>

          <div class="grid gap-0 md:grid-cols-[minmax(0,1fr)_280px]">
            <div class="flex min-h-[560px] flex-col">
              <div id="chat-log" class="flex-1 space-y-4 overflow-y-auto p-5" aria-live="polite">
                <div class="max-w-[88%] rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-700">
                  <strong class="block text-gray-950">ChinaTripBox 도움</strong>
                  지금 무엇을 하려는지, 여행의 어느 단계인지, 이미 어떤 일이 있었는지 알려주세요.
                  AI 도우미가 다음 단계를 제안하고, 사람 검토가 더 적절한 경우도 표시해 줍니다.
                </div>
              </div>

              <div class="border-t border-gray-200 p-4">
                <div class="mb-3 flex flex-wrap gap-2">
                  {quickPrompts.map((prompt) => (
                    <button
                      type="button"
                      class="quick-prompt rounded-full border border-gray-200 bg-white px-3 py-1.5 text-left text-xs font-medium text-gray-700 hover:border-brand-300 hover:bg-brand-50"
                      data-prompt={prompt}
                    >
                      {prompt}
                    </button>
                  ))}
                </div>
                <form id="travel-help-form" class="grid gap-3">
                  <label class="sr-only" for="help-message">여행 질문</label>
                  <textarea
                    id="help-message"
                    name="message"
                    rows="5"
                    class="w-full resize-y rounded-lg border border-gray-300 px-4 py-3 text-sm leading-6 text-gray-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
                    placeholder="예시: 저는 내일 Shanghai에 도착합니다. WeChat Pay에는 Mastercard가 연결되지 않지만 Alipay는 됩니다. 그래도 지하철, DiDi, 음식 배달을 이용할 수 있을까요?"
                    required
                  ></textarea>
                  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <p id="form-status" class="text-sm text-gray-500">민감한 개인정보는 입력하지 마세요.</p>
                    <button id="help-submit" type="submit" class="btn-primary">AI에게 묻기</button>
                  </div>
                </form>
              </div>
            </div>

            <aside class="border-t border-gray-200 bg-gray-50 p-5 md:border-l md:border-t-0">
              <h3 class="text-lg font-bold text-gray-950">요청 정보</h3>
              <div class="mt-4 grid gap-4">
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  여행 단계
                  <select id="trip-stage" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                    <option>출발 전</option>
                    <option>공항에서</option>
                    <option>이미 중국에 있음</option>
                    <option>장기 체류 계획 중</option>
                  </select>
                </label>
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  주요 주제
                  <select id="help-topic" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                    <option>결제 앱</option>
                    <option>인터넷 및 eSIM</option>
                    <option>교통 경로</option>
                    <option>음식, 배달 또는 현지 앱</option>
                    <option>일반 여행 준비</option>
                  </select>
                </label>
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  도시 또는 이동 경로
                  <input
                    id="help-location"
                    class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700"
                    placeholder="예: 상하이, 베이징, 공항에서 호텔까지..."
                  />
                </label>
              </div>

              <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-4">
                <p class="text-sm font-bold text-gray-950">사람 상담으로 전환</p>
                <p class="mt-2 text-sm leading-6 text-gray-700">
                  간단한 안내만으로 부족할 때 사용하세요. 준비된 이메일에는 주제, 단계, 위치,
                  질문이 포함되어 맥락 있게 답변받을 수 있습니다.
                </p>
              </div>

              <a
                id="email-request-link"
                href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Travel%20Help%20Request"
                class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:border-brand-600 hover:text-brand-600 hover:no-underline"
              >
                이메일 요청 준비하기
              </a>
            </aside>
          </div>
        </div>

        <aside class="space-y-6">
          <section class="rounded-lg border border-gray-200 bg-white p-5">
            <p class="section-kicker">지원 범위</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">도움받을 수 있는 내용</h2>
            <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
              {supportAreas.map((area) => (
                <li class="border-b border-gray-100 pb-3 last:border-b-0 last:pb-0">{area}</li>
              ))}
            </ul>
          </section>

          <section class="rounded-lg border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">안전 수칙</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">민감한 정보는 제외하세요</h2>
            <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
              {safetyRules.map((rule) => (
                <li>{rule}</li>
              ))}
            </ul>
          </section>
        </aside>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <div class="card">
          <p class="section-kicker">1단계</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">문제 설명하기</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            도시, 앱, 이동 경로, 마감 시점, 이미 시도한 내용을 알려주세요.
          </p>
        </div>
        <div class="card">
          <p class="section-kicker">2단계</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">다음 단계 받기</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            이 페이지에서 실용적인 첫 답변을 받고 관련 가이드로 이어갈 수 있습니다.
          </p>
        </div>
        <div class="card">
          <p class="section-kicker">3단계</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">이메일로 상담 이어가기</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            1:1 도움이 필요하면 준비된 이메일을 보내고 비공개로 대화를 이어가세요.
          </p>
        </div>
      </section>

      <section class="mt-10 rounded-lg border border-gray-200 bg-white p-5 md:p-6">
        <p class="section-kicker">우선 직접 해결</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950">처음 중국 여행에서 자주 나오는 질문에 답하는 가이드</h2>
        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <a href="/ko/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">중국 첫 여행 계획 가이드</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">결제, 데이터, 교통, 도착 첫날 준비를 아직 정리하는 중이라면 이 가이드를 활용하세요.</p>
          </a>
          <a href="/ko/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">출국 전 준비 체크리스트</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">비행 전에 Alipay, WeChat Pay, eSIM, DiDi, 기차표, 번역, 주소, 현금 백업을 점검하세요.</p>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('travel-help-form') as HTMLFormElement | null;
  const message = document.getElementById('help-message') as HTMLTextAreaElement | null;
  const chatLog = document.getElementById('chat-log');
  const status = document.getElementById('form-status');
  const stage = document.getElementById('trip-stage') as HTMLSelectElement | null;
  const topic = document.getElementById('help-topic') as HTMLSelectElement | null;
  const locationInput = document.getElementById('help-location') as HTMLInputElement | null;
  const emailLink = document.getElementById('email-request-link') as HTMLAnchorElement | null;
  const submitButton = document.getElementById('help-submit') as HTMLButtonElement | null;

  const guideLinks: Record<string, { label: string; href: string }> = {
    '결제 앱': { label: '결제 설정 가이드', href: '/ko/payment/' },
    '인터넷 및 eSIM': { label: 'eSIM 가이드', href: '/ko/esim/' },
    '교통 경로': { label: '교통 가이드', href: '/ko/transport/' },
    '음식, 배달 또는 현지 앱': {
      label: '음식 배달 가이드',
      href: '/ko/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    },
    '일반 여행 준비': { label: '도구 페이지', href: '/ko/tools/' },
  };

  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char] ?? char);

  const updateEmailLink = () => {
    if (!emailLink) return;
    const selectedStage = stage?.value ?? '출발 전';
    const selectedTopic = topic?.value ?? '일반 여행 준비';
    const place = locationInput?.value.trim() || '미입력';
    const question = message?.value.trim() || '';
    const body = [
      'ChinaTripBox 여행 도움 요청',
      '',
      `여행 단계: ${selectedStage}`,
      `주요 주제: ${selectedTopic}`,
      `도시 또는 이동 경로: ${place}`,
      '',
      '질문:',
      question,
      '',
      '여권 사진, 은행 카드 전체 번호, 비밀번호, PIN, 일회용 인증 코드는 포함하지 않아야 한다는 점을 이해했습니다.',
    ].join('\n');

    emailLink.href = `mailto:zh13809022788@gmail.com?subject=${encodeURIComponent(
      `여행 도움: ${selectedTopic}`,
    )}&body=${encodeURIComponent(body)}`;
  };

  const addBubble = (content: string, fromUser = false) => {
    if (!chatLog) return null;
    const wrapper = document.createElement('div');
    wrapper.className = fromUser
      ? 'ml-auto max-w-[88%] rounded-lg bg-brand-600 p-4 text-sm leading-6 text-white'
      : 'max-w-[88%] rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-700';
    wrapper.innerHTML = content;
    chatLog.appendChild(wrapper);
    chatLog.scrollTop = chatLog.scrollHeight;
    return wrapper;
  };

  const formatAiAnswer = (value: string) =>
    escapeHtml(value)
      .replace(/\n{3,}/g, '\n\n')
      .replace(/\n/g, '<br>');

  const buildReply = (question: string) => {
    const selectedTopic = topic?.value ?? '일반 여행 준비';
    const selectedStage = stage?.value ?? '출발 전';
    const place = locationInput?.value.trim();
    const guide = guideLinks[selectedTopic] ?? guideLinks['일반 여행 준비'];
    const needsHuman =
      /screenshot|photo|declin|failed|stuck|urgent|tomorrow|today|passport|verification|identity|hotel|route/i.test(
        question,
      );

    const placeLine = place
      ? `<strong>${escapeHtml(place)}</strong> 관련 내용이므로 이메일에는 정확한 공항, 역, 호텔 지역, 앱 이름, 날짜를 함께 적어 주세요.`
      : '1:1 도움을 요청하기 전에 도시, 공항, 역, 호텔 지역 또는 앱 이름을 추가해 주세요.';

    const escalation = needsHuman
      ? '맥락 확인이나 추가 질의가 필요할 수 있어 사람의 후속 응답이 적합한 사례로 보입니다.'
      : '우선 가이드만으로 해결될 수 있습니다. 상황이 정확히 맞지 않으면 사람의 후속 도움을 요청하세요.';

    return `
      <strong class="block text-gray-950">추천되는 다음 단계</strong>
      <span class="block mt-1">주제: ${escapeHtml(selectedTopic)}. 단계: ${escapeHtml(selectedStage)}.</span>
      <span class="block mt-2">${placeLine}</span>
      <span class="block mt-2">먼저 <a href="${guide.href}" class="font-semibold text-brand-700">${guide.label}</a>부터 확인한 뒤, 여전히 1:1 도움이 필요하면 준비된 이메일 버튼을 사용하세요.</span>
      <span class="block mt-2">${escalation}</span>
    `;
  };

  document.querySelectorAll<HTMLButtonElement>('.quick-prompt').forEach((button) => {
    button.addEventListener('click', () => {
      if (!message) return;
      message.value = button.dataset.prompt ?? '';
      message.focus();
      updateEmailLink();
    });
  });

  [message, stage, topic, locationInput].forEach((element) => {
    element?.addEventListener('input', updateEmailLink);
    element?.addEventListener('change', updateEmailLink);
  });

  const requestAiAnswer = async (question: string) => {
    const response = await fetch('/api/travel-help', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({
        message: question,
        stage: stage?.value ?? '출발 전',
        topic: topic?.value ?? '일반 여행 준비',
        location: locationInput?.value.trim() ?? '',
      }),
    });

    const data = await response.json() as { answer?: string; error?: string };
    if (!response.ok || !data.answer) {
      throw new Error(data.error || 'AI 도우미를 현재 사용할 수 없습니다.');
    }
    return data.answer;
  };

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const question = message?.value.trim() ?? '';
    if (!question) {
      if (status) status.textContent = '먼저 질문을 입력해 주세요.';
      return;
    }
    addBubble(escapeHtml(question), true);
    const thinking = addBubble('AI가 여행 질문을 확인하고 있습니다...');
    if (status) status.textContent = 'AI 여행 도움을 요청하는 중입니다...';
    if (submitButton) submitButton.disabled = true;

    try {
      const answer = await requestAiAnswer(question);
      if (thinking) {
        thinking.innerHTML = `
          <strong class="block text-gray-950">AI 여행 도움</strong>
          <span class="mt-2 block">${formatAiAnswer(answer)}</span>
          <span class="mt-3 block text-xs text-gray-500">계정, 결제, visa, 법률, 의료, 응급 상황처럼 복잡한 문제는 공식 제공처에 다시 확인하거나 사람 검토를 요청하세요.</span>
        `;
      }
      if (status) status.textContent = 'AI 답변이 준비되었습니다. 사람 검토가 필요하면 이메일을 이용하세요.';
    } catch {
      if (thinking) thinking.innerHTML = buildReply(question);
      if (status) status.textContent = 'AI를 사용할 수 없어 로컬 대체 답변을 준비했습니다.';
    } finally {
      if (submitButton) submitButton.disabled = false;
    }
    updateEmailLink();
  });

  updateEmailLink();
</script>