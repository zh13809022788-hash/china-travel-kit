---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';

const title = '무료 중국 여행 플래너';
const description =
  '결제, eSIM, 교통, 앱 설정, 현금, 첫날 체크리스트 추천으로 실용적인 첫 중국 여행 계획을 세우세요.';

const needOptions = [
  { value: 'payment', label: '결제 설정' },
  { value: 'esim', label: 'eSIM 및 인터넷' },
  { value: 'transport', label: '공항 및 기차' },
  { value: 'hotel', label: '호텔 지역 논리' },
  { value: 'apps', label: '앱 및 번역' },
  { value: 'cash', label: '현금 백업' },
  { value: 'visa', label: '비자 면제 입국' },
  { value: 'food', label: '음식 및 배달' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main>
    <section class="border-b border-gray-200 bg-white">
      <div class="container-page grid gap-8 py-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <div>
          <p class="section-kicker">무료 계획 도구</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            비행 전 실용적인 중국 도착 계획 세우기
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            결제, eSIM 데이터, 공항 교통, 앱 설정, 현금 백업, 일일 일정에 대한 1차 계획을 받으세요. 브라우저에서 실행되며 답변을 저장하지 않습니다.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#planner" class="btn-primary">계획 시작</a>
            <a href="/ko/travel-help/" class="btn-outline">여행 도움 요청</a>
            <a href="/ko/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">첫 방문자 가이드 읽기</a>
          </div>
        </div>

        <aside class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="section-kicker">적합 대상</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">첫 방문자 설정</h2>
          <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
            <li>도착 전 결제 준비</li>
            <li>eSIM, 로밍, 앱 접근 결정</li>
            <li>공항에서 시내까지 첫 단계 계획</li>
            <li>도시별 간단한 여행 프레임워크</li>
          </ul>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <AdSlot format="banner" />

      <section id="planner" class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <form id="trip-planner-form" class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm md:p-6">
          <div class="border-b border-gray-200 pb-5">
            <p class="section-kicker">여행 세부 정보</p>
            <h2 class="mt-2 text-2xl font-bold text-gray-950">아는 것을 알려주세요</h2>
          </div>

          <div class="mt-6 grid gap-5 md:grid-cols-2">
            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              출발 국가 또는 지역
              <input id="home-country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="미국, 영국, 싱가포르..." />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              도착 도시
              <select id="arrival-city" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>상하이</option>
                <option>베이징</option>
                <option>광저우</option>
                <option>선전</option>
                <option>청두</option>
                <option>항저우</option>
                <option>기타 도시</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800 md:col-span-2">
              목적지 도시
              <input id="destination-cities" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="상하이, 항저우, 베이징" />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              여행 기간
              <select id="trip-length" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option value="3">3일</option>
                <option value="5">5일</option>
                <option value="7" selected>7일</option>
                <option value="10">10일</option>
                <option value="14">14일</option>
                <option value="21">21일 이상</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              여행 목적
              <select id="trip-purpose" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>관광</option>
                <option>비즈니스</option>
                <option>장기 체류</option>
                <option>디지털 노마드</option>
                <option>가족 방문</option>
                <option>환승</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              예산 범위
              <select id="budget-range" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>저예산</option>
                <option selected>컴포트</option>
                <option>프리미엄</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              여행 스타일
              <select id="travel-style" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>효율적</option>
                <option>저예산</option>
                <option selected>컴포트</option>
                <option>가족</option>
                <option>비즈니스</option>
                <option>음식 중심</option>
              </select>
            </label>
          </div>

          <fieldset class="mt-6">
            <legend class="text-sm font-semibold text-gray-800">무엇에 도움이 필요하신가요?</legend>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              {needOptions.map((option) => (
                <label class="flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-700">
                  <input class="h-4 w-4 rounded border-gray-300 text-brand-600" type="checkbox" name="needs" value={option.value} checked={['payment', 'esim', 'transport', 'apps'].includes(option.value)} />
                  {option.label}
                </label>
              ))}
            </div>
          </fieldset>

          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p id="planner-status" class="text-sm text-gray-500">계정이나 민감한 데이터 불필요.</p>
            <button class="btn-primary" type="submit">계획 생성</button>
          </div>
        </form>

        <aside class="space-y-6">
          <section class="rounded-lg border border-gray-200 bg-white p-5">
            <p class="section-kicker">업그레이드 경로</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">사람의 검토가 필요하세요?</h2>
            <p class="mt-3 text-sm leading-6 text-gray-600">
              동선, 시기, 결제 설정, 또는 첫날이 위험하게 느껴지면, 생성된 계획을 이메일로 보내 사람이 검토한 수정 목록을 요청하세요.
            </p>
            <a id="planner-email-link" class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:border-brand-600 hover:text-brand-600 hover:no-underline" href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Trip%20Review%20Request">
              검토 이메일 준비
            </a>
          </section>

          <section class="rounded-lg border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">한도</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">계획 도움말로 사용</h2>
            <p class="mt-3 text-sm leading-6 text-gray-700">
              이 도구는 법률, 출입국, 의료, 은행, 또는 비상 조언이 아닙니다. 중요한 입국, 항공, 호텔, 카드, 통신, 앱 규정은 공식 출처에서 확인하세요.
            </p>
          </section>
        </aside>
      </section>

      <section id="plan-output" class="mt-10 hidden rounded-lg border border-brand-100 bg-brand-50 p-5 md:p-6" aria-live="polite">
        <div class="border-b border-brand-100 pb-4">
          <p class="section-kicker">생성된 계획</p>
          <h2 class="mt-2 text-2xl font-bold text-gray-950">중국 여행 설정 초안</h2>
        </div>
        <div id="plan-content" class="mt-5 grid gap-5"></div>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <a href="/ko/payment/" class="card block hover:no-underline">
          <p class="section-kicker">결제</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Alipay와 WeChat Pay 준비</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">도착 전 최소 하나의 지갑과 하나의 백업 결제 수단을 설정하세요.</p>
        </a>
        <a href="/ko/esim/" class="card block hover:no-underline">
          <p class="section-kicker">인터넷</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">eSIM 또는 로밍 설정 선택</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">첫날 지도 로드, 번역, 메시지, 차량 호출이 가능한지 확인하세요.</p>
        </a>
        <a href="/ko/transport/" class="card block hover:no-underline">
          <p class="section-kicker">교통</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">첫 동선 계획</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">공항에서 호텔까지 동선과 지하철, 택시, DiDi, 기차 사용 시기를 알으세요.</p>
        </a>
      </section>

      <section class="mt-10 rounded-lg border border-gray-200 bg-white p-5 md:p-6">
        <p class="section-kicker">플래너 사용 전</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950">첫 중국 여행이라면 설정 가이드를 읽으세요</h2>
        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <a href="/ko/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">첫 방문자를 위한 중국 여행 플래너</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">이 도구와 같은 계획 순서 사용: 인터넷, 결제, 공항 동선, 앱, 도시 순서, 첫날 체크리스트.</p>
          </a>
          <a href="/ko/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">중국 여행 전 설정할 것</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Alipay, WeChat Pay, eSIM, DiDi, 기차표, 지도, 현금 백업을 위한 실용적인 출발 전 체크리스트.</p>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('trip-planner-form') as HTMLFormElement | null;
  const output = document.getElementById('plan-output');
  const content = document.getElementById('plan-content');
  const status = document.getElementById('planner-status');
  const emailLink = document.getElementById('planner-email-link') as HTMLAnchorElement | null;

  const getValue = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null)?.value.trim() || '';
  const selectedNeeds = () =>
    Array.from(document.querySelectorAll<HTMLInputElement>('input[name="needs"]:checked')).map((input) => input.value);
  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char] ?? char);

  const splitCities = (value: string, arrival: string) => {
    const typed = value
      .split(',')
      .map((city) => city.trim())
      .filter(Boolean);
    const cities = typed.length ? typed : [arrival];
    return Array.from(new Set(cities));
  };

  const list = (items: string[]) => `<ul class="mt-3 grid gap-2 text-sm leading-6 text-gray-700">${items.map((item) => `<li>${item}</li>`).join('')}</ul>`;
  const panel = (title: string, items: string[]) => `
    <section class="rounded-lg border border-gray-200 bg-white p-5">
      <h3 class="text-lg font-bold text-gray-950">${title}</h3>
      ${list(items)}
    </section>
  `;

  const buildPlan = () => {
    const home = getValue('home-country') || '출발 국가';
    const arrival = getValue('arrival-city') || '상하이';
    const cities = splitCities(getValue('destination-cities'), arrival);
    const days = Number(getValue('trip-length') || '7');
    const purpose = getValue('trip-purpose') || '관광';
    const budget = getValue('budget-range') || '컴포트';
    const style = getValue('travel-style') || '컴포트';
    const needs = selectedNeeds();
    const perCity = Math.max(1, Math.floor(days / Math.max(1, cities.length)));

    const preDeparture = [
      `${escapeHtml(home)}을(를) 떠나기 전에 Alipay, WeChat, DiDi, 번역 앱, 오프라인 지도를 설치하세요.`,
      needs.includes('payment')
        ? 'Alipay에 외국 Visa 또는 Mastercard를 연결하고 출발 전 소액 인증을 시도하세요.'
        : '결제 설정을 단순하게 유지: 모바일 지갑 하나, 실물 카드 하나, RMB 현금 약간.',
      needs.includes('esim')
        ? '항공편 전에 eSIM 또는 로밍 요금제를 구매하고 활성화한 후 QR 코드를 오프라인으로 보관하세요.'
        : '지도나 차량 호출에 의존하기 전에 도착 시 휴대폰에 데이터가 있는지 확인하세요.',
      '호텔 주소를 영어와 중국어로 저장하고 가장 가까운 지하철역도 함께 저장하세요.',
    ];

    const payment = [
      '주 설정: 외국 카드가 연결된 Alipay, 방문객에게 보통 가장 실용적인 첫 지갑이기 때문입니다.',
      '백업 설정: 카드가 성공적으로 연결되면 WeChat Pay, 그리고 실물 Visa 또는 Mastercard 하나.',
      budget === '저예산'
        ? '현금 백업: 노점, 보증금, 또는 카드/지갑 문제를 위해 소량의 RMB를 휴대하세요.'
        : '현금 백업: 모바일 결제 실패에 대비해 택시, 간식, 간단한 식사 비용의 RMB를 충분히 보관하세요.',
      '중국 본국에서 Apple Pay 또는 Google Pay를 주 결제 수단으로 의존하지 마세요.',
    ];

    const internet = [
      '단기 여행의 경우, 휴대폰이 eSIM을 지원하면 여행 eSIM이 보통 가장 쉬운 설정입니다.',
      '더 긴 체류나 대용량 데이터 사용의 경우, 도착 전에 로밍, eSIM, 포켓 WiFi, 현지 SIM 옵션을 비교하세요.',
      '결제 앱, 차량 호출, 번역, 지도가 모두 의존하므로 공항을 떠나기 전에 모바일 데이터를 테스트하세요.',
      '첫 연결이 불안정할 경우를 대비해 호텔과 교통 정보를 오프라인으로 저장하세요.',
    ];

    const transport = [
      `첫 동선: 착륙 전에 ${escapeHtml(arrival)} 공항 또는 역에서 호텔까지 계획하세요.`,
      '예측 가능한 시내 동선에는 지하철, 문 앞까지 이동에는 DiDi, 도시 간 이동에는 고속철도를 사용하세요.',
      needs.includes('transport')
        ? '기차 여행일에는 가능하면 일찍 예약하고 여권 정보를 티켓 플랫폼과 일치시키세요.'
        : '국제 항공편과 장거리 기차 간의 빠듯한 당일 환승을 피하세요.',
      '택시나 호텔 프런트를 위해 중국어 주소 카드를 준비하세요.',
    ];

    const dayPlan = cities.map((city, index) => {
      const start = index * perCity + 1;
      const end = index === cities.length - 1 ? days : Math.min(days, start + perCity - 1);
      return `${start}-${end}일차: ${escapeHtml(city)} - 첫 반나절은 가볍게, 결제/데이터 확인 후 지역별로 명소를 묶으세요.`;
    });

    const mistakes = [
      '도착할 때까지 모든 앱, 카드, 데이터 요금제 설정을 미루지 마세요.',
      '장거리 항공편 직후 빽빽한 관광 일정을 잡지 마세요.',
      '하나의 결제 수단에만 의존하지 마세요.',
      purpose === '비즈니스'
        ? '비즈니스 여행의 경우 교통, 보안 검색, 청구서, 건물 출입을 위한 여유 시간을 두세요.'
        : '레저 여행의 경우 날씨, 인파, 피로를 위해 2-3일마다 유연한 시간 블록을 하나 남겨두세요.',
      style === '음식 중심'
        ? '음식 중심 여행의 경우 식당 이름을 중국어로 저장하고 도시를 횡단하기 전에 영업시간을 확인하세요.'
        : '호텔 근처 식사를 위한 간단한 백업 계획을 유지하세요.',
    ];

    const html = [
      panel('출발 전 체크리스트', preDeparture),
      panel('결제 및 현금 설정', payment),
      panel('인터넷 및 앱 설정', internet),
      panel('교통 및 첫날', transport),
      panel('간단한 일일 프레임워크', dayPlan),
      panel('일반적 실수 경고', mistakes),
    ].join('');

    const emailBody = [
      'ChinaTripBox 여행 검토 요청',
      '',
      `출발 국가 또는 지역: ${home}`,
      `도착 도시: ${arrival}`,
      `목적지 도시: ${cities.join(', ')}`,
      `여행 기간: ${days}일`,
      `목적: ${purpose}`,
      `예산: ${budget}`,
      `스타일: ${style}`,
      `필요: ${needs.join(', ') || '지정되지 않음'}`,
      '',
      '결제, eSIM, 교통, 시기, 첫날 실수에 대해 중국 여행 설정을 검토해 주세요.',
    ].join('\n');

    if (emailLink) {
      emailLink.href = `mailto:zh13809022788@gmail.com?subject=${encodeURIComponent(
        'ChinaTripBox 여행 검토 요청',
      )}&body=${encodeURIComponent(emailBody)}`;
    }

    return html;
  };

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!content || !output) return;
    content.innerHTML = buildPlan();
    output.classList.remove('hidden');
    output.scrollIntoView({ behavior: 'smooth', block: 'start' });
    if (status) status.textContent = '계획이 생성되었습니다. 답변을 조정하고 언제든 다시 생성하세요.';
  });
</script>
