---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = '외국인 여행자를 위한 중국 여행 자료';
const description =
  'A practical resource hub for foreign visitors to China: payments, eSIMs, trains, visas, city guides, tools, and first-trip planning links.';

const resourceGroups = [
  {
    title: 'If you only have 30 minutes',
    description: 'A short reading path for travelers who need a workable China setup fast.',
    links: [
      { href: '/ko/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: 'Pre-departure setup checklist' },
      { href: '/ko/tools/survival-kit/', title: 'China survival kit cards and checklists' },
      { href: '/ko/tools/payment-checker/', title: 'Check your payment fallback plan' },
      { href: '/ko/tools/visa-free-checker/', title: 'Check visa-free entry or transit' },
      { href: '/ko/posts/china-high-speed-rail-guide-foreigners/', title: 'Understand train booking and station entry' },
    ],
  },
  {
    title: 'Start here: first-trip setup',
    description: 'The shortest path from "I am going to China" to a workable arrival plan.',
    links: [
      { href: '/ko/trip-planner/', title: 'Free China trip planner' },
      { href: '/ko/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/', title: 'China trip planner for first-time visitors' },
      { href: '/ko/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: 'What to set up before traveling to China' },
      { href: '/ko/posts/china-visa-free-entry-transit-guide-2026/', title: 'China visa-free entry and transit guide' },
      { href: '/ko/tools/best-time-to-visit/', title: 'Best time to visit China' },
      { href: '/ko/posts/what-to-pack-for-china-a-season-by-season-checklist/', title: 'What to pack for China' },
    ],
  },
  {
    title: '결제s and money',
    description: 'Mobile payments, cash backup, cards, and everyday checkout problems.',
    links: [
      { href: '/ko/posts/how-to-pay-in-china-tourist-guide/', title: 'How to pay in China as a tourist' },
      { href: '/ko/posts/alipay-foreign-credit-card-step-by-step/', title: 'Set up Alipay with a foreign card' },
      { href: '/ko/posts/wechat-pay-foreign-visitors-guide/', title: 'WeChat Pay guide for foreign visitors' },
      { href: '/ko/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: 'Pre-departure payment and app checklist' },
      { href: '/ko/tools/payment-checker/', title: '결제 compatibility checker' },
    ],
  },
  {
    title: 'Internet and apps',
    description: 'Stay online, choose an eSIM, and know which apps work before arrival.',
    links: [
      { href: '/ko/posts/best-esim-for-china-travel-2026/', title: 'Best eSIM for China travel' },
      { href: '/ko/posts/china-esim-vs-roaming-2026-the-real-10-day-cost/', title: 'China eSIM vs roaming cost' },
      { href: '/ko/posts/internet-access-china-apps-that-work-2026/', title: 'Internet access and apps in China' },
      { href: '/ko/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/', title: 'First-time trip planning with eSIM and apps' },
      { href: '/ko/tools/app-availability-checker/', title: 'Will my apps work in China?' },
    ],
  },
  {
    title: '교통 and city guides',
    description: 'Trains, metro, airports, ride-hailing, and practical city planning.',
    links: [
      { href: '/ko/cities/', title: 'China city guide hub' },
      { href: '/ko/posts/china-high-speed-rail-guide-foreigners/', title: 'China high-speed rail guide for foreigners' },
      { href: '/ko/posts/book-china-train-tickets-12306-foreigners/', title: 'Book China train tickets on 12306' },
      { href: '/ko/posts/didi-china-foreign-tourists-guide/', title: 'Use DiDi as a foreign tourist' },
      { href: '/ko/posts/airport-to-city-transport-beijing-shanghai-guangzhou/', title: 'Airport to city transport guide' },
    ],
  },
  {
    title: 'Food, etiquette, and everyday life',
    description: 'Dining, tipping, delivery apps, street food, and practical habits that reduce friction on the ground.',
    links: [
      { href: '/ko/food/', title: 'China food and dining hub' },
      { href: '/ko/posts/ordering-food-in-china-without-chinese-meituan-ele-me/', title: 'Order food without Chinese' },
      { href: '/ko/posts/chengdu-street-food-safety-spice-levels-what-to-order/', title: 'Chengdu street-food safety and spice guide' },
      { href: '/ko/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/', title: 'Tipping in China: when it is expected' },
    ],
  },
  {
    title: 'Longer stays and remote work',
    description: 'For trips measured in weeks or months, start with legality, housing, payment, and work-tool reliability.',
    links: [
      { href: '/ko/long-stay/', title: 'Long-term stay in China guide' },
      { href: '/ko/digital-nomads/', title: 'Digital nomad guide to China' },
      { href: '/ko/digital-nomads/visa/', title: 'China visa guide for digital nomads' },
      { href: '/ko/digital-nomads/payment/', title: '결제 setup for long stays' },
    ],
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-10">
    <section class="max-w-3xl">
      <p class="section-kicker">자료 허브</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </section>

    <section class="mt-10 grid gap-5 md:grid-cols-2">
      {resourceGroups.map((group) => (
        <article class="card">
          <h2 class="text-xl font-bold text-gray-950">{group.title}</h2>
          <p class="mt-2 text-sm leading-6 text-gray-600">{group.description}</p>
          <ul class="mt-5 grid gap-3">
            {group.links.map((link) => (
              <li>
                <a href={link.href} class="font-semibold text-brand-700 hover:text-brand-800">
                  {link.title}
                </a>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>
