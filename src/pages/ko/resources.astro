---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = '중국 여행 자료 모음';
const description =
  '중국 여행 준비에 필요한 핵심 가이드를 주제별로 모아둔 페이지입니다. 결제, eSIM, 교통, 도시 준비, 음식, 장기 체류까지 한눈에 살펴보세요.';

const resourceGroups = [
  {
    title: '30분 안에 끝내는 출발 전 준비',
    description: '출국 전에 빠르게 체크해야 할 핵심 가이드만 먼저 보고 싶다면 여기부터 시작하세요.',
    links: [
      { href: '/ko/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: '출발 전 체크리스트' },
      { href: '/ko/tools/survival-kit/', title: '중국 여행 생존 키트' },
      { href: '/ko/tools/payment-checker/', title: '결제 호환성 확인기' },
      { href: '/ko/tools/visa-free-checker/', title: '무비자·환승 가능 여부 확인기' },
      { href: '/ko/posts/china-high-speed-rail-guide-foreigners/', title: '중국 고속철도 기본 가이드' },
    ],
  },
  {
    title: '처음 가는 중국 여행',
    description: '처음 중국에 가는 여행자가 가장 많이 묻는 준비 순서를 모았습니다.',
    links: [
      { href: '/ko/trip-planner/', title: '중국 여행 플래너' },
      { href: '/ko/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/', title: '초보 여행자용 전체 플랜' },
      { href: '/ko/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: '출발 전 꼭 해둘 설정' },
      { href: '/ko/posts/china-visa-free-entry-transit-guide-2026/', title: '중국 무비자·환승 입국 가이드' },
      { href: '/ko/tools/best-time-to-visit/', title: '중국 여행 시기 플래너' },
      { href: '/ko/posts/what-to-pack-for-china-a-season-by-season-checklist/', title: '계절별 짐 싸기 가이드' },
    ],
  },
  {
    title: '결제와 현금',
    description: '모바일 결제, 카드 연결, 수수료, 예비 현금까지 결제 준비만 따로 정리했습니다.',
    links: [
      { href: '/ko/posts/how-to-pay-in-china-tourist-guide/', title: '중국 결제 전체 가이드' },
      { href: '/ko/posts/alipay-foreign-credit-card-step-by-step/', title: 'Alipay 설정 방법' },
      { href: '/ko/posts/wechat-pay-foreign-visitors-guide/', title: 'WeChat Pay 사용 가이드' },
      { href: '/ko/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: '출발 전 결제 준비 체크' },
      { href: '/ko/tools/payment-checker/', title: '결제 점검 도구' },
    ],
  },
  {
    title: 'eSIM과 인터넷',
    description: 'eSIM 선택, 데이터 전략, 앱 접속성, 도착 직후 인터넷 준비에 필요한 자료입니다.',
    links: [
      { href: '/ko/posts/best-esim-for-china-travel-2026/', title: '중국 여행 eSIM 추천' },
      { href: '/ko/posts/china-esim-vs-roaming-2026-the-real-10-day-cost/', title: 'eSIM vs 로밍 비교' },
      { href: '/ko/posts/internet-access-china-apps-that-work-2026/', title: '중국 인터넷·앱 사용 가이드' },
      { href: '/ko/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/', title: '인터넷 준비 전체 흐름' },
      { href: '/ko/tools/app-availability-checker/', title: '앱 사용 가능 여부 확인기' },
    ],
  },
  {
    title: '교통과 이동',
    description: '고속철도, 공항 이동, 지하철, DiDi, 도시 간 이동 팁을 모았습니다.',
    links: [
      { href: '/ko/cities/', title: '중국 도시 가이드 모음' },
      { href: '/ko/posts/china-high-speed-rail-guide-foreigners/', title: '외국인용 고속철도 가이드' },
      { href: '/ko/posts/book-china-train-tickets-12306-foreigners/', title: '12306 열차 예매 방법' },
      { href: '/ko/posts/didi-china-foreign-tourists-guide/', title: 'DiDi 사용 가이드' },
      { href: '/ko/posts/airport-to-city-transport-beijing-shanghai-guangzhou/', title: '공항에서 시내 이동하기' },
    ],
  },
  {
    title: '음식, 식당, 식문화',
    description: '주문 방법, 길거리 음식, 향신료, 식당 예절 같은 주제를 모았습니다.',
    links: [
      { href: '/ko/food/', title: '중국 음식 가이드 모음' },
      { href: '/ko/posts/ordering-food-in-china-without-chinese-meituan-ele-me/', title: '중국어 없이 음식 주문하기' },
      { href: '/ko/posts/chengdu-street-food-safety-spice-levels-what-to-order/', title: '청두 길거리 음식 가이드' },
      { href: '/ko/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/', title: '중국 팁 문화 이해하기' },
    ],
  },
  {
    title: '장기 체류와 원격 근무',
    description: '장기 체류자, 디지털 노마드, 생활형 여행자를 위한 준비 자료입니다.',
    links: [
      { href: '/ko/long-stay/', title: '중국 장기 체류 가이드' },
      { href: '/ko/digital-nomads/', title: '중국 디지털 노마드 가이드' },
      { href: '/ko/digital-nomads/visa/', title: '장기 체류와 비자 정보' },
      { href: '/ko/digital-nomads/payment/', title: '장기 체류 결제 준비' },
    ],
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-10">
    <section class="max-w-3xl">
      <p class="section-kicker">자료 모음</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </section>

    <section class="mt-10 grid gap-5 md:grid-cols-2">
      {resourceGroups.map((group) => (
        <article class="card">
          <h2 class="text-xl font-bold text-gray-950">{group.title}</h2>
          <p class="mt-2 text-sm leading-6 text-gray-600">{group.description}</p>
          <ul class="mt-5 grid gap-3">
            {group.links.map((link) => (
              <li>
                <a href={link.href} class="font-semibold text-brand-700 hover:text-brand-800">
                  {link.title}
                </a>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>
