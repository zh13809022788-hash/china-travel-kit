---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = '외국인 여행자를 위한 중국 여행 자료';
const description =
  '중국 방문 외국인을 위한 실용적인 자료 허브: 결제, eSIM, 기차, 비자, 도시 가이드, 도구, 첫 여행 계획 링크.';

const resourceGroups = [
  {
    title: '30분만 있는 경우',
    description: '빠르게 작동하는 중국 설정이 필요한 여행자를 위한 짧은 읽기 경로.',
    links: [
      { href: '/ko/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: '출발 전 설정 체크리스트' },
      { href: '/ko/tools/survival-kit/', title: '중국 생존 키트 카드와 체크리스트' },
      { href: '/ko/tools/payment-checker/', title: '결제 백업 계획 확인' },
      { href: '/ko/tools/visa-free-checker/', title: '비자 면제 입국 또는 환승 확인' },
      { href: '/ko/posts/china-high-speed-rail-guide-foreigners/', title: '기차 예약과 역 입국 이해' },
    ],
  },
  {
    title: '여기서 시작: 첫 여행 설정',
    description: '"중국에 간다"에서 작동하는 도착 계획까지의 가장 짧은 경로.',
    links: [
      { href: '/ko/trip-planner/', title: '무료 중국 여행 플래너' },
      { href: '/ko/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/', title: '첫 방문자를 위한 중국 여행 플래너' },
      { href: '/ko/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: '중국 여행 전 설정할 것' },
      { href: '/ko/posts/china-visa-free-entry-transit-guide-2026/', title: '중국 비자 면제 입국 및 환승 가이드' },
      { href: '/ko/tools/best-time-to-visit/', title: '중국 방문 최적의 시기' },
      { href: '/ko/posts/what-to-pack-for-china-a-season-by-season-checklist/', title: '중국 여행 짐 챙기기' },
    ],
  },
  {
    title: '결제와 화폐',
    description: '모바일 결제, 현금 백업, 카드, 일상 결제 문제.',
    links: [
      { href: '/ko/posts/how-to-pay-in-china-tourist-guide/', title: '관광객으로서 중국에서 결제하는 방법' },
      { href: '/ko/posts/alipay-foreign-credit-card-step-by-step/', title: '외국 카드로 Alipay 설정' },
      { href: '/ko/posts/wechat-pay-foreign-visitors-guide/', title: '외국 방문객을 위한 WeChat Pay 가이드' },
      { href: '/ko/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: '출발 전 결제 및 앱 체크리스트' },
      { href: '/ko/tools/payment-checker/', title: '결제 호환성 확인' },
    ],
  },
  {
    title: '인터넷과 앱',
    description: '온라인 유지, eSIM 선택, 도착 전 작동하는 앱 파악.',
    links: [
      { href: '/ko/posts/best-esim-for-china-travel-2026/', title: '중국 여행 최고의 eSIM' },
      { href: '/ko/posts/china-esim-vs-roaming-2026-the-real-10-day-cost/', title: '중국 eSIM vs 로밍 비용' },
      { href: '/ko/posts/internet-access-china-apps-that-work-2026/', title: '중국 인터넷 접속과 앱' },
      { href: '/ko/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/', title: 'eSIM과 앱을 활용한 첫 여행 계획' },
      { href: '/ko/tools/app-availability-checker/', title: '내 앱이 중국에서 작동할까요?' },
    ],
  },
  {
    title: '교통과 도시 가이드',
    description: '기차, 지하철, 공항, 차량 호출, 실용적인 도시 계획.',
    links: [
      { href: '/ko/cities/', title: '중국 도시 가이드 허브' },
      { href: '/ko/posts/china-high-speed-rail-guide-foreigners/', title: '외국인을 위한 중국 고속철도 가이드' },
      { href: '/ko/posts/book-china-train-tickets-12306-foreigners/', title: '12306에서 중국 기차표 예약' },
      { href: '/ko/posts/didi-china-foreign-tourists-guide/', title: '외국 관광객으로서 DiDi 사용' },
      { href: '/ko/posts/airport-to-city-transport-beijing-shanghai-guangzhou/', title: '공항에서 시내까지 교통 가이드' },
    ],
  },
  {
    title: '음식, 에티켓, 일상 생활',
    description: '다이닝, 팁, 배달 앱, 길거리 음식, 현지 마찰을 줄이는 실용적 습관.',
    links: [
      { href: '/ko/food/', title: '중국 음식과 다이닝 허브' },
      { href: '/ko/posts/ordering-food-in-china-without-chinese-meituan-ele-me/', title: '중국어 없이 음식 주문' },
      { href: '/ko/posts/chengdu-street-food-safety-spice-levels-what-to-order/', title: '청두 스트리트 푸드 안전과 매운맛 가이드' },
      { href: '/ko/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/', title: '중국에서 팁: 예상되는 경우' },
    ],
  },
  {
    title: '장기 체류와 원격 근무',
    description: '주 또는 월 단위 여행의 경우, 합법성, 주거, 결제, 업무 도구 신뢰성부터 시작.',
    links: [
      { href: '/ko/long-stay/', title: '중국 장기 체류 가이드' },
      { href: '/ko/digital-nomads/', title: '중국 디지털 노마드 가이드' },
      { href: '/ko/digital-nomads/visa/', title: '디지털 노마드를 위한 중국 비자 가이드' },
      { href: '/ko/digital-nomads/payment/', title: '장기 체류를 위한 결제 설정' },
    ],
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-10">
    <section class="max-w-3xl">
      <p class="section-kicker">자료 허브</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </section>

    <section class="mt-10 grid gap-5 md:grid-cols-2">
      {resourceGroups.map((group) => (
        <article class="card">
          <h2 class="text-xl font-bold text-gray-950">{group.title}</h2>
          <p class="mt-2 text-sm leading-6 text-gray-600">{group.description}</p>
          <ul class="mt-5 grid gap-3">
            {group.links.map((link) => (
              <li>
                <a href={link.href} class="font-semibold text-brand-700 hover:text-brand-800">
                  {link.title}
                </a>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>
