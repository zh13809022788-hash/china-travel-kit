---

import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const CATEGORY = 'esim';
const posts = (await getCollection('posts-ko'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = '중국 eSIM 및 데이터 가이드: 도착 즉시 연결';
const description = '중국 여행에 가장 적합한 eSIM 데이터 요금제를 비교하고 설정하세요. 실물 SIM 교체 없이 도착하자마자 바로 연결됩니다.';

const connectionChoices = [
  {
    title: 'eSIM',
    desc: '대부분의 단기 여행에 가장 적합합니다. 휴대폰이 eSIM을 지원하고 착륙 전에 데이터를 준비하려는 경우에 좋습니다.',
  },
  {
    title: '로밍',
    desc: '뱅킹 SMS 및 첫 시간 연결을 위한 백업으로 유용하지만, 대용량 데이터 사용 시 더 비쌀 수 있습니다.',
  },
  {
    title: '포켓 Wi-Fi 또는 현지 SIM',
    desc: '그룹 여행, 장기 체류 또는 여행용 eSIM을 설치할 수 없는 휴대폰에 적합합니다.',
  },
];

const internetTools = [
  { href: '/ko/tools/esim-comparison/', title: 'eSIM 요금제 비교기', desc: '여행 데이터 요금제, 사용 기간, 예상 활용 상황을 비교해 보세요.' },
  { href: '/ko/tools/app-availability-checker/', title: '앱 사용 가능 여부 확인기', desc: '중국에서 자주 쓰는 앱이 작동하는지, 어떤 대안을 준비해야 하는지 확인해 보세요.' },
  { href: '/ko/posts/internet-access-china-apps-that-work-2026/', title: '인터넷 접속 가이드', desc: '입국 전에 앱 접속 가능 여부, VPN 필요성, 실전 설정 방법을 미리 알아보세요.' },
];
---


<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-10">
    <header>
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">eSIM 데이터</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">eSIM 및 데이터 가이드</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="hub-esim" alt="중국 여행을 위한 모바일 네트워크 및 데이터 연결 옵션" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-esim">
      <h2 id="featured-esim" class="sr-only">추천 인터넷 가이드</h2>
      <a href="/ko/posts/best-esim-for-china-travel-2026/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">2026년 중국 여행용 최고의 eSIM</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">중국 여행용 Airalo, Holafly, Nomad를 비교해 보세요</p>
      </a>
      <a href="/ko/posts/china-esim-vs-roaming-2026-the-real-10-day-cost/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">eSIM과 로밍 비교</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">여행자를 위한 실제 10일 비용 비교</p>
      </a>
      <a href="/ko/posts/do-you-need-a-vpn-in-china-2026/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">2026년 VPN 가이드</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">중국 여행자에게 아직도 VPN이 필요할까요?</p>
      </a>
      <a href="/ko/posts/pocket-wifi-vs-esim-vs-sim-china/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">포켓 WiFi와 eSIM 비교</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">모든 연결 옵션을 비교해 보세요</p>
      </a>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[1fr_340px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">중국 인터넷 사용 구성을 선택하세요</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          여행자에게 가장 안전한 구성은 보통 주 데이터 수단 하나와, 도착 첫날 뱅킹·지도·번역·차량 호출 앱에 대비한 백업 수단 하나를 함께 준비하는 것입니다.
        </p>
        <div class="mt-5 grid gap-3">
          {connectionChoices.map((choice) => (
            <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
              <h3 class="text-sm font-bold text-gray-900">{choice.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{choice.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">인터넷 도구</h2>
        <div class="mt-4 grid gap-3">
          {internetTools.map((tool) => (
            <a href={tool.href} class="rounded-lg border border-brand-100 bg-white p-4 hover:border-brand-200 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-900 hover:text-brand-700">{tool.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{tool.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/ko/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{post.data.category}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">가이드가 곧 공개됩니다.</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>