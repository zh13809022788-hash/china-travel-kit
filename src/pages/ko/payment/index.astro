---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const CATEGORY = 'payment';
const posts = (await getCollection('posts-ko'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = '중국 결제 가이드: Alipay, WeChat Pay, 해외 카드';
const description =
  '중국 여행자를 위한 결제 준비 가이드입니다. Alipay와 WeChat Pay 설정, 카드 연결, 수수료, 현금 예비금까지 정리했습니다.';

const prioritySteps = [
  '출발 전에 Alipay와 WeChat을 설치하고, 본인 인증은 본국 은행과 휴대폰 번호에 접근 가능한 상태에서 끝내세요.',
  'Visa 또는 Mastercard 한 장은 반드시 연결하고, 가능하면 다른 발급사의 예비 카드도 함께 준비하세요.',
  '택시, 소규모 가게, 인증 실패 상황에 대비해 소액의 위안화 현금을 챙겨 두는 것이 좋습니다.',
];

const paymentTools = [
  { href: '/ko/tools/payment-checker/', title: '결제 호환성 확인기', desc: 'Alipay와 WeChat Pay에서 카드 지원 여부, 일반적인 한도, 수수료를 확인합니다.' },
  { href: '/ko/tools/budget-cash-estimator/', title: '예산·현금 계산기', desc: '여행 예산과 예비 현금을 어느 정도 준비할지 계산할 수 있습니다.' },
  { href: '/ko/tools/currency-converter/', title: '위안화 환산기', desc: '위안화 가격을 바로 환산하고 체감 물가를 확인할 수 있습니다.' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-10">
    <header>
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">결제</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">중국 결제 가이드</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-how-to-pay" alt="중국 여행 결제 수단을 보여주는 스마트폰 결제 화면" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-payment">
      <h2 id="featured-payment" class="sr-only">주요 결제 가이드</h2>
      <a href="/ko/posts/alipay-foreign-credit-card-step-by-step/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Alipay 설정</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">앱 설치부터 해외 카드 연결까지 순서대로 설명합니다.</p>
      </a>
      <a href="/ko/posts/wechat-pay-foreign-visitors-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">WeChat Pay</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">해외 여행자 기준 설정과 사용 방법을 정리했습니다.</p>
      </a>
      <a href="/ko/posts/alipay-vs-wechat-pay-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Alipay vs WeChat Pay</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">2026년 기준 어떤 앱을 우선 써야 할지 비교합니다.</p>
      </a>
      <a href="/ko/posts/how-to-pay-in-china-tourist-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">결제 전체 가이드</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">중국에서 여행자가 결제할 때 알아야 할 흐름을 한 번에 정리했습니다.</p>
      </a>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[1fr_340px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">안정적인 결제 구성을 먼저 만드세요</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          중국은 QR 결제가 중심입니다. 여행자에게는 보통 주 결제 앱 하나, 예비 앱 하나,
          카드 두 장, 소액 현금 정도를 준비하는 구성이 가장 안정적입니다.
        </p>
        <ol class="mt-5 space-y-3 text-sm leading-6 text-gray-600">
          {prioritySteps.map((step, index) => (
            <li class="flex gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand-50 text-xs font-bold text-brand-700">{index + 1}</span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">결제 도구</h2>
        <div class="mt-4 grid gap-3">
          {paymentTools.map((tool) => (
            <a href={tool.href} class="rounded-lg border border-brand-100 bg-white p-4 hover:border-brand-200 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-900 hover:text-brand-700">{tool.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{tool.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/ko/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{post.data.category}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">준비 중인 가이드입니다.</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>
