---
import { getCollection } from 'astro:content';
import { CITY_GUIDES, cityName } from '../../../../data/cityGuideData';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import CoverImage from '../../../../components/CoverImage.astro';
import ChinaMap from '../../../../components/ChinaMap.astro';
import AdSlot from '../../../../components/AdSlot.astro';

const POSTS_COLLECTION = 'posts-zh-tw';
const LOCALE = 'zh-TW';
const LOCALE_TAG = 'zh-tw';

const allPosts = await getCollection(POSTS_COLLECTION);
const cityNames = ['beijing', 'shanghai', 'chengdu', 'hangzhou', 'sanya', 'guangzhou', 'xian', 'chongqing', 'kunming', 'nanjing', 'guilin'];
const cityPosts = allPosts
  .filter((post) => cityNames.some((city) => post.slug.includes(city) || post.data.tags.includes(city)))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const title = '外籍旅客的中國城市指南';
const description =
  '透過北京、上海、廣州、成都、西安、杭州、南京、桂林、重慶與三亞等城市指南，規劃更順暢的中國行程，並掌握機場、地鐵、美食與市區交通安排。';

// Dynamic map data from shared CITY_GUIDES
const postedSlugs = new Set(cityPosts.map(p => p.slug));
const mapCities = CITY_GUIDES.map((g) => ({
  name: cityName(g, LOCALE_TAG),
  x: g.mapX,
  y: g.mapY,
  href: postedSlugs.has(g.slug) ? `#${g.slug.replace(/^(.+?)-city-guide.*$/, '$1')}` : '',
}));

const cities = [
  {
    id: 'beijing',
    name: '北京',
    href: '/zh-tw/posts/beijing-city-guide-for-foreigners/',
    desc: '適合喜歡歷史古蹟、胡同風情、長城，以及第一次造訪必看景點的旅客。',
    days: '4 到 5 天',
    bestSeason: '9 月到 10 月',
    difficulty: '中等',
    whyGo: '能深入感受帝王歷史與博物館文化，前往長城也最方便。',
    next: '/zh-tw/posts/beijing-daxing-airport-to-city-center-a-first-timer-s-guide/',
    nextLabel: '大興機場進城指南',
  },
  {
    id: 'shanghai',
    name: '上海',
    href: '/zh-tw/posts/shanghai-city-guide-for-foreigners/',
    desc: '適合想要交通便利、國際美食選擇多、天際線散步舒適，且地鐵系統完善的旅客。',
    days: '3 到 4 天',
    bestSeason: '3 月到 5 月、10 月到 11 月',
    difficulty: '容易',
    whyGo: '地鐵、機場、美食與英語友善服務都很完整，作為第一站最省力。',
    next: '/zh-tw/posts/shanghai-metro-for-foreigners-tickets-qr-codes-transfers/',
    nextLabel: '上海地鐵搭乘指南',
  },
  {
    id: 'chengdu',
    name: '成都',
    href: '/zh-tw/posts/chengdu-city-guide-for-foreigners/',
    desc: '適合愛吃川菜、喜歡茶館慢生活、想看熊貓，也偏好步調沒那麼快的大城市旅客。',
    days: '3 到 5 天',
    bestSeason: '3 月到 6 月、9 月到 11 月',
    difficulty: '中等',
    whyGo: '有熊貓、川菜與茶館文化，花費相對親民，也方便延伸到中國西部。',
    next: '/zh-tw/posts/chengdu-street-food-safety-spice-levels-what-to-order/',
    nextLabel: '成都街頭美食指南',
  },
  {
    id: 'xian',
    name: '西安',
    href: '/zh-tw/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/',
    desc: '適合想看古代歷史、兵馬俑、古城牆，親身感受中華文化底蘊的旅客。',
    days: '3 到 4 天',
    bestSeason: '3 月到 5 月、9 月到 11 月',
    difficulty: '中等',
    whyGo: '兵馬俑、古城牆與回民街美食都很有代表性，歷史氛圍也特別濃厚。',
    next: '/zh-tw/posts/china-high-speed-rail-guide-foreigners/',
    nextLabel: '前往西安的高鐵指南',
  },
  {
    id: 'guangzhou',
    name: '廣州',
    href: '/zh-tw/posts/airport-to-city-transport-beijing-shanghai-guangzhou/',
    desc: '適合想吃粵菜、感受商業城市活力、從華南進出，或順遊香港的旅客。',
    days: '3 到 4 天',
    bestSeason: '10 月到 12 月、3 月到 4 月',
    difficulty: '中等',
    whyGo: '可吃到道地粵式點心，也能安排陳家祠與廣州塔，氣候通常比北京和上海溫暖。',
    next: '/zh-tw/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    nextLabel: '粵菜點餐指南',
  },
  {
    id: 'chongqing',
    name: '重慶',
    href: '/zh-tw/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    desc: '適合愛吃麻辣火鍋、喜歡未來感夜景、山城地形與長江遊船的旅客。',
    days: '3 到 4 天',
    bestSeason: '3 月到 5 月、9 月到 11 月',
    difficulty: '較難',
    whyGo: '有重慶火鍋、洪崖洞、夜景、長江索道，以及辨識度很高的立體城市景觀。',
    next: '/zh-tw/food/',
    nextLabel: '重慶美食指南',
  },
  {
    id: 'hangzhou',
    name: '杭州',
    href: '/zh-tw/posts/hangzhou-city-guide-for-foreigners/',
    desc: '適合想看西湖、親近綠意風景、享受週末節奏，來一趟精緻短旅行的旅客。',
    days: '2 到 3 天',
    bestSeason: '3 月到 5 月、9 月到 11 月',
    difficulty: '容易到中等',
    whyGo: '西湖、茶村與寺廟都很值得安排，也很適合從上海搭高鐵順遊。',
    next: '/zh-tw/transport/',
    nextLabel: '規劃火車與市區交通',
  },
  {
    id: 'sanya',
    name: '三亞',
    href: '/zh-tw/posts/sanya-city-guide-for-foreigners/',
    desc: '適合冬天想避寒、住度假村、放空看海，或安排海南延伸行程的旅客。',
    days: '3 到 7 天',
    bestSeason: '11 月到 4 月',
    difficulty: '中等',
    whyGo: '能享受中國少見的海灘度假感、冬日陽光、海鮮與度假村生活，適合停留久一點。',
    next: '/zh-tw/posts/what-to-pack-for-china-a-season-by-season-checklist/',
    nextLabel: '各季節行李打包指南',
  },
  {
    id: 'nanjing',
    name: '南京',
    href: '/zh-tw/posts/nanjing-city-guide-for-foreigners/',
    desc: '適合想感受明代歷史、秦淮河夜景，以及悠閒文化氛圍的旅客。',
    days: '2 到 3 天',
    bestSeason: '3 月到 5 月、9 月到 11 月',
    difficulty: '容易到中等',
    whyGo: '明孝陵、中山陵、夫子廟秦淮河，歷史氣息濃厚，步調比上海從容。',
    next: '/zh-tw/posts/china-high-speed-rail-guide-foreigners/',
    nextLabel: '前往南京的高鐵指南',
  },
  {
    id: 'guilin',
    name: '桂林',
    href: '/zh-tw/posts/guilin-city-guide-for-foreigners/',
    desc: '適合想看喀斯特山水、灕江遊船、陽朔田園風光與戶外活動的旅客。',
    days: '3 到 4 天',
    bestSeason: '3 月到 10 月',
    difficulty: '中等',
    whyGo: '灕江、陽朔、龍脊梯田、蘆笛岩，擁有中國最美的山水景觀。',
    next: '/zh-tw/posts/china-high-speed-rail-guide-foreigners/',
    nextLabel: '前往桂林的高鐵指南',
  },
];

const routes = [
  {
    name: '第一次中國旅行，8 到 10 天',
    plan: '上海 3 天、杭州 2 天、北京 4 天',
    fit: '兼顧入境便利、經典風景與歷史重點，整體最平衡。',
  },
  {
    name: '美食與慢步調之旅，7 到 9 天',
    plan: '成都 4 天、北京或上海 3 到 4 天',
    fit: '適合想看熊貓、泡茶館、吃火鍋，同時搭配一座主要門戶城市的旅客。',
  },
  {
    name: '冬季避寒之旅，6 到 10 天',
    plan: '三亞 4 到 6 天、上海 2 到 3 天',
    fit: '如果中國北方太冷，想安排海灘加城市的簡單組合，這條路線很合適。',
  },
  {
    name: '南方發現之旅，10 到 12 天',
    plan: '廣州 3 天、桂林 3 天、上海 4 天',
    fit: '適合喜愛美食、山水風景與輕鬆步調，一路感受南方魅力的旅客。',
  },
  {
    name: '千年古都之旅，10 到 12 天',
    plan: '北京 4 天、西安 3 天、南京 2 天、上海 3 天',
    fit: '沿高鐵串聯中國歷代皇都，適合對歷史文化感興趣的深度旅客。',
  },
];

const faqItems = [
  {
    question: '第一次去中國，哪座城市最適合外籍旅客？',
    answer:
      '多數情況下，上海會是最容易上手的第一站，因為機場、地鐵標示、飯店、餐廳和整體國際化服務都對外籍旅客相對友善。北京也不難安排，但通常更需要提早預約，行程動線也要規劃得更仔細。',
  },
  {
    question: '第一次去中國，一趟行程安排幾個城市最剛好？',
    answer:
      '如果是第一次去、總天數約 8 到 10 天，安排兩到三個城市通常最剛好。中國幅員遼闊，機場往返、火車站進出、安檢和換飯店都可能比預期花更多時間。建議選一座門戶城市、一個文化或風景重點，再加一個可有可無的延伸點就夠了。',
  },
  {
    question: '哪一座城市最適合在中國長住？',
    answer:
      '如果重視生活機能與英語友善度，上海通常最適合當長住基地；如果在意生活成本和較悠閒的節奏，成都更有吸引力；杭州則是在自然風景與成熟科技產業之間取得不錯平衡。三亞比較適合冬季短住，不太像全年型城市生活基地。',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
import { getCategoryLabel } from '../../../i18n/categories';
const locale = 'zh-tw';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="zh-TW">
  <Header locale="zh-TW" />
  <main class="container-page py-10">
    <header>
      <p class="section-kicker">城市規劃</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="city-shanghai" alt="黃昏時分的上海天際線與外灘景色，象徵中國城市旅行" loading="eager" />

    <ChinaMap cities={mapCities} />

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3" aria-labelledby="city-shortcuts">
      <h2 id="city-shortcuts" class="sr-only">城市快速導覽</h2>
      {cities.map((city) => (
        <article class="card scroll-mt-20" id={city.id}>
          <h3 class="text-xl font-bold text-gray-950">{city.name}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{city.desc}</p>
          <dl class="mt-4 grid gap-2 text-sm text-gray-700">
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">建議停留天數</dt>
              <dd class="text-right">{city.days}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">最佳旅遊季節</dt>
              <dd class="text-right">{city.bestSeason}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">旅客友善程度</dt>
              <dd class="text-right">{city.difficulty}</dd>
            </div>
          </dl>
          <div class="mt-5 grid gap-2 text-sm font-semibold">
            <a href={city.href} class="text-brand-700 hover:text-brand-800">查看城市指南</a>
            <a href={city.next} class="text-gray-700 hover:text-brand-700">{city.nextLabel}</a>
          </div>
        </article>
      ))}
    </section>

    <section class="mt-12" aria-labelledby="compare-cities">
      <div class="section-heading">
        <div>
          <p class="section-kicker">城市比較</p>
          <h2 id="compare-cities">該先選哪一座中國城市？</h2>
        </div>
      </div>
      <div class="mt-6 overflow-hidden rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
          <thead class="bg-gray-50 text-xs font-semibold uppercase tracking-wide text-gray-600">
            <tr>
              <th class="px-4 py-3">城市</th>
              <th class="px-4 py-3">推薦理由</th>
              <th class="px-4 py-3">建議停留</th>
              <th class="px-4 py-3">最佳季節</th>
              <th class="px-4 py-3">難易度</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {cities.map((city) => (
              <tr>
                <th class="px-4 py-4 font-bold text-gray-950">
                  <a href={city.href} class="text-brand-700 hover:text-brand-800">{city.name}</a>
                </th>
                <td class="px-4 py-4 leading-6 text-gray-700">{city.whyGo}</td>
                <td class="px-4 py-4 text-gray-700">{city.days}</td>
                <td class="px-4 py-4 text-gray-700">{city.bestSeason}</td>
                <td class="px-4 py-4 text-gray-700">{city.difficulty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-12 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]" aria-labelledby="route-ideas">
      <div>
        <p class="section-kicker">路線規劃</p>
        <h2 id="route-ideas" class="mt-2 text-3xl font-bold text-gray-950">實用的城市搭配方式</h2>
        <p class="mt-3 leading-7 text-gray-600">
          好安排的中國行程，通常會讓每座城市各自扮演不同角色。上海適合當作方便進出的第一站，北京主打歷史，杭州偏重風景，成都適合美食與延伸到中國西部，
          三亞則是溫暖放鬆的度假選擇。若天數不多，盡量不要塞進太多航班或頻繁轉車。
        </p>
      </div>
      <div class="grid gap-4">
        {routes.map((route) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-lg font-bold text-gray-950">{route.name}</h3>
            <p class="mt-2 font-semibold text-brand-700">{route.plan}</p>
            <p class="mt-2 text-sm leading-6 text-gray-600">{route.fit}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">所有城市相關指南</p>
            <h2>城市文章與當地交通資訊</h2>
          </div>
        </div>
        <div class="mt-6 grid gap-5 md:grid-cols-2">
          {cityPosts.map((post) => (
            <a href={`/zh-tw/posts/${post.slug}/`} class="card block hover:no-underline">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
              <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <p class="section-kicker">選城市前先確認</p>
        <h2 class="mt-1 text-xl font-bold text-gray-950">先把行程後勤準備好</h2>
        <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
          <li><a href="/zh-tw/payment/" class="font-semibold text-brand-700">付款：</a>如果要去較小的城市，先把 Alipay、WeChat Pay 設定好，也準備一點現金備用。</li>
          <li><a href="/zh-tw/esim/" class="font-semibold text-brand-700">網路：</a>在大量依賴地圖和翻譯之前，先決定要用 eSIM、漫遊還是本地 SIM。</li>
          <li><a href="/zh-tw/transport/" class="font-semibold text-brand-700">交通：</a>比較火車、機場接送、DiDi 與地鐵 QR 碼，看看哪個最適合你的路線。</li>
          <li><a href="/zh-tw/tools/best-time-to-visit/" class="font-semibold text-brand-700">時機：</a>用月份查看天氣、假期和人潮壓力，再決定出發時間。</li>
        </ul>
      </aside>
    </section>

    <section class="mt-12" aria-labelledby="city-faq">
      <div class="section-heading">
        <div>
          <p class="section-kicker">城市常見問題</p>
          <h2 id="city-faq">中國城市規劃常見問答</h2>
        </div>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {faqItems.map((item) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-base font-bold text-gray-950">{item.question}</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">{item.answer}</p>
          </article>
        ))}
      </div>
    </section>

    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  </main>
  <Footer />
</BaseLayout>