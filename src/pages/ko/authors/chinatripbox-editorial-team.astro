---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'ChinaTripBox 편집팀';
const description =
  'ChinaTripBox 편집팀 소개, 실용적인 중국 여행 가이드를 조사하는 방식, 그리고 독자가 정정을 요청하는 방법을 안내합니다.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': new URL('/authors/chinatripbox-editorial-team/#person', Astro.site).toString(),
  name: title,
  url: new URL('/authors/chinatripbox-editorial-team/', Astro.site).toString(),
  affiliation: {
    '@type': 'Organization',
    name: 'ChinaTripBox',
    url: new URL('/', Astro.site).toString(),
  },
  knowsAbout: [
    '중국 여행 계획',
    '중국 내 모바일 결제',
    '중국 eSIM 및 인터넷 접속',
    '중국 고속철도',
    '중국 내 외국인 방문객 이동 및 이용 정보',
  ],
};
---
<!-- AI 지원으로 생성된 콘텐츠, 원어민 검토 완료 -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-12">
    <article class="prose-content article-body">
      <p class="section-kicker">저자</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-900">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>

      <h2>편집 중점 분야</h2>
      <p>
        ChinaTripBox 편집팀은 중국을 방문하는 외국인 여행자를 위한 실용적인 가이드를 작성하며,
        결제 설정, eSIM 및 인터넷 접속, 고속철도, 차량 호출, 공항 이동, 도시 일정 계획, 음식 주문,
        그리고 첫 여행에서 흔히 겪는 문제에 중점을 둡니다.
      </p>

      <h2>가이드를 만드는 방법</h2>
      <p>
        저희는 공식 출처, 서비스 제공업체 문서, 앱 도움말 자료, 독자 질문, 여행자 후기,
        그리고 가능한 경우 직접 확인한 내용을 종합합니다. 무비자 입국, 결제 한도, 앱 이용 가능 여부,
        교통 규정처럼 빠르게 바뀌는 주제의 경우에는 공식 정부 페이지나 서비스 제공업체 페이지를
        최종 기준 정보로 삼습니다.
      </p>

      <h2>정정</h2>
      <p>
        중국 여행 관련 실무 정보는 빠르게 바뀝니다. 오래된 단계, 변경된 정책, 깨진 링크,
        또는 빠진 주의사항을 발견하셨다면 <a href="/contact/">문의 페이지</a>를 통해 해당 페이지 URL을 보내 주세요.
        근거가 명확한 경우, 저희는 정정 내용을 검토하고 영향을 받는 가이드를 업데이트합니다.
      </p>

      <h2>편집 정책</h2>
      <p>
        조사 방식, 업데이트, 제휴 고지, 독립성, 그리고 한계에 관한 자세한 내용은
        <a href="/editorial-policy/">편집 정책</a>을 확인해 주세요.
      </p>

      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    </article>
  </main>
  <Footer />
</BaseLayout>