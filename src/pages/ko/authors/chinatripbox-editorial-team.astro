---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const title = 'ChinaTripBox 에디토리얼 팀';
const description =
  'ChinaTripBox 에디토리얼 팀이 어떤 주제를 다루고, 어떤 방식으로 중국 여행 가이드를 조사하고 업데이트하는지 소개합니다.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': new URL('/authors/chinatripbox-editorial-team/#person', Astro.site).toString(),
  name: title,
  url: new URL('/authors/chinatripbox-editorial-team/', Astro.site).toString(),
  affiliation: {
    '@type': 'Organization',
    name: 'ChinaTripBox',
    url: new URL('/', Astro.site).toString(),
  },
  knowsAbout: [
    '중국 여행 준비',
    '중국 모바일 결제',
    '중국 eSIM 및 인터넷 연결',
    '중국 고속철도',
    '중국 방문객 실무 정보',
  ],
};
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-12">
    <article class="prose-content article-body">
      <p class="section-kicker">작성자</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-900">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>

      <h2>편집 초점</h2>
      <p>
        ChinaTripBox 에디토리얼 팀은 중국을 방문하는 해외 여행자를 위한 실전 가이드를
        작성합니다. 결제 설정, eSIM과 인터넷, 고속철도, 호출 차량, 공항 이동, 도시별 준비,
        음식 주문, 첫 여행에서 자주 생기는 문제를 핵심 주제로 다룹니다.
      </p>

      <h2>가이드를 만드는 방식</h2>
      <p>
        공식 출처, 서비스 제공업체 문서, 앱 도움말, 독자 질문, 여행자 경험, 실제 사용
        흐름 검토를 함께 참고합니다. 무비자 입국, 결제 한도, 앱 사용 가능성, 교통 규정처럼
        빠르게 바뀌는 주제는 정부나 서비스 제공업체의 공식 페이지를 최종 기준으로 봅니다.
      </p>

      <h2>정정 요청</h2>
      <p>
        중국 여행 실무 정보는 자주 바뀝니다. 오래된 단계, 바뀐 정책, 깨진 링크, 빠진
        주의사항을 발견했다면 <a href="/ko/contact/">문의 페이지</a>를 통해 페이지 URL과
        함께 알려 주세요. 근거가 명확하면 관련 가이드를 업데이트합니다.
      </p>

      <h2>편집 정책</h2>
      <p>
        조사 방식, 업데이트 기준, 제휴 고지, 독립성, 한계에 대한 자세한 내용은
        <a href="/ko/editorial-policy/">편집 정책</a>에서 확인할 수 있습니다.
      </p>

      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    </article>
  </main>
  <Footer />
</BaseLayout>
