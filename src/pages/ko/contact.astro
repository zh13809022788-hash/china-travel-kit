---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'Contact Us';
const description =
  'Get in touch with the ChinaTripBox team with questions, corrections, or partnership enquiries.';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-12">
    <article class="prose-content article-body">
      <h1 class="text-3xl font-bold text-gray-900">Contact Us</h1>
      <p class="mt-4">
        We'd love to hear from you. Whether you found an error in a guide, have a question about
        traveling in China, or want to discuss a partnership, use the details below.
      </p>

      <h2>Email</h2>
      <p>
        General enquiries and corrections:
        <a href="mailto:zh13809022788@gmail.com">zh13809022788@gmail.com</a>
      </p>
      <p>
        Partnerships and advertising:
        <a href="mailto:zh13809022788@gmail.com">zh13809022788@gmail.com</a>
      </p>

      <h2>Response Time</h2>
      <p>
        We aim to reply to all messages within 3-5 business days. For time-sensitive travel
        questions, please check our guides first. The answer may already be there.
      </p>

      <h2>Corrections</h2>
      <p>
        Apps, prices, and regulations in China change frequently. If you notice something that no
        longer matches your experience, let us know and we'll verify and update the guide.
      </p>

      <h2>What to Include</h2>
      <p>
        If you are reporting an issue, please include the page URL, the city or service involved,
        and the date when you noticed the problem. This helps us verify the information quickly.
      </p>

      <h2>Important Note</h2>
      <p>
        ChinaTripBox provides general travel information only. We cannot provide legal, immigration,
        banking, medical, or emergency advice. For official requirements, always confirm with the
        relevant government office, airline, bank, telecom provider, or service operator.
      </p>
    </article>
  </main>
  <Footer />
</BaseLayout>
