---
import { getCollection } from 'astro:content';
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import AdSlot from "../../../components/AdSlot.astro";

const seriesSlug = 'history-of-china';
const posts = (await getCollection('posts'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = '중국의 역사 - 여행자를 위한 고대 유적과 이야기';
const description = '외국인 여행자의 시선으로 중국의 역사 유적을 탐험해 보세요: 만리장성, 병마용, 자금성, 실크로드, 고대 수도들, 수향 마을까지 - 눈앞의 풍경 뒤에 숨은 이야기를 알기 쉽게 풀어드립니다.';

const relatedTools = [
  { href: '/posts/china-visa-free-entry-transit-guide-2026/', title: '비자 및 입국 가이드', desc: '무비자 환승 및 입국 요건' },
  { href: '/posts/china-high-speed-rail-guide-foreigners/', title: '고속철도 가이드', desc: '중국 전역의 역사 유적지로 가는 열차' },
  { href: '/posts/book-china-train-tickets-12306-foreigners/', title: '기차표 예약', desc: '외국 여권 소지자를 위한 12306 가이드' },
];

const relatedCities = [
  { href: '/posts/beijing-city-guide-for-foreigners/', title: 'Beijing', desc: '자금성, 만리장성, 천단' },
  { href: '/posts/hangzhou-city-guide-for-foreigners/', title: 'Hangzhou', desc: '남송의 고도' },
  { href: '/posts/chengdu-city-guide-for-foreigners/', title: 'Chengdu', desc: '삼국지 유산과 오래된 거리' },
];

const otherSeries = [
  { href: '/series/food-of-china/', title: '중국의 음식' },
  { href: '/series/culture-of-china/', title: '중국의 문화' },
  { href: '/series/nature-of-china/', title: '중국의 자연' },
];
import { getCategoryLabel } from "../../../i18n/categories";
const locale = 'en';
---
<!-- AI 지원으로 생성된 콘텐츠, 원어민 검토 완료 -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">콘텐츠 시리즈</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">글</p>
            <h2>중국의 역사 시리즈</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">이 시리즈의 글은 현재 준비 중입니다. 곧 다시 확인해 주세요.</p>
        )}
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">실용 도구</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">여행 계획 세우기</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">도시 가이드</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">역사 도시</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">다른 시리즈</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>