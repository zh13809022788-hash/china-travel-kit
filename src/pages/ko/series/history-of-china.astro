---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';

const seriesSlug = 'history-of-china';
const posts = (await getCollection('posts-ko'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = '중국의 역사 시리즈';
const description = '만리장성, 병마용, 자금성, 실크로드, 고도 같은 장소를 여행자가 실제로 보는 관점에서 쉽게 설명하는 역사 시리즈입니다.';

const relatedTools = [
  { href: '/ko/posts/china-visa-free-entry-transit-guide-2026/', title: '비자·입국 가이드', desc: '무비자 입국과 환승 규정 확인' },
  { href: '/ko/posts/china-high-speed-rail-guide-foreigners/', title: '고속철도 가이드', desc: '역사 도시를 오갈 때 필요한 열차 이동 정보' },
  { href: '/ko/posts/book-china-train-tickets-12306-foreigners/', title: '열차표 예매 방법', desc: '해외 여권 소지자를 위한 12306 사용법' },
];

const relatedCities = [
  { href: '/ko/posts/beijing-city-guide-for-foreigners/', title: '베이징', desc: '자금성, 만리장성, 천단이 있는 도시' },
  { href: '/ko/posts/hangzhou-city-guide-for-foreigners/', title: '항저우', desc: '남송의 옛 수도' },
  { href: '/ko/posts/chengdu-city-guide-for-foreigners/', title: '청두', desc: '삼국지 유산과 오래된 거리' },
];

const otherSeries = [
  { href: '/ko/series/food-of-china/', title: '중국의 음식' },
  { href: '/ko/series/culture-of-china/', title: '중국의 문화' },
  { href: '/ko/series/nature-of-china/', title: '중국의 자연' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">콘텐츠 시리즈</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">글 목록</p>
            <h2>중국의 역사 시리즈</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/ko/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{post.data.category}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">이 시리즈의 글은 현재 준비 중입니다. 곧 다시 확인해 주세요.</p>
        )}
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">실용 가이드</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">방문 준비하기</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">도시 가이드</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">역사 도시</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">다른 시리즈</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>
