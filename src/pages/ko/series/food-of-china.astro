---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';

const seriesSlug = 'food-of-china';
const posts = (await getCollection('posts-ko'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = '중국의 음식 시리즈';
const description = '중국 여행자의 시선으로 중국 음식 문화를 풀어보는 시리즈입니다. 8대 요리, 훠궈, 길거리 음식, 아침 식사, 채식, 식당 문화까지 다룹니다.';

const relatedTools = [
  { href: '/ko/posts/ordering-food-in-china-without-chinese-meituan-ele-me/', title: '중국어 없이 음식 주문하기', desc: 'Meituan·Ele.me 설정과 주문 흐름 정리' },
  { href: '/ko/posts/how-to-pay-in-china-tourist-guide/', title: '중국 결제 가이드', desc: '식당에서 결제할 때 필요한 Alipay, WeChat Pay, 현금 정보' },
  { href: '/ko/food/', title: '음식 가이드 전체 보기', desc: 'ChinaTripBox의 음식 관련 글 모음' },
];

const relatedCities = [
  { href: '/ko/posts/chengdu-city-guide-for-foreigners/', title: '청두', desc: '쓰촨 음식의 중심지' },
  { href: '/ko/posts/beijing-city-guide-for-foreigners/', title: '베이징', desc: '베이징 카오야와 북방 요리' },
  { href: '/ko/posts/shanghai-city-guide-for-foreigners/', title: '상하이', desc: '샤오롱바오와 현대적인 식문화' },
];

const otherSeries = [
  { href: '/ko/series/history-of-china/', title: '중국의 역사' },
  { href: '/ko/series/culture-of-china/', title: '중국의 문화' },
  { href: '/ko/series/modern-china/', title: '현대 중국' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">콘텐츠 시리즈</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">글 목록</p>
            <h2>중국의 음식 시리즈</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/ko/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{post.data.category}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">이 시리즈의 글은 현재 준비 중입니다. 곧 다시 확인해 주세요.</p>
        )}
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">실용 가이드</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">중국에서 잘 먹기</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">도시별 음식 가이드</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">어디서 먹을까</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">다른 시리즈</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>
