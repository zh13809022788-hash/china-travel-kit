---

import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CoverImage from '../../../components/CoverImage.astro';
import ChinaMap from '../../../components/ChinaMap.astro';
import AdSlot from '../../../components/AdSlot.astro';

const allPosts = await getCollection('posts-ko');
const cityNames = ['beijing', 'shanghai', 'chengdu', 'hangzhou', 'sanya', 'guangzhou', 'xian', 'chongqing', 'kunming', 'nanjing'];
const cityPosts = allPosts
  .filter((post) => cityNames.some((city) => post.slug.includes(city) || post.data.tags.includes(city)))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const title = '외국인 여행자를 위한 중국 도시 가이드';
const description = '베이징, 상하이, 광저우, 청두, 시안, 항저우, 충칭, 싼야 가이드와 함께 공항, 지하철, 음식, 교통 이용 팁까지 중국 도시 여행 코스를 실용적으로 계획하세요.';

const mapCities = [
  { name: 'Beijing', x: 470, y: 80, href: '#beijing' },
  { name: 'Xi\'an', x: 340, y: 155, href: '#xian' },
  { name: 'Nanjing', x: 490, y: 180, href: '' },
  { name: 'Shanghai', x: 540, y: 200, href: '#shanghai' },
  { name: 'Chengdu', x: 250, y: 220, href: '#chengdu' },
  { name: 'Hangzhou', x: 520, y: 205, href: '#hangzhou' },
  { name: 'Chongqing', x: 310, y: 260, href: '#chongqing' },
  { name: 'Guilin', x: 370, y: 300, href: '' },
  { name: 'Kunming', x: 210, y: 335, href: '' },
  { name: 'Guangzhou', x: 400, y: 370, href: '#guangzhou' },
  { name: 'Shenzhen', x: 430, y: 390, href: '' },
  { name: 'Sanya', x: 360, y: 440, href: '#sanya' },
];

const cities = [
  {
    name: 'Beijing',
    href: '/ko/posts/beijing-city-guide-for-foreigners/',
    desc: '역사, 후통, 만리장성, 첫 방문자의 클래식 관광에 적합.',
    days: '4-5일',
    bestSeason: '9월-10월',
    difficulty: '보통',
    whyGo: '황실 역사, 박물관, 가장 접근하기 쉬운 만리장성.',
    next: '/ko/posts/beijing-daxing-airport-to-city-center-a-first-timer-s-guide/',
    nextLabel: '다싱 공항 환승 가이드',
  },
  {
    name: 'Shanghai',
    href: '/ko/posts/shanghai-city-guide-for-foreigners/',
    desc: '편안한 도착, 국제 음식, 스카이라인 산책, 뛰어난 지하철 노선에 적합.',
    days: '3-4일',
    bestSeason: '3월-5월, 10월-11월',
    difficulty: '쉬움',
    whyGo: '지하철, 공항, 음식, 영어 친화적 서비스가 가장 원활한 첫 정착지.',
    next: '/ko/posts/shanghai-metro-for-foreigners-tickets-qr-codes-transfers/',
    nextLabel: '상하이 지하철 가이드',
  },
  {
    name: 'Chengdu',
    href: '/ko/posts/chengdu-city-guide-for-foreigners/',
    desc: '쓰촨 요리, 찻집 분위기, 판다, 여유로운 대도시 템포에 적합.',
    days: '3-5일',
    bestSeason: '3월-6월, 9월-11월',
    difficulty: '보통',
    whyGo: '판다, 쓰촨 요리, 찻집, 저렴한 비용, 서부 중국 부근 여행.',
    next: '/ko/posts/chengdu-street-food-safety-spice-levels-what-to-order/',
    nextLabel: '청두 스트리트 푸드 가이드',
  },
  {
    name: 'Xi\'an',
    href: '/ko/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/',
    desc: '고대 역사, 병마용, 옛 성벽, 체험형 중국 유산에 적합.',
    days: '3-4일',
    bestSeason: '3월-5월, 9월-11월',
    difficulty: '보통',
    whyGo: '병마용, 고대 성벽, 회민가 음식거리, 그리고 중국 역사의 깊은 체험.',
    next: '/ko/posts/china-high-speed-rail-guide-foreigners/',
    nextLabel: '시안행 고속철도',
  },
  {
    name: 'Guangzhou',
    href: '/ko/posts/airport-to-city-transport-beijing-shanghai-guangzhou/',
    desc: '광둥 요리, 무역 도시 활력, 남부 관문, 홍콩 접근성에 적합.',
    days: '3-4일',
    bestSeason: '10월-12월, 3월-4월',
    difficulty: '보통',
    whyGo: '광둥식 딤섬, 진씨 서원, 광저우 타워, 베이징과 상하이를 대신하는 따뜻한 남부 여행지.',
    next: '/ko/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    nextLabel: '광둥 요리 가이드',
  },
  {
    name: 'Chongqing',
    href: '/ko/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    desc: '쓰촨 훠궈, 미래형 스카이라인, 산악 도시 지형, 양쯔강 크루즈에 적합.',
    days: '3-4일',
    bestSeason: '3월-5월, 9월-11월',
    difficulty: '어려움',
    whyGo: '충칭 훠궈, 홍야동, 야간 스카이라인, 양쯔강 케이블카, 독특한 수직 도시 구조.',
    next: '/ko/food/',
    nextLabel: '충칭 음식 가이드',
  },
  {
    name: 'Hangzhou',
    href: '/ko/posts/hangzhou-city-guide-for-foreigners/',
    desc: '서호, 푸른 풍경, 주말 여행 템포, 세련된 도시 휴식에 적합.',
    days: '2-3일',
    bestSeason: '3월-5월, 9월-11월',
    difficulty: '쉬움-보통',
    whyGo: '서호, 차 마을, 사찰, 상하이에서 고속철도로 편하게 이어지는 여행지.',
    next: '/ko/transport/',
    nextLabel: '기차와 현지 교통 계획',
  },
  {
    name: 'Sanya',
    href: '/ko/posts/sanya-city-guide-for-foreigners/',
    desc: '따뜻한 겨울 날씨, 리조트 숙박, 해변 여행, 하이난 부근 여행에 적합.',
    days: '3-7일',
    bestSeason: '11월-4월',
    difficulty: '보통',
    whyGo: '중국 해변 여행, 겨울 햇살, 해산물, 리조트, 긴 계절 체류.',
    next: '/ko/posts/what-to-pack-for-china-a-season-by-season-checklist/',
    nextLabel: '계절별 짐 챙기기 가이드',
  },
];

const routes = [
  {
    name: '첫 중국 여행, 8-10일',
    plan: '상하이 3일, 항저우 2일, 베이징 4일',
    fit: '편안한 도착, 클래식 풍경, 핵심 역사의 최적 균형.',
  },
  {
    name: '음식과 여유로운 템포, 7-9일',
    plan: '청두 4일, 베이징 또는 상하이 3-4일',
    fit: '판다, 찻집, 훠궈, 그리고 주요 관문 도시를 원하는 여행자에게 적합.',
  },
  {
    name: '겨울 휴양, 6-10일',
    plan: '싼야 4-6일, 상하이 2-3일',
    fit: '북부 중국이 추울 때 해변과 도시를 간단히 결합하고 싶을 때 최적.',
  },
];

const faqItems = [
  {
    question: '처음 중국을 방문하는 외국인 여행자에게 가장 쉬운 도시는 어디인가요?',
    answer:
      '상하이가 보통 가장 쉬운 첫 도시입니다. 공항, 지하철 표지판, 호텔, 레스토랑, 국제 서비스가 외국인에게 가장 친화적이기 때문입니다. 베이징도 여전히 관리하기 쉽지만, 더 많은 사전 예약과 더 신중한 일일 동선 계획이 필요합니다.',
  },
  {
    question: '한 번의 여행에서 몇 개의 중국 도시를 방문해야 하나요?',
    answer:
      '첫 8-10일 여행이라면 두세 개 도시면 충분합니다. 중국은 넓고, 공항 환승, 기차역, 보안 검색, 호텔 변경이 예상보다 많은 시간을 소비할 수 있습니다. 관문 도시 하나, 문화 또는 경관 명소 하나, 선택적 연장지 하나를 선택하세요.',
  },
  {
    question: '중국에서 장기 체류하기 가장 좋은 도시는 어디인가요?',
    answer:
      '상하이는 서비스와 영어 지원에서 가장 쉬운 장기 체류 거점이고, 청두는 저렴한 비용과 여유로운 생활에 강하며, 항저우는 풍경과 강한 기술 경제를 갖춘 중간 지점을 제공합니다. 싼야는 연중 도시 생활보다는 겨울 체류에 적합합니다.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---


<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ko">
  <Header locale="ko" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">도시 계획</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="city-shanghai" alt="황혼의 상하이 스카이라인과 와이탄, 중국 도시 여행을 상징하는 풍경" loading="eager" />

    <ChinaMap cities={mapCities} />

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3" aria-labelledby="city-shortcuts">
      <h2 id="city-shortcuts" class="sr-only">도시 바로가기</h2>
      {cities.map((city) => (
        <article class="card" id={city.name.toLowerCase().replace(/[^a-z]/g, '')}>
          <h3 class="text-xl font-bold text-gray-950">{city.name}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{city.desc}</p>
          <dl class="mt-4 grid gap-2 text-sm text-gray-700">
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">권장 체류일</dt>
              <dd class="text-right">{city.days}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">최적의 계절</dt>
              <dd class="text-right">{city.bestSeason}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">방문자 편의도</dt>
              <dd class="text-right">{city.difficulty}</dd>
            </div>
          </dl>
          <div class="mt-5 grid gap-2 text-sm font-semibold">
            <a href={city.href} class="text-brand-700 hover:text-brand-800">도시 가이드 열기</a>
            <a href={city.next} class="text-gray-700 hover:text-brand-700">{city.nextLabel}</a>
          </div>
        </article>
      ))}
    </section>

    <section class="mt-12" aria-labelledby="compare-cities">
      <div class="section-heading">
        <div>
          <p class="section-kicker">도시 비교</p>
          <h2 id="compare-cities">어느 중국 도시를 선택해야 할까요?</h2>
        </div>
      </div>
      <div class="mt-6 overflow-hidden rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
          <thead class="bg-gray-50 text-xs font-semibold uppercase tracking-wide text-gray-600">
            <tr>
              <th class="px-4 py-3">도시</th>
              <th class="px-4 py-3">방문 이유</th>
              <th class="px-4 py-3">권장 체류일</th>
              <th class="px-4 py-3">최적의 계절</th>
              <th class="px-4 py-3">편의도</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {cities.map((city) => (
              <tr>
                <th class="px-4 py-4 font-bold text-gray-950">
                  <a href={city.href} class="text-brand-700 hover:text-brand-800">{city.name}</a>
                </th>
                <td class="px-4 py-4 leading-6 text-gray-700">{city.whyGo}</td>
                <td class="px-4 py-4 text-gray-700">{city.days}</td>
                <td class="px-4 py-4 text-gray-700">{city.bestSeason}</td>
                <td class="px-4 py-4 text-gray-700">{city.difficulty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-12 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]" aria-labelledby="route-ideas">
      <div>
        <p class="section-kicker">동선 계획</p>
        <h2 id="route-ideas" class="mt-2 text-3xl font-bold text-gray-950">실용적인 도시 조합</h2>
        <p class="mt-3 leading-7 text-gray-600">
          성공적인 중국 여행 일정은 보통 도시마다 서로 다른 역할을 부여할 때 더 잘 작동합니다. 상하이를 편안한 도착 지점으로, 베이징은 역사, 항저우는 풍경, 청두는 음식과 서부 중국 접근, 싼야는 따뜻한 휴식으로 활용하세요. 짧은 여행에 너무 많은 항공편이나 기차역 환승을 추가하는 것은 피하세요.
        </p>
      </div>
      <div class="grid gap-4">
        {routes.map((route) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-lg font-bold text-gray-950">{route.name}</h3>
            <p class="mt-2 font-semibold text-brand-700">{route.plan}</p>
            <p class="mt-2 text-sm leading-6 text-gray-600">{route.fit}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">모든 도시 관련 가이드</p>
            <h2>도시 관련 글과 현지 교통</h2>
          </div>
        </div>
        <div class="mt-6 grid gap-5 md:grid-cols-2">
          {cityPosts.map((post) => (
            <a href={`/ko/posts/${post.slug}/`} class="card block hover:no-underline">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{post.data.category}</span>
              <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <p class="section-kicker">도시 선택 전 확인</p>
        <h2 class="mt-1 text-xl font-bold text-gray-950">물류 환경 확인</h2>
        <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
          <li><a href="/ko/payment/" class="font-semibold text-brand-700">결제:</a> 소도시 여행 전 Alipay, WeChat Pay, 현금 대비를 설정하세요.</li>
          <li><a href="/ko/esim/" class="font-semibold text-brand-700">인터넷:</a> 지도와 번역에 의존하기 전에 eSIM, 로밍 또는 현지 SIM을 선택하세요.</li>
          <li><a href="/ko/transport/" class="font-semibold text-brand-700">교통:</a> 기차, 공항 환승, DiDi, 지하철 QR 코드를 비교하세요.</li>
          <li><a href="/ko/tools/best-time-to-visit/" class="font-semibold text-brand-700">시기:</a> 월별 날씨, 공휴일, 인파 압력을 확인하세요.</li>
        </ul>
      </aside>
    </section>

    <section class="mt-12" aria-labelledby="city-faq">
      <div class="section-heading">
        <div>
          <p class="section-kicker">도시 FAQ</p>
          <h2 id="city-faq">중국 도시 계획 자주 묻는 질문</h2>
        </div>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {faqItems.map((item) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-base font-bold text-gray-950">{item.question}</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">{item.answer}</p>
          </article>
        ))}
      </div>
    </section>

    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  </main>
  <Footer />
</BaseLayout>
