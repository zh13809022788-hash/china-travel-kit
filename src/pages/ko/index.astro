---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import { Image } from 'astro:assets';
import heroImage from '../../assets/images/city-shanghai.jpg';

const posts = await getCollection('posts-ko');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categoryLabels: Record<string, string> = {
  payment: '결제',
  esim: 'eSIM',
  transport: '교통',
  essentials: '여행 준비',
  food: '음식',
};
---

<BaseLayout
  title="ChinaTripBox 한국어 가이드 | 중국 여행 결제·eSIM·교통 준비"
  description="중국 여행 전에 꼭 알아야 할 실전 가이드를 한국어로 정리했습니다. Alipay, WeChat Pay, eSIM, 고속철도, DiDi, 첫날 체크리스트까지 한 번에 준비하세요."
  locale="ko"
  alternates={{ en: '/', 'zh-TW': '/zh-tw/', ja: '/ja/', ko: '/ko/', ru: '/ru/', fr: '/fr/', de: '/de/', es: '/es/' }}
>
  <Header locale="ko" />
  <main>
    <section class="border-b border-gray-200 bg-gray-50">
      <div class="container-page grid gap-8 py-12 lg:grid-cols-[1fr_360px] lg:items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-wide text-brand-700">ChinaTripBox 한국어</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            중국 여행 전에 필요한 결제·통신·교통 정보를 한곳에서 정리하세요
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            처음 중국을 가는 여행자도 바로 이해할 수 있도록 핵심 준비만 추려서 설명합니다.
            Alipay, WeChat Pay, eSIM, 고속철도, DiDi 같은 실전 정보를 빠르게 확인해 보세요.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/ko/posts/how-to-pay-in-china-tourist-guide/" class="btn-primary">결제 가이드부터 보기</a>
            <a href="/ko/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-outline">출발 전 체크리스트</a>
          </div>
        </div>

        <aside class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
          <Image
            src={heroImage}
            alt="중국 여행 준비에 참고할 수 있는 상하이 도시 풍경"
            widths={[360, 720]}
            sizes="(max-width: 1024px) 100vw, 360px"
            quality={65}
            loading="eager"
            class="h-52 w-full object-cover"
          />
          <div class="p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">여행 전 빠른 시작</p>
            <h2 class="mt-2 text-lg font-bold text-gray-950">무엇부터 준비해야 하는지 헷갈릴 때</h2>
            <p class="mt-2 text-sm leading-6 text-gray-600">
              결제, 통신, 교통, 필수 앱, 공항 도착 직후 동선까지 우선순위에 맞춰 필요한 정보를
              차례대로 확인할 수 있습니다.
            </p>
          </div>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <AdSlot format="banner" />

      <section class="py-8">
        <div class="section-heading">
          <div>
            <p class="section-kicker">최신 한국어 가이드</p>
            <h2>중국 여행 실전 글 모음</h2>
          </div>
          <a href="/" class="text-sm font-semibold text-brand-700 hover:text-brand-800">전체 보기</a>
        </div>

        <div class="mt-6 divide-y divide-gray-200 rounded-lg border border-gray-200 bg-white">
          {sortedPosts.map((post) => (
            <a href={`/ko/posts/${post.slug}/`} class="group block p-5 hover:bg-gray-50 hover:no-underline">
              <div class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-wide text-brand-700">
                <span>{categoryLabels[post.data.category] ?? post.data.category}</span>
                <span class="text-gray-300">/</span>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </div>
              <h3 class="mt-2 text-lg font-bold text-gray-950 group-hover:text-brand-700">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>

      <AdSlot format="banner" />
    </div>
  </main>
  <Footer />
</BaseLayout>
