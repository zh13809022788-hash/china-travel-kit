---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';

const seriesSlug = 'modern-china';
const posts = (await getCollection('posts'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Modernes China — Was Ausländer am meisten überrascht';
const description = 'Entdecke das moderne China als ausländischer Reisender: bargeldlose Gesellschaft, die schnellsten Züge der Welt, Orientierung in Megastädten, Super-Apps, Nachtzüge und die Technologie, die den Alltag prägt.';

const relatedTools = [
  { href: '/posts/how-to-pay-in-china-tourist-guide/', title: 'Wie man in China bezahlt', desc: 'Einrichtung mobiler Zahlungen für Touristen' },
  { href: '/posts/china-high-speed-rail-guide-foreigners/', title: 'Leitfaden für Hochgeschwindigkeitszüge', desc: 'Mit Chinas Hochgeschwindigkeitszügen fahren' },
  { href: '/posts/best-esim-for-china-travel-2026/', title: 'Beste eSIM für China', desc: 'Bei der Ankunft verbunden bleiben' },
];

const relatedCities = [
  { href: '/posts/shanghai-city-guide-for-foreigners/', title: 'Shanghai', desc: 'Chinas Finanz-Megastadt' },
  { href: '/posts/beijing-city-guide-for-foreigners/', title: 'Beijing', desc: 'Alte Hauptstadt trifft auf modernes Zentrum' },
  { href: '/posts/shanghai-metro-for-foreigners-tickets-qr-codes-transfers/', title: 'Shanghai Metro', desc: 'Sich in einem riesigen Verkehrssystem zurechtfinden' },
];

const otherSeries = [
  { href: '/series/food-of-china/', title: 'Essen in China' },
  { href: '/series/history-of-china/', title: 'Geschichte Chinas' },
  { href: '/series/culture-of-china/', title: 'Kultur Chinas' },
];
import { getCategoryLabel } from '../../i18n/categories';
const locale = 'en';
---
<!-- KI-unterstutzt erstellter Inhalt, von muttersprachlichem Redakteur gepruft -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Inhaltsreihe</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Artikel</p>
            <h2>Reihe „Modernes China“</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">Die Artikel in dieser Reihe werden gerade vorbereitet. Schau bald wieder vorbei.</p>
        )}
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Praktische Tools</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Modernes China navigieren</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Stadtführer</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Megastädte</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Weitere Reihen</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>