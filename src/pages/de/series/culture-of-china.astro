---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';

const seriesSlug = 'culture-of-china';
const posts = (await getCollection('posts'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Kultur Chinas — Traditionen & Bräuche für Reisende';
const description = 'Entdecke die chinesische Kultur als ausländischer Reisender: Teezeremonie, Frühlingsfest, Gesicht und Guanxi, Kalligrafie, Kung Fu, der Tierkreis und die Traditionen, die das tägliche Leben in China prägen.';

const relatedTools = [
  { href: '/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/', title: 'Trinkgeld & Etikette', desc: 'Wann man Trinkgeld gibt, wann nicht und warum' },
  { href: '/posts/what-to-pack-for-china-a-season-by-season-checklist/', title: 'Packen für Festivals', desc: 'Was man während der Feiertagssaison mitbringen sollte' },
  { href: '/posts/how-to-pay-in-china-tourist-guide/', title: 'Wie man in China bezahlt', desc: 'Zahlungen während der Festtagssaison' },
];

const relatedCities = [
  { href: '/posts/beijing-city-guide-for-foreigners/', title: 'Beijing', desc: 'Imperiale Kultur und Hutong-Leben' },
  { href: '/posts/hangzhou-city-guide-for-foreigners/', title: 'Hangzhou', desc: 'Teekultur und das Erbe des West Lake' },
  { href: '/posts/chengdu-city-guide-for-foreigners/', title: 'Chengdu', desc: 'Teestubenkultur und entschleunigtes Leben' },
];

const otherSeries = [
  { href: '/series/food-of-china/', title: 'Essen in China' },
  { href: '/series/history-of-china/', title: 'Geschichte Chinas' },
  { href: '/series/modern-china/', title: 'Modernes China' },
];
import { getCategoryLabel } from '../../i18n/categories';
const locale = 'en';
---
<!-- KI-unterstutzt erstellter Inhalt, von muttersprachlichem Redakteur gepruft -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Inhaltsreihe</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Artikel</p>
            <h2>Kultur Chinas Reihe</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">Artikel in dieser Reihe werden gerade vorbereitet. Schau bald wieder vorbei.</p>
        )}
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Praktische Hilfen</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Mit kulturellem Bewusstsein reisen</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Stadtführer</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Kulturelle Städte</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Weitere Reihen</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>