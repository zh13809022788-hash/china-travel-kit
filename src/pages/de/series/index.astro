---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";

const title = 'Inhaltsreihe über China-Reisen';
const description = 'Entdecke China in fünf thematischen Reihen: Essen, Geschichte, modernes Leben, Natur und Kultur — jeweils darauf ausgelegt, ausländische Reisende zu inspirieren und zu informieren.';

const seriesList = [
  {
    href: '/series/food-of-china/',
    title: 'Essen in China',
    desc: 'Von Straßenständen bis zu Bankettsälen — die kulinarische Reise eines Ausländers durch die acht großen Küchen, regionale Frühstücke, Hotpot-Stile und die Gerichte, für die es sich lohnt, eine Stadt zu durchqueren.',
    icon: 'Essen & Trinken',
  },
  {
    href: '/series/history-of-china/',
    title: 'Geschichte Chinas',
    desc: 'Antike Stätten für Reisende entschlüsselt — die Große Mauer, die Terrakotta-Armee, die Verbotene Stadt, die Seidenstraße und die Geschichten hinter dem, was du dir tatsächlich ansiehst.',
    icon: 'Geschichte',
  },
  {
    href: '/series/modern-china/',
    title: 'Modernes China',
    desc: 'Was Ausländer am meisten überrascht — bargeldlose Straßen, die schnellsten Züge der Welt, das Ausmaß von Megastädten, Super-Apps und die Alltagstechnologie, die das Leben im heutigen China prägt.',
    icon: 'Modernes Leben',
  },
  {
    href: '/series/nature-of-china/',
    title: 'Natur Chinas',
    desc: 'Avatar-Berge, märchenhafte Seen, Karstlandschaften und das tibetische Hochland — Chinas spektakulärste Naturstätten mit praktischen Reiseführern für ausländische Besucher.',
    icon: 'Natur',
  },
  {
    href: '/series/culture-of-china/',
    title: 'Kultur Chinas',
    desc: 'Teezeremonie, Frühlingsfest, Gesicht und Guanxi, Kalligrafie, Kung-Fu und der Tierkreis — kulturelle Traditionen erklärt für Reisende, die über oberflächlichen Tourismus hinausgehen möchten.',
    icon: 'Kultur',
  },
];
import { getCategoryLabel } from "../../../i18n/categories";
const locale = 'en';
---
<!-- KI-unterstutzt erstellter Inhalt, von muttersprachlichem Redakteur gepruft -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header>
      <p class="section-kicker">Inhaltsreihen</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <section class="mt-10 grid gap-5 md:grid-cols-2">
      {seriesList.map((s) => (
        <a href={s.href} class="card block hover:no-underline">
          <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{s.icon}</span>
          <h2 class="mt-2 text-xl font-bold text-gray-950">{s.title}</h2>
          <p class="mt-2 text-sm leading-6 text-gray-600">{s.desc}</p>
          <span class="mt-4 inline-flex text-sm font-semibold text-brand-700">Reihe entdecken</span>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>