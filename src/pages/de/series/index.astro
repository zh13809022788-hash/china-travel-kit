---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const title = 'China-Reise-Inhaltsreihen';
const description = 'Entdecke China in fünf Themenreihen: Essen, Geschichte, modernes Leben, Natur und Kultur - jede davon soll ausländische Reisende inspirieren und informieren.';

const seriesList = [
  {
    href: '/de/series/food-of-china/',
    title: 'Essen in China',
    desc: 'Von Straßenständen bis zu Bankettsälen - eine kulinarische Reise für Ausländer durch acht große Küchen, regionale Frühstücke, Hotpot-Stile und Gerichte, für die sich der Weg ans andere Ende der Stadt lohnt.',
    icon: 'Essen & Trinken',
  },
  {
    href: '/de/series/history-of-china/',
    title: 'Geschichte Chinas',
    desc: 'Antike Stätten für Reisende verständlich erklärt - die Große Mauer, die Terrakotta-Armee, die Verbotene Stadt, die Seidenstraße und die Geschichten hinter dem, was du wirklich vor dir siehst.',
    icon: 'Geschichte',
  },
  {
    href: '/de/series/modern-china/',
    title: 'Modernes China',
    desc: 'Was Ausländer am meisten überrascht - bargeldlose Straßen, die schnellsten Züge der Welt, Megacity-Dimensionen, Super-Apps und die Alltagstechnologie, die das Leben in China heute prägt.',
    icon: 'Modernes Leben',
  },
  {
    href: '/de/series/nature-of-china/',
    title: 'Natur in China',
    desc: 'Avatar-Berge, märchenhafte Seen, Karstlandschaften und das tibetische Hochplateau - Chinas spektakulärste Naturorte mit praktischen Reiseführern für ausländische Besucher.',
    icon: 'Natur',
  },
  {
    href: '/de/series/culture-of-china/',
    title: 'Kultur in China',
    desc: 'Teezeremonie, Frühlingsfest, Gesicht und Guanxi, Kalligrafie, Kung Fu und Tierkreiszeichen - kulturelle Traditionen erklärt für Reisende, die über oberflächlichen Tourismus hinausgehen möchten.',
    icon: 'Kultur',
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Inhaltsreihen</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <section class="mt-10 grid gap-5 md:grid-cols-2">
      {seriesList.map((s) => (
        <a href={s.href} class="card block hover:no-underline">
          <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{s.icon}</span>
          <h2 class="mt-2 text-xl font-bold text-gray-950">{s.title}</h2>
          <p class="mt-2 text-sm leading-6 text-gray-600">{s.desc}</p>
          <span class="mt-4 inline-flex text-sm font-semibold text-brand-700">Reihe entdecken</span>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>
