---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';

const seriesSlug = 'nature-of-china';
const posts = (await getCollection('posts-de'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Natur Chinas — Landschaften & wilde Orte';
const description = 'Erkunde Chinas Naturwunder als ausländischer Reisender: Zhangjiajies Avatar-Berge, Jiuzhaigous märchenhafte Seen, Huangshans Wolkenmeer, Guilins Karstspitzen und das tibetische Hochplateau.';

const relatedTools = [
  { href: '/de/posts/what-to-pack-for-china-a-season-by-season-checklist/', title: 'Pack-Checkliste', desc: 'Ausrüstung für Outdoor-Trips nach Saison' },
  { href: '/de/posts/china-visa-free-entry-transit-guide-2026/', title: 'Visa- und Einreiseleitfaden', desc: 'Genehmigungen und Einreiseregeln für abgelegene Regionen' },
  { href: '/de/trip-planner/', title: 'Reiseplaner', desc: 'Erstelle deine China-Natur-Reiseroute' },
];

const relatedCities = [
  { href: '/de/posts/sanya-city-guide-for-foreigners/', title: 'Sanya', desc: 'Tropische Strände und Regenwald' },
  { href: '/de/posts/hangzhou-city-guide-for-foreigners/', title: 'Hangzhou', desc: 'Westsee und Teehügel' },
  { href: '/de/posts/chengdu-city-guide-for-foreigners/', title: 'Chengdu', desc: 'Tor zu westlichen Bergen und Pandas' },
];

const otherSeries = [
  { href: '/de/series/history-of-china/', title: 'Geschichte Chinas' },
  { href: '/de/series/culture-of-china/', title: 'Kultur Chinas' },
  { href: '/de/series/food-of-china/', title: 'Essen in China' },
];
import { getCategoryLabel } from '../../../i18n/categories';
const locale = 'de';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Inhaltsreihe</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Artikel</p>
            <h2>Reihe Natur Chinas</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/de/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">Artikel in dieser Reihe werden vorbereitet. Schauen Sie bald wieder vorbei.</p>
        )}
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Praktische Tools</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Planen Sie Ihre Reise</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Stadtführer</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Gateway-Städte</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Weitere Reihen</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>