---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CoverImage from '../../../components/CoverImage.astro';
import AdSlot from '../../../components/AdSlot.astro';

const title = 'Wichtige China-Apps: Downloadlinks und Web-Alternativen';
const description = 'Ein vollständiges Verzeichnis der Apps, die du in China brauchst: WeChat, Alipay, DiDi, Baidu Maps, Meituan, 12306, VPN und mehr. Jede App enthält Downloadlinks für App Store / Google Play sowie H5-Webversionen, die ohne Installation funktionieren.';

const appGroups = [
  {
    category: 'Bezahlung & digitale Geldbörse',
    apps: [
      {
        name: 'Alipay',
        desc: 'Die am häufigsten akzeptierte digitale Geldbörse in China. Verknüpfe eine ausländische Visa- oder Mastercard und bezahle per QR-Code in Geschäften, Restaurants, Taxis und bei Straßenständen.',
        android: 'https://play.google.com/store/apps/details?id=com.eg.android.AlipayGphone',
        ios: 'https://apps.apple.com/app/alipay/id333206289',
        h5: null,
        note: 'Die Einrichtung dauert 10-15 Minuten. Für die Verifizierung ist ein Reisepass erforderlich.',
        guide: '/de/posts/alipay-foreign-credit-card-step-by-step/',
      },
      {
        name: 'WeChat',
        desc: 'Chinas Super-App. Nutze sie für Nachrichten, Anrufe, Moments und WeChat Pay. Die meisten Menschen in China verwenden sie täglich für fast alles.',
        android: 'https://play.google.com/store/apps/details?id=com.tencent.mm',
        ios: 'https://apps.apple.com/app/wechat/id414478124',
        h5: 'https://web.wechat.com/',
        note: 'WeChat Pay benötigt eine verknüpfte Karte. WeChat selbst funktioniert für Nachrichten auch ohne Einrichtung.',
        guide: '/de/posts/link-a-foreign-visa-or-mastercard-to-wechat-pay-in-china/',
      },
    ],
  },
  {
    category: 'Verkehr & Fahrdienste',
    apps: [
      {
        name: 'DiDi',
        desc: 'Chinas Uber. Buche Taxis und private Fahrdienste. Unterstützt eine englische Oberfläche. Bezahlen kannst du mit Alipay oder WeChat Pay.',
        android: 'https://play.google.com/store/apps/details?id=com.didi.sdk',
        ios: 'https://apps.apple.com/app/didi/id1164272094',
        h5: 'https://m.didiglobal.com/',
        note: 'Die H5-Version funktioniert im Browser oder als WeChat-Mini-Programm. Für gelegentliche Fahrten ist keine App nötig.',
        guide: '/de/posts/didi-china-foreign-tourists-guide/',
      },
      {
        name: 'Alipay Verkehrs-Mini-Programm',
        desc: 'Nutze in Alipay das Verkehrs-Mini-Programm, um in den meisten Großstädten QR-Codes für U-Bahn und Busse zu scannen.',
        android: null,
        ios: null,
        h5: null,
        note: 'Öffne Alipay und tippe auf das Symbol „Verkehr“. Keine separate Installation nötig.',
        guide: '/de/transport/',
      },
      {
        name: '12306',
        desc: 'Offizielle App der chinesischen Eisenbahn zum Buchen von Zugtickets. Nur chinesische Oberfläche, Verifizierung erforderlich. Alternative: Trip.com nutzen.',
        android: 'https://play.google.com/store/apps/details?id=com.cars.blaili',
        ios: 'https://apps.apple.com/app/12306/id564757494',
        h5: 'https://www.12306.cn/',
        note: 'Für Ausländer etwas kompliziert. Nutze Trip.com (Englisch, keine umständliche Verifizierung).',
        guide: '/de/posts/book-china-train-tickets-12306-foreigners/',
      },
      {
        name: 'Trip.com (Ctrip)',
        desc: 'Englischfreundliche App zum Buchen von Zügen, Flügen und Hotels. Akzeptiert ausländische Karten direkt.',
        android: 'https://play.google.com/store/apps/details?id=com.ctrip',
        ios: 'https://apps.apple.com/app/trip-com/id1612956441',
        h5: 'https://www.trip.com/',
        note: 'Beste Alternative zu 12306 für Zugtickets. Höhere Servicegebühr, aber deutlich einfacher.',
        guide: null,
      },
    ],
  },
  {
    category: 'Navigation & Karten',
    apps: [
      {
        name: 'Baidu Maps',
        desc: 'Die detaillierteste Karte für China. Schritt-für-Schritt-Navigation, Routen mit öffentlichen Verkehrsmitteln und Restaurantsuche. Nur auf Chinesisch, aber mit Gesten nutzbar.',
        android: 'https://play.google.com/store/apps/details?id=com.baidu.BaiduMap',
        ios: 'https://apps.apple.com/app/baidu-maps/id452186370',
        h5: 'https://map.baidu.com/',
        note: 'Google Maps ist in China blockiert. Für Navigation brauchst du Baidu oder Amap.',
        guide: null,
      },
      {
        name: 'Amap (Gaode)',
        desc: 'Alternative zu Baidu Maps. Viele Einheimische bevorzugen Amap. Besser für Taxi-Navigation, Live-Verkehr und Restaurantbewertungen.',
        android: 'https://play.google.com/store/apps/details?id=com.autonavi.minimap',
        ios: 'https://apps.apple.com/app/amap/id461703208',
        h5: 'https://ditu.amap.com/',
        note: 'Sowohl Baidu als auch Amap funktionieren. Wähle eine App. Amap ist beim Taxi-Rufen tendenziell genauer.',
        guide: null,
      },
      {
        name: 'Google Maps',
        desc: 'Funktioniert in China teilweise zum Stöbern, aber Navigation und Echtzeitverkehr sind unzuverlässig. Gut für die Reiseplanung vorab.',
        android: null,
        ios: null,
        h5: 'https://maps.google.com/',
        note: 'Schritt-für-Schritt-Navigation funktioniert in China ohne VPN nicht.',
        guide: '/de/posts/do-you-need-a-vpn-in-china-2026/',
      },
    ],
  },
  {
    category: 'Essen & Restaurants',
    apps: [
      {
        name: 'Meituan',
        desc: 'Essenslieferung, Restaurantreservierungen, Kinotickets und Hotelbuchungen. Nur auf Chinesisch. Für englische Hilfe im Alipay-Mini-Programm nutzen.',
        android: 'https://play.google.com/store/apps/details?id=com.sankuai.meituan',
        ios: 'https://apps.apple.com/app/meituan/id423924287',
        h5: 'https://waimai.meituan.com/',
        note: 'Die H5-Essenslieferung funktioniert im Browser. Bei Lieferung mit Alipay bezahlen.',
        guide: '/de/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
      },
      {
        name: 'Ele.me',
        desc: 'App für Essenslieferungen (gehört zu Alibaba). Ähnlich wie Meituan. Essen kann mit Alipay bestellt werden.',
        android: 'https://play.google.com/store/apps/details?id=me.ele',
        ios: 'https://apps.apple.com/app/ele-me/id532785356',
        h5: 'https://www.ele.me/',
        note: 'Sowohl Meituan als auch Ele.me funktionieren. Probiere beide aus, um die beste Restaurantabdeckung zu erhalten.',
        guide: '/de/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
      },
      {
        name: 'Dianping',
        desc: 'Das Yelp Chinas. Restaurantbewertungen, Rezensionen und Fotos. Hilft dabei, gute lokale Lokale zu finden. Nur auf Chinesisch.',
        android: 'https://play.google.com/store/apps/details?id=com.dianping.v1',
        ios: 'https://apps.apple.com/app/dianping/id416896465',
        h5: 'https://www.dianping.com/',
        note: 'Nutze die Fotosuche, um vor der Bestellung zu sehen, wie Gerichte aussehen.',
        guide: '/de/food/',
      },
    ],
  },
  {
    category: 'Kommunikation & VPN',
    apps: [
      {
        name: 'VPN (vor der Reise auswählen)',
        desc: 'Installiere ein VPN, BEVOR du abreist. ExpressVPN, NordVPN und Astrill funktionieren in China. Kostenlose VPNs sind meist blockiert.',
        android: null,
        ios: null,
        h5: null,
        note: 'WICHTIG: Vor der Ankunft installieren und testen. Nach der Landung aktivieren.',
        guide: '/de/posts/do-you-need-a-vpn-in-china-2026/',
      },
      {
        name: 'Google Translate',
        desc: 'Kameraübersetzung für Speisekarten, Schilder und Dokumente. Lade das Offline-Paket für Chinesisch (vereinfacht) herunter.',
        android: 'https://play.google.com/store/apps/details?id=com.google.android.apps.translate',
        ios: 'https://apps.apple.com/app/google-translate/id414706506',
        h5: 'https://translate.google.com/',
        note: 'Bestes Übersetzungstool. Offline-Paket vor der Reise herunterladen.',
        guide: '/de/tools/survival-kit/',
      },
    ],
  },
  {
    category: 'Reisebuchung',
    apps: [
      {
        name: 'Trip.com (Hotels)',
        desc: 'Am besten zum Buchen von Hotels mit ausländischen Karten. Große Abdeckung. Englische Oberfläche.',
        android: null,
        ios: null,
        h5: 'https://www.trip.com/hotels/',
        note: 'Funktioniert auch für Flüge und Züge. Alles aus einer Hand.',
        guide: null,
      },
      {
        name: 'Fliggy (Alitrip)',
        desc: 'Alibabas Plattform für Reisebuchungen. In der Alipay-App integriert. Gut für Inlandsflüge.',
        android: null,
        ios: null,
        h5: 'https://www.fliggy.com/',
        note: 'Bezahlung mit Alipay möglich. Kein separater Download nötig.',
        guide: null,
      },
    ],
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Mobile Anwendungen</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">Wichtige China-Apps</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-internet-apps" alt="Smartphone mit Symbolen wichtiger China-Reise-Apps" loading="eager" />

    <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-5 text-sm leading-6 text-amber-900">
      <strong>Vor der Abreise:</strong> Installiere diese Apps vor der Abreise im WLAN. Manche App-Marktplätze sind in China langsam oder blockiert. Lade Offline-Übersetzungspakete und VPN-Apps zu Hause herunter.
    </div>

    <AdSlot format="banner" />

    {appGroups.map((group) => (
      <section class="mt-12" aria-labelledby={group.category.replace(/\s+/g, '-').toLowerCase()}>
        <h2 id={group.category.replace(/\s+/g, '-').toLowerCase()} class="text-2xl font-bold text-gray-950">{group.category}</h2>
        <div class="mt-5 grid gap-5 md:grid-cols-2">
          {group.apps.map((app) => (
            <article class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
              <h3 class="text-lg font-bold text-gray-950">{app.name}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{app.desc}</p>

              <div class="mt-4 flex flex-wrap gap-2">
                {app.ios && (
                  <a href={app.ios} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md bg-gray-900 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-gray-700">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
                    App Store
                  </a>
                )}
                {app.android && (
                  <a href={app.android} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md bg-green-700 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-green-600">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M18.33 8.7c-.55-.96-1.1-1.91-1.66-2.86l.32-.32c.18-.18.36-.36.54-.54.77-.77.77-1.53 0-2.3-.74-.74-1.52-.74-2.26 0-.36.36-.72.72-1.08 1.08l-.1.1A7.83 7.83 0 0 0 12 3.5c-1.1 0-2.15.2-3.12.61l-.1-.1c-.36-.36-.72-.72-1.08-1.08-.74-.74-1.52-.74-2.26 0-.77.77-.77 1.53 0 2.3.18.18.36.36.54.54l.32.32C5.2 6.8 4.64 7.75 4.08 8.7c-.55.95-1.09 1.9-1.64 2.86h15.53c-.55-.96-1.1-1.91-1.64-2.86M7.75 5.75c-.4 0-.72-.33-.72-.72s.32-.72.72-.72c.4 0 .72.33.72.72s-.32.72-.72.72m8.2 0c-.4 0-.72-.33-.72-.72s.32-.72.72-.72c.4 0 .72.33.72.72s-.32.72-.72.72M6.3 13.36v4.58c0 .66.53 1.2 1.2 1.2h.7c.66 0 1.2-.54 1.2-1.2v-4.58c0-.66-.54-1.2-1.2-1.2h-.7c-.67 0-1.2.54-1.2 1.2m8.72 0v4.58c0 .66.53 1.2 1.2 1.2h.7c.66 0 1.2-.54 1.2-1.2v-4.58c0-.66-.54-1.2-1.2-1.2h-.7c-.67 0-1.2.54-1.2 1.2"/></svg>
                    Google Play
                  </a>
                )}
                {app.h5 && (
                  <a href={app.h5} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-gray-700 transition-colors hover:bg-gray-50">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                    Webversion öffnen
                  </a>
                )}
              </div>

              {app.note && (
                <p class="mt-3 text-xs leading-5 text-gray-500"><span class="font-semibold">Tipp:</span> {app.note}</p>
              )}
              {app.guide && (
                <a href={app.guide} class="mt-2 inline-block text-xs font-semibold text-brand-700 hover:text-brand-800">Einrichtungsanleitung lesen &rarr;</a>
              )}
            </article>
          ))}
        </div>
      </section>
    ))}

    <section class="mt-12 rounded-lg border border-gray-200 p-6">
      <h2 class="text-xl font-bold text-gray-950">H5-Web-Apps: Kein Download nötig</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        Viele Dienste in China haben <strong>webbasierte (H5) Versionen</strong>, die direkt im Smartphone-Browser oder in WeChat-/Alipay-Mini-Programmen funktionieren. Sie sind ideal für Kurzzeitreisende, die ihr Smartphone nicht mit mehr als 10 Apps überladen möchten. Die wichtigsten:
      </p>
      <div class="mt-4 grid gap-3 text-sm sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">DiDi</strong> — <span class="text-gray-600">m.didiglobal.com (Englisch verfügbar)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Baidu Maps</strong> — <span class="text-gray-600">map.baidu.com (nur Chinesisch)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">WeChat Web</strong> — <span class="text-gray-600">web.wechat.com (nur Nachrichten)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Meituan</strong> — <span class="text-gray-600">waimai.meituan.com (Essenslieferung)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Dianping</strong> — <span class="text-gray-600">dianping.com (Restaurantsuche)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Alipay-Mini-Programme</strong> — <span class="text-gray-600">Alles in Alipay (keine zusätzliche Installation)</span></div>
      </div>
      <p class="mt-4 text-xs text-gray-500">
        <strong>Webversionen funktionieren in den meisten Fällen ohne VPN</strong>. App-Downloads solltest du vor der Ankunft im heimischen WLAN installieren.
      </p>
    </section>

    <section class="mt-10 text-center">
      <p class="text-sm text-gray-500">Links zum App Store öffnen offizielle Seiten. Preise und Verfügbarkeit können regionalen Einschränkungen unterliegen.</p>
    </section>
  </main>
  <Footer />
</BaseLayout>

