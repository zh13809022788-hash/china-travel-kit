---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const CATEGORY = 'transport';
const posts = (await getCollection('posts-de'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Verkehr in China: Züge, Fahrdienste und Mobilität';
const description =
  'So buchen ausländische Besucher Hochgeschwindigkeitszüge, nutzen DiDi und kommen mit öffentlichen Verkehrsmitteln zurecht.';

const transportPaths = [
  { href: '/de/posts/china-high-speed-rail-guide-foreigners/', title: 'Long-distance trains', desc: 'Use this for city-to-city planning, seat classes, passport entry, and station timing.' },
  { href: '/de/posts/airport-to-city-transport-beijing-shanghai-guangzhou/', title: 'Airport arrival', desc: 'Compare metro, taxi, ride-hailing, and airport rail for the first ride into town.' },
  { href: '/de/posts/didi-china-foreign-tourists-guide/', title: 'Ride-hailing', desc: 'Set up DiDi, use translated pickup pins, and reduce driver-call friction.' },
  { href: '/de/posts/shanghai-metro-for-foreigners-tickets-qr-codes-transfers/', title: 'Metro systems', desc: 'Learn QR tickets, transfers, and rush-hour habits through the Shanghai example.' },
];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Verkehr</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">China-Verkehrsguides</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="hub-transport" alt="Moderner Hochgeschwindigkeitszug und Eisenbahnsystem in China" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-transport">
      <h2 id="featured-transport" class="sr-only">Empfohlene Verkehrsguides</h2>
      <a href="/de/posts/china-high-speed-rail-guide-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Hochgeschwindigkeitszug-Guide</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Tickets buchen, Klassen wählen, Bahnhöfe navigieren</p>
      </a>
      <a href="/de/posts/book-china-train-tickets-12306-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">12306-Zugbuchung</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Schritt-für-Schritt-Guide mit ausländischem Reisepass</p>
      </a>
      <a href="/de/posts/didi-china-foreign-tourists-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">DiDi-Fahrdienstvermittlung</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">So nutzt du Chinas Fahrdienst-App</p>
      </a>
      <a href="/de/posts/airport-to-city-transport-beijing-shanghai-guangzhou/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Flughafentransfers</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Guides für Peking, Shanghai, Guangzhou</p>
      </a>
    </section>

    <section class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4" aria-labelledby="transport-paths">
      <h2 id="transport-paths" class="sr-only">Planungswege für Verkehr</h2>
      {transportPaths.map((path) => (
        <a href={path.href} class="card block hover:no-underline">
          <h3 class="text-lg font-bold text-gray-950">{path.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{path.desc}</p>
        </a>
      ))}
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/de/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{post.data.category}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('de-DE', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">Guides erscheinen bald.</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>