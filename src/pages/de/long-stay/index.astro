    href: '/de/digital-nomads/',
  },
  {
    title: 'China-Visum fuer digitale Nomaden (2026)',
    description: 'Alle legalen Optionen fuer laengere Aufenthalte: Touristenvisa, Geschaeftsvisa, Transitregeln und Grenzreisen.',
