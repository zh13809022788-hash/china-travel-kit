---

import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import AdSlot from '../../../../components/AdSlot.astro';
import CoverImage from '../../../../components/CoverImage.astro';

const CATEGORY = 'essentials';
const posts = (await getCollection('posts-zh-tw'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = '中國旅行規劃指南：簽證、時間與行前準備';
const description = 'วางแผนการเดินทางสู่จีนอย่างมั่นใจ: วีซ่าและกฎการเข้าเมือง ช่วงเวลาที่ดีที่สุดในการเที่ยว สิ่งที่ต้องเตรียม ความปลอดภัย และทุกอย่างที่ต้องจัดการก่อนออกเดินทาง';
import { getCategoryLabel } from '../../../../i18n/categories';
const locale = 'th';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="th">
  <Header locale="th" />
  <main class="container-page py-10">
    <header>
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">行前規劃</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">中國行前準備指南</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="hub-essentials" alt="中國旅行必備物品與行前規劃裝備" loading="lazy" />


    <div class="mt-8 space-y-4 text-justify text-lg leading-8 text-gray-600">
      <p>
  ก่อนขึ้นเครื่อง มีการตัดสินใจสองสามอย่างที่กำหนดว่าสองสามวันแรกในจีนจะราบรื่นเพียงใด วีซ่า แอปชำระเงิน eSIM ความคาดหวังเรื่อง VPN การเตรียมกระเป๋า และรายละเอียดมารยาทเล็กๆ น้อยๆ อย่างการให้ทิปและการต่อคิว ล้วนมีผลกระทบอย่างมากต่อการเดินทางจริง หน้านี้รวบรวมสิ่งที่นักเดินทางทุกคนต้องคิดให้รอบคอบก่อนออกเดินทาง
      </p>
      <p>
  คุณสามารถอ่านคู่มือด้านล่างในลำดับใดก็ได้ นักเดินทางส่วนใหญ่สามารถจัดการการตั้งค่าให้เสร็จภายในบ่ายวันเดียว โดยใช้เพียงโทรศัพท์และร้านค้าแอปที่เกี่ยวข้อง แต่การเริ่มต้นแต่เนิ่นๆ ช่วยให้คุณมีเวลาสำรองในกรณีที่ต้องเปลี่ยนบัตรหรือขั้นตอนการยืนยันใช้เวลาหลายวัน
      </p>
    </div>

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/zh-tw/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{getCategoryLabel(post.data.category, locale)}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">指南即將上線。</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>
