---
import { getCollection } from 'astro:content';
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import AdSlot from "../../../components/AdSlot.astro";
import CoverImage from "../../../components/CoverImage.astro";

const posts = (await getCollection('posts'))
  .filter((p) => p.data.category === 'food' || p.data.tags.includes('tipping') || p.data.tags.includes('restaurants'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'China Food, Dining & Etiquette Guides';
const description =
  'Praktische China-Food-Guides fur auslandische Besucher: Essenslieferungen bestellen, Sicherheit bei Streetfood, Scharfegrade, Trinkgeld, Restaurantetikette und Esskultur.';

const pathways = [
  {
    title: 'Ohne Chinesisch bestellen',
    desc: 'Richte Liefer-Apps ein, speichere Hoteladressen und vermeide Verwirrung bei Anrufen von Kurieren.',
    href: '/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
  },
  {
    title: 'Streetfood sicher essen',
    desc: 'Nutze Umschlagshaufigkeit, sichtbare Hitze, Wassergewohnheiten und Formulierungen zur Scharfe, um bessere Stande auszuwahlen.',
    href: '/posts/chengdu-street-food-safety-spice-levels-what-to-order/',
  },
  {
    title: 'Mit Restaurantetikette umgehen',
    desc: 'Wisse, wann man kein Trinkgeld gibt, wann Servicegebuhren wichtig sind und wie lokale Restaurantgewohnheiten funktionieren.',
    href: '/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/',
  },
];

const cultureLinks = [
  {
    href: 'https://baijiu365.com/baijiu-101/',
    title: 'Baijiu 101',
    desc: 'Nutzlicher Hintergrund, wenn ein Bankett oder ein bewirtetes Abendessen Chinas Nationalspirituose einschlieBt.',
  },
  {
    href: 'https://baijiu365.com/how-to-drink-baijiu/',
    title: 'Wie man baijiu hoflich trinkt',
    desc: 'Ein vertiefender Begleitguide fur Trinkspruche, kleine Einschenke und dafur, bei formellen Mahlzeiten das Tempo zu halten.',
  },
];
import { getCategoryLabel } from "../../../i18n/categories";
const locale = 'en';
---
<!-- KI-unterstutzt erstellter Inhalt, von muttersprachlichem Redakteur gepruft -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header>
      <p class="section-kicker">Essen & Gastronomie</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 max-w-3xl text-justify text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <div class="mt-6">
      <CoverImage name="topic-chinese-cuisine" alt="Scharfe Sichuan-Streetfood-Gerichte auf einem Nachtmarkt in China" loading="lazy" />
    </div>

    <div class="mt-8 space-y-4 text-justify text-lg leading-8 text-gray-600">
      <p>
  Die chinesische Kuche ist eine der groBen kulinarischen Traditionen der Welt, mit acht groBen regionalen Stilrichtungen. Vom feurigen Sichuan-Hotpot bis zum feinen kantonesischen Dim Sum, von Beijings legendarem Peking-Ente bis zu Xians handgezogenen Nudeln - jede Region bietet einzigartige Aromen und Erlebnisse. Als auslandischer Besucher findest du eine unglaubliche Bandbreite an Essensmoglichkeiten, von Streetfood-Standen und Nudelshops bis hin zu gehobenen Restaurants und Food Courts in jeder Mall. Das moderne China bietet auBerdem Liefer-Apps fur Essen wie Meituan und Ele.me, wodurch es einfach ist, Mahlzeiten zu deinem Hotel zu bestellen. In den meisten Stadten gibt es auch internationale Essensoptionen, auch wenn das wahre Abenteuer darin besteht, in die lokale chinesische Kuche einzutauchen.
      </p>
      <p>
  Wenn du in China auswarts isst, helfen ein paar praktische Tipps: In groBen Stadten werden Alipay und WeChat Pay uberall akzeptiert, aber Bargeld ist fur kleine Streetfood-Verkaufer nutzlich. Englische Speisekarten sind in touristischen Gebieten verbreitet, aber es hilft, in lokalen Restaurants eine Ubersetzungs-App griffbereit zu haben. Trinkgeld wird in China nicht erwartet. Die Lebensmittelsicherheit ist in beliebten Restaurants im Allgemeinen gut, auch wenn es klug ist, sich an belebte Orte mit hoher Umschlagshaufigkeit zu halten. Fur Menschen mit Ernahrungsbeschrankungen gilt: In der chinesischen Kuche wird MSG weit verbreitet verwendet, und viele Gerichte enthalten Sojabohnenol. Vegetarische Optionen gibt es, aber eine klare Kommunikation hilft, Missverstandnisse zu vermeiden.
      </p>
    </div>

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 md:grid-cols-3 auto-rows-fr" aria-labelledby="food-pathways">
      <h2 id="food-pathways" class="sr-only">Wege zur Essensplanung</h2>
      {pathways.map((item) => (
        <a href={item.href} class="card flex flex-col justify-between rounded-xl border border-gray-200 bg-white p-5 shadow-sm hover:border-brand-200 hover:bg-brand-50 hover:no-underline h-full">
          <div>
            <h3 class="text-lg font-bold text-gray-950">{item.title}</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">{item.desc}</p>
          </div>
          <span class="mt-4 inline-flex text-sm font-semibold text-brand-700">Guide lesen</span>
        </a>
      ))}
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Guides</p>
            <h2>Artikel zu Essen und Etikette</h2>
          </div>
        </div>
        <div class="mt-6 grid gap-5 md:grid-cols-2 auto-rows-fr">
          {posts.map((post) => (
            <a href={`/posts/${post.slug}/`} class="card flex flex-col p-5 rounded-xl border border-gray-200 bg-white shadow-sm hover:border-brand-200 hover:bg-brand-50 hover:no-underline h-full">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
              <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600 flex-1">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
        <p class="section-kicker">Kulturelle Begleitung</p>
        <h2 class="mt-1 text-xl font-bold text-gray-950">Wenn baijiu auftaucht</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          Die meisten Mahlzeiten fur Touristen erfordern kein Wissen uber Alkohol, aber bei bewirteten Banketten, Geschaftsessen
          und Mahlzeiten mit Familien auf dem Land gibt es manchmal baijiu-Trinkspruche. Diese Begleitressourcen gehen tiefer,
          wahrend ChinaTripBox auf die Reiselogistik fokussiert bleibt.
        </p>
        <div class="mt-5 grid gap-3">
          {cultureLinks.map((link) => (
            <a href={link.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-950">{link.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{link.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>
  
    <section class="mt-12 rounded-lg border border-gray-200 bg-gray-50 p-6">
      <h2 class="text-xl font-bold text-gray-950">Weitere Tipps zu Essen & Gastronomie</h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <a href="/posts/china-food-guide-regional-foreigners/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Regionaler Food-Guide</p>
          <p class="mt-1 text-sm text-gray-600">Was man je nach Region essen sollte: Sichuan, kantonesische Kuche, Beijing und mehr</p>
        </a>
        <a href="/posts/ordering-food-in-china-without-chinese-meituan-ele-me/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Essen ohne Chinesisch bestellen</p>
          <p class="mt-1 text-sm text-gray-600">Nutze Meituan und Ele.me als auslandischer Besucher</p>
        </a>
        <a href="/posts/chengdu-street-food-safety-spice-levels-what-to-order/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Chengdu Street Food</p>
          <p class="mt-1 text-sm text-gray-600">Sicherheitstipps, Scharfegrade und Gerichte, die man probieren muss</p>
        </a>
        <a href="/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Trinkgeld-Etikette</p>
          <p class="mt-1 text-sm text-gray-600">Wann man in China Trinkgeld gibt und wann nicht</p>
        </a>
      </div>
    </section>
</main>
  <Footer />
</BaseLayout>