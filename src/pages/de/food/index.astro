---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const posts = (await getCollection('posts-de'))
  .filter((p) => p.data.category === 'food' || p.data.tags.includes('tipping') || p.data.tags.includes('restaurants'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'China-Leitfaden zu Essen, Restaurants und Etikette';
const description = 'Praktische China-Leitfäden rund ums Essen für ausländische Besucher: Essenslieferung bestellen, Sicherheit bei Streetfood, Schärfegrade, Trinkgeld, Restaurantetikette und Esskultur.';

const pathways = [
  {
    title: 'Ohne Chinesisch bestellen',
    desc: 'Liefer-Apps einrichten, Hoteladressen speichern und Missverständnisse bei Anrufen vom Kurier vermeiden.',
    href: '/de/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
  },
  {
    title: 'Streetfood sicher genießen',
    desc: 'Anhand von Andrang, sichtbarer Hitze, Wasserbedingungen und Formulierungen zur Schärfe bessere Stände auswählen.',
    href: '/de/posts/chengdu-street-food-safety-spice-levels-what-to-order/',
  },
  {
    title: 'Restaurantetikette beherrschen',
    desc: 'Wissen, wann kein Trinkgeld erwartet wird, wann Servicegebühren zählen und wie lokale Restaurantregeln funktionieren.',
    href: '/de/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/',
  },
];

const cultureLinks = [
  {
    href: 'https://baijiu365.com/baijiu-101/',
    title: 'Baijiu 101',
    desc: 'Hilfreicher Hintergrund, wenn bei einem Bankett oder Essen mit Gästen die chinesische Nationalspirituose ins Spiel kommt.',
  },
  {
    href: 'https://baijiu365.com/how-to-drink-baijiu/',
    title: 'Baijiu höflich trinken',
    desc: 'Ein vertiefender Begleitfaden zu Trinksprüchen, kleinen Einschenkungen und dem Tempo bei formellen Mahlzeiten.',
  },
];
import { getCategoryLabel } from '../../../i18n/categories';
const locale = 'de';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Essen und Restaurants</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-chinese-cuisine" alt="Scharfe Sichuan-Gerichte von einem Streetfood-Markt in China" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 md:grid-cols-3" aria-labelledby="food-pathways">
      <h2 id="food-pathways" class="sr-only">Wege zur Essensplanung</h2>
      {pathways.map((item) => (
        <a href={item.href} class="card block hover:no-underline">
          <h3 class="text-lg font-bold text-gray-950">{item.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{item.desc}</p>
          <span class="mt-4 inline-flex text-sm font-semibold text-brand-700">Leitfaden lesen</span>
        </a>
      ))}
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Reiseführer</p>
            <h2>Artikel zu Essen und Etikette</h2>
          </div>
        </div>
        <div class="mt-6 grid gap-5 md:grid-cols-2">
          {posts.map((post) => (
            <a href={`/de/posts/${post.slug}/`} class="card block hover:no-underline">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
              <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
        <p class="section-kicker">Kulturbegleiter</p>
        <h2 class="mt-1 text-xl font-bold text-gray-950">Wenn Baijiu auftaucht</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          Die meisten Mahlzeiten für Touristen erfordern kein Wissen über Alkohol, aber offizielle Bankette, Geschäftsessen
          und Mahlzeiten bei Familien auf dem Land beinhalten manchmal Baijiu-Trinksprüche. Diese Begleitressourcen gehen tiefer,
          während ChinaTripBox auf die Reiselogistik fokussiert bleibt.
        </p>
        <div class="mt-5 grid gap-3">
          {cultureLinks.map((link) => (
            <a href={link.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-950">{link.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{link.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>
---