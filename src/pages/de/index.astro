---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import { Image } from 'astro:assets';
import heroImage from '../../assets/images/city-shanghai.jpg';

const posts = await getCollection('posts-de');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const categoryLabels: Record<string, string> = {
  payment: 'Bezahlung',
  esim: 'eSIM und Internet',
  transport: 'Verkehr',
  essentials: 'Reiseplanung',
  food: 'Essen',
};
---

<BaseLayout
  title="ChinaTripBox auf Deutsch | Bezahlung, Internet und Verkehr in China"
  description="Praktische Reiseführer für deutschsprachige China-Reisende: Alipay, WeChat Pay, eSIM, Hochgeschwindigkeitszüge, DiDi, Visa und Reisevorbereitung."
  locale="de"
  alternates={{ en: '/', 'zh-TW': '/zh-tw/', ja: '/ja/', ko: '/ko/', ru: '/ru/', fr: '/fr/', de: '/de/', es: '/es/' }}
>
  <Header locale="de" />
  <main>
    <section class="border-b border-gray-200 bg-gray-50">
      <div class="container-page grid gap-8 py-12 lg:grid-cols-[1fr_360px] lg:items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-wide text-brand-700">ChinaTripBox Deutsch</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Bezahlung, Internet und Verkehr vor der China-Reise einrichten
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Praktische Reiseführer für deutschsprachige Touristen: Alipay, WeChat Pay, eSIM, Hochgeschwindigkeitszüge, DiDi — alles, was vor der Abreise zu klären ist.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/de/posts/how-to-pay-in-china-tourist-guide/" class="btn-primary">Zahlungsratgeber</a>
            <a href="/de/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-outline">Checkliste vor Abflug</a>
          </div>
        </div>

        <aside class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
          <Image
            src={heroImage}
            alt="Shanghai Skyline, China-Reiseplanung"
            widths={[360, 720]}
            sizes="(max-width: 1024px) 100vw, 360px"
            quality={65}
            loading="eager"
            class="h-52 w-full object-cover"
          />
          <div class="p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Lesereihenfolge</p>
            <h2 class="mt-2 text-lg font-bold text-gray-950">Beginnen Sie mit dem, was Sie am ersten Tag brauchen</h2>
            <p class="mt-2 text-sm leading-6 text-gray-600">
              Bezahlung, Internet, Taxi und Zugtickets — die vier Dinge, die sich am meisten lohnen, vorab vorzubereiten.
            </p>
          </div>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <AdSlot format="banner" />

      <section class="py-8">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Neue Artikel auf Deutsch</p>
            <h2>Praktische China-Reiseführer</h2>
          </div>
          <a href="/" class="text-sm font-semibold text-brand-700 hover:text-brand-800">Englische Version</a>
        </div>

        {sortedPosts.length > 0 ? (
          <div class="mt-6 divide-y divide-gray-200 rounded-lg border border-gray-200 bg-white">
            {sortedPosts.map((post) => (
              <a href={`/de/posts/${post.slug}/`} class="group block p-5 hover:bg-gray-50 hover:no-underline">
                <div class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-wide text-brand-700">
                  <span>{categoryLabels[post.data.category] ?? post.data.category}</span>
                  <span class="text-gray-300">/</span>
                  <time datetime={post.data.pubDate.toISOString()}>
                    {post.data.pubDate.toLocaleDateString('de-DE', { year: 'numeric', month: 'long', day: 'numeric' })}
                  </time>
                </div>
                <h3 class="mt-2 text-lg font-bold text-gray-950 group-hover:text-brand-700">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <div class="mt-6 rounded-lg border border-gray-200 bg-gray-50 p-8 text-center">
            <p class="text-gray-500">Deutsche Übersetzungen folgen in Kürze. <a href="/" class="text-brand-600 hover:underline">Auf Englisch lesen</a>.</p>
          </div>
        )}
      </section>

      <AdSlot format="banner" />
    </div>
  </main>
  <Footer />
</BaseLayout>
