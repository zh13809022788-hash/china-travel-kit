---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { Image } from 'astro:assets';
import heroImage from '../assets/images/city-shanghai.jpg';

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 12);

import { getCategoryLabel } from '../i18n/categories';
const locale = 'en';
---
<!-- KI-unterstutzt erstellter Inhalt, von muttersprachlichem Redakteur gepruft -->


<BaseLayout
  title="ChinaTripBox - Zahlungs-, eSIM- und Transportleitfäden für Reisen nach China"
  description="Praktische China-Reiseführer für ausländische Besucher: Zahlungen, eSIMs, Hochgeschwindigkeitszug, DiDi, visumfreier Transit und was Sie vor der Landung einrichten sollten."
  alternates={{ en: '/', 'zh-TW': '/zh-tw/', ja: '/ja/', ko: '/ko/', ru: '/ru/', fr: '/fr/', de: '/de/', es: '/es/' }}
>
  <Header />
  <main>
    <section class="border-b border-gray-200 bg-gray-50">
      <div class="container-page grid gap-8 py-12 lg:grid-cols-[1fr_360px] lg:items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-wide text-brand-700">ChinaTripBox Reise-Toolkit</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Regeln Sie Zahlungen, Internet, Visa und Transport, bevor Sie in China landen
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Praktische Leitfäden und Tools für ausländische Besucher. Richten Sie Alipay, WeChat Pay, eSIM, Hochgeschwindigkeitszug, DiDi und visumfreien Transit ein — lösen Sie zuerst die Logistik und genießen Sie dann die Reise.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/posts/how-to-pay-in-china-tourist-guide/" class="btn-primary">Mit Zahlungen anfangen</a>
            <a href="/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-outline">Checkliste vor der Abreise</a>
          </div>
        </div>

        <aside class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
          <Image
            src={heroImage}
            alt="Skyline von Shanghai als Sinnbild für die Reiseplanung in Chinas Städten"
            widths={[360, 720]}
            sizes="(max-width: 1024px) 100vw, 360px"
            quality={65}
            loading="eager"
            class="h-52 w-full object-cover"
          />
          <div class="p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Empfohlene Reihenfolge zum Lesen</p>
            <h2 class="mt-2 text-lg font-bold text-gray-950">Lösen Sie zuerst die Probleme des Ankunftstags</h2>
            <p class="mt-2 text-sm leading-6 text-gray-600">
              Zahlungen, Internet, Ride-Hailing und Zugtickets sind die vier Dinge, die Sie am besten vor der Landung einrichten sollten.
            </p>
          </div>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <AdSlot format="banner" />

      <section class="py-8">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Neueste Leitfäden</p>
            <h2>Praktische Artikel für Reisen nach China</h2>
          </div>
        </div>

        <div class="mt-6 divide-y divide-gray-200 rounded-lg border border-gray-200 bg-white">
          {sortedPosts.map((post) => (
            <a href={`/posts/${post.slug}/`} class="group block p-5 hover:bg-gray-50 hover:no-underline">
              <div class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-wide text-brand-700">
                <span>{getCategoryLabel(post.data.category, locale)}</span>
                <span class="text-gray-300">/</span>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </div>
              <h3 class="mt-2 text-lg font-bold text-gray-950 group-hover:text-brand-700">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>

      <AdSlot format="banner" />

      <section class="py-8">
        <NewsletterSignup locale="en" />
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>