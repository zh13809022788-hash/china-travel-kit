---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";

const title = 'China-Reiseressourcen fur auslandische Besucher';
const description =
  'Ein praktisches Ressourcenportal fur auslandische Besucher in China: Zahlungen, eSIMs, Zuge, Visa, Stadtfuhrer, Tools und Links fur die Planung der ersten Reise.';

const resourceGroups = [
  {
    title: 'Wenn Sie nur 30 Minuten haben',
    description: 'Ein kurzer Lesepfad fur Reisende, die schnell ein funktionierendes China-Setup brauchen.',
    links: [
      { href: '/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: 'Checkliste fur die Vorbereitung vor der Abreise' },
      { href: '/tools/survival-kit/', title: 'China-Survival-Kit-Karten und Checklisten' },
      { href: '/tools/payment-checker/', title: 'Prufen Sie Ihren Zahlungs-Notfallplan' },
      { href: '/tools/visa-free-checker/', title: 'Visafreie Einreise oder Transit prufen' },
      { href: '/posts/china-high-speed-rail-guide-foreigners/', title: 'Verstehen, wie Zugbuchung und Zutritt zum Bahnhof funktionieren' },
    ],
  },
  {
    title: 'Hier beginnen: Vorbereitung fur die erste Reise',
    description: 'Der kurzeste Weg von "Ich reise nach China" zu einem funktionierenden Ankunftsplan.',
    links: [
      { href: '/trip-planner/', title: 'Kostenloser China-Reiseplaner' },
      { href: '/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/', title: 'China-Reiseplaner fur Erstbesucher' },
      { href: '/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: 'Was Sie vor der Reise nach China einrichten sollten' },
      { href: '/posts/china-visa-free-entry-transit-guide-2026/', title: 'Leitfaden zur visafreien Einreise und zum Transit in China' },
      { href: '/tools/best-time-to-visit/', title: 'Beste Reisezeit fur China' },
      { href: '/posts/what-to-pack-for-china-a-season-by-season-checklist/', title: 'Was Sie fur China einpacken sollten' },
    ],
  },
  {
    title: 'Zahlungen und Geld',
    description: 'Mobile Zahlungen, Bargeld als Reserve, Karten und alltagliche Probleme beim Bezahlen.',
    links: [
      { href: '/posts/how-to-pay-in-china-tourist-guide/', title: 'Wie man als Tourist in China bezahlt' },
      { href: '/posts/alipay-foreign-credit-card-step-by-step/', title: 'Alipay mit einer auslandischen Karte einrichten' },
      { href: '/posts/wechat-pay-foreign-visitors-guide/', title: 'WeChat Pay-Leitfaden fur auslandische Besucher' },
      { href: '/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: 'Checkliste fur Zahlungen und Apps vor der Abreise' },
      { href: '/tools/payment-checker/', title: 'Prufung der Zahlungskompatibilitat' },
    ],
  },
  {
    title: 'Internet und Apps',
    description: 'Online bleiben, eine eSIM auswahlen und wissen, welche Apps vor der Ankunft funktionieren.',
    links: [
      { href: '/posts/best-esim-for-china-travel-2026/', title: 'Beste eSIM fur Reisen nach China' },
      { href: '/posts/china-esim-vs-roaming-2026-the-real-10-day-cost/', title: 'Kosten von China-eSIM im Vergleich zu Roaming' },
      { href: '/posts/internet-access-china-apps-that-work-2026/', title: 'Internetzugang und Apps in China' },
      { href: '/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/', title: 'Reiseplanung fur Erstbesucher mit eSIM und Apps' },
      { href: '/tools/app-availability-checker/', title: 'Funktionieren meine Apps in China?' },
    ],
  },
  {
    title: 'Transport und Stadtfuhrer',
    description: 'Zuge, U-Bahn, Flughafen, Ride-Hailing und praktische Stadtplanung.',
    links: [
      { href: '/cities/', title: 'Portal fur China-Stadtfuhrer' },
      { href: '/posts/china-high-speed-rail-guide-foreigners/', title: 'Leitfaden fur Chinas Hochgeschwindigkeitsbahn fur Auslander' },
      { href: '/posts/book-china-train-tickets-12306-foreigners/', title: 'China-Zugtickets auf 12306 buchen' },
      { href: '/posts/didi-china-foreign-tourists-guide/', title: 'DiDi als auslandischer Tourist nutzen' },
      { href: '/posts/airport-to-city-transport-beijing-shanghai-guangzhou/', title: 'Leitfaden fur den Transport vom Flughafen in die Stadt' },
    ],
  },
  {
    title: 'Essen, Etikette und Alltag',
    description: 'Essen gehen, Trinkgeld, Liefer-Apps, Streetfood und praktische Gewohnheiten, die vor Ort Reibung verringern.',
    links: [
      { href: '/food/', title: 'Portal fur Essen und Dining in China' },
      { href: '/posts/ordering-food-in-china-without-chinese-meituan-ele-me/', title: 'Essen ohne Chinesisch bestellen' },
      { href: '/posts/chengdu-street-food-safety-spice-levels-what-to-order/', title: 'Leitfaden zu Streetfood-Sicherheit und Scharfegrad in Chengdu' },
      { href: '/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/', title: 'Trinkgeld in China: wann es erwartet wird' },
    ],
  },
  {
    title: 'Langere Aufenthalte und Remote-Arbeit',
    description: 'Fur Reisen, die sich uber Wochen oder Monate erstrecken, beginnen Sie mit Rechtslage, Unterkunft, Zahlung und der Zuverlassigkeit Ihrer Arbeitstools.',
    links: [
      { href: '/long-stay/', title: 'Leitfaden fur einen langfristigen Aufenthalt in China' },
      { href: '/digital-nomads/', title: 'Leitfaden fur digitale Nomaden in China' },
      { href: '/digital-nomads/visa/', title: 'China-Visaleitfaden fur digitale Nomaden' },
      { href: '/digital-nomads/payment/', title: 'Zahlungseinrichtung fur langere Aufenthalte' },
    ],
  },
];
---
<!-- KI-unterstutzt erstellter Inhalt, von muttersprachlichem Redakteur gepruft -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <section class="max-w-3xl">
      <p class="section-kicker">Ressourcenportal</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </section>

    <section class="mt-10 grid gap-5 md:grid-cols-2">
      {resourceGroups.map((group) => (
        <div class="card">
          <h2 class="text-xl font-bold text-gray-950">{group.title}</h2>
          <p class="mt-2 text-sm leading-6 text-gray-600">{group.description}</p>
          <ul class="mt-5 grid gap-2">
            {group.links.map((link) => (
              <li>
                <a href={link.href}
                   class="block rounded-lg border border-gray-200 px-4 py-3 text-sm font-semibold
                          text-brand-700 transition-colors hover:border-brand-300 hover:bg-brand-50">
                  {link.title}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>