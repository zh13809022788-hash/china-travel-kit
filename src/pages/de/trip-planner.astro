---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';

const title = 'Kostenloser China-Reiseplaner';
const description =
  'Erstelle einen praktischen ersten China-Reiseplan mit Empfehlungen zu Zahlung, eSIM, Transport, App-Einrichtung, Bargeld und einer Checkliste für den ersten Tag.';

const needOptions = [
  { value: 'payment', label: 'Zahlungseinrichtung' },
  { value: 'esim', label: 'eSIM und Internet' },
  { value: 'transport', label: 'Flughafen und Züge' },
  { value: 'hotel', label: 'Logik für die Hotellage' },
  { value: 'apps', label: 'Apps und Übersetzung' },
  { value: 'cash', label: 'Bargeld als Absicherung' },
  { value: 'visa', label: 'Visumfreie Einreise' },
  { value: 'food', label: 'Essen und Lieferung' },
];
---
<!-- KI-unterstutzt erstellter Inhalt, von muttersprachlichem Redakteur gepruft -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main>
    <section class="border-b border-gray-200 bg-white">
      <div class="container-page grid gap-8 py-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <div>
          <p class="section-kicker">Kostenloses Planungstool</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Erstelle einen praktischen Plan für deine Ankunft in China, bevor du losfliegst
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Erhalte einen ersten Plan für Zahlungen, eSIM-Daten, Flughafentransport, App-Einrichtung,
            Bargeld als Absicherung und den täglichen Rhythmus. Er läuft in deinem Browser und speichert deine Antworten nicht.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#planner" class="btn-primary">Planung starten</a>
            <a href="/travel-help/" class="btn-outline">Reisehilfe anfragen</a>
            <a href="/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">Leitfaden für Erstbesucher lesen</a>
          </div>
        </div>

        <aside class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="section-kicker">Am besten geeignet für</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Einrichtung für Erstbesucher</h2>
          <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
            <li>Zahlungsbereitschaft vor der Ankunft</li>
            <li>Entscheidungen zu eSIM, Roaming und App-Zugriff</li>
            <li>Planung des ersten Schritts vom Flughafen in die Stadt</li>
            <li>Einfaches Gerüst für die Reise von Stadt zu Stadt</li>
          </ul>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <AdSlot format="banner" />

      <section id="planner" class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <form id="trip-planner-form" class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm md:p-6">
          <div class="border-b border-gray-200 pb-5">
            <p class="section-kicker">Reisedetails</p>
            <h2 class="mt-2 text-2xl font-bold text-gray-950">Sag uns, was du schon weißt</h2>
          </div>

          <div class="mt-6 grid gap-5 md:grid-cols-2">
            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Heimatland oder Region
              <input id="home-country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="Vereinigte Staaten, Vereinigtes Königreich, Singapur..." />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Ankunftsstadt
              <select id="arrival-city" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Shanghai</option>
                <option>Beijing</option>
                <option>Guangzhou</option>
                <option>Shenzhen</option>
                <option>Chengdu</option>
                <option>Hangzhou</option>
                <option>Andere Stadt</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800 md:col-span-2">
              Zielstädte
              <input id="destination-cities" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="Shanghai, Hangzhou, Beijing" />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Reisedauer
              <select id="trip-length" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option value="3">3 Tage</option>
                <option value="5">5 Tage</option>
                <option value="7" selected>7 Tage</option>
                <option value="10">10 Tage</option>
                <option value="14">14 Tage</option>
                <option value="21">21 Tage oder mehr</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Reisezweck
              <select id="trip-purpose" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Tourismus</option>
                <option>Geschäftlich</option>
                <option>Längerer Aufenthalt</option>
                <option>Digitaler Nomade</option>
                <option>Familienbesuch</option>
                <option>Transit</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Budgetrahmen
              <select id="budget-range" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Günstig</option>
                <option selected>Komfort</option>
                <option>Premium</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Reisestil
              <select id="travel-style" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Effizient</option>
                <option>Günstig</option>
                <option selected>Komfort</option>
                <option>Familie</option>
                <option>Geschäftlich</option>
                <option>Essen im Fokus</option>
              </select>
            </label>
          </div>

          <fieldset class="mt-6">
            <legend class="text-sm font-semibold text-gray-800">Wobei brauchst du Hilfe?</legend>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              {needOptions.map((option) => (
                <label class="flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-700">
                  <input class="h-4 w-4 rounded border-gray-300 text-brand-600" type="checkbox" name="needs" value={option.value} checked={['payment', 'esim', 'transport', 'apps'].includes(option.value)} />
                  {option.label}
                </label>
              ))}
            </div>
          </fieldset>

          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p id="planner-status" class="text-sm text-gray-500">Kein Konto und keine sensiblen Daten erforderlich.</p>
            <button class="btn-primary" type="submit">Plan erstellen</button>
          </div>
        </form>

        <aside class="space-y-6">
          <section class="rounded-lg border border-gray-200 bg-white p-5">
            <p class="section-kicker">Upgrade-Pfad</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Brauchst du eine menschliche Prüfung?</h2>
            <p class="mt-3 text-sm leading-6 text-gray-600">
              Wenn deine Route, dein Timing, deine Zahlungseinrichtung oder dein erster Tag riskant wirkt, sende den generierten
              Plan per E-Mail und bitte um eine von Menschen geprüfte Korrekturliste.
            </p>
            <a id="planner-email-link" class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:border-brand-600 hover:text-brand-600 hover:no-underline" href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Trip%20Review%20Request">
              Prüfungs-E-Mail vorbereiten
            </a>
          </section>

          <section class="rounded-lg border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Grenzen</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Nutze dies als Planungshilfe</h2>
            <p class="mt-3 text-sm leading-6 text-gray-700">
              Dieses Tool ist keine rechtliche, einwanderungsbezogene, medizinische, bankbezogene oder Notfallberatung. Prüfe
              wichtige Regeln zu Einreise, Fluggesellschaft, Hotel, Karte, Telekommunikation und Apps anhand offizieller Quellen.
            </p>
          </section>
        </aside>
      </section>

      <section id="plan-output" class="mt-10 hidden rounded-lg border border-brand-100 bg-brand-50 p-5 md:p-6" aria-live="polite">
        <div class="border-b border-brand-100 pb-4">
          <p class="section-kicker">Generierter Plan</p>
          <h2 class="mt-2 text-2xl font-bold text-gray-950">Dein Entwurf für die Einrichtung deiner China-Reise</h2>
        </div>
        <div id="plan-content" class="mt-5 grid gap-5"></div>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <a href="/payment/" class="card block hover:no-underline">
          <p class="section-kicker">Zahlung</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Bereite Alipay und WeChat Pay vor</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Richte vor der Ankunft mindestens eine Wallet und eine Ersatz-Zahlungsmethode ein.</p>
        </a>
        <a href="/esim/" class="card block hover:no-underline">
          <p class="section-kicker">Internet</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Wähle eine eSIM- oder Roaming-Einrichtung</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Stelle sicher, dass du am ersten Tag Karten laden, übersetzen, Nachrichten senden und eine Fahrt rufen kannst.</p>
        </a>
        <a href="/transport/" class="card block hover:no-underline">
          <p class="section-kicker">Transport</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Plane deine erste Route</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Kenne deine Route vom Flughafen zum Hotel und wann du Metro, Taxi, DiDi oder Zug nutzen solltest.</p>
        </a>
      </section>

      <section class="mt-10 rounded-lg border border-gray-200 bg-white p-5 md:p-6">
        <p class="section-kicker">Vor der Nutzung des Planers</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950">Lies die Einrichtungsleitfäden, wenn dies deine erste China-Reise ist</h2>
        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <a href="/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">China-Reiseplaner für Erstbesucher</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Nutze dieselbe Planungsreihenfolge wie dieses Tool: Internet, Zahlung, Flughafentransfer, Apps, Reihenfolge der Städte und Checkliste für den ersten Tag.</p>
          </a>
          <a href="/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Was du vor einer Reise nach China einrichten solltest</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Eine praktische Checkliste vor der Abreise für Alipay, WeChat Pay, eSIM, DiDi, Zugtickets, Karten und Bargeld als Absicherung.</p>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('trip-planner-form') as HTMLFormElement | null;
  const output = document.getElementById('plan-output');
  const content = document.getElementById('plan-content');
  const status = document.getElementById('planner-status');
  const emailLink = document.getElementById('planner-email-link') as HTMLAnchorElement | null;

  const getValue = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null)?.value.trim() || '';
  const selectedNeeds = () =>
    Array.from(document.querySelectorAll<HTMLInputElement>('input[name="needs"]:checked')).map((input) => input.value);
  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char] ?? char);

  const splitCities = (value: string, arrival: string) => {
    const typed = value
      .split(',')
      .map((city) => city.trim())
      .filter(Boolean);
    const cities = typed.length ? typed : [arrival];
    return Array.from(new Set(cities));
  };

  const list = (items: string[]) => `<ul class="mt-3 grid gap-2 text-sm leading-6 text-gray-700">${items.map((item) => `<li>${item}</li>`).join('')}</ul>`;
  const panel = (title: string, items: string[]) => `
    <section class="rounded-lg border border-gray-200 bg-white p-5">
      <h3 class="text-lg font-bold text-gray-950">${title}</h3>
      ${list(items)}
    </section>
  `;

  const buildPlan = () => {
    const home = getValue('home-country') || 'dein Heimatland';
    const arrival = getValue('arrival-city') || 'Shanghai';
    const cities = splitCities(getValue('destination-cities'), arrival);
    const days = Number(getValue('trip-length') || '7');
    const purpose = getValue('trip-purpose') || 'Tourismus';
    const budget = getValue('budget-range') || 'Komfort';
    const style = getValue('travel-style') || 'Komfort';
    const needs = selectedNeeds();
    const perCity = Math.max(1, Math.floor(days / Math.max(1, cities.length)));

    const preDeparture = [
      `Installiere Alipay, WeChat, DiDi, eine Übersetzungs-App und eine Offline-Karte, bevor du ${escapeHtml(home)} verlässt.`,
      needs.includes('payment')
        ? 'Verknüpfe eine ausländische Visa oder Mastercard mit Alipay und versuche vor der Abreise eine kleine Verifizierung.'
        : 'Halte die Zahlungseinrichtung einfach: eine mobile Wallet, eine physische Karte und etwas RMB in bar.',
      needs.includes('esim')
        ? 'Kaufe und aktiviere vor dem Flug eine eSIM oder einen Roaming-Tarif und halte dann den QR-Code offline verfügbar.'
        : 'Bestätige, dass dein Handy bei der Ankunft Datenzugang hat, bevor du dich auf Karten oder Ride-Hailing verlässt.',
      'Speichere deine Hoteladresse auf Englisch und Chinesisch sowie die nächstgelegene Metrostation.',
    ];

    const payment = [
      'Primäre Einrichtung: Alipay mit einer ausländischen Karte, weil es für Besucher in der Regel die praktischste erste Wallet ist.',
      'Ersatz-Einrichtung: WeChat Pay, wenn sich deine Karte erfolgreich verknüpfen lässt, plus eine physische Visa oder Mastercard.',
      budget === 'Budget'
        ? 'Bargeld als Absicherung: Nimm einen kleinen Betrag RMB für Stände, Kautionen oder Probleme mit Karte oder Wallet mit.'
        : 'Bargeld als Absicherung: Halte genug RMB für Taxi, Snacks und eine einfache Mahlzeit bereit, falls mobiles Bezahlen ausfällt.',
      'Verlasse dich auf dem chinesischen Festland nicht auf Apple Pay oder Google Pay als wichtigste Zahlungsmethode.',
    ];

    const internet = [
      'Für kurze Reisen ist eine Reise-eSIM meist die einfachste Einrichtung, wenn dein Handy eSIM unterstützt.',
      'Für längere Aufenthalte oder hohen Datenverbrauch vergleiche vor der Ankunft Roaming-, eSIM-, Pocket-WiFi- und lokale SIM-Optionen.',
      'Teste die mobilen Daten, bevor du den Flughafen verlässt, denn Zahlungs-Apps, Ride-Hailing, Übersetzung und Karten hängen alle davon ab.',
      'Speichere Hotel- und Transportinformationen offline, falls deine erste Verbindung instabil ist.',
    ];

    const transport = [
      `Erste Route: Plane den Weg vom Flughafen oder Bahnhof in ${escapeHtml(arrival)} zum Hotel, bevor du landest.`,
      'Nutze die Metro für berechenbare Stadtfahrten, DiDi für Fahrten von Tür zu Tür und Hochgeschwindigkeitszüge für Reisen zwischen Städten.',
      needs.includes('transport')
        ? 'Für Tage mit Zugfahrten buche möglichst früher und achte darauf, dass die Passdaten mit der Ticketplattform übereinstimmen.'
        : 'Vermeide enge Umstiege am selben Tag zwischen internationalen Flügen und Fernzügen.',
      'Halte eine chinesische Adresskarte für Taxis oder Hotelrezeptionen bereit.',
    ];

    const dayPlan = cities.map((city, index) => {
      const start = index * perCity + 1;
      const end = index === cities.length - 1 ? days : Math.min(days, start + perCity - 1);
      return `Tage ${start}-${end}: ${escapeHtml(city)} - halte den ersten halben Tag leichter, bestätige Zahlung und Datenzugang und gruppiere dann Sehenswürdigkeiten nach Bezirk.`;
    });

    const mistakes = [
      'Warte nicht bis zur Ankunft, um jede App, Karte und jeden Datentarif einzurichten.',
      'Plane nicht unmittelbar nach einem Langstreckenflug einen dicht gepackten Besichtigungstag.',
      'Verlasse dich nicht nur auf eine einzige Zahlungsmethode.',
      purpose === 'Business'
        ? 'Für Geschäftsreisen solltest du zusätzliche Zeit für Verkehr, Sicherheitskontrollen, Rechnungen und den Gebäudezugang einplanen.'
        : 'Lass bei Freizeitreisen alle zwei oder drei Tage einen flexiblen Block für Wetter, Menschenmengen oder Erschöpfung frei.',
      style === 'Food-focused'
        ? 'Bei Reisen mit Fokus auf Essen speichere Restaurantnamen auf Chinesisch und prüfe die Öffnungszeiten, bevor du quer durch die Stadt fährst.'
        : 'Halte einen einfachen Ersatzplan für Mahlzeiten in der Nähe deines Hotels bereit.',
    ];

    const html = [
      panel('Checkliste vor der Abreise', preDeparture),
      panel('Einrichtung von Zahlung und Bargeld', payment),
      panel('Einrichtung von Internet und Apps', internet),
      panel('Transport und erster Tag', transport),
      panel('Einfaches Gerüst Tag für Tag', dayPlan),
      panel('Warnungen vor häufigen Fehlern', mistakes),
    ].join('');

    const emailBody = [
      'ChinaTripBox Trip Review Request',
      '',
      `Home country or region: ${home}`,
      `Arrival city: ${arrival}`,
      `Destination cities: ${cities.join(', ')}`,
      `Trip length: ${days} days`,
      `Purpose: ${purpose}`,
      `Budget: ${budget}`,
      `Style: ${style}`,
      `Needs: ${needs.join(', ') || 'not specified'}`,
      '',
      'Please review my China trip setup for payment, eSIM, transport, timing, and first-day mistakes.',
    ].join('\n');

    if (emailLink) {
      emailLink.href = `mailto:zh13809022788@gmail.com?subject=${encodeURIComponent(
        'ChinaTripBox Trip Review Request',
      )}&body=${encodeURIComponent(emailBody)}`;
    }

    return html;
  };

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!content || !output) return;
    content.innerHTML = buildPlan();
    output.classList.remove('hidden');
    output.scrollIntoView({ behavior: 'smooth', block: 'start' });
    if (status) status.textContent = 'Plan erstellt. Passe deine Antworten an und erstelle ihn jederzeit neu.';
  });
</script>