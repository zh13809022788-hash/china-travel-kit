---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';

const title = 'Kostenloser China-Reiseplaner';
const description =
  'Erstelle einen praktischen Plan für deine erste China-Reise mit Empfehlungen zu Zahlung, eSIM, Verkehr, App-Einrichtung, Bargeld und Checkliste für den ersten Tag.';

const needOptions = [
  { value: 'payment', label: 'Zahlung einrichten' },
  { value: 'esim', label: 'eSIM und Internet' },
  { value: 'transport', label: 'Flughafen und Züge' },
  { value: 'hotel', label: 'Logik der Hotelgegend' },
  { value: 'apps', label: 'Apps und Übersetzung' },
  { value: 'cash', label: 'Bargeldreserve' },
  { value: 'visa', label: 'Visafreie Einreise' },
  { value: 'food', label: 'Essen und Lieferung' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main>
    <section class="border-b border-gray-200 bg-white">
      <div class="container-page grid gap-8 py-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <div>
          <p class="section-kicker">Kostenloses Planungstool</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Erstelle vor dem Abflug einen praktischen Ankunftsplan für China
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Erhalte einen ersten Plan für Zahlungen, eSIM-Daten, Flughafentransfer, App-Einrichtung,
            Bargeldreserve und Tagesrhythmus. Er läuft in deinem Browser und speichert deine Antworten nicht.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#planner" class="btn-primary">Planung starten</a>
            <a href="/de/travel-help/" class="btn-outline">Reisehilfe anfragen</a>
            <a href="/de/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">Erstreise-Guide lesen</a>
          </div>
        </div>

        <aside class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="section-kicker">Am besten für</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Einrichtung für Erstbesucher</h2>
          <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
            <li>Zahlungsbereitschaft vor der Ankunft</li>
            <li>Entscheidungen zu eSIM, Roaming und App-Zugriff</li>
            <li>Planung des ersten Schritts vom Flughafen in die Stadt</li>
            <li>Einfacher Reiseaufbau von Stadt zu Stadt</li>
          </ul>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <AdSlot format="banner" />

      <section id="planner" class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <form id="trip-planner-form" class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm md:p-6">
          <div class="border-b border-gray-200 pb-5">
            <p class="section-kicker">Reisedetails</p>
            <h2 class="mt-2 text-2xl font-bold text-gray-950">Sag uns, was du schon weißt</h2>
          </div>

          <div class="mt-6 grid gap-5 md:grid-cols-2">
            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Heimatland oder Region
              <input id="home-country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="Deutschland, Schweiz, Österreich..." />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Ankunftsstadt
              <select id="arrival-city" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Shanghai</option>
                <option>Beijing</option>
                <option>Guangzhou</option>
                <option>Shenzhen</option>
                <option>Chengdu</option>
                <option>Hangzhou</option>
                <option>Andere Stadt</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800 md:col-span-2">
              Zielstädte
              <input id="destination-cities" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="Shanghai, Hangzhou, Beijing" />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Reisedauer
              <select id="trip-length" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option value="3">3 Tage</option>
                <option value="5">5 Tage</option>
                <option value="7" selected>7 Tage</option>
                <option value="10">10 Tage</option>
                <option value="14">14 Tage</option>
                <option value="21">21 Tage oder mehr</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Reisezweck
              <select id="trip-purpose" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Tourismus</option>
                <option>Geschäftlich</option>
                <option>Langzeitaufenthalt</option>
                <option>Digitaler Nomade</option>
                <option>Familienbesuch</option>
                <option>Transit</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Budgetbereich
              <select id="budget-range" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Sparsam</option>
                <option selected>Komfort</option>
                <option>Premium</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Reisestil
              <select id="travel-style" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Effizient</option>
                <option>Sparsam</option>
                <option selected>Komfort</option>
                <option>Familie</option>
                <option>Geschäftlich</option>
                <option>Essensorientiert</option>
              </select>
            </label>
          </div>

          <fieldset class="mt-6">
            <legend class="text-sm font-semibold text-gray-800">Wobei brauchst du Hilfe?</legend>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              {needOptions.map((option) => (
                <label class="flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-700">
                  <input class="h-4 w-4 rounded border-gray-300 text-brand-600" type="checkbox" name="needs" value={option.value} checked={['payment', 'esim', 'transport', 'apps'].includes(option.value)} />
                  {option.label}
                </label>
              ))}
            </div>
          </fieldset>

          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p id="planner-status" class="text-sm text-gray-500">Kein Konto und keine sensiblen Daten erforderlich.</p>
            <button class="btn-primary" type="submit">Plan erstellen</button>
          </div>
        </form>

        <aside class="space-y-6">
          <section class="rounded-lg border border-gray-200 bg-white p-5">
            <p class="section-kicker">Nächste Option</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Brauchst du eine menschliche Prüfung?</h2>
            <p class="mt-3 text-sm leading-6 text-gray-600">
              Wenn Route, Timing, Zahlungseinrichtung oder erster Tag riskant wirken, sende den erstellten
              Plan per E-Mail und bitte um eine von Menschen geprüfte Korrekturliste.
            </p>
            <a id="planner-email-link" class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:border-brand-600 hover:text-brand-600 hover:no-underline" href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Anfrage%20zur%20Reiseprüfung">
              Prüf-E-Mail vorbereiten
            </a>
          </section>

          <section class="rounded-lg border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Grenzen</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Nutze dies als Planungshilfe</h2>
            <p class="mt-3 text-sm leading-6 text-gray-700">
              Dieses Tool ist keine Rechts-, Einwanderungs-, Medizin-, Bank- oder Notfallberatung. Prüfe
              wichtige Regeln zu Einreise, Fluggesellschaft, Hotel, Karte, Telekommunikation und Apps anhand offizieller Quellen.
            </p>
          </section>
        </aside>
      </section>

      <section id="plan-output" class="mt-10 hidden rounded-lg border border-brand-100 bg-brand-50 p-5 md:p-6" aria-live="polite">
        <div class="border-b border-brand-100 pb-4">
          <p class="section-kicker">Erstellter Plan</p>
          <h2 class="mt-2 text-2xl font-bold text-gray-950">Dein Entwurf für die China-Reiseeinrichtung</h2>
        </div>
        <div id="plan-content" class="mt-5 grid gap-5"></div>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <a href="/de/payment/" class="card block hover:no-underline">
          <p class="section-kicker">Bezahlung</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Alipay und WeChat Pay vorbereiten</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Richte vor der Ankunft mindestens eine Wallet und eine Ersatzzahlungsmethode ein.</p>
        </a>
        <a href="/de/esim/" class="card block hover:no-underline">
          <p class="section-kicker">Internet</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Wähle eine eSIM- oder Roaming-Einrichtung</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Stelle sicher, dass du am ersten Tag Karten laden, übersetzen, Nachrichten senden und eine Fahrt rufen kannst.</p>
        </a>
        <a href="/de/transport/" class="card block hover:no-underline">
          <p class="section-kicker">Verkehr</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Plane deine erste Route</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Kenne deine Route vom Flughafen zum Hotel und wann du Metro, Taxi, DiDi oder Zug nutzt.</p>
        </a>
      </section>

      <section class="mt-10 rounded-lg border border-gray-200 bg-white p-5 md:p-6">
        <p class="section-kicker">Vor der Nutzung des Planers</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950">Lies die Einrichtungs-Guides, wenn dies deine erste China-Reise ist</h2>
        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <a href="/de/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">China-Reiseplaner für Erstbesucher</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Nutze dieselbe Planungsreihenfolge wie dieses Tool: Internet, Zahlung, Flughafenroute, Apps, Stadtreihenfolge und Checkliste für den ersten Tag.</p>
          </a>
          <a href="/de/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Was du vor einer Reise nach China einrichten solltest</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Eine praktische Checkliste vor der Abreise für Alipay, WeChat Pay, eSIM, DiDi, Zugtickets, Karten und Bargeldreserve.</p>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('trip-planner-form') as HTMLFormElement | null;
  const output = document.getElementById('plan-output');
  const content = document.getElementById('plan-content');
  const status = document.getElementById('planner-status');
  const emailLink = document.getElementById('planner-email-link') as HTMLAnchorElement | null;

  const getValue = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null)?.value.trim() || '';
  const selectedNeeds = () =>
    Array.from(document.querySelectorAll<HTMLInputElement>('input[name="needs"]:checked')).map((input) => input.value);
  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char] ?? char);

  const splitCities = (value: string, arrival: string) => {
    const typed = value
      .split(',')
      .map((city) => city.trim())
      .filter(Boolean);
    const cities = typed.length ? typed : [arrival];
    return Array.from(new Set(cities));
  };

  const list = (items: string[]) => `<ul class="mt-3 grid gap-2 text-sm leading-6 text-gray-700">${items.map((item) => `<li>${item}</li>`).join('')}</ul>`;
  const panel = (title: string, items: string[]) => `
    <section class="rounded-lg border border-gray-200 bg-white p-5">
      <h3 class="text-lg font-bold text-gray-950">${title}</h3>
      ${list(items)}
    </section>
  `;

  const buildPlan = () => {
    const home = getValue('home-country') || 'dein Heimatland';
    const arrival = getValue('arrival-city') || 'Shanghai';
    const cities = splitCities(getValue('destination-cities'), arrival);
    const days = Number(getValue('trip-length') || '7');
    const purpose = getValue('trip-purpose') || 'Tourismus';
    const budget = getValue('budget-range') || 'Komfort';
    const style = getValue('travel-style') || 'Komfort';
    const needs = selectedNeeds();
    const needLabels: Record<string, string> = {
      payment: 'Zahlung einrichten',
      esim: 'eSIM und Internet',
      transport: 'Flughafen und Züge',
      hotel: 'Logik der Hotelgegend',
      apps: 'Apps und Übersetzung',
      cash: 'Bargeldreserve',
      visa: 'Visafreie Einreise',
      food: 'Essen und Lieferung',
    };
    const needsText = needs.map((need) => needLabels[need] ?? need).join(', ');
    const perCity = Math.max(1, Math.floor(days / Math.max(1, cities.length)));

    const preDeparture = [
      `Installiere Alipay, WeChat, DiDi, eine Übersetzungs-App und eine Offline-Karte, bevor du ${escapeHtml(home)} verlässt.`,
      needs.includes('payment')
        ? 'Verknüpfe eine ausländische Visa oder Mastercard mit Alipay und versuche vor der Abreise eine kleine Verifizierung.'
        : 'Halte die Zahlungseinrichtung einfach: eine mobile Wallet, eine physische Karte und etwas RMB-Bargeld.',
      needs.includes('esim')
        ? 'Kaufe und aktiviere vor dem Flug eine eSIM oder einen Roaming-Tarif und halte den QR-Code offline bereit.'
        : 'Bestätige, dass dein Telefon bei der Ankunft mobile Daten hat, bevor du dich auf Karten oder Fahrdienste verlässt.',
      'Speichere deine Hoteladresse auf Englisch und Chinesisch sowie die nächste Metrostation.',
    ];

    const payment = [
      'Primäre Einrichtung: Alipay mit einer ausländischen Karte, weil dies für Besucher meist die praktischste erste Wallet ist.',
      'Ersatzlösung: WeChat Pay, falls deine Karte erfolgreich verknüpft wird, plus eine physische Visa oder Mastercard.',
      budget === 'Sparsam'
        ? 'Bargeldreserve: Nimm einen kleinen RMB-Betrag für Stände, Kautionen oder Karten-/Wallet-Probleme mit.'
        : 'Bargeldreserve: Halte genug RMB für Taxi, Snacks und eine einfache Mahlzeit bereit, falls mobile Zahlung ausfällt.',
      'Verlasse dich in Festland-China nicht auf Apple Pay oder Google Pay als Hauptzahlungsmethode.',
    ];

    const internet = [
      'Für kurze Reisen ist eine Reise-eSIM meist die einfachste Einrichtung, wenn dein Telefon eSIM unterstützt.',
      'Für längere Aufenthalte oder intensive Datennutzung vergleiche vor der Ankunft Roaming, eSIM, Pocket-WiFi und lokale SIM-Optionen.',
      'Teste mobile Daten, bevor du den Flughafen verlässt, denn Zahlungs-Apps, Fahrdienste, Übersetzung und Karten hängen davon ab.',
      'Speichere Hotel- und Verkehrsinformationen offline, falls deine erste Verbindung instabil ist.',
    ];

    const transport = [
      `Erste Route: Plane vor der Landung den Weg vom Flughafen oder Bahnhof in ${escapeHtml(arrival)} zum Hotel.`,
      'Nutze die Metro für berechenbare Stadtrouten, DiDi für Tür-zu-Tür-Fahrten und Hochgeschwindigkeitszüge für Reisen zwischen Städten.',
      needs.includes('transport')
        ? 'Buche Zugtage nach Möglichkeit früher und achte darauf, dass Passdaten mit der Ticketplattform übereinstimmen.'
        : 'Vermeide knappe Umstiege am selben Tag zwischen internationalen Flügen und Fernzügen.',
      'Halte eine chinesische Adresskarte für Taxis oder Hotelrezeptionen bereit.',
    ];

    const dayPlan = cities.map((city, index) => {
      const start = index * perCity + 1;
      const end = index === cities.length - 1 ? days : Math.min(days, start + perCity - 1);
      return `Tage ${start}-${end}: ${escapeHtml(city)} - halte den ersten halben Tag leichter, bestätige Zahlung/Daten und gruppiere Sehenswürdigkeiten dann nach Bezirk.`;
    });

    const mistakes = [
      'Warte nicht bis zur Ankunft, um jede App, Karte und jeden Datentarif einzurichten.',
      'Plane direkt nach einem Langstreckenflug keinen vollgepackten Sightseeing-Tag.',
      'Verlasse dich nicht nur auf eine einzige Zahlungsmethode.',
      purpose === 'Geschäftlich'
        ? 'Plane bei Geschäftsreisen zusätzliche Zeit für Verkehr, Sicherheitskontrollen, Rechnungen und Gebäudezugang ein.'
        : 'Lass bei Freizeitreisen alle zwei oder drei Tage einen flexiblen Block für Wetter, Menschenmengen oder Müdigkeit frei.',
      style === 'Essensorientiert'
        ? 'Speichere bei essensorientierten Reisen Restaurantnamen auf Chinesisch und bestätige Öffnungszeiten, bevor du quer durch die Stadt fährst.'
        : 'Halte einen einfachen Ersatzplan für Mahlzeiten in Hotelnähe bereit.',
    ];

    const html = [
      panel('Checkliste vor der Abreise', preDeparture),
      panel('Zahlungs- und Bargeldeinrichtung', payment),
      panel('Internet- und App-Einrichtung', internet),
      panel('Verkehr und erster Tag', transport),
      panel('Einfacher Tagesplan-Rahmen', dayPlan),
      panel('Warnungen vor häufigen Fehlern', mistakes),
    ].join('');

    const emailBody = [
      'ChinaTripBox Anfrage zur Reiseprüfung',
      '',
      `Heimatland oder Region: ${home}`,
      `Ankunftsstadt: ${arrival}`,
      `Zielstädte: ${cities.join(', ')}`,
      `Reisedauer: ${days} Tage`,
      `Zweck: ${purpose}`,
      `Budget: ${budget}`,
      `Stil: ${style}`,
      `Bedarf: ${needsText || 'nicht angegeben'}`,
      '',
      'Bitte prüfen Sie meine China-Reiseeinrichtung auf Zahlung, eSIM, Verkehr, Timing und Fehler am ersten Tag.',
    ].join('\n');

    if (emailLink) {
      emailLink.href = `mailto:zh13809022788@gmail.com?subject=${encodeURIComponent(
        'ChinaTripBox Anfrage zur Reiseprüfung',
      )}&body=${encodeURIComponent(emailBody)}`;
    }

    return html;
  };

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!content || !output) return;
    content.innerHTML = buildPlan();
    output.classList.remove('hidden');
    output.scrollIntoView({ behavior: 'smooth', block: 'start' });
    if (status) status.textContent = 'Plan erstellt. Passe deine Antworten an und erstelle ihn jederzeit neu.';
  });
</script>
