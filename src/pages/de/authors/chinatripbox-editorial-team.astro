---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";

const title = 'Redaktionsteam von ChinaTripBox';
const description =
  'Über das Redaktionsteam von ChinaTripBox, wie wir praktische Reiseführer für China recherchieren und wie Leser Korrekturen anfordern können.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': new URL('/authors/chinatripbox-editorial-team/#person', Astro.site).toString(),
  name: title,
  url: new URL('/authors/chinatripbox-editorial-team/', Astro.site).toString(),
  affiliation: {
    '@type': 'Organization',
    name: 'ChinaTripBox',
    url: new URL('/', Astro.site).toString(),
  },
  knowsAbout: [
    'Reiseplanung für China',
    'mobile Zahlungen in China',
    'China eSIM und Internetzugang',
    'Hochgeschwindigkeitszüge in China',
    'Logistik für ausländische Besucher in China',
  ],
};
---
<!-- KI-unterstutzt erstellter Inhalt, von muttersprachlichem Redakteur gepruft -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-12">
    <article class="prose-content article-body">
      <p class="section-kicker">Autor</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-900">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>

      <h2>Redaktioneller Schwerpunkt</h2>
      <p>
        Das Redaktionsteam von ChinaTripBox verfasst praktische Leitfäden für ausländische Besucher in China, mit
        einem Schwerpunkt auf der Einrichtung von Zahlungsmethoden, eSIM und Internetzugang, Hochgeschwindigkeitszügen, Fahrdiensten, Flughafentransfers,
        Stadtplanung, Essensbestellungen und häufigen Problemen auf der ersten Reise.
      </p>

      <h2>Wie wir Leitfäden erstellen</h2>
      <p>
        Wir kombinieren offizielle Quellen, Dokumentation von Anbietern, Hilfematerialien von Apps, Fragen von Lesern,
        Reiseberichte und praktische Überprüfungen, wo dies möglich ist. Bei sich schnell ändernden Themen wie
        visumfreier Einreise, Zahlungslimits, App-Verfügbarkeit und Verkehrsregeln betrachten wir offizielle
        Regierungs- oder Anbieterseiten als maßgebliche Quelle.
      </p>

      <h2>Korrekturen</h2>
      <p>
        Die Reiselogistik in China ändert sich schnell. Wenn Sie einen veralteten Schritt, eine geänderte Richtlinie, einen defekten
        Link oder einen fehlenden Hinweis finden, senden Sie bitte die URL der Seite über unsere <a href="/contact/">Kontaktseite</a>.
        Wir prüfen Korrekturen und aktualisieren betroffene Leitfäden, wenn die Belege eindeutig sind.
      </p>

      <h2>Redaktionsrichtlinie</h2>
      <p>
        Lesen Sie unsere <a href="/editorial-policy/">Redaktionsrichtlinie</a> für Einzelheiten zu Recherche,
        Aktualisierungen, Affiliate-Offenlegung, Unabhängigkeit und Einschränkungen.
      </p>

      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    </article>
  </main>
  <Footer />
</BaseLayout>