---

import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const CATEGORY = 'esim';
const posts = (await getCollection('posts-de'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'China eSIM und Daten: direkt nach der Ankunft online';
const description = 'Vergleiche und richte die besten eSIM-Datentarife für Reisen nach China ein. Sei sofort nach der Landung online, ganz ohne Wechsel der physischen SIM-Karte.';

const connectionChoices = [
  {
    title: 'eSIM',
    desc: 'Für die meisten Kurzreisen die beste Wahl, wenn dein Smartphone eSIM unterstützt und du schon vor der Landung mobile Daten nutzen möchtest.',
  },
  {
    title: 'Roaming',
    desc: 'Praktisch als Absicherung für Banking-SMS und Erreichbarkeit in der ersten Stunde, bei hohem Datenverbrauch aber oft teurer.',
  },
  {
    title: 'Pocket-WLAN oder lokale SIM-Karte',
    desc: 'Sinnvoll für Gruppen, längere Aufenthalte oder Smartphones, auf denen sich keine Reise-eSIM installieren lässt.',
  },
];

const internetTools = [
  { href: '/de/tools/esim-comparison/', title: 'eSIM-Tarifvergleich', desc: 'Vergleiche Reisedatentarife, Laufzeiten und typische Einsatzbereiche.' },
  { href: '/de/tools/app-availability-checker/', title: 'Prüfer für App-Verfügbarkeit', desc: 'Prüfe, welche gängigen Apps in China funktionieren und welche Alternativen du vorab vorbereiten solltest.' },
  { href: '/de/posts/internet-access-china-apps-that-work-2026/', title: 'Leitfaden zum Internetzugang', desc: 'Verstehe den App-Zugang, realistische VPN-Erwartungen und die praktische Vorbereitung vor der Ankunft.' },
];
import { getCategoryLabel } from '../../../i18n/categories';
const locale = 'de';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">eSIM</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Ratgeber zu eSIM und mobilen Daten</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="hub-esim" alt="Mobilfunknetz und Datenverbindungsoptionen für Chinareisen" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-esim">
      <h2 id="featured-esim" class="sr-only">Empfohlene Internet-Ratgeber</h2>
      <a href="/de/posts/best-esim-for-china-travel-2026/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Beste eSIM 2026</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Vergleiche Airalo, Holafly und Nomad für Reisen nach China</p>
      </a>
      <a href="/de/posts/china-esim-vs-roaming-2026-the-real-10-day-cost/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">eSIM oder Roaming</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Der echte Kostenvergleich für 10 Tage als Tourist</p>
      </a>
      <a href="/de/posts/do-you-need-a-vpn-in-china-2026/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">VPN-Ratgeber 2026</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Brauchen Touristen in China überhaupt noch ein VPN?</p>
      </a>
      <a href="/de/posts/pocket-wifi-vs-esim-vs-sim-china/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Pocket WiFi oder eSIM</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Vergleiche alle Möglichkeiten für die Internetverbindung</p>
      </a>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[1fr_340px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">Wähle die passende Internetlösung für China</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          Für Besucher ist eine Kombination aus einer primären Datenlösung und einer Ausweichoption für Banking, Karten, Übersetzungen und Ride-Hailing am ersten Tag meist die sicherste Wahl.
        </p>
        <div class="mt-5 grid gap-3">
          {connectionChoices.map((choice) => (
            <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
              <h3 class="text-sm font-bold text-gray-900">{choice.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{choice.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Hilfreiche Internet-Tools</h2>
        <div class="mt-4 grid gap-3">
          {internetTools.map((tool) => (
            <a href={tool.href} class="rounded-lg border border-brand-100 bg-white p-4 hover:border-brand-200 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-900 hover:text-brand-700">{tool.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{tool.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/de/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{getCategoryLabel(post.data.category, locale)}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('de-DE', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">Ratgeber folgen in Kürze.</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>