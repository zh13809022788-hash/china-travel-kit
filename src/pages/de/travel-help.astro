---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'China-Reisehilfe';
const description =
  'Stelle individuelle Fragen zu China-Reisen zu Zahlungen, eSIMs, Transport, Apps und der Einrichtung am ersten Tag mit KI-gestutzter Ersteinschatzung und optionaler menschlicher Hilfe.';

const quickPrompts = [
  'Meine Alipay- oder WeChat Pay-Karte lasst sich nicht verknupfen.',
  'Ich brauche einen eSIM- und App-Zugriffsplan fur meine Reise.',
  'Ich brauche Hilfe, um vom Flughafen zu meinem Hotel zu kommen.',
  'Ich bin mir nicht sicher, wie viel Bargeld ich mitbringen soll.',
];

const supportAreas = [
  'Zahlungseinrichtung: Alipay, WeChat Pay, Karten, Gebuhren und Bargeld als Reserve',
  'Konnektivitat: eSIMs, Roaming, VPN-sensitive Apps und Datenzugang bei der Ankunft am Flughafen',
  'Transport: Flughafenrouten, Metro, DiDi, Taxis und Grundlagen zum Hochgeschwindigkeitszug',
  'App-Nutzung: Ubersetzung, Essenslieferung, Karten, Ride-Hailing und Screenshots',
  'Reisevorbereitung: Checkliste fur den ersten Tag, stadtspezifische Vorbereitung und praktische nachste Schritte',
  'Weitergabe an Menschen: komplexe Falle, die Ruckfragen und Kontext brauchen',
];

const safetyRules = [
  'Sende keine Passfotos, vollstandigen Kartennummern, Passworter, PINs oder Einmalcodes.',
  'Bitte niemanden darum, sich in deine Konten einzuloggen oder Identitatsprufungen fur dich abzuschliessen.',
  'Nutze dies nicht fur rechtliche, Einwanderungs-, medizinische, Bank- oder Notfallberatung.',
  'Prufe wichtige Regeln bei offiziellen Quellen, Fluggesellschaften, Banken, Telekommunikationsanbietern oder App-Betreibern.',
];
---
<!-- KI-unterstutzt erstellter Inhalt, von muttersprachlichem Redakteur gepruft -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main>
    <section class="border-b border-gray-200 bg-white">
      <div class="container-page grid gap-8 py-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <div>
          <p class="section-kicker">Individuelle Reiseunterstutzung</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Stelle eine Frage zu deiner China-Reise, bevor sie dich ausbremst
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Starte mit kostenloser KI-Hilfe fur praktische Probleme bei China-Reisen. Wenn deine
            Frage menschliches Urteilsvermogen, Screenshots oder Ruckfragen mit Kontext braucht,
            wandle sie in eine Prufungsanfrage um.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#travel-help-chat" class="btn-primary">Anfrage starten</a>
            <a href="/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-outline">Checkliste vor der Reise nutzen</a>
            <a href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Travel%20Help%20Request" class="btn-outline">
              Direkt per E-Mail
            </a>
          </div>
        </div>

        <aside class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Pilotstatus</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Zuerst KI, spater menschliche Prufung</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Kostenlose Antworten werden von KI erzeugt. Menschlich geprufte Reisehilfe wird noch
            per E-Mail weitergeleitet, wahrend wir den Ablauf testen.
          </p>
          <dl class="mt-5 grid gap-3 text-sm">
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">Am besten geeignet fur</dt>
              <dd class="font-semibold text-gray-900">Praktische Reisevorbereitung</dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">Antwortweg</dt>
              <dd class="font-semibold text-gray-900">KI + Nachverfolgung per E-Mail</dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">Bezahlung</dt>
              <dd class="font-semibold text-gray-900">Nicht aktiv</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <section id="travel-help-chat" class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
          <div class="border-b border-gray-200 bg-gray-50 px-5 py-4">
          <p class="section-kicker">Kostenlose KI-Reisehilfe</p>
            <h2 class="mt-1 text-2xl font-bold text-gray-950">Reisehilfe-Schalter</h2>
          </div>

          <div class="grid gap-0 md:grid-cols-[minmax(0,1fr)_280px]">
            <div class="flex min-h-[560px] flex-col">
              <div id="chat-log" class="flex-1 space-y-4 overflow-y-auto p-5" aria-live="polite">
                <div class="max-w-[88%] rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-700">
                  <strong class="block text-gray-950">ChinaTripBox-Hilfe</strong>
                  Erzahl uns, was du tun willst, wo du dich in der Reise befindest und was bereits
                  passiert ist. Die KI-Hilfe schlagt nachste Schritte vor und weist darauf hin, wann
                  eine menschliche Prufung besser ist.
                </div>
              </div>

              <div class="border-t border-gray-200 p-4">
                <div class="mb-3 flex flex-wrap gap-2">
                  {quickPrompts.map((prompt) => (
                    <button
                      type="button"
                      class="quick-prompt rounded-full border border-gray-200 bg-white px-3 py-1.5 text-left text-xs font-medium text-gray-700 hover:border-brand-300 hover:bg-brand-50"
                      data-prompt={prompt}
                    >
                      {prompt}
                    </button>
                  ))}
                </div>
                <form id="travel-help-form" class="grid gap-3">
                  <label class="sr-only" for="help-message">Deine Reisefrage</label>
                  <textarea
                    id="help-message"
                    name="message"
                    rows="5"
                    class="w-full resize-y rounded-lg border border-gray-300 px-4 py-3 text-sm leading-6 text-gray-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
                    placeholder="Beispiel: Ich komme morgen in Shanghai an. Meine Mastercard lasst sich nicht mit WeChat Pay verknupfen, aber Alipay funktioniert. Kann ich trotzdem Metro, DiDi und Essenslieferung nutzen?"
                    required
                  ></textarea>
                  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <p id="form-status" class="text-sm text-gray-500">Vermeide sensible personliche Daten.</p>
                    <button id="help-submit" type="submit" class="btn-primary">KI fragen</button>
                  </div>
                </form>
              </div>
            </div>

            <aside class="border-t border-gray-200 bg-gray-50 p-5 md:border-l md:border-t-0">
              <h3 class="text-lg font-bold text-gray-950">Anfragedetails</h3>
              <div class="mt-4 grid gap-4">
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  Reisestadium
                  <select id="trip-stage" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                    <option>Vor der Abreise</option>
                    <option>Am Flughafen</option>
                    <option>Bereits in China</option>
                    <option>Planung fur Langzeitaufenthalt</option>
                  </select>
                </label>
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  Hauptthema
                  <select id="help-topic" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                    <option>Zahlungs-Apps</option>
                    <option>Internet und eSIM</option>
                    <option>Transportroute</option>
                    <option>Essen, Lieferung oder lokale Apps</option>
                    <option>Allgemeine Reisevorbereitung</option>
                  </select>
                </label>
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  Stadt oder Route
                  <input
                    id="help-location"
                    class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700"
                    placeholder="Shanghai, Beijing, Flughafen zum Hotel..."
                  />
                </label>
              </div>

              <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-4">
                <p class="text-sm font-bold text-gray-950">Menschliches Upgrade</p>
                <p class="mt-2 text-sm leading-6 text-gray-700">
                  Nutze dies, wenn eine einfache Anleitung nicht ausreicht. Die vorbereitete E-Mail
                  enthalt dein Thema, Stadium, deinen Ort und deine Frage, damit eine Person mit
                  Kontext antworten kann.
                </p>
              </div>

              <a
                id="email-request-link"
                href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Travel%20Help%20Request"
                class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:border-brand-600 hover:text-brand-600 hover:no-underline"
              >
                E-Mail-Anfrage vorbereiten
              </a>
            </aside>
          </div>
        </div>

        <aside class="space-y-6">
          <section class="rounded-lg border border-gray-200 bg-white p-5">
            <p class="section-kicker">Umfang</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Wobei das helfen kann</h2>
            <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
              {supportAreas.map((area) => (
                <li class="border-b border-gray-100 pb-3 last:border-b-0 last:pb-0">{area}</li>
              ))}
            </ul>
          </section>

          <section class="rounded-lg border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Sicherheitsregeln</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Halte sensible Daten heraus</h2>
            <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
              {safetyRules.map((rule) => (
                <li>{rule}</li>
              ))}
            </ul>
          </section>
        </aside>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <div class="card">
          <p class="section-kicker">Schritt 1</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Beschreibe das Problem</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Teile die Stadt, App, Route, Frist und mit, was du bereits versucht hast.
          </p>
        </div>
        <div class="card">
          <p class="section-kicker">Schritt 2</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Erhalte einen nachsten Schritt</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Die Seite gibt eine praktische erste Antwort und verweist dich auf relevante Leitfaden.
          </p>
        </div>
        <div class="card">
          <p class="section-kicker">Schritt 3</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Per E-Mail eskalieren</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Fur individuelle Hilfe sende die vorbereitete E-Mail und setze das Gesprach privat fort.
          </p>
        </div>
      </section>

      <section class="mt-10 rounded-lg border border-gray-200 bg-white p-5 md:p-6">
        <p class="section-kicker">Zuerst Selbstbedienung</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950">Leitfaden, die haufige Fragen zur ersten Reise beantworten</h2>
        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <a href="/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">China-Reiseplaner fur Erstbesucher</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Nutze dies, wenn du noch Zahlung, Daten, Transport und deinen ersten Ankunftstag organisierst.</p>
          </a>
          <a href="/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Checkliste fur die Vorbereitung vor der Abreise</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Prufe Alipay, WeChat Pay, eSIM, DiDi, Zugtickets, Ubersetzung, Adressen und Bargeldreserve, bevor du fliegst.</p>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('travel-help-form') as HTMLFormElement | null;
  const message = document.getElementById('help-message') as HTMLTextAreaElement | null;
  const chatLog = document.getElementById('chat-log');
  const status = document.getElementById('form-status');
  const stage = document.getElementById('trip-stage') as HTMLSelectElement | null;
  const topic = document.getElementById('help-topic') as HTMLSelectElement | null;
  const locationInput = document.getElementById('help-location') as HTMLInputElement | null;
  const emailLink = document.getElementById('email-request-link') as HTMLAnchorElement | null;
  const submitButton = document.getElementById('help-submit') as HTMLButtonElement | null;

  const guideLinks: Record<string, { label: string; href: string }> = {
    'Payment apps': { label: 'Anleitung zur Zahlungseinrichtung', href: '/payment/' },
    'Internet and eSIM': { label: 'eSIM-Anleitung', href: '/esim/' },
    'Transport route': { label: 'Transport-Anleitung', href: '/transport/' },
    'Food, delivery, or local apps': {
      label: 'Anleitung zur Essenslieferung',
      href: '/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    },
    'General trip setup': { label: 'Tool-Seite', href: '/tools/' },
  };

  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char] ?? char);

  const updateEmailLink = () => {
    if (!emailLink) return;
    const selectedStage = stage?.value ?? 'Before departure';
    const selectedTopic = topic?.value ?? 'General trip setup';
    const place = locationInput?.value.trim() || 'Nicht angegeben';
    const question = message?.value.trim() || '';
    const body = [
      'ChinaTripBox Travel Help Request',
      '',
      `Trip stage: ${selectedStage}`,
      `Main topic: ${selectedTopic}`,
      `City or route: ${place}`,
      '',
      'Question:',
      question,
      '',
      'I understand I should not include passport photos, full bank card numbers, passwords, PINs, or one-time codes.',
    ].join('\n');

    emailLink.href = `mailto:zh13809022788@gmail.com?subject=${encodeURIComponent(
      `Travel help: ${selectedTopic}`,
    )}&body=${encodeURIComponent(body)}`;
  };

  const addBubble = (content: string, fromUser = false) => {
    if (!chatLog) return null;
    const wrapper = document.createElement('div');
    wrapper.className = fromUser
      ? 'ml-auto max-w-[88%] rounded-lg bg-brand-600 p-4 text-sm leading-6 text-white'
      : 'max-w-[88%] rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-700';
    wrapper.innerHTML = content;
    chatLog.appendChild(wrapper);
    chatLog.scrollTop = chatLog.scrollHeight;
    return wrapper;
  };

  const formatAiAnswer = (value: string) =>
    escapeHtml(value)
      .replace(/\n{3,}/g, '\n\n')
      .replace(/\n/g, '<br>');

  const buildReply = (question: string) => {
    const selectedTopic = topic?.value ?? 'General trip setup';
    const selectedStage = stage?.value ?? 'Before departure';
    const place = locationInput?.value.trim();
    const guide = guideLinks[selectedTopic] ?? guideLinks['General trip setup'];
    const needsHuman =
      /screenshot|photo|declin|failed|stuck|urgent|tomorrow|today|passport|verification|identity|hotel|route/i.test(
        question,
      );

    const placeLine = place
      ? `Weil dies <strong>${escapeHtml(place)}</strong> betrifft, gib in deiner E-Mail den genauen Flughafen, Bahnhof, Hotelbereich, App-Namen und das Datum an.`
      : 'Erganz deine Stadt, deinen Flughafen, Bahnhof, Hotelbereich oder App-Namen, bevor du dies fur individuelle Hilfe abschickst.';

    const escalation = needsHuman
      ? 'Das sieht nach einem guten Fall fur menschliche Nachverfolgung aus, weil es Kontext oder Ruckfragen brauchen konnte.'
      : 'Das lasst sich moglicherweise zuerst mit dem Leitfaden beantworten; nutze menschliche Nachverfolgung, wenn der Leitfaden nicht zu deiner genauen Situation passt.';

    return `
      <strong class="block text-gray-950">Vorgeschlagener nachster Schritt</strong>
      <span class="block mt-1">Thema: ${escapeHtml(selectedTopic)}. Stadium: ${escapeHtml(selectedStage)}.</span>
      <span class="block mt-2">${placeLine}</span>
      <span class="block mt-2">Starte mit der <a href="${guide.href}" class="font-semibold text-brand-700">${guide.label}</a> und nutze dann die Schaltflache fur die vorbereitete E-Mail, wenn du weiterhin individuelle Hilfe brauchst.</span>
      <span class="block mt-2">${escalation}</span>
    `;
  };

  document.querySelectorAll<HTMLButtonElement>('.quick-prompt').forEach((button) => {
    button.addEventListener('click', () => {
      if (!message) return;
      message.value = button.dataset.prompt ?? '';
      message.focus();
      updateEmailLink();
    });
  });

  [message, stage, topic, locationInput].forEach((element) => {
    element?.addEventListener('input', updateEmailLink);
    element?.addEventListener('change', updateEmailLink);
  });

  const requestAiAnswer = async (question: string) => {
    const response = await fetch('/api/travel-help', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({
        message: question,
        stage: stage?.value ?? 'Before departure',
        topic: topic?.value ?? 'General trip setup',
        location: locationInput?.value.trim() ?? '',
      }),
    });

    const data = await response.json() as { answer?: string; error?: string };
    if (!response.ok || !data.answer) {
      throw new Error(data.error || 'AI helper unavailable.');
    }
    return data.answer;
  };

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const question = message?.value.trim() ?? '';
    if (!question) {
      if (status) status.textContent = 'Fuge zuerst deine Frage hinzu.';
      return;
    }
    addBubble(escapeHtml(question), true);
    const thinking = addBubble('Die KI pruft gerade deine Reisefrage...');
    if (status) status.textContent = 'KI-Reisehilfe wird gefragt...';
    if (submitButton) submitButton.disabled = true;

    try {
      const answer = await requestAiAnswer(question);
      if (thinking) {
        thinking.innerHTML = `
          <strong class="block text-gray-950">KI-Reisehilfe</strong>
          <span class="mt-2 block">${formatAiAnswer(answer)}</span>
          <span class="mt-3 block text-xs text-gray-500">Bei komplexen Konto-, Zahlungs-, Visum-, Rechts-, Medizin- oder Notfallthemen prufe dies beim offiziellen Anbieter oder fordere eine menschliche Prufung an.</span>
        `;
      }
      if (status) status.textContent = 'KI-Antwort ist bereit. Nutze E-Mail, wenn du menschliche Prufung willst.';
    } catch {
      if (thinking) thinking.innerHTML = buildReply(question);
      if (status) status.textContent = 'Die KI ist nicht verfugbar, daher wurde eine lokale Ausweichantwort vorbereitet.';
    } finally {
      if (submitButton) submitButton.disabled = false;
    }
    updateEmailLink();
  });

  updateEmailLink();
</script>