---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'China Reisehilfe';
const description =
  'Stelle individuelle Fragen zu China-Reisen rund um Zahlungen, eSIMs, Verkehr, Apps und die Einrichtung am ersten Tag - mit KI-gestützter Ersteinschätzung und optionaler menschlicher Hilfe.';

const quickPrompts = [
  'Meine Karte lässt sich nicht mit Alipay oder WeChat Pay verknüpfen.',
  'Ich brauche einen Plan für eSIM und App-Zugang für meine Reise.',
  'Ich brauche Hilfe, um vom Flughafen zu meinem Hotel zu kommen.',
  'Ich bin nicht sicher, wie viel Bargeld ich mitnehmen soll.',
];

const supportAreas = [
  'Zahlungseinrichtung: Alipay, WeChat Pay, Karten, Gebühren und Bargeldreserve',
  'Konnektivität: eSIMs, Roaming, VPN-empfindliche Apps und Daten bei der Ankunft am Flughafen',
  'Verkehr: Flughafenrouten, Metro, DiDi, Taxis und Grundlagen zum Hochgeschwindigkeitszug',
  'App-Nutzung: Übersetzung, Essenslieferung, Karten, Fahrdienste und Screenshots',
  'Reiseeinrichtung: Checkliste für den ersten Tag, stadtspezifische Vorbereitung und praktische nächste Schritte',
  'Menschliche Eskalation: komplexe Fälle, die Kontext und Rückfragen erfordern',
];

const safetyRules = [
  'Sende keine Passfotos, vollständigen Kartennummern, Passwörter, PINs oder Einmalcodes.',
  'Bitte niemanden, sich in deine Konten einzuloggen oder Identitätsprüfungen für dich abzuschließen.',
  'Nutze dies nicht für Rechts-, Einwanderungs-, Medizin-, Bank- oder Notfallberatung.',
  'Prüfe wichtige Regeln bei offiziellen Quellen, Fluggesellschaften, Banken, Telekommunikationsanbietern oder App-Betreibern.',
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main>
    <section class="border-b border-gray-200 bg-white">
      <div class="container-page grid gap-8 py-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <div>
          <p class="section-kicker">Individuelle Reiseunterstützung</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Stelle deine China-Reisefrage, bevor sie dich ausbremst
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Starte mit kostenloser KI-Hilfe für praktische China-Reiseprobleme. Wenn deine Frage
            menschliches Urteil, Screenshots oder Rückfragen braucht, wandle sie in eine Prüfanfrage um.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#travel-help-chat" class="btn-primary">Anfrage starten</a>
            <a href="/de/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-outline">Checkliste vor der Reise nutzen</a>
            <a href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Reisehilfe-Anfrage" class="btn-outline">
              Direkt per E-Mail schreiben
            </a>
          </div>
        </div>

        <aside class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Pilotstatus</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Erst KI, später menschliche Prüfung</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Kostenlose Antworten werden von KI generiert. Menschlich geprüfte Reisehilfe läuft noch per E-Mail,
            während wir den Ablauf testen.
          </p>
          <dl class="mt-5 grid gap-3 text-sm">
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">Am besten für</dt>
              <dd class="font-semibold text-gray-900">Praktische Reiseeinrichtung</dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">Antwortweg</dt>
              <dd class="font-semibold text-gray-900">KI + E-Mail-Nachfassen</dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">Zahlung</dt>
              <dd class="font-semibold text-gray-900">Nicht aktiv</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <section id="travel-help-chat" class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
          <div class="border-b border-gray-200 bg-gray-50 px-5 py-4">
          <p class="section-kicker">Kostenlose KI-Reisehilfe</p>
            <h2 class="mt-1 text-2xl font-bold text-gray-950">Reisehilfecenter</h2>
          </div>

          <div class="grid gap-0 md:grid-cols-[minmax(0,1fr)_280px]">
            <div class="flex min-h-[560px] flex-col">
              <div id="chat-log" class="flex-1 space-y-4 overflow-y-auto p-5" aria-live="polite">
                <div class="max-w-[88%] rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-700">
                  <strong class="block text-gray-950">ChinaTripBox Hilfe</strong>
                  Sag uns, was du tun möchtest, wo du dich in der Reiseplanung oder Reise befindest und was bereits
                  passiert ist. Die KI-Hilfe schlägt nächste Schritte vor und weist darauf hin, wann eine menschliche Prüfung besser ist.
                </div>
              </div>

              <div class="border-t border-gray-200 p-4">
                <div class="mb-3 flex flex-wrap gap-2">
                  {quickPrompts.map((prompt) => (
                    <button
                      type="button"
                      class="quick-prompt rounded-full border border-gray-200 bg-white px-3 py-1.5 text-left text-xs font-medium text-gray-700 hover:border-brand-300 hover:bg-brand-50"
                      data-prompt={prompt}
                    >
                      {prompt}
                    </button>
                  ))}
                </div>
                <form id="travel-help-form" class="grid gap-3">
                  <label class="sr-only" for="help-message">Deine Reisefrage</label>
                  <textarea
                    id="help-message"
                    name="message"
                    rows="5"
                    class="w-full resize-y rounded-lg border border-gray-300 px-4 py-3 text-sm leading-6 text-gray-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
                    placeholder="Beispiel: Ich komme morgen in Shanghai an. Meine Mastercard lässt sich nicht mit WeChat Pay verknüpfen, aber Alipay funktioniert. Kann ich trotzdem Metro, DiDi und Essenslieferungen nutzen?"
                    required
                  ></textarea>
                  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <p id="form-status" class="text-sm text-gray-500">Vermeide sensible personenbezogene Daten.</p>
                    <button id="help-submit" type="submit" class="btn-primary">KI fragen</button>
                  </div>
                </form>
              </div>
            </div>

            <aside class="border-t border-gray-200 bg-gray-50 p-5 md:border-l md:border-t-0">
              <h3 class="text-lg font-bold text-gray-950">Anfragedetails</h3>
              <div class="mt-4 grid gap-4">
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  Reisephase
                  <select id="trip-stage" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                    <option>Vor der Abreise</option>
                    <option>Am Flughafen</option>
                    <option>Bereits in China</option>
                    <option>Planung eines Langzeitaufenthalts</option>
                  </select>
                </label>
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  Hauptthema
                  <select id="help-topic" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                    <option>Zahlungs-Apps</option>
                    <option>Internet und eSIM</option>
                    <option>Verkehrsroute</option>
                    <option>Essen, Lieferung oder lokale Apps</option>
                    <option>Allgemeine Reiseeinrichtung</option>
                  </select>
                </label>
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  Stadt oder Route
                  <input
                    id="help-location"
                    class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700"
                    placeholder="Shanghai, Beijing, Flughafen zum Hotel..."
                  />
                </label>
              </div>

              <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-4">
                <p class="text-sm font-bold text-gray-950">Menschliche Prüfung</p>
                <p class="mt-2 text-sm leading-6 text-gray-700">
                  Nutze dies, wenn ein einfacher Leitfaden nicht ausreicht. Die vorbereitete E-Mail enthält dein Thema,
                  deine Reisephase, deinen Ort und deine Frage, damit eine Person mit Kontext antworten kann.
                </p>
              </div>

              <a
                id="email-request-link"
                href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Reisehilfe-Anfrage"
                class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:border-brand-600 hover:text-brand-600 hover:no-underline"
              >
                E-Mail-Anfrage vorbereiten
              </a>
            </aside>
          </div>
        </div>

        <aside class="space-y-6">
          <section class="rounded-lg border border-gray-200 bg-white p-5">
            <p class="section-kicker">Umfang</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Wobei dies helfen kann</h2>
            <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
              {supportAreas.map((area) => (
                <li class="border-b border-gray-100 pb-3 last:border-b-0 last:pb-0">{area}</li>
              ))}
            </ul>
          </section>

          <section class="rounded-lg border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Sicherheitsregeln</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Sensible Daten weglassen</h2>
            <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
              {safetyRules.map((rule) => (
                <li>{rule}</li>
              ))}
            </ul>
          </section>
        </aside>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <div class="card">
          <p class="section-kicker">Schritt 1</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Problem beschreiben</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Teile Stadt, App, Route, Frist und das, was du bereits versucht hast.
          </p>
        </div>
        <div class="card">
          <p class="section-kicker">Schritt 2</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Nächsten Schritt erhalten</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Die Seite gibt eine praktische erste Antwort und verweist dich auf passende Leitfäden.
          </p>
        </div>
        <div class="card">
          <p class="section-kicker">Schritt 3</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Per E-Mail eskalieren</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Für individuelle Hilfe sendest du die vorbereitete E-Mail und führst das Gespräch privat weiter.
          </p>
        </div>
      </section>

      <section class="mt-10 rounded-lg border border-gray-200 bg-white p-5 md:p-6">
        <p class="section-kicker">Zuerst Selbsthilfe</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950">Leitfäden, die häufige Fragen zur ersten Reise beantworten</h2>
        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <a href="/de/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">China-Reiseplaner für Erstbesucher</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Nutze ihn, wenn du Zahlung, Daten, Verkehr und deinen ersten Ankunftstag noch organisierst.</p>
          </a>
          <a href="/de/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Einrichtungscheckliste vor der Abreise</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Prüfe Alipay, WeChat Pay, eSIM, DiDi, Zugtickets, Übersetzung, Adressen und Bargeldreserve, bevor du fliegst.</p>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('travel-help-form') as HTMLFormElement | null;
  const message = document.getElementById('help-message') as HTMLTextAreaElement | null;
  const chatLog = document.getElementById('chat-log');
  const status = document.getElementById('form-status');
  const stage = document.getElementById('trip-stage') as HTMLSelectElement | null;
  const topic = document.getElementById('help-topic') as HTMLSelectElement | null;
  const locationInput = document.getElementById('help-location') as HTMLInputElement | null;
  const emailLink = document.getElementById('email-request-link') as HTMLAnchorElement | null;
  const submitButton = document.getElementById('help-submit') as HTMLButtonElement | null;

  const guideLinks: Record<string, { label: string; href: string }> = {
    'Zahlungs-Apps': { label: 'Leitfaden zur Zahlungseinrichtung', href: '/de/payment/' },
    'Internet und eSIM': { label: 'eSIM-Leitfaden', href: '/de/esim/' },
    'Verkehrsroute': { label: 'Verkehrsleitfaden', href: '/de/transport/' },
    'Essen, Lieferung oder lokale Apps': {
      label: 'Leitfaden zur Essenslieferung',
      href: '/de/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    },
    'Allgemeine Reiseeinrichtung': { label: 'Tools-Seite', href: '/de/tools/' },
  };

  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char] ?? char);

  const updateEmailLink = () => {
    if (!emailLink) return;
    const selectedStage = stage?.value ?? 'Vor der Abreise';
    const selectedTopic = topic?.value ?? 'Allgemeine Reiseeinrichtung';
    const place = locationInput?.value.trim() || 'Nicht angegeben';
    const question = message?.value.trim() || '';
    const body = [
      'ChinaTripBox Reisehilfe-Anfrage',
      '',
      `Reisephase: ${selectedStage}`,
      `Hauptthema: ${selectedTopic}`,
      `Stadt oder Route: ${place}`,
      '',
      'Frage:',
      question,
      '',
      'Ich verstehe, dass ich keine Passfotos, vollständigen Bankkartennummern, Passwörter, PINs oder Einmalcodes angeben sollte.',
    ].join('\n');

    emailLink.href = `mailto:zh13809022788@gmail.com?subject=${encodeURIComponent(
      `Reisehilfe: ${selectedTopic}`,
    )}&body=${encodeURIComponent(body)}`;
  };

  const addBubble = (content: string, fromUser = false) => {
    if (!chatLog) return null;
    const wrapper = document.createElement('div');
    wrapper.className = fromUser
      ? 'ml-auto max-w-[88%] rounded-lg bg-brand-600 p-4 text-sm leading-6 text-white'
      : 'max-w-[88%] rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-700';
    wrapper.innerHTML = content;
    chatLog.appendChild(wrapper);
    chatLog.scrollTop = chatLog.scrollHeight;
    return wrapper;
  };

  const formatAiAnswer = (value: string) =>
    escapeHtml(value)
      .replace(/\n{3,}/g, '\n\n')
      .replace(/\n/g, '<br>');

  const buildReply = (question: string) => {
    const selectedTopic = topic?.value ?? 'Allgemeine Reiseeinrichtung';
    const selectedStage = stage?.value ?? 'Vor der Abreise';
    const place = locationInput?.value.trim();
    const guide = guideLinks[selectedTopic] ?? guideLinks['Allgemeine Reiseeinrichtung'];
    const needsHuman =
      /screenshot|photo|declin|failed|stuck|urgent|tomorrow|today|passport|verification|identity|hotel|route/i.test(
        question,
      );

    const placeLine = place
      ? `Da es hierbei um <strong>${escapeHtml(place)}</strong> geht, nenne in deiner E-Mail den genauen Flughafen, Bahnhof, Hotelbereich, App-Namen und das Datum.`
      : 'Füge deine Stadt, deinen Flughafen, Bahnhof, Hotelbereich oder App-Namen hinzu, bevor du dies für individuelle Hilfe sendest.';

    const escalation = needsHuman
      ? 'Das eignet sich wahrscheinlich für ein menschliches Nachfassen, weil Kontext oder Rückfragen nötig sein könnten.'
      : 'Das lässt sich möglicherweise zuerst mit dem Leitfaden beantworten; nutze menschliches Nachfassen, wenn der Leitfaden nicht zu deiner genauen Situation passt.';

    return `
      <strong class="block text-gray-950">Vorgeschlagener nächster Schritt</strong>
      <span class="block mt-1">Thema: ${escapeHtml(selectedTopic)}. Phase: ${escapeHtml(selectedStage)}.</span>
      <span class="block mt-2">${placeLine}</span>
      <span class="block mt-2">Beginne mit dem <a href="${guide.href}" class="font-semibold text-brand-700">${guide.label}</a> und nutze danach die vorbereitete E-Mail-Schaltfläche, falls du weiterhin individuelle Hilfe brauchst.</span>
      <span class="block mt-2">${escalation}</span>
    `;
  };

  document.querySelectorAll<HTMLButtonElement>('.quick-prompt').forEach((button) => {
    button.addEventListener('click', () => {
      if (!message) return;
      message.value = button.dataset.prompt ?? '';
      message.focus();
      updateEmailLink();
    });
  });

  [message, stage, topic, locationInput].forEach((element) => {
    element?.addEventListener('input', updateEmailLink);
    element?.addEventListener('change', updateEmailLink);
  });

  const requestAiAnswer = async (question: string) => {
    const response = await fetch('/api/travel-help', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({
        message: question,
        stage: stage?.value ?? 'Vor der Abreise',
        topic: topic?.value ?? 'Allgemeine Reiseeinrichtung',
        location: locationInput?.value.trim() ?? '',
      }),
    });

    const data = await response.json() as { answer?: string; error?: string };
    if (!response.ok || !data.answer) {
      throw new Error(data.error || 'KI-Hilfe nicht verfügbar.');
    }
    return data.answer;
  };

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const question = message?.value.trim() ?? '';
    if (!question) {
      if (status) status.textContent = 'Füge zuerst deine Frage hinzu.';
      return;
    }
    addBubble(escapeHtml(question), true);
    const thinking = addBubble('Die KI prüft deine Reisefrage...');
    if (status) status.textContent = 'KI-Reisehilfe wird gefragt...';
    if (submitButton) submitButton.disabled = true;

    try {
      const answer = await requestAiAnswer(question);
      if (thinking) {
        thinking.innerHTML = `
          <strong class="block text-gray-950">KI-Reisehilfe</strong>
          <span class="mt-2 block">${formatAiAnswer(answer)}</span>
          <span class="mt-3 block text-xs text-gray-500">Bei komplexen Konto-, Zahlungs-, Visa-, Rechts-, Medizin- oder Notfallfragen prüfe die Angaben beim offiziellen Anbieter oder fordere eine menschliche Prüfung an.</span>
        `;
      }
      if (status) status.textContent = 'KI-Antwort ist bereit. Nutze E-Mail, wenn du eine menschliche Prüfung möchtest.';
    } catch {
      if (thinking) thinking.innerHTML = buildReply(question);
      if (status) status.textContent = 'Die KI ist nicht verfügbar, daher wurde eine lokale Ersatzantwort vorbereitet.';
    } finally {
      if (submitButton) submitButton.disabled = false;
    }
    updateEmailLink();
  });

  updateEmailLink();
</script>
