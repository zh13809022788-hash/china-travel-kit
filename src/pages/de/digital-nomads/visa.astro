const url = '/digital-nomads/visa/';
const datePublished = '2026-07-09';

const breadcrumbs = [
  { label: 'Startseite', href: '/' },
  { label: 'Digitale Nomaden', href: '/digital-nomads/' },
  { label: 'Visum-Guide' },
];

const toc = [
  { id: 'no-nomad-visa', label: 'Das Wichtigste in Kürze' },
  { id: 'tourist', label: 'Option 1: Touristenvisum (L)' },
  { id: 'business', label: 'Option 2: Geschäftsvisum (M)' },
