const faqs = [
  {
    question: 'Hat China ein Visum für digitale Nomaden?',
    answer:
      'Nein. Stand 2026 hat China keine Visumkategorie, die für Remote-Arbeiter oder ortsunabhängige Berufstätige ausgelegt ist. Digitale Nomaden nutzen stattdessen Touristenvisa (L), Geschäftsvisa (M) oder visumfreien Transit und kombinieren oder verlängern diese, um die benötigte Aufenthaltsdauer abzudecken.',
  },
  {
    question: 'Darf ich mit einem Touristenvisum in China legal remote arbeiten?',
    answer:
      'Online für dein eigenes ausländisches Unternehmen oder für ausländische Kunden zu arbeiten, während du mit einem Touristenvisum in China bist, bewegt sich in einer unregulierten Grauzone, statt klar erlaubt zu sein. Klar verboten ist dagegen, eine lokale Beschäftigung anzunehmen oder bezahlte Arbeit für chinesische Kunden mit einem L-Visum zu leisten. Halte deine Arbeit strikt grenzüberschreitend, vermeide jede lokale wirtschaftliche Tätigkeit und gib bei der Einreise nicht an, dass du arbeitest.',
  },
  {
    question: 'Was passiert, wenn ich mein chinesisches Visum überziehe?',
    answer:
      'Ein überzogener Aufenthalt führt zu einer täglichen Geldstrafe (häufig bis zu 500 RMB pro Tag, mit einer Obergrenze), möglicher Haft bei längeren Überschreitungen und einem Eintrag, der künftige Visumanträge erschweren kann. Verlängere es immer beim lokalen Exit-Entry-Büro oder reise aus, bevor dein erlaubter Aufenthalt endet. Verlass dich niemals darauf, einfach durchgewunken zu werden.',
  },
  {
    question: 'Kann ich mein Touristenvisum innerhalb Chinas verlängern?',
    answer:
      'Oft ja, einmal. Viele Staatsangehörige können beim lokalen Exit-Entry-Büro des Public Security Bureau eine einmalige 30-tägige Verlängerung eines L-Visums beantragen, sofern sie dies mehrere Tage vor Ablauf des aktuellen Aufenthalts tun und eine Hotelbuchung oder Wohnsitzregistrierung sowie einen Finanzierungsnachweis vorlegen. Die Genehmigung liegt im Ermessen des Beamten und ist nicht garantiert.',
  },
  {
    question: 'Kann ich von einem Touristenvisum zu einem Geschäftsvisum wechseln, ohne China zu verlassen?',
    answer:
      'Im Allgemeinen nein. Ein Wechsel des Visumtyps erfordert normalerweise, das neue Visum außerhalb des chinesischen Festlands zu beantragen, oft im Heimatland oder in einem nahegelegenen Drehkreuz wie Hong Kong. Plane den Wechsel eher als Ausreise-und-Wiedereinreise-Reise statt als Umwandlung innerhalb des Landes.',
  },
  {
    question: 'Ist ein Border Run nach Hong Kong eine verlässliche Methode, um meinen Aufenthalt zurückzusetzen?',
    answer:
      'Es kann funktionieren, wenn dein Visum mehrere Einreisen erlaubt, ist aber weniger verlässlich als früher. Einwanderungsbeamte achten auf wiederholte kurze Ausreisen, die dazu genutzt werden, dauerhaft in China zu leben, und können Fragen stellen oder Aufenthalte verkürzen. Betrachte Border Runs als gelegentliches Hilfsmittel, nicht als langfristige Visastrategie.',
  },
  {
    question: 'Wie lange im Voraus sollte ich ein China-Visum beantragen?',
    answer:
      'Beantrage es drei bis sechs Wochen vor der Reise. Touristen- und Geschäftsvisa werden nach Einreichung typischerweise in etwa vier bis sieben Arbeitstagen bearbeitet, aber die Verfügbarkeit von Terminen in Visazentren, das Zusammenstellen der Unterlagen (einschließlich eines etwaigen Einladungsschreibens für ein M-Visum) und die Kurierzeit summieren sich. Zu knapp zu planen erhöht das Risiko eines abgelehnten oder unvollständigen Antrags.',
  },
];

const related = [
  {
    title: 'Wie man in China als Ausländer bezahlt',
    description: 'Wenn dein Visum geregelt ist, richte Alipay und WeChat Pay ein und verstehe den Umgang mit Bargeld und Karten.',
