const toc = [
  { id: 'why-mobile', label: 'Warum mobile Zahlungen alles bestimmen' },
  { id: 'alipay', label: 'Alipay fur Auslander' },
  { id: 'wechat', label: 'WeChat Pay fur Auslander' },
  { id: 'cash', label: 'Braucht man noch Bargeld?' },
  { id: 'cards', label: 'Verwendung auslandischer Kreditkarten' },
