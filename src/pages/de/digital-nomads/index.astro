];

const toc = [
  { id: 'overview', label: 'China for Digital Nomads' },
  { id: 'guides', label: 'Core Guides' },
  { id: 'internet', label: 'Internet & Remote Work' },
  { id: 'cost', label: 'Cost of Living by City' },
  { id: 'english', label: 'English & Livability' },
