---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const CATEGORY = 'payment';
const posts = (await getCollection('posts-de'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Bezahlen in China: Alipay, WeChat Pay und ausländische Karten';
const description =
  'Schritt-für-Schritt-Leitfäden zum Bezahlen in China: Alipay und WeChat Pay einrichten, Karten verknüpfen und typische Probleme vermeiden.';

const prioritySteps = [
  'Installiere Alipay und WeChat vor der Abreise und verifiziere deine Identität, solange du noch Zugriff auf deine Hausbank und Telefonnummer hast.',
  'Verknüpfe mindestens eine Visa- oder Mastercard und behalte eine zweite Karte einer anderen Bank als Reserve.',
  'Führe einen kleinen Betrag an RMB-Bargeld mit dir für Taxis, kleine Geschäfte und Momente, in denen die Wallet-Verifizierung oder Kartenautorisierung scheitert.',
];

const paymentTools = [
  { href: '/de/tools/payment-checker/', title: 'Prüfer für Zahlungs-Kompatibilität', desc: 'Prüfe Kartenunterstützung, typische Limits und Gebühren für Alipay und WeChat Pay.' },
  { href: '/de/tools/budget-cash-estimator/', title: 'Budget- und Bargeldrechner', desc: 'Schätze Reiseausgaben und wie viel Bargeld du als Reserve mitnehmen solltest.' },
  { href: '/de/tools/currency-converter/', title: 'RMB-Währungsumrechner', desc: 'Wandle Preise in Yuan um und verstehe alltägliche Kosten.' },
];
import { getCategoryLabel } from '../../../i18n/categories';
const locale = 'de';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Bezahlung</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Zahlungsleitfäden für China</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-how-to-pay" alt="Smartphone mit mobilen Zahlungsmethoden für Reisen nach China" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-payment">
      <h2 id="featured-payment" class="sr-only">Empfohlene Zahlungsleitfäden</h2>
      <a href="/de/posts/alipay-foreign-credit-card-step-by-step/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Alipay einrichten</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Schritt-für-Schritt-Anleitung zur Installation von Alipay und zum Verknüpfen einer ausländischen Kreditkarte</p>
      </a>
      <a href="/de/posts/wechat-pay-foreign-visitors-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">WeChat Pay</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Vollständiger Leitfaden zur Einrichtung und Nutzung für ausländische Besucher</p>
      </a>
      <a href="/de/posts/alipay-vs-wechat-pay-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Alipay vs. WeChat Pay</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Welche Zahlungs-App solltest du 2026 verwenden?</p>
      </a>
      <a href="/de/posts/how-to-pay-in-china-tourist-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Vollständiger Zahlungsleitfaden</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Alles, was du als Tourist über das Bezahlen in China wissen musst</p>
      </a>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[1fr_340px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">Beginne mit einer zuverlässigen Zahlungseinrichtung</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          In China stehen QR-Zahlungen meist an erster Stelle. Eine touristenfreundliche Einrichtung bedeutet in der Regel eine Haupt-Wallet, eine Reserve-Wallet, zwei Kartenoptionen und einen kleinen Bargeldbetrag für Ausnahmen.
        </p>
        <ol class="mt-5 space-y-3 text-sm leading-6 text-gray-600">
          {prioritySteps.map((step, index) => (
            <li class="flex gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand-50 text-xs font-bold text-brand-700">{index + 1}</span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Zahlungstools</h2>
        <div class="mt-4 grid gap-3">
          {paymentTools.map((tool) => (
            <a href={tool.href} class="rounded-lg border border-brand-100 bg-white p-4 hover:border-brand-200 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-900 hover:text-brand-700">{tool.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{tool.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/de/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{post.data.category === 'payment' ? 'Bezahlung' : post.data.category}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('de-DE', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">Leitfäden erscheinen in Kürze.</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>
---