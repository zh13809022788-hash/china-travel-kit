---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Wichtige chinesische Sätze für Reisende';
const description =
  'Eine praktische, druckfreundliche Sammlung wichtiger Mandarin-Sätze für China-Reisende mit chinesischen Schriftzeichen und Pinyin. Enthält Begrüßungen, Bezahlung, Verkehr, Essen und Notfälle.';

interface Phrase {
  de: string;
  zh: string;
  pinyin: string;
}
interface Group {
  id: string;
  label: string;
  icon: string;
  phrases: Phrase[];
}

const groups: Group[] = [
  {
    id: 'basics', label: 'Begrüßung & Grundlagen', icon: '🗣️',
    phrases: [
      { de: 'Hallo', zh: '你好', pinyin: 'ni hao' },
      { de: 'Danke', zh: '谢谢', pinyin: 'xie xie' },
      { de: 'Gern geschehen', zh: '不客气', pinyin: 'bu ke qi' },
      { de: 'Entschuldigung', zh: '对不起', pinyin: 'dui bu qi' },
      { de: 'Ja', zh: '对', pinyin: 'dui' },
      { de: 'Nein', zh: '不是', pinyin: 'bu shi' },
      { de: 'Ich verstehe nicht', zh: '我不明白', pinyin: 'wo bu ming bai' },
      { de: 'Sprechen Sie Englisch?', zh: '你会说英语吗？', pinyin: 'ni hui shuo ying yu ma' },
    ],
  },
  {
    id: 'payment', label: 'Geld & Bezahlung', icon: '💸',
    phrases: [
      { de: 'Wie viel kostet das?', zh: '多少钱？', pinyin: 'duo shao qian' },
      { de: 'Kann ich mit Alipay bezahlen?', zh: '可以用支付宝吗？', pinyin: 'ke yi yong zhi fu bao ma' },
      { de: 'Kann ich mit WeChat Pay bezahlen?', zh: '可以用微信支付吗？', pinyin: 'ke yi yong wei xin zhi fu ma' },
      { de: 'Das ist zu teuer', zh: '太贵了', pinyin: 'tai gui le' },
      { de: 'Kann ich mit Karte bezahlen?', zh: '可以刷卡吗？', pinyin: 'ke yi shua ka ma' },
      { de: 'Ich scanne Ihren QR-Code', zh: '我扫你的码', pinyin: 'wo sao ni de ma' },
    ],
  },
  {
    id: 'transport', label: 'Unterwegs', icon: '🚇',
    phrases: [
      { de: 'Wo ist die U-Bahn?', zh: '地铁站在哪里？', pinyin: 'di tie zhan zai na li' },
      { de: 'Bitte bringen Sie mich zu dieser Adresse', zh: '请带我去这个地址', pinyin: 'qing dai wo qu zhe ge di zhi' },
      { de: 'Bitte hier anhalten', zh: '请在这里停', pinyin: 'qing zai zhe li ting' },
      { de: 'Bahnhof', zh: '火车站', pinyin: 'huo che zhan' },
      { de: 'Flughafen', zh: '机场', pinyin: 'ji chang' },
      { de: 'Wie komme ich nach ...?', zh: '怎么去……？', pinyin: 'zen me qu' },
    ],
  },
  {
    id: 'food', label: 'Essen & Restaurant', icon: '🍜',
    phrases: [
      { de: 'Die Speisekarte, bitte', zh: '请给我菜单', pinyin: 'qing gei wo cai dan' },
      { de: 'Ich esse vegetarisch', zh: '我吃素', pinyin: 'wo chi su' },
      { de: 'Bitte nicht scharf', zh: '请不要辣', pinyin: 'qing bu yao la' },
      { de: 'Wasser, bitte', zh: '请给我水', pinyin: 'qing gei wo shui' },
      { de: 'Die Rechnung, bitte', zh: '买单', pinyin: 'mai dan' },
      { de: 'Es schmeckt sehr gut', zh: '很好吃', pinyin: 'hen hao chi' },
    ],
  },
  {
    id: 'help', label: 'Hilfe & Notfall', icon: '🆘',
    phrases: [
      { de: 'Hilfe!', zh: '救命！', pinyin: 'jiu ming' },
      { de: 'Wo ist die Toilette?', zh: '洗手间在哪里？', pinyin: 'xi shou jian zai na li' },
      { de: 'Ich brauche einen Arzt', zh: '我需要看医生', pinyin: 'wo xu yao kan yi sheng' },
      { de: 'Rufen Sie bitte die Polizei', zh: '请报警', pinyin: 'qing bao jing' },
      { de: 'Ich habe mich verlaufen', zh: '我迷路了', pinyin: 'wo mi lu le' },
      { de: 'Bitte schreiben Sie es auf', zh: '请写下来', pinyin: 'qing xie xia lai' },
    ],
  },
];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Tool</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Wichtige chinesische Sätze</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 flex flex-wrap items-center gap-3 print:hidden">
      <button data-filter="all" class="phrase-filter btn-primary text-sm">Alle</button>
      {groups.map((g) => (
        <button data-filter={g.id} class="phrase-filter rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:border-brand-400">
          {g.icon} {g.label}
        </button>
      ))}
      <button id="print-btn" class="ml-auto rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:border-brand-400">
        Drucken / als PDF speichern
      </button>
    </div>

    <div class="mt-6 space-y-8">
      {groups.map((g) => (
        <section class="phrase-group" data-group={g.id}>
          <h2 class="mb-3 text-xl font-bold text-gray-900">{g.icon} {g.label}</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            {g.phrases.map((p) => (
              <div class="card flex flex-col">
                <span class="text-sm text-gray-500">{p.de}</span>
                <span class="mt-1 text-2xl font-bold text-gray-900">{p.zh}</span>
                <span class="mt-0.5 text-sm italic text-brand-600">{p.pinyin}</span>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>

    <AffiliateCta
      title="Unterwegs übersetzen und navigieren"
      description="Mit einer funktionierenden China-eSIM bleiben Übersetzungs-Apps, Karten und Messenger schon ab der Landung einsatzbereit."
      buttonText="eSIM-Optionen ansehen"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.phrase-filter');
  const sections = document.querySelectorAll<HTMLElement>('.phrase-group');
  const printBtn = document.getElementById('print-btn');

  const idleCls = ['rounded-lg', 'border', 'border-gray-300', 'px-3', 'py-1.5', 'text-sm', 'font-medium', 'text-gray-700', 'hover:border-brand-400'];

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      sections.forEach((s) => {
        s.classList.toggle('hidden', filter !== 'all' && s.dataset.group !== filter);
      });
      buttons.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('btn-primary', on);
        idleCls.forEach((c) => b.classList.toggle(c, !on));
      });
    });
  });

  printBtn?.addEventListener('click', () => window.print());
</script>
