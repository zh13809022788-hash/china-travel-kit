---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const titel = 'Nützliche chinesische Redewendungen für Reisende';
const beschreibung =
  'Eine praktische, druckbare Sammlung nützlicher Mandarin-Redewendungen für Reisen in China – mit Pinyin und deutscher Bedeutung. Mit Formulierungen für Begrüßungen, Bezahlen, unterwegs sein, Essen und Notfälle.';

interface Redewendung {
  de: string;
  zh: string;
  pinyin: string;
}
interface Gruppe {
  id: string;
  bezeichnung: string;
  symbol: string;
  redewendungen: Redewendung[];
}

const gruppen: Gruppe[] = [
  {
    id: 'grundlagen', bezeichnung: 'Begrüßung & Grundbegriffe', symbol: '👋',
    redewendungen: [
      { de: 'Hallo', zh: '你好', pinyin: 'nǐ hǎo' },
      { de: 'Danke', zh: '谢谢', pinyin: 'xièxie' },
      { de: 'Gern geschehen', zh: '不客气', pinyin: 'bú kèqi' },
      { de: 'Entschuldigung / Es tut mir leid', zh: '对不起', pinyin: 'duìbuqǐ' },
      { de: 'Ja / Das stimmt', zh: '对', pinyin: 'duì' },
      { de: 'Nein / Nicht', zh: '不是', pinyin: 'bú shì' },
      { de: 'Ich verstehe nicht', zh: '我不明白', pinyin: 'wǒ bù míngbái' },
      { de: 'Sprechen Sie Englisch?', zh: '你会说英语吗？', pinyin: 'nǐ huì shuō yīngyǔ ma?' },
    ],
  },
  {
    id: 'bezahlen', bezeichnung: 'Geld & Bezahlen', symbol: '💳',
    redewendungen: [
      { de: 'Wie viel kostet das?', zh: '多少钱？', pinyin: 'duōshao qián?' },
      { de: 'Kann ich mit Alipay bezahlen?', zh: '可以用支付宝吗？', pinyin: 'kěyǐ yòng zhīfùbǎo ma?' },
      { de: 'Kann ich mit WeChat Pay bezahlen?', zh: '可以用微信支付吗？', pinyin: 'kěyǐ yòng wēixìn zhīfù ma?' },
      { de: 'Das ist zu teuer', zh: '太贵了', pinyin: 'tài guì le' },
      { de: 'Kann ich mit Karte bezahlen?', zh: '可以刷卡吗？', pinyin: 'kěyǐ shuākǎ ma?' },
      { de: 'Ich scanne Ihren QR-Code', zh: '我扫你的码', pinyin: 'wǒ sǎo nǐ de mǎ' },
    ],
  },
  {
    id: 'unterwegs', bezeichnung: 'Unterwegs', symbol: '🚕',
    redewendungen: [
      { de: 'Wo ist die U-Bahn?', zh: '地铁站在哪里？', pinyin: 'dìtiě zhàn zài nǎlǐ?' },
      { de: 'Bitte bringen Sie mich zu dieser Adresse', zh: '请带我去这个地址', pinyin: 'qǐng dài wǒ qù zhège dìzhǐ' },
      { de: 'Bitte halten Sie hier an', zh: '请在这里停', pinyin: 'qǐng zài zhèlǐ tíng' },
      { de: 'Bahnhof', zh: '火车站', pinyin: 'huǒchē zhàn' },
      { de: 'Flughafen', zh: '机场', pinyin: 'jīchǎng' },
      { de: 'Wie komme ich zu ...?', zh: '怎么去...？', pinyin: 'zěnme qù...?' },
    ],
  },
  {
    id: 'essen', bezeichnung: 'Essen & Trinken', symbol: '🍜',
    redewendungen: [
      { de: 'Die Speisekarte, bitte', zh: '请给我菜单', pinyin: 'qǐng gěi wǒ càidān' },
      { de: 'Ich bin Vegetarier / Vegetarierin', zh: '我吃素', pinyin: 'wǒ chī sù' },
      { de: 'Bitte nicht scharf', zh: '请不要辣', pinyin: 'qǐng búyào là' },
      { de: 'Wasser, bitte', zh: '请给我水', pinyin: 'qǐng gěi wǒ shuǐ' },
      { de: 'Die Rechnung, bitte', zh: '买单', pinyin: 'mǎidān' },
      { de: 'Das schmeckt sehr gut', zh: '很好吃', pinyin: 'hěn hǎochī' },
    ],
  },
  {
    id: 'notfaelle', bezeichnung: 'Hilfe & Notfälle', symbol: '🆘',
    redewendungen: [
      { de: 'Hilfe!', zh: '救命！', pinyin: 'jiùmìng!' },
      { de: 'Wo ist die Toilette?', zh: '洗手间在哪里？', pinyin: 'xǐshǒujiān zài nǎlǐ?' },
      { de: 'Ich brauche einen Arzt', zh: '我需要看医生', pinyin: 'wǒ xūyào kàn yīshēng' },
      { de: 'Rufen Sie die Polizei', zh: '请报警', pinyin: 'qǐng bàojǐng' },
      { de: 'Ich habe mich verlaufen', zh: '我迷路了', pinyin: 'wǒ mílù le' },
      { de: 'Bitte schreiben Sie das auf', zh: '请写下来', pinyin: 'qǐng xiě xiàlái' },
    ],
  },
];
---
<BaseLayout title={`${titel} | ChinaTripBox`} description={beschreibung} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Hilfsmittel</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Nützliche chinesische Redewendungen</h1>
      <p class="mt-3 text-lg text-gray-600">{beschreibung}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 flex flex-wrap items-center gap-3 print:hidden">
      <button data-filter="alle" class="phrase-filter btn-primary text-sm">Alle Themen</button>
      {gruppen.map((gruppe) => (
        <button data-filter={gruppe.id} class="phrase-filter rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:border-brand-400">
          {gruppe.symbol} {gruppe.bezeichnung}
        </button>
      ))}
      <button id="druck-btn" class="ml-auto rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:border-brand-400">
        🖨️ Drucken / als PDF speichern
      </button>
    </div>

    <div class="mt-6 space-y-8">
      {gruppen.map((gruppe) => (
        <section class="phrase-group" data-group={gruppe.id}>
          <h2 class="mb-3 text-xl font-bold text-gray-900">{gruppe.symbol} {gruppe.bezeichnung}</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            {gruppe.redewendungen.map((redewendung) => (
              <div class="card flex flex-col">
                <span class="text-sm text-gray-500">{redewendung.de}</span>
                <span class="mt-1 text-2xl font-bold text-gray-900">{redewendung.zh}</span>
                <span class="mt-0.5 text-sm italic text-brand-600">{redewendung.pinyin}</span>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>

    <AffiliateCta
      title="Bleiben Sie online, damit Sie unterwegs übersetzen können"
      description="Mit einer eSIM für China funktionieren Übersetzungs-Apps und Karten direkt nach der Landung."
      buttonText="Jetzt verbinden"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script>
  const filterSchaltflaechen = document.querySelectorAll<HTMLButtonElement>('.phrase-filter');
  const gruppenAbschnitte = document.querySelectorAll<HTMLElement>('.phrase-group');
  const druckButton = document.getElementById('druck-btn');

  const inaktiveKlassen = ['rounded-lg', 'border', 'border-gray-300', 'px-3', 'py-1.5', 'text-sm', 'font-medium', 'text-gray-700', 'hover:border-brand-400'];

  filterSchaltflaechen.forEach((schaltflaeche) => {
    schaltflaeche.addEventListener('click', () => {
      const filter = schaltflaeche.dataset.filter;
      gruppenAbschnitte.forEach((abschnitt) => {
        abschnitt.classList.toggle('hidden', filter !== 'alle' && abschnitt.dataset.group !== filter);
      });
      filterSchaltflaechen.forEach((button) => {
        const istAktiv = button === schaltflaeche;
        button.classList.toggle('btn-primary', istAktiv);
        inaktiveKlassen.forEach((klasse) => button.classList.toggle(klasse, !istAktiv));
      });
    });
  });

  druckButton?.addEventListener('click', () => window.print());
</script>
