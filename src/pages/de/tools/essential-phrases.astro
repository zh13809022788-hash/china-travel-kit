---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import AdSlot from "../../../components/AdSlot.astro";
import AffiliateCta from "../../../components/AffiliateCta.astro";
import { AFFILIATE_LINKS } from "../../../config";

const title = 'Wichtige chinesische Redewendungen für Reisende';
const description =
  'Eine praktische, druckbare Liste mit wichtigen mandarinchinesischen Redewendungen für Touristen in China — mit Pinyin und Englisch. Umfasst Begrüßungen, Bezahlen, Transport, Essen und Notfälle.';

interface Phrase {
  en: string;
  zh: string;
  pinyin: string;
}
interface Group {
  id: string;
  label: string;
  icon: string;
  phrases: Phrase[];
}

const groups: Group[] = [
  {
    id: 'basics', label: 'Begrüßungen & Grundlagen', icon: '👋',
    phrases: [
      { en: 'Hallo', zh: '你好', pinyin: 'nǐ hǎo' },
      { en: 'Danke', zh: '谢谢', pinyin: 'xièxie' },
      { en: 'Gern geschehen', zh: '不客气', pinyin: 'bú kèqi' },
      { en: 'Entschuldigung / Verzeihung', zh: '对不起', pinyin: 'duìbuqǐ' },
      { en: 'Ja / Richtig', zh: '对', pinyin: 'duì' },
      { en: 'Nein / Nicht', zh: '不是', pinyin: 'bú shì' },
      { en: 'Ich verstehe nicht', zh: '我不明白', pinyin: 'wǒ bù míngbái' },
      { en: 'Sprechen Sie Englisch?', zh: '你会说英语吗？', pinyin: 'nǐ huì shuō yīngyǔ ma?' },
    ],
  },
  {
    id: 'payment', label: 'Geld & Bezahlen', icon: '💳',
    phrases: [
      { en: 'Wie viel kostet das?', zh: '多少钱？', pinyin: 'duōshao qián?' },
      { en: 'Kann ich Alipay benutzen?', zh: '可以用支付宝吗？', pinyin: 'kěyǐ yòng zhīfùbǎo ma?' },
      { en: 'Kann ich WeChat Pay benutzen?', zh: '可以用微信支付吗？', pinyin: 'kěyǐ yòng wēixìn zhīfù ma?' },
      { en: 'Zu teuer', zh: '太贵了', pinyin: 'tài guì le' },
      { en: 'Kann ich mit Karte bezahlen?', zh: '可以刷卡吗？', pinyin: 'kěyǐ shuākǎ ma?' },
      { en: 'Ich scanne Ihren Code', zh: '我扫你的码', pinyin: 'wǒ sǎo nǐ de mǎ' },
    ],
  },
  {
    id: 'transport', label: 'Unterwegs', icon: '🚕',
    phrases: [
      { en: 'Wo ist die U-Bahn?', zh: '地铁站在哪里？', pinyin: 'dìtiě zhàn zài nǎlǐ?' },
      { en: 'Bitte bringen Sie mich zu dieser Adresse', zh: '请带我去这个地址', pinyin: 'qǐng dài wǒ qù zhège dìzhǐ' },
      { en: 'Bitte hier anhalten', zh: '请在这里停', pinyin: 'qǐng zài zhèlǐ tíng' },
      { en: 'Bahnhof', zh: '火车站', pinyin: 'huǒchē zhàn' },
      { en: 'Flughafen', zh: '机场', pinyin: 'jīchǎng' },
      { en: 'Wie komme ich nach...?', zh: '怎么去...？', pinyin: 'zěnme qù...?' },
    ],
  },
  {
    id: 'food', label: 'Essen & Restaurant', icon: '🍜',
    phrases: [
      { en: 'Die Speisekarte, bitte', zh: '请给我菜单', pinyin: 'qǐng gěi wǒ càidān' },
      { en: 'Ich bin Vegetarier / Vegetarierin', zh: '我吃素', pinyin: 'wǒ chī sù' },
      { en: 'Nicht scharf, bitte', zh: '请不要辣', pinyin: 'qǐng búyào là' },
      { en: 'Wasser, bitte', zh: '请给我水', pinyin: 'qǐng gěi wǒ shuǐ' },
      { en: 'Die Rechnung, bitte', zh: '买单', pinyin: 'mǎidān' },
      { en: 'Es ist lecker', zh: '很好吃', pinyin: 'hěn hǎochī' },
    ],
  },
  {
    id: 'help', label: 'Hilfe & Notfälle', icon: '🆘',
    phrases: [
      { en: 'Hilfe!', zh: '救命！', pinyin: 'jiùmìng!' },
      { en: 'Wo ist die Toilette?', zh: '洗手间在哪里？', pinyin: 'xǐshǒujiān zài nǎlǐ?' },
      { en: 'Ich brauche einen Arzt', zh: '我需要看医生', pinyin: 'wǒ xūyào kàn yīshēng' },
      { en: 'Rufen Sie die Polizei', zh: '请报警', pinyin: 'qǐng bàojǐng' },
      { en: 'Ich habe mich verlaufen', zh: '我迷路了', pinyin: 'wǒ mílù le' },
      { en: 'Bitte schreiben Sie es auf', zh: '请写下来', pinyin: 'qǐng xiě xiàlái' },
    ],
  },
];
---
<!-- KI-unterstutzt erstellter Inhalt, von muttersprachlichem Redakteur gepruft -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Tool</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Wichtige chinesische Redewendungen</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- Controls -->
    <div class="mt-6 flex flex-wrap items-center gap-3 print:hidden">
      <button data-filter="all" class="phrase-filter btn-primary text-sm">Alle</button>
      {groups.map((g) => (
        <button data-filter={g.id} class="phrase-filter rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:border-brand-400">
          {g.icon} {g.label}
        </button>
      ))}
      <button id="print-btn" class="ml-auto rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:border-brand-400">
        🖨️ Drucken / Als PDF speichern
      </button>
    </div>

    <!-- Phrase groups -->
    <div class="mt-6 space-y-8">
      {groups.map((g) => (
        <section class="phrase-group" data-group={g.id}>
          <h2 class="mb-3 text-xl font-bold text-gray-900">{g.icon} {g.label}</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            {g.phrases.map((p) => (
              <div class="card flex flex-col">
                <span class="text-sm text-gray-500">{p.en}</span>
                <span class="mt-1 text-2xl font-bold text-gray-900">{p.zh}</span>
                <span class="mt-0.5 text-sm italic text-brand-600">{p.pinyin}</span>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>

    <AffiliateCta
      title="Unterwegs online bleiben, um zu übersetzen"
      description="Eine China-Reise-eSIM sorgt dafür, dass Übersetzungs-Apps und Karten funktionieren, sobald Sie landen."
      buttonText="Verbindung herstellen"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.phrase-filter');
  const sections = document.querySelectorAll<HTMLElement>('.phrase-group');
  const printBtn = document.getElementById('print-btn');

  const activeCls = ['btn-primary'];
  const idleCls = ['rounded-lg', 'border', 'border-gray-300', 'px-3', 'py-1.5', 'text-sm', 'font-medium', 'text-gray-700', 'hover:border-brand-400'];

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      sections.forEach((s) => {
        s.classList.toggle('hidden', filter !== 'all' && s.dataset.group !== filter);
      });
      buttons.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('btn-primary', on);
        idleCls.forEach((c) => b.classList.toggle(c, !on));
      });
    });
  });

  printBtn?.addEventListener('click', () => window.print());
</script>