---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ShowToLocal from '../../../components/ShowToLocal.astro';
import SurvivalChecklist from '../../../components/SurvivalChecklist.astro';
import survivalKits from '../../../data/survival-kits.json';

const title = 'China Survival Kit: Ubersetzungskarten und Reise-Checklisten';
const description =
  'Interaktive China-Survival-Kits fur auslandische Besucher: Vollbild-Ubersetzungskarten, Checklisten fur die Ankunft, Karten fur Lebensmittelallergien und Tools fur die lokale Kommunikation.';
---
<!-- KI-unterstutzt erstellter Inhalt, von muttersprachlichem Redakteur gepruft -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Survival-Kit</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-950 md:text-4xl">China Survival Kit</h1>
<p class="mt-4 max-w-3xl text-lg leading-8 text-gray-600">
  Unser China Survival Kit hilft Ihnen, sich mit Zuversicht auf Ihre Reise vorzubereiten. Es enthalt interaktive Checklisten, die jeden Schritt der Vorbereitung vor der Abreise abdecken: Visumantrag, Reiseversicherung, Einrichtung von Zahlungsmethoden (Alipay/WeChat Pay), Kauf einer eSIM oder SIM-Karte, Buchung der Unterkunft und wichtige Dinge zum Packen. Im Bereich der Redekarten konnen Sie Einheimischen chinesischen Text fur haufige Situationen zeigen, etwa beim Essenbestellen, beim Fragen nach dem Weg und beim Aushandeln von Taxipreisen. Sie konnen auch benutzerdefinierte Karten mit Ihren eigenen Formulierungen hinzufugen. Alles wird in Ihrem Browser gespeichert, sodass Sie jederzeit wahrend Ihrer Reise darauf zuruckkommen konnen, ohne ein Konto zu erstellen.
</p>
      <p class="mt-3 text-lg leading-8 text-gray-600">
        Verwenden Sie Vollbild-Ubersetzungskarten und gespeicherte Checklisten fur die Momente, in denen das Lesen eines langen Reisefuhrers zu langsam ist:
        Ankunft am Flughafen, Hotel-Check-in, Taxis, Restaurants, Allergien und die Einrichtung am ersten Tag.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="#arrival" class="btn-primary">Mit der Ankunft beginnen</a>
        <a href="#food" class="btn-outline">Essenskarten offnen</a>
      </div>
    </header>

    <section class="mt-8 grid gap-4 md:grid-cols-3">
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Vollbild-Karten</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Tippen Sie auf eine Karte und zeigen Sie einem Fahrer, dem Hotelpersonal oder Restaurantmitarbeitern groBen chinesischen Text.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Gespeicherte Checklisten</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Der Fortschritt der Checkliste wird in Ihrem Browser gespeichert, sodass Sie sie schlieBen und spater zuruckkehren konnen.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Context-AI-Einstieg</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Verwenden Sie den schwebenden Helfer, um die Reisehilfe von ChinaTripBox mit einer themenbezogenen Eingabeaufforderung zu offnen.</p>
      </div>
    </section>

    <div class="mt-10 grid gap-8">
      {survivalKits.map((kit) => (
        <section id={kit.slug} class="grid gap-5 rounded-xl border border-gray-200 bg-gray-50 p-5">
          <div class="max-w-3xl">
            <p class="section-kicker">{kit.slug} kit</p>
            <h2 class="mt-1 text-2xl font-bold text-gray-950">{kit.title}</h2>
            <p class="mt-2 text-sm leading-6 text-gray-600">{kit.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {kit.related_paths.map((path) => (
                <a href={path} class="rounded-full border border-gray-200 bg-white px-3 py-1.5 text-xs font-semibold text-brand-700 hover:border-brand-300 hover:no-underline">
                  Verwandter Leitfaden
                </a>
              ))}
            </div>
          </div>
          <div class="grid gap-5 lg:grid-cols-[1fr_0.85fr]">
            <ShowToLocal themeId={kit.theme_id} tools={kit.tools} />
            <SurvivalChecklist themeId={kit.theme_id} steps={kit.checklist_steps} />
          </div>
        </section>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>