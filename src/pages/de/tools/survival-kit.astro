---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ShowToLocal from '../../../components/ShowToLocal.astro';
import SurvivalChecklist from '../../../components/SurvivalChecklist.astro';
import ContextAiBubble from '../../../components/ContextAiBubble.astro';
import survivalKits from '../../../data/survival-kits.json';

const title = 'China-Notfallkit: Übersetzungskarten und Reise-Checklisten';
const description =
  'Interaktive China-Notfallkits für internationale Reisende: Vollbild-Übersetzungskarten, Ankunfts-Checklisten, Karten für Lebensmittelallergien und praktische Tools für die Kommunikation vor Ort.';
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Notfallkit</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-950 md:text-4xl">China-Notfallkit</h1>
      <p class="mt-3 text-lg leading-8 text-gray-600">
        Nutze Vollbild-Übersetzungskarten und gespeicherte Checklisten für Situationen, in denen ein langer Reiseführer zu unpraktisch ist:
        Ankunft am Flughafen, Hotel-Check-in, Taxis, Restaurants, Allergien und die wichtigsten Erledigungen am ersten Tag.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="#arrival" class="btn-primary">Mit der Ankunft beginnen</a>
        <a href="#food" class="btn-outline">Essenskarten öffnen</a>
      </div>
    </header>

    <section class="mt-8 grid gap-4 md:grid-cols-3">
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Vollbild-Karten</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Tippe auf eine Karte und zeige den großen chinesischen Text einem Fahrer, dem Hotelpersonal oder dem Restaurantteam.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Gespeicherte Checklisten</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Dein Fortschritt wird im Browser gespeichert, damit du später genau dort weitermachen kannst, wo du aufgehört hast.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Kontextbezogener KI-Start</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Nutze den schwebenden Helfer, um die Reisehilfe von ChinaTripBox direkt mit einem passenden Themen-Prompt zu öffnen.</p>
      </div>
    </section>

    <div class="mt-10 grid gap-8">
      {survivalKits.map((kit) => (
        <section id={kit.slug} class="grid gap-5 rounded-xl border border-gray-200 bg-gray-50 p-5">
          <div class="max-w-3xl">
            <p class="section-kicker">{kit.slug} Paket</p>
            <h2 class="mt-1 text-2xl font-bold text-gray-950">{kit.title}</h2>
            <p class="mt-2 text-sm leading-6 text-gray-600">{kit.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {kit.related_paths.map((path) => (
                <a href={path} class="rounded-full border border-gray-200 bg-white px-3 py-1.5 text-xs font-semibold text-brand-700 hover:border-brand-300 hover:no-underline">
                  Passender Reiseführer
                </a>
              ))}
            </div>
          </div>
          <div class="grid gap-5 lg:grid-cols-[1fr_0.85fr]">
            <ShowToLocal themeId={kit.theme_id} tools={kit.tools} />
            <SurvivalChecklist themeId={kit.theme_id} steps={kit.checklist_steps} />
          </div>
        </section>
      ))}
    </div>
  </main>
  <ContextAiBubble defaultPrompt="Hilf mir dabei, das China-Notfallkit für Ankunft, Restaurants, Übersetzungskarten und die Vorbereitung meiner Checkliste zu nutzen." />
  <Footer />
</BaseLayout>
