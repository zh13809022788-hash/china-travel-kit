---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'China-Reisebudget- & Bargeldrechner';
const description =
  'Schätzen Sie Ihr Tagesbudget und wie viel Bargeld Sie für China mitnehmen sollten, basierend auf Reiselänge, Reisestil und Stadtkategorie. Erhalten Sie eine klare Aufschlüsselung in RMB und USD.';
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Werkzeug</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Budget- & Bargeldrechner</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- Eingabesteuerungen -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Reisedauer (Nächte)</span>
        <input id="nights" type="number" min="1" max="60" value="7"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Anzahl der Reisenden</span>
        <input id="travelers" type="number" min="1" max="10" value="1"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Reisestil</span>
        <select id="style" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="budget">Budget (Hostels, Streetfood, Metro)</option>
          <option value="mid" selected>Mittelklasse (3–4★ Hotels, Restaurants)</option>
          <option value="comfort">Komfort (4–5★ Hotels, Taxis, gehobenes Essen)</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Stadtkategorie</span>
        <select id="tier" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="tier1">Kategorie 1 (Peking, Shanghai, Shenzhen)</option>
          <option value="tier2" selected>Kategorie 2 (Chengdu, Xi'an, Hangzhou)</option>
          <option value="tier3">Kleinere Städte & Orte</option>
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="calc-btn" class="btn-primary w-full sm:w-auto">Mein Budget schätzen</button>
      </div>
    </div>

    <!-- Ergebnis -->
    <div id="result" class="mt-6 hidden">
      <div class="grid gap-5 md:grid-cols-2">
        <div class="card" id="budget-card"></div>
        <div class="card" id="cash-card"></div>
      </div>
      <div class="card mt-5" id="breakdown-card"></div>
      <p class="mt-3 text-xs text-gray-400">
        Schätzungen sind ungefähre Angaben und schließen internationale Flüge aus. Tatsächliche Kosten variieren je nach Saison,
        Wechselkurs und persönlichen Entscheidungen. Angenommener Wechselkurs: ~7,2 RMB pro USD.
      </p>

      <AffiliateCta
        title="Wie Einheimische bezahlen, Gebühren sparen"
        description="Richten Sie eine reisebereite Zahlungsmethode ein, damit die meisten Ihrer Ausgaben ganz ohne Bargeld auskommen."
        buttonText="Bezahloptionen ansehen"
        placeholder={AFFILIATE_LINKS.payment}
      />
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  type StyleKey = 'budget' | 'mid' | 'comfort';
  type TierKey = 'tier1' | 'tier2' | 'tier3';

  const USD_RATE = 7.2; // RMB pro USD (ungefähr)

  // Tägliche Ausgaben pro Person in RMB, ohne Unterkunft.
  const dailySpend: Record<StyleKey, { food: number; transport: number; activities: number; misc: number }> = {
    budget: { food: 80, transport: 30, activities: 40, misc: 30 },
    mid: { food: 180, transport: 70, activities: 100, misc: 60 },
    comfort: { food: 400, transport: 200, activities: 220, misc: 130 },
  };

  // Unterkunft pro Nacht in RMB (pro Zimmer, angenommen geteilt von bis zu 2 Personen).
  const lodging: Record<StyleKey, number> = {
    budget: 150,
    mid: 450,
    comfort: 1100,
  };

  // Kostenmultiplikator für die Stadtkategorie.
  const tierMult: Record<TierKey, number> = {
    tier1: 1.25,
    tier2: 1.0,
    tier3: 0.8,
  };

  const rmb = (n: number) => `¥${Math.round(n).toLocaleString()}`;
  const usd = (n: number) => `$${Math.round(n / USD_RATE).toLocaleString()}`;

  const btn = document.getElementById('calc-btn');
  const result = document.getElementById('result');
  const budgetCard = document.getElementById('budget-card');
  const cashCard = document.getElementById('cash-card');
  const breakdownCard = document.getElementById('breakdown-card');

  const nightsEl = document.getElementById('nights') as HTMLInputElement;
  const travelersEl = document.getElementById('travelers') as HTMLInputElement;
  const styleEl = document.getElementById('style') as HTMLSelectElement;
  const tierEl = document.getElementById('tier') as HTMLSelectElement;

  function calc() {
    if (!budgetCard || !cashCard || !breakdownCard || !result) return;

    const nights = Math.max(1, Math.min(60, Number(nightsEl.value) || 1));
    const travelers = Math.max(1, Math.min(10, Number(travelersEl.value) || 1));
    const style = styleEl.value as StyleKey;
    const tier = tierEl.value as TierKey;
    const mult = tierMult[tier];

    const spend = dailySpend[style];
    const perPersonDaily = (spend.food + spend.transport + spend.activities + spend.misc) * mult;

    // Unterkunft: 1 Zimmer pro 2 Reisende, aufgerundet.
    const rooms = Math.ceil(travelers / 2);
    const lodgingTotal = lodging[style] * mult * rooms * nights;

    const spendTotal = perPersonDaily * travelers * nights;
    const grandTotal = spendTotal + lodgingTotal;

    // Empfohlenes Bargeld: ~10% der täglichen Ausgaben, begrenzt auf einen sinnvollen Betrag.
    const dailyCashFloat = Math.min(perPersonDaily * 0.15 * travelers, 200 * travelers);
    const cashRecommended = Math.min(dailyCashFloat * nights, 2000 + 100 * travelers);

    budgetCard.innerHTML = `
      <h3 class="text-lg font-bold text-gray-900">Geschätztes Gesamtbudget</h3>
      <p class="mt-2 text-3xl font-bold text-brand-600">${rmb(grandTotal)}</p>
      <p class="text-sm text-gray-500">≈ ${usd(grandTotal)} für ${travelers} Reisende(n), ${nights} Nacht/Nächte</p>
      <dl class="mt-4 space-y-2 text-sm">
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Unterkunft</dt><dd class="font-medium text-gray-900">${rmb(lodgingTotal)}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Tägliche Ausgaben</dt><dd class="font-medium text-gray-900">${rmb(spendTotal)}</dd></div>
        <div class="flex justify-between gap-4 border-t border-gray-100 pt-2"><dt class="text-gray-700 font-semibold">Pro Person</dt><dd class="font-semibold text-gray-900">${rmb(grandTotal / travelers)}</dd></div>
      </dl>`;

    cashCard.innerHTML = `
      <h3 class="text-lg font-bold text-gray-900">Mitzunehmendes Bargeld</h3>
      <p class="mt-2 text-3xl font-bold text-gray-900">${rmb(cashRecommended)}</p>
      <p class="text-sm text-gray-500">≈ ${usd(cashRecommended)} in physischem RMB</p>
      <p class="mt-4 text-sm text-gray-600">
        China ist auf mobiles Bezahlen ausgerichtet — fast alles bezahlen Sie mit Alipay oder WeChat Pay, verknüpft mit einer
        ausländischen Karte. Dieses Bargeld ist ein Sicherheitsnetz für Taxis ohne QR-Lesegeräte, kleine ländliche Händler und
        Automaten, die nur Scheine annehmen. Bringen Sie kleine Stückelungen mit (¥10, ¥20, ¥50).
      </p>`;

    breakdownCard.innerHTML = `
      <h3 class="text-lg font-bold text-gray-900">Aufschlüsselung der täglichen Ausgaben <span class="text-sm font-normal text-gray-500">(pro Person)</span></h3>
      <dl class="mt-4 grid gap-3 sm:grid-cols-4 text-sm">
        <div><dt class="text-gray-500">Essen</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.food * mult)}</dd></div>
        <div><dt class="text-gray-500">Nahverkehr</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.transport * mult)}</dd></div>
        <div><dt class="text-gray-500">Aktivitäten</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.activities * mult)}</dd></div>
        <div><dt class="text-gray-500">Sonstiges</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.misc * mult)}</dd></div>
      </dl>`;

    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  btn?.addEventListener('click', calc);
</script>