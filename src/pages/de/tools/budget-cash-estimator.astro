---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Reisebudget- und Bargeldrechner für China';
const description =
  'Schätzen Sie Ihr Tagesbudget und wie viel Bargeld Sie für China mitnehmen sollten – basierend auf Reisedauer, Reisestil und Stadtkategorie. Sie erhalten eine klare Aufschlüsselung in RMB und USD.';
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Rechner</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Reisebudget- und Bargeldrechner</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Anzahl der Nächte</span>
        <input id="nights" type="number" min="1" max="60" value="7"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Anzahl der Reisenden</span>
        <input id="travelers" type="number" min="1" max="10" value="1"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Reisestil</span>
        <select id="style" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="guenstig">Günstig (Hostels, Streetfood, Metro)</option>
          <option value="mittel" selected>Mittelklasse (3- bis 4-Sterne-Hotels, Restaurants)</option>
          <option value="komfort">Komfortabel (4- bis 5-Sterne-Hotels, Taxis, gehobene Restaurants)</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Stadtkategorie</span>
        <select id="tier" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="metropole">Kategorie 1 (Peking, Shanghai, Shenzhen)</option>
          <option value="grossstadt" selected>Kategorie 2 (Chengdu, Xi'an, Hangzhou)</option>
          <option value="kleinstadt">Kleinere Städte und ländliche Regionen</option>
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="calc-btn" class="btn-primary w-full sm:w-auto">Budget berechnen</button>
      </div>
    </div>

    <div id="result" class="mt-6 hidden">
      <div class="grid gap-5 md:grid-cols-2">
        <div class="card" id="budget-card"></div>
        <div class="card" id="cash-card"></div>
      </div>
      <div class="card mt-5" id="breakdown-card"></div>
      <p class="mt-3 text-xs text-gray-400">
        Diese Schätzwerte dienen nur zur Orientierung und enthalten keine internationalen Flüge. Die tatsächlichen Kosten hängen von Saison,
        Wechselkurs und Ihren persönlichen Entscheidungen ab. Grundlage ist ein Wechselkurs von etwa 7,2 RMB pro USD.
      </p>

      <AffiliateCta
        title="Wie Einheimische zahlen und wie Sie Gebühren vermeiden"
        description="Richten Sie eine reisetaugliche Zahlungsmethode ein, damit Sie den Großteil Ihrer Ausgaben auch ohne Bargeld bequem begleichen können."
        buttonText="Zahlungsoptionen ansehen"
        placeholder={AFFILIATE_LINKS.payment}
      />
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  type StyleKey = 'guenstig' | 'mittel' | 'komfort';
  type TierKey = 'metropole' | 'grossstadt' | 'kleinstadt';

  const USD_RATE = 7.2; // RMB pro USD (ca.)

  // Tägliche Ausgaben pro Person in RMB, ohne Unterkunft.
  const dailySpend: Record<StyleKey, { essen: number; transport: number; aktivitaeten: number; sonstiges: number }> = {
    guenstig: { essen: 80, transport: 30, aktivitaeten: 40, sonstiges: 30 },
    mittel: { essen: 180, transport: 70, aktivitaeten: 100, sonstiges: 60 },
    komfort: { essen: 400, transport: 200, aktivitaeten: 220, sonstiges: 130 },
  };

  // Unterkunft pro Nacht in RMB (pro Zimmer, gerechnet mit bis zu 2 Personen pro Zimmer).
  const lodging: Record<StyleKey, number> = {
    guenstig: 150,
    mittel: 450,
    komfort: 1100,
  };

  // Kostenfaktor je nach Stadtkategorie.
  const tierMult: Record<TierKey, number> = {
    metropole: 1.25,
    grossstadt: 1.0,
    kleinstadt: 0.8,
  };

  const rmb = (n: number) => `¥${Math.round(n).toLocaleString()}`;
  const usd = (n: number) => `$${Math.round(n / USD_RATE).toLocaleString()}`;

  const btn = document.getElementById('calc-btn');
  const result = document.getElementById('result');
  const budgetCard = document.getElementById('budget-card');
  const cashCard = document.getElementById('cash-card');
  const breakdownCard = document.getElementById('breakdown-card');

  const nightsEl = document.getElementById('nights') as HTMLInputElement;
  const travelersEl = document.getElementById('travelers') as HTMLInputElement;
  const styleEl = document.getElementById('style') as HTMLSelectElement;
  const tierEl = document.getElementById('tier') as HTMLSelectElement;

  function calc() {
    if (!budgetCard || !cashCard || !breakdownCard || !result) return;

    const nights = Math.max(1, Math.min(60, Number(nightsEl.value) || 1));
    const travelers = Math.max(1, Math.min(10, Number(travelersEl.value) || 1));
    const style = styleEl.value as StyleKey;
    const tier = tierEl.value as TierKey;
    const mult = tierMult[tier];

    const spend = dailySpend[style];
    const perPersonDaily = (spend.essen + spend.transport + spend.aktivitaeten + spend.sonstiges) * mult;

    // Unterkunft: 1 Zimmer pro 2 Reisende, aufgerundet.
    const rooms = Math.ceil(travelers / 2);
    const lodgingTotal = lodging[style] * mult * rooms * nights;

    const spendTotal = perPersonDaily * travelers * nights;
    const grandTotal = spendTotal + lodgingTotal;

    // Empfohlenes Bargeld: etwa 10-15 % der laufenden Ausgaben, gedeckelt auf einen praktikablen Betrag.
    const dailyCashFloat = Math.min(perPersonDaily * 0.15 * travelers, 200 * travelers);
    const cashRecommended = Math.min(dailyCashFloat * nights, 2000 + 100 * travelers);

    budgetCard.innerHTML = `
      <h3 class="text-lg font-bold text-gray-900">Geschätztes Gesamtbudget</h3>
      <p class="mt-2 text-3xl font-bold text-brand-600">${rmb(grandTotal)}</p>
      <p class="text-sm text-gray-500">≈ ${usd(grandTotal)} für ${travelers} Reisende und ${nights} Nächte</p>
      <dl class="mt-4 space-y-2 text-sm">
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Unterkunft</dt><dd class="font-medium text-gray-900">${rmb(lodgingTotal)}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Laufende Ausgaben</dt><dd class="font-medium text-gray-900">${rmb(spendTotal)}</dd></div>
        <div class="flex justify-between gap-4 border-t border-gray-100 pt-2"><dt class="text-gray-700 font-semibold">Pro Person</dt><dd class="font-semibold text-gray-900">${rmb(grandTotal / travelers)}</dd></div>
      </dl>`;

    cashCard.innerHTML = `
      <h3 class="text-lg font-bold text-gray-900">Empfohlenes Bargeld</h3>
      <p class="mt-2 text-3xl font-bold text-gray-900">${rmb(cashRecommended)}</p>
      <p class="text-sm text-gray-500">≈ ${usd(cashRecommended)} als Bargeldreserve in RMB</p>
      <p class="mt-4 text-sm text-gray-600">
        In China wird meist mobil bezahlt. Fast alles lässt sich mit Alipay oder WeChat Pay begleichen, verknüpft mit einer
        ausländischen Karte. Dieses Bargeld ist als Reserve gedacht, etwa für Taxis ohne QR-Zahlung, kleine Händler in ländlichen Gegenden und
        Automaten, die nur Banknoten annehmen. Praktisch sind kleine Scheine wie ¥10, ¥20 und ¥50.
      </p>`;

    breakdownCard.innerHTML = `
      <h3 class="text-lg font-bold text-gray-900">Tägliche Ausgaben im Überblick <span class="text-sm font-normal text-gray-500">(pro Person)</span></h3>
      <dl class="mt-4 grid gap-3 sm:grid-cols-4 text-sm">
        <div><dt class="text-gray-500">Essen</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.essen * mult)}</dd></div>
        <div><dt class="text-gray-500">Nahverkehr</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.transport * mult)}</dd></div>
        <div><dt class="text-gray-500">Aktivitäten</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.aktivitaeten * mult)}</dd></div>
        <div><dt class="text-gray-500">Sonstiges</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.sonstiges * mult)}</dd></div>
      </dl>`;

    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  btn?.addEventListener('click', calc);
</script>
