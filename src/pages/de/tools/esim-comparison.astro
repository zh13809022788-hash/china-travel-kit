---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'eSIM-Tarifvergleich für Reisen nach China';
const description =
  'Vergleiche gängige eSIM-Tarife für China nach Datenvolumen, Laufzeit, Preis und Netz. Mit den Filtern findest du schneller den passenden Tarif für deine Reise.';

const plans = [
  { id: 1, name: 'China-Entdecker 5 GB', data: 5, dataLabel: '5 GB', days: 7, price: 9.5, network: 'China Unicom', note: 'Umgeht typische Einschränkungen lokaler Apps' },
  { id: 2, name: 'China-Entdecker 10 GB', data: 10, dataLabel: '10 GB', days: 15, price: 16, network: 'China Unicom', note: 'Umgeht typische Einschränkungen lokaler Apps' },
  { id: 3, name: 'Festland Kompakt 3 GB', data: 3, dataLabel: '3 GB', days: 7, price: 6.5, network: 'China Mobile', note: 'Lokales Netz ohne VPN-Umleitung' },
  { id: 4, name: 'Großchina 8 GB', data: 8, dataLabel: '8 GB', days: 30, price: 18.9, network: 'China Unicom', note: 'Deckt Festlandchina, Hongkong, Macau und Taiwan ab' },
  { id: 5, name: 'Täglich unbegrenzt', data: 9999, dataLabel: 'Unbegrenzt*', days: 10, price: 29, network: 'China Unicom', note: 'Drosselung nach Fair Use ab 2 GB pro Tag' },
  { id: 6, name: 'Geschäftsreise 20 GB', data: 20, dataLabel: '20 GB', days: 30, price: 32, network: 'China Unicom', note: 'Umgeht typische Einschränkungen lokaler Apps' },
  { id: 7, name: 'Kurzreise 1 GB', data: 1, dataLabel: '1 GB', days: 3, price: 3.2, network: 'China Mobile', note: 'Praktisch für kurze Zwischenstopps' },
  { id: 8, name: 'Familie 30 GB', data: 30, dataLabel: '30 GB', days: 30, price: 45, network: 'China Unicom', note: 'Per Hotspot mit mehreren Geräten nutzbar' },
];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Werkzeug</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">eSIM-Tarifvergleich</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 flex flex-wrap items-end gap-4 rounded-xl border border-gray-200 bg-gray-50 p-4">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Sortieren nach</span>
        <select id="sort-by" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="price-asc">Preis: niedrig nach hoch</option>
          <option value="price-desc">Preis: hoch nach niedrig</option>
          <option value="data-desc">Datenvolumen: viel nach wenig</option>
          <option value="days-desc">Laufzeit: lang nach kurz</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Netz</span>
        <select id="filter-network" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="alle">Alle Netze</option>
          <option value="China Unicom">China Unicom</option>
          <option value="China Mobile">China Mobile</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Mindest-Datenvolumen</span>
        <select id="filter-data" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="0">Beliebig</option>
          <option value="5">Ab 5 GB</option>
          <option value="10">Ab 10 GB</option>
          <option value="20">Ab 20 GB</option>
        </select>
      </label>
    </div>

    <div class="mt-6 overflow-x-auto">
      <table class="w-full min-w-[720px] border-collapse text-sm">
        <thead>
          <tr class="border-b-2 border-gray-200 text-left text-gray-500">
            <th class="py-3 pr-4 font-semibold">Tarif</th>
            <th class="py-3 pr-4 font-semibold">Datenvolumen</th>
            <th class="py-3 pr-4 font-semibold">Laufzeit</th>
            <th class="py-3 pr-4 font-semibold">Preis (USD)</th>
            <th class="py-3 pr-4 font-semibold">Netz</th>
            <th class="py-3 pr-4 font-semibold">Hinweis</th>
          </tr>
        </thead>
        <tbody id="plan-rows"></tbody>
      </table>
      <p id="no-results" class="hidden py-8 text-center text-gray-500">Für diese Filter wurde kein passender Tarif gefunden.</p>
    </div>

    <AffiliateCta
      title="Direkt nach der Landung online"
      description="Aktiviere vor der Abreise eine passende China-eSIM, damit Karten, Messenger und Bezahl-Apps sofort funktionieren."
      buttonText="eSIM-Angebote ansehen"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ plans }}>
  const rowsEl = document.getElementById('plan-rows');
  const noResults = document.getElementById('no-results');
  const sortBy = document.getElementById('sort-by');
  const filterNetwork = document.getElementById('filter-network');
  const filterData = document.getElementById('filter-data');

  function render() {
    let list = [...plans];
    const net = filterNetwork.value;
    const minData = Number(filterData.value);

    if (net !== 'alle') list = list.filter((p) => p.network === net);
    if (minData > 0) list = list.filter((p) => p.data >= minData);

    switch (sortBy.value) {
      case 'price-asc': list.sort((a, b) => a.price - b.price); break;
      case 'price-desc': list.sort((a, b) => b.price - a.price); break;
      case 'data-desc': list.sort((a, b) => b.data - a.data); break;
      case 'days-desc': list.sort((a, b) => b.days - a.days); break;
    }

    rowsEl.innerHTML = list
      .map(
        (p) => `
      <tr class="border-b border-gray-100">
        <td class="py-3 pr-4 font-semibold text-gray-900">${p.name}</td>
        <td class="py-3 pr-4">${p.dataLabel}</td>
        <td class="py-3 pr-4">${p.days} Tage</td>
        <td class="py-3 pr-4 font-semibold">$${p.price.toFixed(2)}</td>
        <td class="py-3 pr-4">${p.network}</td>
        <td class="py-3 pr-4 text-gray-500">${p.note}</td>
      </tr>`
      )
      .join('');

    noResults.classList.toggle('hidden', list.length > 0);
  }

  [sortBy, filterNetwork, filterData].forEach((el) => el.addEventListener('change', render));
  render();
</script>
