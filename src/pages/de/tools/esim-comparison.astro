---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'eSIM Plan Comparator for China Travel';
const description =
  'Compare the top China travel eSIM plans by data, validity, price, and network. Filter and sort to find the best plan for your trip.';

// 8 preset China travel eSIM products (representative sample data)
const plans = [
  { id: 1, name: 'China Explorer 5GB', data: 5, dataLabel: '5 GB', days: 7, price: 9.5, network: 'China Unicom', note: 'Bypasses local app restrictions' },
  { id: 2, name: 'China Explorer 10GB', data: 10, dataLabel: '10 GB', days: 15, price: 16, network: 'China Unicom', note: 'Bypasses local app restrictions' },
  { id: 3, name: 'Mainland Lite 3GB', data: 3, dataLabel: '3 GB', days: 7, price: 6.5, network: 'China Mobile', note: 'Local network, no VPN routing' },
  { id: 4, name: 'Greater China 8GB', data: 8, dataLabel: '8 GB', days: 30, price: 18.9, network: 'China Unicom', note: 'Covers CN, HK, MO, TW' },
  { id: 5, name: 'Unlimited Daily', data: 9999, dataLabel: 'Unlimited*', days: 10, price: 29, network: 'China Unicom', note: 'Fair-use cap after 2GB/day' },
  { id: 6, name: 'Business 20GB', data: 20, dataLabel: '20 GB', days: 30, price: 32, network: 'China Unicom', note: 'Bypasses local app restrictions' },
  { id: 7, name: 'Short Trip 1GB', data: 1, dataLabel: '1 GB', days: 3, price: 3.2, network: 'China Mobile', note: 'Best for quick layovers' },
  { id: 8, name: 'Family 30GB', data: 30, dataLabel: '30 GB', days: 30, price: 45, network: 'China Unicom', note: 'Shareable via hotspot' },
];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Tool</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">eSIM-Tarifvergleich</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- Steuerelemente -->
    <div class="mt-6 flex flex-wrap items-end gap-4 rounded-xl border border-gray-200 bg-gray-50 p-4">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Sortieren nach</span>
        <select id="sort-by" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="price-asc">Preis: Niedrig bis hoch</option>
          <option value="price-desc">Preis: Hoch bis niedrig</option>
          <option value="data-desc">Daten: Hoch bis niedrig</option>
          <option value="days-desc">Gültigkeit: Lang bis kurz</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Netzwerk</span>
        <select id="filter-network" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="all">Alle Netzwerke</option>
          <option value="China Unicom">China Unicom</option>
          <option value="China Mobile">China Mobile</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Min. Daten (GB)</span>
        <select id="filter-data" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="0">Beliebig</option>
          <option value="5">5+ GB</option>
          <option value="10">10+ GB</option>
          <option value="20">20+ GB</option>
        </select>
      </label>
    </div>

    <!-- Vergleichstabelle -->
    <div class="mt-6 overflow-x-auto">
      <table class="w-full min-w-[720px] border-collapse text-sm">
        <thead>
          <tr class="border-b-2 border-gray-200 text-left text-gray-500">
            <th class="py-3 pr-4 font-semibold">Tarif</th>
            <th class="py-3 pr-4 font-semibold">Daten</th>
            <th class="py-3 pr-4 font-semibold">Gültigkeit</th>
            <th class="py-3 pr-4 font-semibold">Preis (USD)</th>
            <th class="py-3 pr-4 font-semibold">Netzwerk</th>
            <th class="py-3 pr-4 font-semibold">Hinweise</th>
          </tr>
        </thead>
        <tbody id="plan-rows"></tbody>
      </table>
      <p id="no-results" class="hidden py-8 text-center text-gray-500">Keine Tarife entsprechen deinen Filtern.</p>
    </div>

    <AffiliateCta
      title="Bereit, verbunden zu werden?"
      description="Aktiviere eine empfohlene China-eSIM und sei online, sobald du landest."
      buttonText="Hol dir deine eSIM"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ plans }}>
  const rowsEl = document.getElementById('plan-rows');
  const noResults = document.getElementById('no-results');
  const sortBy = document.getElementById('sort-by');
  const filterNetwork = document.getElementById('filter-network');
  const filterData = document.getElementById('filter-data');

  function render() {
    let list = [...plans];
    const net = filterNetwork.value;
    const minData = Number(filterData.value);

    if (net !== 'all') list = list.filter((p) => p.network === net);
    if (minData > 0) list = list.filter((p) => p.data >= minData);

    switch (sortBy.value) {
      case 'price-asc': list.sort((a, b) => a.price - b.price); break;
      case 'price-desc': list.sort((a, b) => b.price - a.price); break;
      case 'data-desc': list.sort((a, b) => b.data - a.data); break;
      case 'days-desc': list.sort((a, b) => b.days - a.days); break;
    }

    rowsEl.innerHTML = list
      .map(
        (p) => `
      <tr class="border-b border-gray-100">
        <td class="py-3 pr-4 font-semibold text-gray-900">${p.name}</td>
        <td class="py-3 pr-4">${p.dataLabel}</td>
        <td class="py-3 pr-4">${p.days} Tage</td>
        <td class="py-3 pr-4 font-semibold">$${p.price.toFixed(2)}</td>
        <td class="py-3 pr-4">${p.network}</td>
        <td class="py-3 pr-4 text-gray-500">${p.note}</td>
      </tr>`
      )
      .join('');

    noResults.classList.toggle('hidden', list.length > 0);
  }

  [sortBy, filterNetwork, filterData].forEach((el) => el.addEventListener('change', render));
  render();
</script>