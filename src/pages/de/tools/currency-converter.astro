---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'RMB-Währungsrechner für China-Reisende';
const description =
  'Rechne deine Heimatwährung in chinesische Yuan (RMB) und zurück um und sieh, was alltägliche Dinge in China kosten, damit du Preise direkt vor Ort besser einschätzen kannst.';
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Werkzeug</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">RMB-Währungsrechner</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- Rechner -->
    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-6">
      <div class="grid gap-4 sm:grid-cols-[1fr_auto_1fr] sm:items-end">
        <label class="flex flex-col text-sm">
          <span class="mb-1 font-medium text-gray-700">Deine Währung</span>
          <div class="flex gap-2">
            <select id="currency" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
              <option value="USD">USD ($)</option>
              <option value="EUR">EUR (€)</option>
              <option value="GBP">GBP (£)</option>
              <option value="AUD">AUD (A$)</option>
              <option value="CAD">CAD (C$)</option>
              <option value="JPY">JPY (¥)</option>
              <option value="SGD">SGD (S$)</option>
            </select>
            <input
              id="foreign-amount"
              type="number"
              min="0"
              value="100"
              class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"
            />
          </div>
        </label>
        <div class="hidden pb-2 text-center text-gray-400 sm:block">⇄</div>
        <label class="flex flex-col text-sm">
          <span class="mb-1 font-medium text-gray-700">Chinesische Yuan (RMB)</span>
          <input
            id="rmb-amount"
            type="number"
            min="0"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm"
          />
        </label>
      </div>
      <p id="rate-line" class="mt-3 text-sm text-gray-500"></p>
      <p class="mt-1 text-xs text-gray-400">
        Die Kurse sind ungefähre Richtwerte für deine Planung und keine Live-Marktkurse. Prüfe bei deiner Bank oder in einem Live-Währungsrechner den genauen Kurs zum Zeitpunkt deiner Transaktion.
      </p>
    </div>

    <!-- Preise in China -->
    <section class="mt-8">
      <h2 class="text-xl font-bold text-gray-900">Was Dinge in China kosten</h2>
      <p class="mt-1 text-sm text-gray-500">Typische Preise in RMB, zum Vergleich auch in deiner Währung.</p>
      <div id="cost-grid" class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3"></div>
    </section>

    <AffiliateCta
      title="Wechselstuben meiden"
      description="Verbinde eine Karte ohne Fremdwährungsgebühren mit Alipay oder WeChat Pay und zahle zum echten Wechselkurs, ohne Aufschlag beim Bargeldtausch."
      buttonText="Zahlungs-Setup ansehen"
      placeholder={AFFILIATE_LINKS.payment}
    />
  </main>
  <Footer />
</BaseLayout>

<script>
  // Ungefähre Referenzkurse: 1 Einheit der jeweiligen Währung = X RMB.
  const ratesToRmb: Record<string, number> = {
    USD: 7.2,
    EUR: 7.8,
    GBP: 9.1,
    AUD: 4.7,
    CAD: 5.2,
    JPY: 0.048,
    SGD: 5.3,
  };
  const symbols: Record<string, string> = {
    USD: '$', EUR: '€', GBP: '£', AUD: 'A$', CAD: 'C$', JPY: '¥', SGD: 'S$',
  };

  const commonCosts: { label: string; rmb: number }[] = [
    { label: 'Flasche Wasser', rmb: 2 },
    { label: 'Fahrt mit der Metro', rmb: 4 },
    { label: 'Streetfood-Snack', rmb: 10 },
    { label: 'Kaffee im Café', rmb: 30 },
    { label: 'Essen in einem einfachen Restaurant', rmb: 45 },
    { label: 'Kurze Fahrt mit DiDi oder dem Taxi', rmb: 25 },
    { label: 'Hochgeschwindigkeitszug (1 bis 2 Std.)', rmb: 250 },
    { label: 'Eintritt für Museum oder Sehenswürdigkeit', rmb: 60 },
    { label: 'Mittelklassehotel pro Nacht', rmb: 450 },
  ];

  const currencyEl = document.getElementById('currency') as HTMLSelectElement;
  const foreignEl = document.getElementById('foreign-amount') as HTMLInputElement;
  const rmbEl = document.getElementById('rmb-amount') as HTMLInputElement;
  const rateLine = document.getElementById('rate-line');
  const costGrid = document.getElementById('cost-grid');

  function rate() {
    return ratesToRmb[currencyEl.value];
  }
  function sym() {
    return symbols[currencyEl.value];
  }

  function fromForeign() {
    const v = Number(foreignEl.value) || 0;
    rmbEl.value = (v * rate()).toFixed(2);
    updateMeta();
  }
  function fromRmb() {
    const v = Number(rmbEl.value) || 0;
    foreignEl.value = (v / rate()).toFixed(2);
    updateMeta();
  }

  function updateMeta() {
    if (rateLine) {
      rateLine.textContent = `Referenzkurs: 1 ${currencyEl.value} entspricht ungefähr ¥${rate().toFixed(2)} RMB`;
    }
    if (costGrid) {
      costGrid.innerHTML = commonCosts
        .map((c) => `
          <div class="card">
            <span class="text-sm text-gray-500">${c.label}</span>
            <div class="mt-1 flex items-baseline gap-2">
              <span class="text-xl font-bold text-gray-900">¥${c.rmb}</span>
              <span class="text-sm text-brand-600">ca. ${sym()}${(c.rmb / rate()).toFixed(2)}</span>
            </div>
          </div>`)
        .join('');
    }
  }

  foreignEl.addEventListener('input', fromForeign);
  rmbEl.addEventListener('input', fromRmb);
  currencyEl.addEventListener('change', fromForeign);

  fromForeign();
</script>