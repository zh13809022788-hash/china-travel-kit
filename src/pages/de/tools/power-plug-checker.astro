---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Steckdosen- und Spannungscheck für China';
const description =
  'Prüfen Sie anhand Ihres Heimatlands, ob Sie für Ihre Reise nach China einen Reiseadapter oder Spannungswandler brauchen. In China werden 220 V sowie die Steckertypen A, C und I verwendet.';

const countries = [
  'Vereinigte Staaten', 'Vereinigtes Königreich', 'Kanada', 'Australien',
  'Deutschland', 'Frankreich', 'Italien', 'Spanien', 'Niederlande', 'Japan',
  'Südkorea', 'Singapur', 'Indien', 'Brasilien', 'Neuseeland', 'Schweiz',
  'Südafrika', 'Vereinigte Arabische Emirate', 'Andere',
];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Tool</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Steckdosen- und Spannungscheck</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-6">
      <label class="flex flex-col text-sm sm:max-w-sm">
        <span class="mb-1 font-medium text-gray-700">Abreiseland</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <button id="check-btn" class="btn-primary mt-4 w-full sm:w-auto">Jetzt prüfen</button>
    </div>

    <!-- Referenzwerte für China -->
    <div class="mt-6 grid gap-4 sm:grid-cols-3">
      <div class="card"><dt class="text-sm text-gray-500">Spannung</dt><dd class="text-2xl font-bold text-gray-900">220 V</dd></div>
      <div class="card"><dt class="text-sm text-gray-500">Frequenz</dt><dd class="text-2xl font-bold text-gray-900">50 Hz</dd></div>
      <div class="card"><dt class="text-sm text-gray-500">Steckertypen</dt><dd class="text-2xl font-bold text-gray-900">A · C · I</dd></div>
    </div>

    <!-- Ergebnis -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>

      <AffiliateCta
        title="Universaladapter für China kaufen"
        description="Ein kompakter Universal-Reiseadapter, der in chinesische Steckdosen passt und mehrere Geräte gleichzeitig laden kann."
        buttonText="Empfohlenen Adapter ansehen"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  // Netzspannung und Steckertypen nach Land.
  const data: Record<string, { volts: number; plugs: string[] }> = {
    'Vereinigte Staaten': { volts: 120, plugs: ['A', 'B'] },
    'Kanada': { volts: 120, plugs: ['A', 'B'] },
    'Japan': { volts: 100, plugs: ['A', 'B'] },
    'Brasilien': { volts: 127, plugs: ['C', 'N'] },
    'Vereinigtes Königreich': { volts: 230, plugs: ['G'] },
    'Australien': { volts: 230, plugs: ['I'] },
    'Neuseeland': { volts: 230, plugs: ['I'] },
    'Deutschland': { volts: 230, plugs: ['C', 'F'] },
    'Frankreich': { volts: 230, plugs: ['C', 'E'] },
    'Italien': { volts: 230, plugs: ['C', 'F', 'L'] },
    'Spanien': { volts: 230, plugs: ['C', 'F'] },
    'Niederlande': { volts: 230, plugs: ['C', 'F'] },
    'Schweiz': { volts: 230, plugs: ['C', 'J'] },
    'Südkorea': { volts: 220, plugs: ['C', 'F'] },
    'Singapur': { volts: 230, plugs: ['G'] },
    'Indien': { volts: 230, plugs: ['C', 'D', 'M'] },
    'Südafrika': { volts: 230, plugs: ['C', 'D', 'M', 'N'] },
    'Vereinigte Arabische Emirate': { volts: 230, plugs: ['C', 'D', 'G'] },
    'Andere': { volts: 0, plugs: [] },
  };

  // In China sind die Steckertypen A, C und I gebräuchlich.
  const CHINA_PLUGS = ['A', 'C', 'I'];
  const CHINA_VOLTS = 220;

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const country = countryEl.value;
    const info = data[country];

    let heading: string, body: string, tone: 'gut' | 'warnung' | 'hinweis';
    const points: string[] = [];

    if (!info || info.volts === 0) {
      tone = 'hinweis';
      heading = 'Bitte Steckertyp und Spannung Ihres Geräts prüfen';
      body = 'Für diese Auswahl liegen keine genauen Daten vor. Prüfen Sie das Typenschild Ihres Ladegeräts: Steht dort "100-240V", brauchen Sie für chinesische Steckdosen der Typen A, C oder I in der Regel nur einen Reiseadapter.';
      points.push('In China werden 220 V, 50 Hz sowie die Steckertypen A, C und I verwendet.');
      points.push('Die meisten Ladegeräte für Smartphones und Laptops unterstützen 100-240 V und benötigen daher nur einen Reiseadapter.');
    } else {
      const plugMatch = info.plugs.some((p) => CHINA_PLUGS.includes(p));
      const voltMatch = Math.abs(info.volts - CHINA_VOLTS) <= 20;

      if (plugMatch && voltMatch) {
        tone = 'gut';
        heading = 'Wahrscheinlich brauchen Sie keinen Adapter';
        body = `${country} verwendet kompatible Steckertypen (${info.plugs.join(', ')}) und eine ähnliche Spannung (${info.volts} V). Ihre Stecker sollten daher direkt in chinesische Steckdosen passen.`;
        points.push('Prüfen Sie trotzdem jeden Stecker einzeln und nehmen Sie vorsichtshalber einen Adapter mit, falls eine Steckdose besonders stramm sitzt.');
      } else if (!plugMatch && voltMatch) {
        tone = 'warnung';
        heading = 'Sie brauchen einen Reiseadapter, aber keinen Spannungswandler';
        body = `${country} verwendet eine ähnliche Spannung (${info.volts} V), deshalb sind Ihre Geräte in der Regel sicher nutzbar. Ihr Steckertyp (${info.plugs.join(', ')}) passt jedoch nicht in chinesische Steckdosen. Packen Sie daher einen Reiseadapter ein.`;
        points.push('Ein einfacher und günstiger Reiseadapter für Typ A/C/I reicht aus.');
        points.push('Ein zusätzlicher Spannungswandler ist nicht nötig.');
      } else if (plugMatch && !voltMatch) {
        tone = 'warnung';
        heading = 'Achten Sie bei Geräten mit fester Spannung auf die Voltzahl';
        body = `Ihre Stecker (${info.plugs.join(', ')}) passen möglicherweise, aber die Spannung in ${country} (${info.volts} V) weicht von den 220 V in China ab.`;
        points.push('Smartphones, Laptops und Kameras mit der Angabe 100-240 V funktionieren normalerweise problemlos.');
        points.push('Geräte mit fester Spannung, zum Beispiel manche Haartrockner oder Glätteisen, brauchen einen Spannungswandler oder sollten besser zu Hause bleiben.');
      } else {
        tone = 'warnung';
        heading = 'Sie brauchen einen Reiseadapter und sollten die Spannung prüfen';
        body = `${country} verwendet andere Steckertypen (${info.plugs.join(', ')}) und eine andere Spannung (${info.volts} V) als die 220 V in China. Nehmen Sie daher einen Reiseadapter für Typ A/C/I mit.`;
        points.push('Ladegeräte mit Weitbereichsspannung von 100-240 V brauchen nur den Reiseadapter.');
        points.push('Leistungsstarke Geräte mit fester Spannung brauchen zusätzlich einen Spannungswandler. Alternativ können Sie vor Ort ein passendes Gerät kaufen.');
      }
    }

    const toneStyles = {
      gut: 'border-green-200 bg-green-50',
      warnung: 'border-amber-200 bg-amber-50',
      hinweis: 'border-blue-200 bg-blue-50',
    } as const;
    const toneBadge = {
      gut: 'bg-green-600 text-white',
      warnung: 'bg-amber-500 text-white',
      hinweis: 'bg-blue-600 text-white',
    } as const;
    const toneLabel = {
      gut: 'Kein Adapter erforderlich',
      warnung: 'Adapter erforderlich',
      hinweis: 'Gerät prüfen'
    } as const;

    card.className = `card border ${toneStyles[tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[tone]}">${toneLabel[tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${heading}</h2>
      <p class="mt-2 text-gray-700">${body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
