---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import AffiliateCta from '../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../config';

const title = 'Steckdosen- & Spannungs-Checker für China';
const description =
  'Finde heraus, ob du für China einen Steckdosenadapter oder Spannungswandler brauchst, basierend auf deinem Heimatland. In China werden 220 V und die Steckdosentypen A, C und I verwendet.';

const countries = [
  'Vereinigte Staaten', 'Vereinigtes Königreich', 'Kanada', 'Australien', 'Deutschland',
  'Frankreich', 'Italien', 'Spanien', 'Niederlande', 'Japan', 'Südkorea',
  'Singapur', 'Indien', 'Brasilien', 'Neuseeland', 'Schweiz',
  'Südafrika', 'Vereinigte Arabische Emirate', 'Andere',
];
---
<!-- KI-unterstutzt erstellter Inhalt, von muttersprachlichem Redakteur gepruft -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Tool</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Steckdosen- & Spannungs-Checker</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-6">
      <label class="flex flex-col text-sm sm:max-w-sm">
        <span class="mb-1 font-medium text-gray-700">Reise aus</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <button id="check-btn" class="btn-primary mt-4 w-full sm:w-auto">Prüfen, was ich brauche</button>
    </div>

    <!-- Reference: China's own standard -->
    <div class="mt-6 grid gap-4 sm:grid-cols-3">
      <div class="card"><dt class="text-sm text-gray-500">Spannung</dt><dd class="text-2xl font-bold text-gray-900">220 V</dd></div>
      <div class="card"><dt class="text-sm text-gray-500">Frequenz</dt><dd class="text-2xl font-bold text-gray-900">50 Hz</dd></div>
      <div class="card"><dt class="text-sm text-gray-500">Steckdosentypen</dt><dd class="text-2xl font-bold text-gray-900">A · C · I</dd></div>
    </div>

    <!-- Result -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>

      <AffiliateCta
        title="Hol dir einen Universaladapter für China"
        description="Ein kompakter All-in-one-Reiseadapter, der in Chinas Steckdosen passt und mehrere Geräte gleichzeitig lädt."
        buttonText="Empfohlenen Adapter ansehen"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  // Each country's domestic voltage and the plug types it uses.
  const data: Record<string, { volts: number; plugs: string[] }> = {
    'Vereinigte Staaten': { volts: 120, plugs: ['A', 'B'] },
    'Kanada': { volts: 120, plugs: ['A', 'B'] },
    'Japan': { volts: 100, plugs: ['A', 'B'] },
    'Brasilien': { volts: 127, plugs: ['C', 'N'] },
    'Vereinigtes Königreich': { volts: 230, plugs: ['G'] },
    'Australien': { volts: 230, plugs: ['I'] },
    'Neuseeland': { volts: 230, plugs: ['I'] },
    'Deutschland': { volts: 230, plugs: ['C', 'F'] },
    'Frankreich': { volts: 230, plugs: ['C', 'E'] },
    'Italien': { volts: 230, plugs: ['C', 'F', 'L'] },
    'Spanien': { volts: 230, plugs: ['C', 'F'] },
    'Niederlande': { volts: 230, plugs: ['C', 'F'] },
    'Schweiz': { volts: 230, plugs: ['C', 'J'] },
    'Südkorea': { volts: 220, plugs: ['C', 'F'] },
    'Singapur': { volts: 230, plugs: ['G'] },
    'Indien': { volts: 230, plugs: ['C', 'D', 'M'] },
    'Südafrika': { volts: 230, plugs: ['C', 'D', 'M', 'N'] },
    'Vereinigte Arabische Emirate': { volts: 230, plugs: ['C', 'D', 'G'] },
    'Andere': { volts: 0, plugs: [] },
  };

  // China accepts plug types A, C, and I.
  const CHINA_PLUGS = ['A', 'C', 'I'];
  const CHINA_VOLTS = 220;

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const country = countryEl.value;
    const info = data[country];

    let heading: string, body: string, tone: 'good' | 'warn' | 'info';
    const points: string[] = [];

    if (!info || info.volts === 0) {
      tone = 'info';
      heading = 'Prüfe deinen spezifischen Steckertyp und die Spannung';
      body = 'Wir haben keine Daten für deine Auswahl. Schau auf das Etikett deines Ladegeräts — wenn dort "100–240V" steht, brauchst du nur einen Steckdosenadapter für Chinas Steckdosen vom Typ A, C oder I.';
      points.push('In China werden 220V, 50Hz sowie die Steckdosentypen A, C und I verwendet.');
      points.push('Die meisten Handy- und Laptop-Ladegeräte sind für mehrere Spannungen ausgelegt (100–240V) und benötigen nur einen Steckdosenadapter.');
    } else {
      const plugMatch = info.plugs.some((p) => CHINA_PLUGS.includes(p));
      const voltMatch = Math.abs(info.volts - CHINA_VOLTS) <= 20;

      if (plugMatch && voltMatch) {
        tone = 'good';
        heading = 'Du brauchst wahrscheinlich keinen Adapter';
        body = `${country} verwendet kompatible Steckertypen (${info.plugs.join(', ')}) und eine ähnliche Spannung (${info.volts}V). Deine Stecker sollten direkt in Chinas Steckdosen passen.`;
        points.push('Prüfe trotzdem jeden Stecker noch einmal — nimm vorsichtshalber einen Adapter mit, falls eine Steckdose eng sitzt.');
      } else if (!plugMatch && voltMatch) {
        tone = 'warn';
        heading = 'Du brauchst einen Steckdosenadapter (aber keinen Spannungswandler)';
        body = `${country} verwendet eine ähnliche Spannung (${info.volts}V), daher sind deine Geräte sicher. Aber dein Steckertyp (${info.plugs.join(', ')}) passt nicht in Chinas Steckdosen — pack einen Steckdosenadapter ein.`;
        points.push('Ein einfacher, günstiger Steckdosenadapter für Typ A/C/I ist alles, was du brauchst.');
        points.push('Kein sperriger Spannungswandler erforderlich.');
      } else if (plugMatch && !voltMatch) {
        tone = 'warn';
        heading = 'Achte bei Geräten mit nur einer Spannung auf die Spannung';
        body = `Deine Stecker (${info.plugs.join(', ')}) passen möglicherweise, aber die Spannung in ${country} (${info.volts}V) unterscheidet sich von Chinas 220V.`;
        points.push('Handys, Laptops und Kameras mit der Kennzeichnung 100–240V funktionieren überall.');
        points.push('Geräte mit nur einer Spannung (einige Haartrockner, Glätteisen) benötigen einen Spannungswandler oder sollten zu Hause bleiben.');
      } else {
        tone = 'warn';
        heading = 'Du brauchst einen Steckdosenadapter — und solltest die Spannung prüfen';
        body = `${country} verwendet andere Stecker (${info.plugs.join(', ')}) und eine andere Spannung (${info.volts}V) als Chinas 220V. Bring einen Steckdosenadapter für Typ A/C/I mit.`;
        points.push('Ladegeräte mit mehreren Spannungen (100–240V) benötigen nur den Steckdosenadapter.');
        points.push('Geräte mit nur einer Spannung und hoher Wattzahl benötigen zusätzlich einen Spannungswandler — oder du kaufst stattdessen ein lokales Äquivalent.');
      }
    }

    const toneStyles = {
      good: 'border-green-200 bg-green-50',
      warn: 'border-amber-200 bg-amber-50',
      info: 'border-blue-200 bg-blue-50',
    } as const;
    const toneBadge = {
      good: 'bg-green-600 text-white',
      warn: 'bg-amber-500 text-white',
      info: 'bg-blue-600 text-white',
    } as const;
    const toneLabel = { good: 'Kein Adapter nötig', warn: 'Adapter nötig', info: 'Ladegerät prüfen' } as const;

    card.className = `card border ${toneStyles[tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[tone]}">${toneLabel[tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${heading}</h2>
      <p class="mt-2 text-gray-700">${body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>