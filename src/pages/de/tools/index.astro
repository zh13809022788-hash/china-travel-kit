---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import AdSlot from "../../../components/AdSlot.astro";
import { TOOLS as tools } from "../../../config";

const title = 'Kostenlose China-Reisetools: Visum, Zahlung, eSIM, Budget, Fahrerkarten und Redewendungen';
const description =
  'Kostenlose interaktive Tools fur die Reiseplanung nach China: visumfreie Einreise prufen, Kompatibilitat von Zahlungskarten, eSIM-Optionen, Reisebudget, Bargeld als Reserve, Steckdosen, chinesische Redewendungen und Adresskarten fur Taxifahrer.';

const toolUseCases = [
  {
    title: 'Vor der Flugbuchung',
    text: 'Nutze den Checker fur visumfreie Einreise, den Planer fur die beste Reisezeit und den Budget-Rechner, bevor du Termine und Stadte festlegst.',
    links: [
      { href: '/tools/visa-free-checker/', label: 'Checker fur visumfreie Einreise' },
      { href: '/tools/best-time-to-visit/', label: 'Beste Reisezeit' },
      { href: '/tools/budget-cash-estimator/', label: 'Budget-Rechner' },
    ],
  },
  {
    title: 'Vor der Abreise',
    text: 'Nutze die Tools fur Zahlung, eSIM, Apps, Stecker und Redewendungen, solange du noch Zeit hast, Einrichtungsprobleme zu Hause zu beheben.',
    links: [
      { href: '/tools/payment-checker/', label: 'Zahlungs-Checker' },
      { href: '/tools/esim-comparison/', label: 'eSIM-Vergleich' },
      { href: '/tools/app-availability-checker/', label: 'App-Checker' },
    ],
  },
  {
    title: 'Vor Ort in China',
    text: 'Nutze Fahrerkarten, Wahrungsumrechnung und wichtige Redewendungen, wenn Apps, Taxis, Speisekarten oder Hotelrezeptionen verwirrend werden.',
    links: [
      { href: '/tools/survival-kit/', label: 'Survival kit' },
      { href: '/tools/show-to-driver/', label: 'Show to Driver' },
      { href: '/tools/currency-converter/', label: 'RMB-Umrechner' },
      { href: '/tools/essential-phrases/', label: 'Wichtige Redewendungen' },
    ],
  },
];

const toolsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  hasPart: tools.map((tool) => ({
    '@type': 'WebApplication',
    name: tool.title,
    description: tool.desc,
    applicationCategory: 'TravelApplication',
    url: new URL(tool.href, 'https://www.chinatripbox.com').toString(),
  })),
};
---
<!-- KI-unterstutzt erstellter Inhalt, von muttersprachlichem Redakteur gepruft -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(toolsJsonLd)} />
  <Header />
  <main class="container-page py-12">
    <header class="max-w-2xl">
      <p class="section-kicker">Tool-Center</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Kostenlose China-Reisetools</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-primary">Checkliste vor der Reise nutzen</a>
        <a href="/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">Planer fur Erstbesucher lesen</a>
      </div>
    </header>

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 lg:grid-cols-3" aria-labelledby="tool-use-cases-heading">
      <div class="lg:col-span-3">
        <h2 id="tool-use-cases-heading" class="text-2xl font-bold text-gray-950">Welches Tool solltest du zuerst nutzen?</h2>
      </div>
      {toolUseCases.map((useCase) => (
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <h3 class="text-lg font-bold text-gray-950">{useCase.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{useCase.text}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {useCase.links.map((link) => (
              <a href={link.href} class="block rounded-lg border border-brand-200 bg-brand-50 px-4 py-2 text-sm font-semibold text-brand-700 hover:border-brand-300 hover:bg-brand-100 hover:no-underline">{link.label}</a>
            ))}
          </div>
        </div>
      ))}
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {tools.map((tool) => (
        <a href={tool.href} class="card block hover:no-underline">
          <div class="text-3xl">{tool.icon}</div>
          <h2 class="mt-3 text-lg font-bold text-gray-900">{tool.title}</h2>
          <p class="mt-1.5 text-sm text-gray-600">{tool.desc}</p>
          <span class="mt-3 inline-block text-sm font-semibold text-brand-600">Tool offnen →</span>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>