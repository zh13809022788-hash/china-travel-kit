---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import { TOOLS as tools } from '../../../config';

const title = 'Kostenlose Tools: Visum, Zahlung, eSIM, Budget, Fahrerkarten und Sätze';
const description =
  'Kostenlose interaktive Tools für die China-Reiseplanung: Prüfen Sie visumfreie Einreise, Kartenkompatibilität für Zahlungen, eSIM-Optionen, Reisebudget, Bargeldreserve, Netzstecker, chinesische Sätze und Adresskarten für Taxifahrer.';

const toolUseCases = [
  {
    title: 'Vor der Flugbuchung',
    text: 'Nutzen Sie den Visafrei-Checker, den Planer für die beste Reisezeit und den Budget-Schätzer, bevor Sie Termine und Städte festlegen.',
    links: [
      { href: '/de/tools/visa-free-checker/', label: 'Visafrei-Checker' },
      { href: '/de/tools/best-time-to-visit/', label: 'Beste Reisezeit' },
      { href: '/de/tools/budget-cash-estimator/', label: 'Budget-Schätzer' },
    ],
  },
  {
    title: 'Vor der Abreise',
    text: 'Nutzen Sie Zahlungs-, eSIM-, App-, Stecker- und Satz-Tools, solange Sie zu Hause noch Zeit haben, Einrichtungsprobleme zu beheben.',
    links: [
      { href: '/de/tools/payment-checker/', label: 'Zahlungs-Checker' },
      { href: '/de/tools/esim-comparison/', label: 'eSIM-Vergleich' },
      { href: '/de/tools/app-availability-checker/', label: 'App-Checker' },
    ],
  },
  {
    title: 'Vor Ort in China',
    text: 'Nutzen Sie Fahrerkarten, Währungsumrechnung und wichtige Sätze, wenn Apps, Taxis, Speisekarten oder Rezeptionen verwirrend werden.',
    links: [
      { href: '/de/tools/survival-kit/', label: 'Notfallkit' },
      { href: '/de/tools/show-to-driver/', label: 'Dem Fahrer zeigen' },
      { href: '/de/tools/currency-converter/', label: 'RMB-Umrechner' },
      { href: '/de/tools/essential-phrases/', label: 'Wichtige Sätze' },
    ],
  },
];

const toolsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  hasPart: tools.map((tool) => ({
    '@type': 'WebApplication',
    name: tool.title,
    description: tool.desc,
    applicationCategory: 'TravelApplication',
    url: new URL(tool.href, 'https://www.chinatripbox.com').toString(),
  })),
};
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(toolsJsonLd)} />
  <Header locale="de" />
  <main class="container-page py-12">
    <header class="max-w-2xl">
      <p class="section-kicker">Tool-Zentrum</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Kostenlose China-Reisetools</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="/de/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-primary">Checkliste vor der Reise nutzen</a>
        <a href="/de/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">Planer für Erstbesucher lesen</a>
      </div>
    </header>

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 lg:grid-cols-3" aria-labelledby="tool-use-cases-heading">
      <div class="lg:col-span-3">
        <h2 id="tool-use-cases-heading" class="text-2xl font-bold text-gray-950">Welches Tool sollten Sie zuerst verwenden?</h2>
      </div>
      {toolUseCases.map((useCase) => (
        <article class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <h3 class="text-lg font-bold text-gray-950">{useCase.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{useCase.text}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {useCase.links.map((link) => (
              <a href={link.href} class="rounded-full border border-gray-200 px-3 py-1.5 text-xs font-semibold text-brand-700 hover:border-brand-300 hover:bg-brand-50 hover:no-underline">{link.label}</a>
            ))}
          </div>
        </article>
      ))}
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {tools.map((tool) => (
        <a href={tool.href} class="card block hover:no-underline">
          <div class="text-3xl">{tool.icon}</div>
          <h2 class="mt-3 text-lg font-bold text-gray-900">{tool.title}</h2>
          <p class="mt-1.5 text-sm text-gray-600">{tool.desc}</p>
          <span class="mt-3 inline-block text-sm font-semibold text-brand-600">Tool öffnen →</span>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>