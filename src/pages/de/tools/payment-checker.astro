---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import AffiliateCta from '../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../config';
import FaqSection from '../../components/FaqSection.astro';

const title = 'Kompatibilitatsprufer fur Zahlungskarten in China';
const description =
  'Prufen Sie, ob Ihre Kreditkarte mit Alipay und WeChat Pay in China funktioniert. Sehen Sie Unterstutzungsstatus, Limits, Gebuhren und wie die Einrichtung je nach Nationalitat und Kartennetzwerk erfolgt.';

const nationalities = [
  'Vereinigte Staaten', 'Vereinigtes Konigreich', 'Kanada', 'Australien',
  'Deutschland', 'Frankreich', 'Japan', 'Singapur', 'Andere',
];
const cardNetworks = ['Visa', 'Mastercard', 'Amex', 'Discover'];

const nextSteps = [
  { href: '/posts/alipay-foreign-credit-card-step-by-step/', title: 'Alipay mit einer auslandischen Karte einrichten' },
  { href: '/posts/link-a-foreign-visa-or-mastercard-to-wechat-pay-in-china/', title: 'Visa oder Mastercard mit WeChat Pay verknupfen' },
  { href: '/posts/can-you-still-use-cash-in-china-as-a-foreigner-in-2026/', title: 'Wissen, wann Bargeld weiterhin hilft' },
  { href: '/payment/', title: 'Alle Zahlungsleitfaden fur China ansehen' },
];

const faqItems = [
  {
    question: 'Wird jede auslandische Visa oder Mastercard in China funktionieren?',
    answer:
      'Nein. Visa und Mastercard sind fur Alipay und WeChat Pay der sicherste Ausgangspunkt, aber einzelne Banken konnen die Verifizierung dennoch blockieren, das Verknupfen mit Online-Wallets ablehnen oder China-Transaktionen markieren. Halten Sie eine zweite Karte und etwas Bargeld als Reserve bereit.',
  },
  {
    question: 'Sollten Touristen sowohl Alipay als auch WeChat Pay einrichten?',
    answer:
      'Ja, wenn moglich. Alipay ist fur Besucher oft einfacher einzurichten, wahrend WeChat Pay fur Mini-Programme, Restaurants und lokale Dienste nutzlich sein kann. Beides zu haben verringert die Wahrscheinlichkeit, bei einem Handler festzustecken.',
  },
  {
    question: 'Wie viel Bargeld sollte ich mitbringen, wenn mobiles Bezahlen funktioniert?',
    answer:
      'Bringen Sie genug kleine Scheine fur den Flughafentransport, Mahlzeiten als Reserve und kleine Geschafte mit, verlassen Sie sich aber nicht allein auf Bargeld. Viele Orte bevorzugen QR-Zahlung, und manche Mitarbeiter haben moglicherweise kein Wechselgeld parat.',
  },
];
---
<!-- KI-unterstutzt erstellter Inhalt, von muttersprachlichem Redakteur gepruft -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Tool</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Kompatibilitatsprufer fur Zahlungen</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <section class="mt-6 grid gap-4 md:grid-cols-3" aria-label="Wobei dieser Zahlungsprufer hilft">
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">Wallet-Unterstutzung prufen</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Sehen Sie, ob Ihr Kartennetzwerk gut zu Alipay und WeChat Pay passt.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">Rund um Limits planen</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Prufen Sie ubliche Transaktionslimits und Gebuhren, bevor Sie grosere Einkaufe tatigen.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">Einen Reserveplan erstellen</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Wissen Sie, wann Sie Bargeld dabeihaben, die Karte wechseln oder beide Zahlungs-Apps vorbereiten sollten.</p>
      </div>
    </section>

    <AdSlot format="banner" />

    <!-- Input controls -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Ihre Nationalitat</span>
        <select id="nationality" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {nationalities.map((n) => <option value={n}>{n}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Kartennetzwerk</span>
        <select id="network" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {cardNetworks.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="check-btn" class="btn-primary w-full sm:w-auto">Kompatibilitat prufen</button>
      </div>
    </div>

    <!-- Results -->
    <div id="result" class="mt-6 hidden">
      <div class="grid gap-5 md:grid-cols-2">
        <div class="card" id="alipay-card"></div>
        <div class="card" id="wechat-card"></div>
      </div>

      <AffiliateCta
        title="Eine reisefertige Karte einrichten"
        description="Holen Sie sich eine Prepaid-Reisekarte, die sich fur Ihre China-Reise zuverlassig mit Alipay und WeChat Pay verknupfen lasst."
        buttonText="Empfohlene Karte ansehen"
        placeholder={AFFILIATE_LINKS.payment}
      />
    </div>

    <section class="mt-12 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">So verwenden Sie diesen Prufdienst</h2>
        <ol class="mt-4 space-y-3 text-sm leading-6 text-gray-600">
          <li><strong class="text-gray-900">1. Wahlen Sie Ihr Pass- oder Wohnsitzland.</strong> Das hilft dabei, typische Bank- und Verifizierungsprobleme einzuordnen.</li>
          <li><strong class="text-gray-900">2. Wahlen Sie Ihr Kartennetzwerk.</strong> Visa und Mastercard sind fur China-Reise-Wallets normalerweise die besten ersten Optionen.</li>
          <li><strong class="text-gray-900">3. Bereiten Sie mindestens eine Ausweichmoglichkeit vor.</strong> Nehmen Sie eine zweite Karte mit, installieren Sie beide Zahlungs-Apps und halten Sie etwas Bargeld fur Sonderfalle bereit.</li>
        </ol>
        <p class="mt-4 text-sm leading-6 text-gray-600">
          Zahlungsregeln, Wallet-Verifizierung und Risikoprufungen von Kartenausstellern konnen sich andern. Betrachten Sie das Ergebnis als praktische Orientierung fur die Reiseplanung und bestatigen Sie dann alle grosseren Transaktionslimits vor der Abreise in Alipay, WeChat Pay und bei Ihrem Kartenaussteller.
        </p>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Nachste Zahlungsschritte</h2>
        <div class="mt-4 grid gap-3">
          {nextSteps.map((item) => (
            <a href={item.href} class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">
              {item.title}
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6" aria-labelledby="payment-checker-seo">
      <h2 id="payment-checker-seo" class="text-2xl font-bold text-gray-900">Was dieser Prufdienst Ihnen sagen kann und was nicht</h2>
      <p class="mt-3 text-sm leading-6 text-gray-600">
        Dieses Tool ist fur die Planung vor der Abreise gedacht. Es hilft Ihnen, Kartennetzwerk,
        Wallet-Unterstutzung, wahrscheinliche Gebuhrenpunkte und Reserve-Methoden durchzudenken, bevor Sie an einer Kasse in China
        stehen. Es kann nicht garantieren, dass Ihre individuelle Bank jede Zahlung genehmigen wird.
      </p>
      <div class="mt-5 overflow-x-auto rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200 text-sm">
          <thead class="bg-gray-50 text-left text-gray-700">
            <tr>
              <th class="px-4 py-3 font-semibold">Risiko</th>
              <th class="px-4 py-3 font-semibold">Warum es passiert</th>
              <th class="px-4 py-3 font-semibold">Beste Reserve</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 bg-white text-gray-600">
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">Kartenverknupfung scheitert</td>
              <td class="px-4 py-3">Der Aussteller blockiert die Wallet-Verifizierung oder 3-D Secure schlagt fehl.</td>
              <td class="px-4 py-3">Versuchen Sie eine andere Visa/Mastercard von einer anderen Bank.</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">Grose Zahlung abgelehnt</td>
              <td class="px-4 py-3">Ein Wallet-, Handler- oder Ausstellerlimit lost eine Prufung aus.</td>
              <td class="px-4 py-3">Teilen Sie die Zahlung auf, verwenden Sie die physische Karte oder fragen Sie Hotel/Handler nach Optionen.</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">Kein Signal an der Kasse</td>
              <td class="px-4 py-3">Schwache mobile Daten, kein Roaming oder die App kann nicht laden.</td>
              <td class="px-4 py-3">Nutzen Sie die andere Wallet, das WLAN des Handlers oder etwas Bargeld als Reserve.</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-sm leading-6 text-gray-600">
        Fur die starkste Vorbereitung lesen Sie den vollstandigen <a href="/posts/how-to-pay-in-china-tourist-guide/" class="font-semibold">Zahlungsleitfaden fur China-Touristen</a>,
        vergleichen Sie <a href="/posts/alipay-vs-wechat-pay-foreigners/" class="font-semibold">Alipay vs WeChat Pay</a>,
        und halten Sie mit unserem <a href="/posts/how-much-cash-to-bring-to-china/" class="font-semibold">Bargeldleitfaden</a> eine kleine RMB-Reserve bereit.
      </p>
    </section>

    <FaqSection items={faqItems} title="FAQ zum Zahlungsprufdienst" />
  </main>
  <Footer />
</BaseLayout>

<script>
  type NetworkKey = 'Visa' | 'Mastercard' | 'Amex' | 'Discover';

  // Static compatibility matrix (representative guidance)
  const matrix: Record<NetworkKey, {
    alipay: { status: string; single: string; daily: string; fee: string; how: string };
    wechat: { status: string; single: string; daily: string; fee: string; how: string };
  }> = {
    Visa: {
      alipay: { status: 'Unterstutzt', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% uber 200 RMB', how: 'Karte in Alipay Wallet hinzufugen, Reisepass verifizieren' },
      wechat: { status: 'Unterstutzt', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% uber 200 RMB', how: 'Karte in WeChat Wallet hinzufugen, Reisepass verifizieren' },
    },
    Mastercard: {
      alipay: { status: 'Unterstutzt', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% uber 200 RMB', how: 'Karte in Alipay Wallet hinzufugen, Reisepass verifizieren' },
      wechat: { status: 'Unterstutzt', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% uber 200 RMB', how: 'Karte in WeChat Wallet hinzufugen, Reisepass verifizieren' },
    },
    Amex: {
      alipay: { status: 'Teilweise unterstutzt', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% uber 200 RMB', how: 'Amex funktioniert in Alipay in den meisten Fallen; halten Sie Visa/MC als Reserve bereit' },
      wechat: { status: 'Begrenzt', single: 'Variiert', daily: 'Variiert', fee: '~3% uber 200 RMB', how: 'Die Unterstutzung ist uneinheitlich; in WeChat besser Visa/Mastercard bevorzugen' },
    },
    Discover: {
      alipay: { status: 'Begrenzt', single: 'Variiert', daily: 'Variiert', fee: 'Variiert', how: 'Die Akzeptanz ist begrenzt; eine Visa/Mastercard wird dringend empfohlen' },
      wechat: { status: 'Nicht empfohlen', single: '—', daily: '—', fee: '—', how: 'Verwenden Sie stattdessen eine Visa oder Mastercard' },
    },
  };

  const statusColor = (status: string) => {
    if (/^supported/i.test(status)) return 'text-green-700 bg-green-50 border-green-200';
    if (/partial|limited/i.test(status)) return 'text-amber-700 bg-amber-50 border-amber-200';
    return 'text-red-700 bg-red-50 border-red-200';
  };

  function cardHtml(wallet: string, d: { status: string; single: string; daily: string; fee: string; how: string }) {
    return `
      <h3 class="text-lg font-bold text-gray-900">${wallet}</h3>
      <span class="mt-2 inline-block rounded-full border px-3 py-0.5 text-xs font-semibold ${statusColor(d.status)}">${d.status}</span>
      <dl class="mt-4 space-y-2 text-sm">
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Einzeltransaktion</dt><dd class="font-medium text-gray-900">${d.single}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Tageslimit</dt><dd class="font-medium text-gray-900">${d.daily}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Bearbeitungsgebuhr</dt><dd class="font-medium text-gray-900">${d.fee}</dd></div>
        <div class="pt-2 text-gray-600"><dt class="text-gray-500">So richten Sie es ein</dt><dd class="mt-1">${d.how}</dd></div>
      </dl>`;
  }

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const networkEl = document.getElementById('network') as HTMLSelectElement;
  const alipayCard = document.getElementById('alipay-card');
  const wechatCard = document.getElementById('wechat-card');

  btn?.addEventListener('click', () => {
    const net = networkEl.value as NetworkKey;
    const data = matrix[net];
    if (!data || !alipayCard || !wechatCard || !result) return;
    alipayCard.innerHTML = cardHtml('Alipay', data.alipay);
    wechatCard.innerHTML = cardHtml('WeChat Pay', data.wechat);
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>