---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';
import FaqSection from '../../../components/FaqSection.astro';

const title = 'Kompatibilitätsprüfer für Zahlungskarten in China';
const description =
  'Prüfen Sie, ob Ihre Kreditkarte in China mit Alipay und WeChat Pay funktioniert. Sehen Sie Unterstützungsstatus, Limits, Gebühren und Einrichtungshinweise nach Nationalität und Kartennetzwerk.';

const nationalities = [
  'Vereinigte Staaten', 'Vereinigtes Königreich', 'Kanada', 'Australien',
  'Deutschland', 'Frankreich', 'Japan', 'Singapur', 'Andere',
];
const cardNetworks = ['Visa', 'Mastercard', 'Amex', 'Discover'];

const nextSteps = [
  { href: '/de/posts/alipay-foreign-credit-card-step-by-step/', title: 'Alipay mit einer ausländischen Karte einrichten' },
  { href: '/de/posts/link-a-foreign-visa-or-mastercard-to-wechat-pay-in-china/', title: 'Visa oder Mastercard mit WeChat Pay verknüpfen' },
  { href: '/de/posts/can-you-still-use-cash-in-china-as-a-foreigner-in-2026/', title: 'Wissen, wann Bargeld noch hilft' },
  { href: '/de/payment/', title: 'Alle Zahlungsratgeber fur China ansehen' },
];

const faqItems = [
  {
    question: 'Funktioniert jede ausländische Visa oder Mastercard in China?',
    answer:
      'Nein. Visa und Mastercard sind der sicherste Ausgangspunkt für Alipay und WeChat Pay, aber einzelne Banken können die Verifizierung blockieren, die Verknüpfung mit einer Online-Wallet ablehnen oder Transaktionen in China markieren. Halten Sie eine zweite Karte und etwas Bargeld als Reserve bereit.',
  },
  {
    question: 'Sollten Touristen sowohl Alipay als auch WeChat Pay einrichten?',
    answer:
      'Ja, wenn möglich. Alipay ist für Besucher oft einfacher einzurichten, während WeChat Pay für Mini-Programme, Restaurants und lokale Dienste nützlich sein kann. Beides zu haben verringert das Risiko, bei einem Händler nicht bezahlen zu können.',
  },
  {
    question: 'Wie viel Bargeld sollte ich mitnehmen, wenn mobiles Bezahlen funktioniert?',
    answer:
      'Nehmen Sie genug kleine Scheine für Flughafentransfers, Mahlzeiten als Reserve und kleine Geschäfte mit, verlassen Sie sich aber nicht allein auf Bargeld. Viele Orte bevorzugen QR-Zahlungen, und manche Mitarbeiter haben möglicherweise kein Wechselgeld bereit.',
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Tool</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Kompatibilitätsprüfer für Zahlungen</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <section class="mt-6 grid gap-4 md:grid-cols-3" aria-label="Wobei dieser Zahlungsprufer hilft">
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">Wallet-Unterstützung prüfen</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Sehen Sie, ob Ihr Kartennetzwerk gut zu Alipay und WeChat Pay passt.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">Limits einplanen</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Prüfen Sie typische Transaktionslimits und Gebühren, bevor Sie größere Einkäufe tätigen.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">Backup-Plan erstellen</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Wissen Sie, wann Sie Bargeld mitnehmen, Karten wechseln oder beide Zahlungs-Apps vorbereiten sollten.</p>
      </div>
    </section>

    <AdSlot format="banner" />

    <!-- Eingabesteuerung -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Ihre Nationalität</span>
        <select id="nationality" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {nationalities.map((n) => <option value={n}>{n}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Kartennetzwerk</span>
        <select id="network" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {cardNetworks.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="check-btn" class="btn-primary w-full sm:w-auto">Kompatibilität prüfen</button>
      </div>
    </div>

    <!-- Ergebnisse -->
    <div id="result" class="mt-6 hidden">
      <div class="grid gap-5 md:grid-cols-2">
        <div class="card" id="alipay-card"></div>
        <div class="card" id="wechat-card"></div>
      </div>

      <AffiliateCta
        title="Eine reisefertige Karte einrichten"
        description="Holen Sie sich eine Prepaid-Reisekarte, die sich für Ihre China-Reise zuverlässig mit Alipay und WeChat Pay verknüpfen lässt."
        buttonText="Empfohlene Karte ansehen"
        placeholder={AFFILIATE_LINKS.payment}
      />
    </div>

    <section class="mt-12 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">So verwenden Sie diesen Prüfer</h2>
        <ol class="mt-4 space-y-3 text-sm leading-6 text-gray-600">
          <li><strong class="text-gray-900">1. Wählen Sie Ihr Pass- oder Wohnsitzland.</strong> Das hilft, typische Bank- und Verifizierungsprobleme einzuordnen.</li>
          <li><strong class="text-gray-900">2. Wählen Sie Ihr Kartennetzwerk.</strong> Visa und Mastercard sind für Reise-Wallets in China meist die beste erste Wahl.</li>
          <li><strong class="text-gray-900">3. Bereiten Sie mindestens eine Alternative vor.</strong> Nehmen Sie eine zweite Karte mit, installieren Sie beide Zahlungs-Apps und halten Sie für Sonderfälle etwas Bargeld bereit.</li>
        </ol>
        <p class="mt-4 text-sm leading-6 text-gray-600">
          Zahlungsregeln, Wallet-Verifizierung und Risikoprüfungen des Kartenherausgebers können sich ändern. Nutzen Sie das Ergebnis als praktische Orientierung für Ihre Reiseplanung und bestätigen Sie vor der Abreise alle größeren Transaktionslimits in Alipay, WeChat Pay und bei Ihrem Kartenherausgeber.
        </p>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Nächste Zahlungsschritte</h2>
        <div class="mt-4 grid gap-3">
          {nextSteps.map((item) => (
            <a href={item.href} class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">
              {item.title}
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6" aria-labelledby="payment-checker-seo">
      <h2 id="payment-checker-seo" class="text-2xl font-bold text-gray-900">Was dieser Prüfer Ihnen sagen kann und was nicht</h2>
      <p class="mt-3 text-sm leading-6 text-gray-600">
        Dieses Tool ist für die Planung vor der Abreise gedacht. Es hilft Ihnen, Kartennetzwerk,
        Wallet-Unterstützung, wahrscheinliche Gebührenpunkte und Backup-Methoden zu durchdenken,
        bevor Sie an einer Kasse in China stehen. Es kann nicht garantieren, dass Ihre einzelne Bank jede Zahlung genehmigt.
      </p>
      <div class="mt-5 overflow-x-auto rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200 text-sm">
          <thead class="bg-gray-50 text-left text-gray-700">
            <tr>
              <th class="px-4 py-3 font-semibold">Risiko</th>
              <th class="px-4 py-3 font-semibold">Warum es passiert</th>
              <th class="px-4 py-3 font-semibold">Beste Alternative</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 bg-white text-gray-600">
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">Kartenverknüpfung scheitert</td>
              <td class="px-4 py-3">Der Herausgeber blockiert die Wallet-Verifizierung oder 3-D Secure schlägt fehl.</td>
              <td class="px-4 py-3">Probieren Sie eine andere Visa/Mastercard von einer anderen Bank.</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">Große Zahlung abgelehnt</td>
              <td class="px-4 py-3">Ein Limit der Wallet, des Händlers oder des Herausgebers löst eine Prüfung aus.</td>
              <td class="px-4 py-3">Teilen Sie die Zahlung auf, nutzen Sie die physische Karte oder fragen Sie Hotel/Händler nach Optionen.</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">Kein Signal an der Kasse</td>
              <td class="px-4 py-3">Schwache mobile Daten, kein Roaming oder die App kann nicht laden.</td>
              <td class="px-4 py-3">Nutzen Sie die andere Wallet, das WLAN des Händlers oder etwas Bargeld als Reserve.</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-sm leading-6 text-gray-600">
        Für die stärkste Vorbereitung lesen Sie den vollständigen <a href="/de/posts/how-to-pay-in-china-tourist-guide/" class="font-semibold">Zahlungsratgeber für China-Touristen</a>,
        vergleichen Sie <a href="/de/posts/alipay-vs-wechat-pay-foreigners/" class="font-semibold">Alipay im Vergleich zu WeChat Pay</a>,
        und halten Sie mit unserem <a href="/de/posts/how-much-cash-to-bring-to-china/" class="font-semibold">Bargeldratgeber</a> eine kleine RMB-Reserve bereit.
      </p>
    </section>

    <FaqSection items={faqItems} title="FAQ zum Zahlungsprüfer" />
  </main>
  <Footer />
</BaseLayout>

<script>
  type NetworkKey = 'Visa' | 'Mastercard' | 'Amex' | 'Discover';

  // Statische Kompatibilitätsmatrix (repräsentative Orientierung)
  const matrix: Record<NetworkKey, {
    alipay: { status: string; single: string; daily: string; fee: string; how: string };
    wechat: { status: string; single: string; daily: string; fee: string; how: string };
  }> = {
    Visa: {
      alipay: { status: 'Unterstützt', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% über 200 RMB', how: 'Karte in der Alipay Wallet hinzufügen, Reisepass verifizieren' },
      wechat: { status: 'Unterstützt', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% über 200 RMB', how: 'Karte in der WeChat Wallet hinzufügen, Reisepass verifizieren' },
    },
    Mastercard: {
      alipay: { status: 'Unterstützt', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% über 200 RMB', how: 'Karte in der Alipay Wallet hinzufügen, Reisepass verifizieren' },
      wechat: { status: 'Unterstützt', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% über 200 RMB', how: 'Karte in der WeChat Wallet hinzufügen, Reisepass verifizieren' },
    },
    Amex: {
      alipay: { status: 'Teilweise unterstützt', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% über 200 RMB', how: 'Amex funktioniert in Alipay in den meisten Fällen; halten Sie Visa/MC als Reserve bereit' },
      wechat: { status: 'Eingeschränkt', single: 'Variiert', daily: 'Variiert', fee: '~3% über 200 RMB', how: 'Die Unterstützung ist uneinheitlich; bevorzugen Sie Visa/Mastercard in WeChat' },
    },
    Discover: {
      alipay: { status: 'Eingeschränkt', single: 'Variiert', daily: 'Variiert', fee: 'Variiert', how: 'Die Akzeptanz ist begrenzt; Visa/Mastercard wird dringend empfohlen' },
      wechat: { status: 'Nicht empfohlen', single: '—', daily: '—', fee: '—', how: 'Verwenden Sie stattdessen Visa oder Mastercard' },
    },
  };

  const statusColor = (status: string) => {
    if (/^unterstützt/i.test(status)) return 'text-green-700 bg-green-50 border-green-200';
    if (/teilweise|eingeschränkt/i.test(status)) return 'text-amber-700 bg-amber-50 border-amber-200';
    return 'text-red-700 bg-red-50 border-red-200';
  };

  function cardHtml(wallet: string, d: { status: string; single: string; daily: string; fee: string; how: string }) {
    return `
      <h3 class="text-lg font-bold text-gray-900">${wallet}</h3>
      <span class="mt-2 inline-block rounded-full border px-3 py-0.5 text-xs font-semibold ${statusColor(d.status)}">${d.status}</span>
      <dl class="mt-4 space-y-2 text-sm">
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Einzeltransaktion</dt><dd class="font-medium text-gray-900">${d.single}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Tageslimit</dt><dd class="font-medium text-gray-900">${d.daily}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Bearbeitungsgebühr</dt><dd class="font-medium text-gray-900">${d.fee}</dd></div>
        <div class="pt-2 text-gray-600"><dt class="text-gray-500">Einrichtung</dt><dd class="mt-1">${d.how}</dd></div>
      </dl>`;
  }

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const networkEl = document.getElementById('network') as HTMLSelectElement;
  const alipayCard = document.getElementById('alipay-card');
  const wechatCard = document.getElementById('wechat-card');

  btn?.addEventListener('click', () => {
    const net = networkEl.value as NetworkKey;
    const data = matrix[net];
    if (!data || !alipayCard || !wechatCard || !result) return;
    alipayCard.innerHTML = cardHtml('Alipay', data.alipay);
    wechatCard.innerHTML = cardHtml('WeChat Pay', data.wechat);
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
