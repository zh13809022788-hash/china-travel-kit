---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Prüfer für visumfreie Einreise und Transit in China';
const description =
  'Prüfen Sie anhand Ihrer Staatsangehörigkeit und Reiseart, ob Sie visumfrei nach China einreisen können, den 240-Stunden-Transit ohne Visum nutzen können oder ein Visum beantragen müssen.';

const lastReviewed = '13. Juli 2026';

// Repräsentative Richtliniendaten für 2026. Dies dient nur zur Orientierung und ist keine Rechtsberatung;
// Reisende sollten sich vor der Buchung bei einer Botschaft rückversichern.
const countries = [
  { value: 'United States', label: 'Vereinigte Staaten' },
  { value: 'United Kingdom', label: 'Vereinigtes Königreich' },
  { value: 'Canada', label: 'Kanada' },
  { value: 'Australia', label: 'Australien' },
  { value: 'Germany', label: 'Deutschland' },
  { value: 'France', label: 'Frankreich' },
  { value: 'Italy', label: 'Italien' },
  { value: 'Spain', label: 'Spanien' },
  { value: 'Netherlands', label: 'Niederlande' },
  { value: 'Japan', label: 'Japan' },
  { value: 'South Korea', label: 'Südkorea' },
  { value: 'Singapore', label: 'Singapur' },
  { value: 'Malaysia', label: 'Malaysia' },
  { value: 'Thailand', label: 'Thailand' },
  { value: 'Brazil', label: 'Brasilien' },
  { value: 'New Zealand', label: 'Neuseeland' },
  { value: 'Switzerland', label: 'Schweiz' },
  { value: 'Ireland', label: 'Irland' },
  { value: 'Norway', label: 'Norwegen' },
  { value: 'Other', label: 'Sonstige' },
];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Werkzeug</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Prüfer für visumfreie Einreise und Transit</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <p class="mt-3 text-sm text-gray-500">
        Zuletzt geprüft: {lastReviewed}. Dieser Prüfer ist eine Planungshilfe und keine offizielle Entscheidung über Ihre Berechtigung.
      </p>
    </header>

    <AdSlot format="banner" />

    <!-- Eingabesteuerung -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Staatsangehörigkeit laut Reisepass</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c.value}>{c.label}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Reiseart</span>
        <select id="trip" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="tourism">Tourismus / Besuch</option>
          <option value="business">Geschäftsreise</option>
          <option value="transit">Nur Transit in ein anderes Land</option>
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="check-btn" class="btn-primary w-full sm:w-auto">Berechtigung prüfen</button>
      </div>
    </div>

    <!-- Ergebnis -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>
      <p class="mt-3 text-xs text-gray-400">
        Richtlinien ändern sich häufig und hängen von Ihren konkreten Umständen ab. Lassen Sie sich vor der Buchung immer von einer
        chinesischen Botschaft oder einem Konsulat bestätigen. Dieses Tool bietet nur allgemeine Orientierung.
      </p>

      <AffiliateCta
        title="Planen Sie den Rest Ihrer Reise"
        description="Kümmern Sie sich um Internet, Zahlungen und Transport, bevor Sie in China landen."
        buttonText="Reise-Essentials ansehen"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6" aria-labelledby="official-sources">
      <h2 id="official-sources" class="text-xl font-bold text-gray-950">Offizielle Quellen, die Sie vor der Buchung prüfen sollten</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        Listen visumfreier Länder, Einreisehäfen, erlaubte Reisegebiete und Boarding-Prüfungen der Fluggesellschaften können sich ändern.
        Maßgeblich sind immer die offiziellen Regeln von Behörden und Fluggesellschaften.
      </p>
      <ul class="mt-4 grid gap-2 text-sm leading-6 text-gray-700">
        <li><a href="https://en.nia.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">Nationale Einwanderungsbehörde</a> für Aktualisierungen zu Grenzkontrollen und Transitbefreiungen.</li>
        <li><a href="https://english.www.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">Informationsportal des Staatsrats</a> für englischsprachige politische Bekanntmachungen.</li>
        <li><a href="https://www.mfa.gov.cn/eng/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">Außenministerium</a> sowie die Websites chinesischer Botschaften oder Konsulate für passspezifische Regeln.</li>
      </ul>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">So vermeiden Sie Fehler bei visumfreier Einreise</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          Der häufigste Fehler ist die Verwechslung der normalen visumfreien Einreise mit dem visumfreien Transit. Eine
          klassische Hin- und Rückreise und ein Zwischenstopp in ein Drittland sind nicht dieselbe Reiseroute. Fluggesellschaften
          prüfen Dokumente vor dem Boarding, sodass ein Missverständnis die Reise stoppen kann, bevor Sie
          China erreichen.
        </p>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-gray-600">
          <li><strong class="text-gray-900">Prüfen Sie zuerst die Staatsangehörigkeit laut Reisepass.</strong> Wohnsitzland und Abrechnungsland Ihrer Karte entscheiden nicht über die visumfreie Berechtigung.</li>
          <li><strong class="text-gray-900">Unterscheiden Sie zwischen Einreise und Transit.</strong> Transit erfordert in der Regel eine bestätigte Weiterreise in ein Drittland oder eine Drittregion.</li>
          <li><strong class="text-gray-900">Bestätigen Sie die Einreisehäfen.</strong> Transitregeln hängen von ausgewiesenen Häfen und erlaubten Reisegebieten ab.</li>
          <li><strong class="text-gray-900">Halten Sie Nachweise bereit.</strong> Fluggesellschaften und Grenzbeamte können nach Weiterreiseticket, Hotel, Reiseroute oder Einladungsdetails fragen.</li>
        </ul>
      </div>
      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Planen Sie den Rest Ihrer Ankunft</h2>
        <div class="mt-4 grid gap-3">
          <a href="/de/posts/china-visa-free-entry-transit-guide-2026/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Vollständigen Leitfaden zur visumfreien Einreise lesen</a>
          <a href="/de/posts/first-24-hours-in-china-arrival-checklist/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Ankunfts-Checkliste nutzen</a>
          <a href="/de/posts/airport-to-city-transport-beijing-shanghai-guangzhou/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Flughafentransfer planen</a>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  type TripKey = 'tourism' | 'business' | 'transit';

  // Staatsangehörigkeiten, die für die 30-tägige einseitige visumfreie Einreise berechtigt sind (Programm 2026).
  const visaFree30 = new Set([
    'Germany', 'France', 'Italy', 'Spain', 'Netherlands', 'Switzerland',
    'Ireland', 'Norway', 'Japan', 'South Korea', 'Brazil', 'New Zealand',
    'Malaysia', 'Thailand', 'Australia',
  ]);

  // Staatsangehörigkeiten, die für den 240-Stunden-Transit (10 Tage) ohne Visum über
  // ausgewiesene Häfen bei Weiterreise in ein Drittland oder eine Drittregion berechtigt sind.
  const transit240 = new Set([
    'United States', 'United Kingdom', 'Canada', 'Australia', 'Germany',
    'France', 'Italy', 'Spain', 'Netherlands', 'Japan', 'South Korea',
    'Singapore', 'Switzerland', 'Ireland', 'Norway', 'Brazil', 'New Zealand',
  ]);

  interface Verdict {
    tone: 'good' | 'warn' | 'info';
    heading: string;
    body: string;
    points: string[];
  }

  function evaluate(country: string, trip: TripKey): Verdict {
    const has30 = visaFree30.has(country);
    const hasTransit = transit240.has(country);

    if (trip === 'transit') {
      if (hasTransit) {
        return {
          tone: 'good',
          heading: 'Sie erfüllen wahrscheinlich die Voraussetzungen für den visumfreien 240-Stunden-Transit',
          body: `Als Inhaber eines Reisepasses aus ${countryName(country)} können Sie beim Transit durch China in ein Drittland in der Regel bis zu 240 Stunden (10 Tage) ohne Visum bleiben, wenn Sie über einen berechtigten Hafen einreisen.`,
          points: [
            'Sie müssen ein bestätigtes Weiterreiseticket in ein Drittland oder eine Drittregion innerhalb von 240 Stunden besitzen.',
            'Ein- und Ausreise müssen über ausgewiesene Transithäfen erfolgen; die meisten großen internationalen Flughäfen sind berechtigt.',
            'Sie sind in der Regel auf die Provinz oder Region der Einreise beschränkt. Prüfen Sie daher die spezifischen Hafenregeln.',
          ],
        };
      }
      return {
        tone: 'warn',
        heading: 'Die Transitvisumbefreiung gilt möglicherweise nicht für Ihre Staatsangehörigkeit',
        body: `${countryName(country)} steht in unseren Daten nicht auf der Standardliste für den 240-Stunden-Transit. Möglicherweise kommen Sie dennoch für eine visumfreie Einreise infrage oder benötigen ein Transitvisum (G).`,
        points: [
          'Prüfen Sie, ob Ihre Staatsangehörigkeit stattdessen für die vollständige visumfreie Einreise berechtigt ist.',
          'Falls nicht, beantragen Sie vor der Reise das passende Visum.',
        ],
      };
    }

    // Tourismus oder Geschäftsreise
    if (has30) {
      return {
        tone: 'good',
        heading: 'Sie erfüllen wahrscheinlich die Voraussetzungen für 30 Tage visumfreie Einreise',
        body: `Als Inhaber eines Reisepasses aus ${countryName(country)} können Sie nach der aktuellen einseitigen Regelung in der Regel bis zu 30 Tage visumfrei für Tourismus, Geschäftsreisen, Familienbesuche oder Transit nach China einreisen.`,
        points: [
          'Ihr Reisepass sollte noch mindestens 6 Monate gültig sein und freie Seiten enthalten.',
          'Halten Sie Nachweise über Weiter- oder Rückreise sowie Ihre Unterkunft für die Grenzkontrolle bereit.',
          'Die 30 Tage gelten pro Einreise. Bestätigen Sie vor der Buchung die aktuelle Auslegung der Zählweise.',
        ],
      };
    }
    if (hasTransit) {
      return {
        tone: 'info',
        heading: 'Ein Visum ist wahrscheinlich erforderlich, die Transitbefreiung kann jedoch helfen',
        body: `${countryName(country)} steht nicht auf unserer 30-Tage-Liste für visumfreie Einreise zu Tourismus- oder Geschäftszwecken, daher ist in der Regel ein Visum erforderlich. Wenn Sie jedoch in ein Drittland weiterreisen, können Sie stattdessen möglicherweise den visumfreien 240-Stunden-Transit nutzen.`,
        points: [
          'Für einen gezielten Aufenthalt beantragen Sie im Voraus ein L-Visum für Tourismus oder ein M-Visum für Geschäftsreisen.',
          'Für einen Zwischenstopp auf dem Weg in ein anderes Land können Sie sich möglicherweise für den 240-Stunden-Transit qualifizieren. Wechseln Sie bei "Reiseart" zu Transit, um dies zu prüfen.',
        ],
      };
    }
    return {
      tone: 'warn',
      heading: 'Ein Visum ist wahrscheinlich erforderlich',
      body: `Nach unseren Daten benötigen Inhaber eines Reisepasses aus ${countryName(country)} für diese Reiseart in der Regel ein Visum für die Einreise nach China. Beantragen Sie es vor der Reise über eine chinesische Botschaft, ein Konsulat oder ein autorisiertes Visazentrum.`,
      points: [
        'Beantragen Sie ein L-Visum für Tourismus oder ein M-Visum für Geschäftsreisen rechtzeitig vor Ihrer Reise.',
        'Zu den Anforderungen gehören typischerweise eine Einladung oder Reiseroute, Hotelbuchungen und Rückflugtickets.',
      ],
    };
  }

  const countryLabels: Record<string, string> = {
    'United States': 'den Vereinigten Staaten',
    'United Kingdom': 'dem Vereinigten Königreich',
    Canada: 'Kanada',
    Australia: 'Australien',
    Germany: 'Deutschland',
    France: 'Frankreich',
    Italy: 'Italien',
    Spain: 'Spanien',
    Netherlands: 'den Niederlanden',
    Japan: 'Japan',
    'South Korea': 'Südkorea',
    Singapore: 'Singapur',
    Malaysia: 'Malaysia',
    Thailand: 'Thailand',
    Brazil: 'Brasilien',
    'New Zealand': 'Neuseeland',
    Switzerland: 'der Schweiz',
    Ireland: 'Irland',
    Norway: 'Norwegen',
    Other: 'einem sonstigen Land',
  };

  function countryName(country: string): string {
    return countryLabels[country] ?? country;
  }

  const toneStyles: Record<Verdict['tone'], string> = {
    good: 'border-green-200 bg-green-50',
    warn: 'border-amber-200 bg-amber-50',
    info: 'border-blue-200 bg-blue-50',
  };
  const toneBadge: Record<Verdict['tone'], string> = {
    good: 'bg-green-600 text-white',
    warn: 'bg-amber-500 text-white',
    info: 'bg-blue-600 text-white',
  };
  const toneLabel: Record<Verdict['tone'], string> = {
    good: 'Wahrscheinlich berechtigt',
    warn: 'Visum wahrscheinlich erforderlich',
    info: 'Hängt von Ihrem Reiseplan ab',
  };

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;
  const tripEl = document.getElementById('trip') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const v = evaluate(countryEl.value, tripEl.value as TripKey);
    card.className = `card border ${toneStyles[v.tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[v.tone]}">${toneLabel[v.tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${v.heading}</h2>
      <p class="mt-2 text-gray-700">${v.body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${v.points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>