---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import AffiliateCta from '../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../config';

const title = 'China Visa-Free & Transit Checker';
const description =
  'Prufe, ob du visumfrei nach China einreisen kannst, den 240-stundigen visumfreien Transit nutzen kannst oder je nach deiner Staatsangehorigkeit und Reiseart ein Visum beantragen musst.';

const lastReviewed = '13. Juli 2026';

// Reprasentative Richtliniendaten fur 2026. Dies ist eine Orientierungshilfe, keine Rechtsberatung;
// Reisende mussen sich vor der Buchung bei einer Botschaft vergewissern.
const countries = [
  'United States', 'United Kingdom', 'Canada', 'Australia', 'Germany',
  'France', 'Italy', 'Spain', 'Netherlands', 'Japan', 'South Korea',
  'Singapore', 'Malaysia', 'Thailand', 'Brazil', 'New Zealand',
  'Switzerland', 'Ireland', 'Norway', 'Other',
];
---
<!-- KI-unterstutzt erstellter Inhalt, von muttersprachlichem Redakteur gepruft -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Tool</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Visumfrei- & Transit-Checker</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <p class="mt-3 text-sm text-gray-500">
        Zuletzt gepruft: {lastReviewed}. Dieser Checker ist eine Planungshilfe, keine offizielle Entscheidung uber die Berechtigung.
      </p>
    </header>

    <AdSlot format="banner" />

    <!-- Eingabesteuerungen -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Staatsangehorigkeit deines Reisepasses</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Reiseart</span>
        <select id="trip" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="tourism">Tourismus / Besuch</option>
          <option value="business">Geschaftlich</option>
          <option value="transit">Nur Durchreise in ein anderes Land</option>
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="check-btn" class="btn-primary w-full sm:w-auto">Meine Berechtigung prufen</button>
      </div>
    </div>

    <!-- Ergebnis -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>
      <p class="mt-3 text-xs text-gray-400">
        Richtlinien andern sich haufig und hangen von deinen konkreten Umstanden ab. Bestatige dies immer bei einer
        chinesischen Botschaft oder einem Konsulat, bevor du eine Reise buchst. Dieses Tool bietet nur allgemeine Orientierung.
      </p>

      <AffiliateCta
        title="Plane den Rest deiner Reise"
        description="Kummere dich um Konnektivitat, Zahlungen und Transport, bevor du in China landest."
        buttonText="Reise-Essentials ansehen"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6" aria-labelledby="official-sources">
      <h2 id="official-sources" class="text-xl font-bold text-gray-950">Offizielle Quellen, die du vor der Buchung prufen solltest</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        Listen visumfreier Lander, Einreisehafen, erlaubte Reisegebiete und Boarding-Kontrollen der Fluggesellschaften konnen sich andern.
        Betrachte offizielle Regierungs- und Fluglinienregeln als verbindlich.
      </p>
      <ul class="mt-4 grid gap-2 text-sm leading-6 text-gray-700">
        <li><a href="https://en.nia.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">National Immigration Administration</a> fur Aktualisierungen zu Grenzkontrollen und Transitbefreiungen.</li>
        <li><a href="https://english.www.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">State Council information portal</a> fur englischsprachige Bekanntmachungen zu Richtlinien.</li>
        <li><a href="https://www.mfa.gov.cn/eng/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">Ministry of Foreign Affairs</a> sowie Websites chinesischer Botschaften oder Konsulate fur passspezifische Regeln.</li>
      </ul>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">So vermeidest du Fehler bei der visumfreien Einreise</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          Der haufigste Fehler besteht darin, die normale visumfreie Einreise mit dem visumfreien Transit zu verwechseln. Eine
          normale Hin- und Ruckreise und ein Zwischenstopp auf dem Weg in ein Drittland sind nicht dieselbe Reiseroute. Fluggesellschaften
          prufen Dokumente vor dem Boarding, daher kann ein Missverstandnis die Reise stoppen, noch bevor du
          China erreichst.
        </p>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-gray-600">
          <li><strong class="text-gray-900">Prufe zuerst die Staatsangehorigkeit des Reisepasses.</strong> Wohnsitzland und Kartenabrechnungsland entscheiden nicht uber die visumfreie Berechtigung.</li>
          <li><strong class="text-gray-900">Trenne Einreise von Transit.</strong> Transit erfordert in der Regel eine bestatigte Weiterreise in ein Drittland oder eine Drittregion.</li>
          <li><strong class="text-gray-900">Bestatige die Einreisehafen.</strong> Transitrichtlinien hangen von ausgewiesenen Hafen und erlaubten Reisegebieten ab.</li>
          <li><strong class="text-gray-900">Halte Nachweise bereit.</strong> Fluggesellschaften und Grenzbeamte konnen nach Weiterflugticket, Hotel, Reiseplan oder Einladungsdetails fragen.</li>
        </ul>
      </div>
      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Plane den Rest deiner Ankunft</h2>
        <div class="mt-4 grid gap-3">
          <a href="/posts/china-visa-free-entry-transit-guide-2026/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Den vollstandigen Leitfaden zur visumfreien Einreise lesen</a>
          <a href="/posts/first-24-hours-in-china-arrival-checklist/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Die Ankunfts-Checkliste nutzen</a>
          <a href="/posts/airport-to-city-transport-beijing-shanghai-guangzhou/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Flughafentransport planen</a>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  type TripKey = 'tourism' | 'business' | 'transit';

  // Staatsangehorigkeiten, die fur die einseitige 30-tagige visumfreie Einreise infrage kommen (Programm 2026).
  const visaFree30 = new Set([
    'Germany', 'France', 'Italy', 'Spain', 'Netherlands', 'Switzerland',
    'Ireland', 'Norway', 'Japan', 'South Korea', 'Brazil', 'New Zealand',
    'Malaysia', 'Thailand', 'Australia',
  ]);

  // Staatsangehorigkeiten, die fur den 240-stundigen (10-tagigen) visumfreien Transit uber
  // ausgewiesene Hafen infrage kommen, wenn die Weiterreise in ein Drittland/eine Drittregion erfolgt.
  const transit240 = new Set([
    'United States', 'United Kingdom', 'Canada', 'Australia', 'Germany',
    'France', 'Italy', 'Spain', 'Netherlands', 'Japan', 'South Korea',
    'Singapore', 'Switzerland', 'Ireland', 'Norway', 'Brazil', 'New Zealand',
  ]);

  interface Verdict {
    tone: 'good' | 'warn' | 'info';
    heading: string;
    body: string;
    points: string[];
  }

  function evaluate(country: string, trip: TripKey): Verdict {
    const has30 = visaFree30.has(country);
    const hasTransit = transit240.has(country);

    if (trip === 'transit') {
      if (hasTransit) {
        return {
          tone: 'good',
          heading: 'Du erfullst wahrscheinlich die Voraussetzungen fur den 240-stundigen visumfreien Transit',
          body: `Als Inhaber eines Reisepasses aus ${country} kannst du bei der Durchreise durch China in ein Drittland in der Regel bis zu 240 Stunden (10 Tage) ohne Visum bleiben, wenn du uber einen zulassigen Hafen einreist.`,
          points: [
            'Du musst innerhalb von 240 Stunden ein bestatigtes Weiterreiseticket in ein Drittland oder eine Drittregion haben.',
            'Ein- und Ausreise mussen uber ausgewiesene Transithafen erfolgen (die meisten grossen internationalen Flughafen kommen infrage).',
            'Du bist in der Regel auf die Provinz/Region der Einreise beschrankt - prufe die spezifischen Regeln des jeweiligen Hafens.',
          ],
        };
      }
      return {
        tone: 'warn',
        heading: 'Die Transit-Visumbefreiung gilt moglicherweise nicht fur deine Staatsangehorigkeit',
        body: `${country} steht in unseren Daten nicht auf der Standardliste fur den 240-stundigen Transit. Moglicherweise kommst du dennoch fur die visumfreie Einreise infrage, falls berechtigt, oder du benotigst ein Transitvisum (G).`,
        points: [
          'Prufe, ob deine Staatsangehorigkeit stattdessen fur die vollstandige visumfreie Einreise infrage kommt.',
          'Falls nicht, beantrage vor der Reise das passende Visum.',
        ],
      };
    }

    // tourism or business
    if (has30) {
      return {
        tone: 'good',
        heading: 'Du erfullst wahrscheinlich die Voraussetzungen fur die 30-tagige visumfreie Einreise',
        body: `Als Inhaber eines Reisepasses aus ${country} kannst du nach der aktuellen einseitigen Regelung in der Regel fur bis zu 30 Tage visumfrei nach China einreisen, fur Tourismus, Geschaftsreisen, Familienbesuche oder Transit.`,
        points: [
          'Dein Reisepass sollte noch mindestens 6 Monate gultig sein und leere Seiten haben.',
          'Halte fur die Einwanderungsbehorde Nachweise uber Weiter-/Ruckreise und Unterkunft bereit.',
          'Die 30 Tage gelten pro Einreise - bestatige die aktuelle Berechnung, bevor du buchst.',
        ],
      };
    }
    if (hasTransit) {
      return {
        tone: 'info',
        heading: 'Ein Visum ist wahrscheinlich erforderlich - aber die Transitbefreiung kann helfen',
        body: `${country} steht fur Tourismus/Geschaftsreisen nicht auf unserer Liste fur die 30-tagige visumfreie Einreise, daher ist in der Regel ein Visum erforderlich. Wenn du jedoch auf dem Weg in ein Drittland nur durchreist, kannst du stattdessen den 240-stundigen visumfreien Transit nutzen.`,
        points: [
          'Fur einen gezielten Besuch beantrage im Voraus ein L-Visum (Tourismus) oder M-Visum (Geschaft).',
          'Fur einen Zwischenstopp auf dem Weg anderswohin kannst du fur den 240-stundigen Transit infrage kommen - wechsle bei "Reiseart" zu Transit, um das zu prufen.',
        ],
      };
    }
    return {
      tone: 'warn',
      heading: 'Ein Visum ist wahrscheinlich erforderlich',
      body: `Nach unseren Daten benotigen Inhaber eines Reisepasses aus ${country} fur diese Reiseart in der Regel ein Visum fur die Einreise nach China. Beantrage es vor der Reise uber eine chinesische Botschaft, ein Konsulat oder ein autorisiertes Visazentrum.`,
      points: [
        'Beantrage ein L-Visum (Tourismus) oder M-Visum (Geschaft) rechtzeitig vor deiner Reise.',
        'Zu den Anforderungen gehoren in der Regel eine Einladung oder ein Reiseplan, Hotelbuchungen und Ruckflugtickets.',
      ],
    };
  }

  const toneStyles: Record<Verdict['tone'], string> = {
    good: 'border-green-200 bg-green-50',
    warn: 'border-amber-200 bg-amber-50',
    info: 'border-blue-200 bg-blue-50',
  };
  const toneBadge: Record<Verdict['tone'], string> = {
    good: 'bg-green-600 text-white',
    warn: 'bg-amber-500 text-white',
    info: 'bg-blue-600 text-white',
  };
  const toneLabel: Record<Verdict['tone'], string> = {
    good: 'Wahrscheinlich berechtigt',
    warn: 'Visum wahrscheinlich erforderlich',
    info: 'Hangt von deinem Reiseplan ab',
  };

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;
  const tripEl = document.getElementById('trip') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const v = evaluate(countryEl.value, tripEl.value as TripKey);
    card.className = `card border ${toneStyles[v.tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[v.tone]}">${toneLabel[v.tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${v.heading}</h2>
      <p class="mt-2 text-gray-700">${v.body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${v.points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>