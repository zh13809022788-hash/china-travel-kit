---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Funktionieren meine Apps in China? App-Verfügbarkeitsprüfer';
const description =
  'Prüfen Sie, ob Google, WhatsApp, Instagram und andere Apps in China ohne VPN funktionieren — und sehen Sie die lokale Alternative für jeden gesperrten Dienst.';

interface AppInfo {
  name: string;
  category: string;
  status: 'works' | 'blocked' | 'partial';
  note: string;
  alt?: string;
}

const apps: AppInfo[] = [
  { name: 'Google Search', category: 'Google', status: 'blocked', note: 'Ohne VPN gesperrt.', alt: 'Bing (funktioniert) oder Baidu' },
  { name: 'Google Maps', category: 'Google', status: 'partial', note: 'Lädt, aber Daten sind im chinesischen Festland ungenau/verschoben.', alt: 'Apple Maps, Amap oder Baidu Maps' },
  { name: 'Gmail', category: 'Google', status: 'blocked', note: 'Ohne VPN gesperrt.', alt: 'Outlook / eine Nicht-Google-E-Mail' },
  { name: 'YouTube', category: 'Google', status: 'blocked', note: 'Ohne VPN gesperrt.', alt: 'Bilibili (lokal)' },
  { name: 'WhatsApp', category: 'Nachrichten', status: 'blocked', note: 'Ohne VPN gesperrt.', alt: 'WeChat' },
  { name: 'Facebook', category: 'Soziales', status: 'blocked', note: 'Ohne VPN gesperrt.', alt: 'WeChat Moments / RED' },
  { name: 'Instagram', category: 'Soziales', status: 'blocked', note: 'Ohne VPN gesperrt.', alt: 'RED (Xiaohongshu)' },
  { name: 'X (Twitter)', category: 'Soziales', status: 'blocked', note: 'Ohne VPN gesperrt.', alt: 'Weibo' },
  { name: 'Telegram', category: 'Nachrichten', status: 'blocked', note: 'Ohne VPN gesperrt.', alt: 'WeChat' },
  { name: 'WeChat', category: 'Nachrichten', status: 'works', note: 'Funktioniert vollständig — der Standard in China.' },
  { name: 'Apple-Dienste (iMessage, App Store)', category: 'Apple', status: 'works', note: 'Funktioniert normal.' },
  { name: 'Microsoft / Bing / Outlook', category: 'Microsoft', status: 'works', note: 'Funktioniert normal.' },
  { name: 'Booking.com', category: 'Reise', status: 'works', note: 'Funktioniert normal.' },
  { name: 'Airbnb', category: 'Reise', status: 'works', note: 'Funktioniert normal.' },
  { name: 'Trip.com', category: 'Reise', status: 'works', note: 'Funktioniert vollständig — toll für Züge und Hotels.' },
  { name: 'Alipay', category: 'Bezahlung', status: 'works', note: 'Funktioniert vollständig — unterstützt ausländische Karten.' },
  { name: 'Uber', category: 'Verkehr', status: 'blocked', note: 'Nicht im chinesischen Festland verfügbar.', alt: 'DiDi' },
  { name: 'Netflix', category: 'Medien', status: 'blocked', note: 'Nicht im chinesischen Festland verfügbar.', alt: 'Lokales Streaming oder vorher herunterladen' },
  { name: 'Spotify', category: 'Medien', status: 'blocked', note: 'Nicht im chinesischen Festland verfügbar.', alt: 'QQ Music / zuerst offline herunterladen' },
];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Werkzeug</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Funktionieren meine Apps in China?</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-4">
      <label class="flex flex-col text-sm sm:max-w-sm">
        <span class="mb-1 font-medium text-gray-700">Apps suchen oder filtern</span>
        <input id="search" type="text" placeholder="z. B. WhatsApp, Google, Netflix"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <div class="mt-3 flex flex-wrap gap-2 text-sm">
        <button data-status="all" class="status-filter btn-primary px-3 py-1">Alle</button>
        <button data-status="works" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">✅ Funktioniert</button>
        <button data-status="partial" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">⚠️ Teilweise</button>
        <button data-status="blocked" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">🚫 Gesperrt</button>
      </div>
    </div>

    <div id="app-list" class="mt-6 grid gap-3 sm:grid-cols-2"></div>
    <p id="no-results" class="hidden py-8 text-center text-gray-500">Keine Apps entsprechen Ihrer Suche.</p>

    <AffiliateCta
      title="Halten Sie Ihre Apps mit einer Reise-eSIM funktionsfähig"
      description="Eine China-Reise-eSIM, die lokale Einschränkungen umgeht, hält Ihre gewohnten Apps online — keine separate VPN-Einrichtung erforderlich."
      buttonText="eSIM-Optionen ansehen"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ apps }}>
  const listEl = document.getElementById('app-list');
  const noResults = document.getElementById('no-results');
  const searchEl = document.getElementById('search');
  const filters = document.querySelectorAll('.status-filter');
  let activeStatus = 'all';

  const badge = {
    works: { cls: 'bg-green-100 text-green-800', label: '✅ Funktioniert' },
    partial: { cls: 'bg-amber-100 text-amber-800', label: '⚠️ Teilweise' },
    blocked: { cls: 'bg-red-100 text-red-800', label: '🚫 Gesperrt' },
  };

  function render() {
    const q = searchEl.value.trim().toLowerCase();
    const list = apps.filter((a) => {
      const matchStatus = activeStatus === 'all' || a.status === activeStatus;
      const matchQuery = !q || a.name.toLowerCase().includes(q) || a.category.toLowerCase().includes(q);
      return matchStatus && matchQuery;
    });

    listEl.innerHTML = list
      .map((a) => `
        <div class="card">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="font-bold text-gray-900">${a.name}</h3>
              <span class="text-xs text-gray-400">${a.category}</span>
            </div>
            <span class="whitespace-nowrap rounded-full px-2.5 py-0.5 text-xs font-semibold ${badge[a.status].cls}">${badge[a.status].label}</span>
          </div>
          <p class="mt-2 text-sm text-gray-600">${a.note}</p>
          ${a.alt ? `<p class="mt-1.5 text-sm"><span class="text-gray-500">Stattdessen verwenden:</span> <span class="font-medium text-brand-600">${a.alt}</span></p>` : ''}
        </div>`)
      .join('');

    noResults.classList.toggle('hidden', list.length > 0);
  }

  searchEl.addEventListener('input', render);
  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeStatus = btn.dataset.status;
      filters.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('btn-primary', on);
        ['rounded-lg', 'border', 'border-gray-300', 'font-medium', 'text-gray-700'].forEach((c) => b.classList.toggle(c, !on));
      });
      render();
    });
  });

  render();
</script>