---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Beste Reisezeit für China: Städte- und Monatsplaner';
const description =
  'Sieh dir für wichtige Städte in China Monat für Monat Wetter, Andrang und Packtipps an. So findest du leichter die passende Reisezeit für Peking, Shanghai, Xi\'an, Chengdu, Guangzhou und Harbin.';

const cities = ['Peking', 'Shanghai', "Xi'an", 'Chengdu', 'Guangzhou', 'Harbin'];
const months = ['Jan', 'Feb', 'Mär', 'Apr', 'Mai', 'Jun', 'Jul', 'Aug', 'Sep', 'Okt', 'Nov', 'Dez'];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Tool</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Beste Reisezeit für China</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Stadt</span>
        <select id="city" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {cities.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Reisemonat</span>
        <select id="month" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {months.map((m, i) => <option value={i}>{m}</option>)}
        </select>
      </label>
    </div>

    <div id="result" class="mt-6">
      <div class="card" id="result-card"></div>
    </div>

    <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
      <strong>Große Ferienzeiten im Blick behalten:</strong> Rund um das chinesische Neujahr
      (Ende Januar oder Februar), den Tag der Arbeit Anfang Mai und die Goldene Woche Anfang Oktober
      steigt der Inlandsreiseverkehr stark an. Züge und Hotels sind schneller ausgebucht, und die
      Preise ziehen deutlich an. Wenn möglich, buche früh oder plane bewusst außerhalb dieser Zeiten.
    </div>

    <AffiliateCta
      title="Züge und Hotels rechtzeitig sichern"
      description="Beliebte Strecken und Unterkünfte sind in der Hochsaison schnell weg. Buche Hochgeschwindigkeitszüge und Hotels besser frühzeitig."
      buttonText="Buchungsoptionen ansehen"
      placeholder={AFFILIATE_LINKS.transport}
    />
  </main>
  <Footer />
</BaseLayout>

<script>
