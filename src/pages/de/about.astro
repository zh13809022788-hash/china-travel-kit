---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'Über ChinaTripBox';
const description =
  'ChinaTripBox is an independent travel resource helping foreign visitors handle payments, connectivity, transport, and practical trip planning in China.';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="de">
  <Header locale="de" />
  <main class="container-page py-12">
    <article class="prose-content article-body">
      <h1 class="text-3xl font-bold text-gray-900">Über ChinaTripBox</h1>
      <p class="mt-4">
        ChinaTripBox is an independent guide built for foreign visitors who want a smooth,
        stress-free trip to China. Traveling in China has never been easier, but the digital-first
        ecosystem of mobile payments, eSIM data, and app-based transport can feel overwhelming if
        you have never used it before.
      </p>
      <p>
        Our mission is simple: turn the questions travelers actually ask into clear, tested,
        step-by-step answers. Every guide is written in plain English, focused on what works right
        now, and updated as apps and regulations change.
      </p>

      <h2>Who This Site Is For</h2>
      <p>
        We write for first-time tourists, repeat visitors, long-stay travelers, digital nomads, and
        anyone who needs practical help before arriving in China. Our content focuses on everyday
        travel decisions: how to pay, how to stay connected, how to move between cities, and how to
        avoid common setup problems.
      </p>

      <h2>What We Cover</h2>
      <ul>
        <li><strong>Bezahlung:</strong> setting up Alipay and WeChat Pay, linking foreign cards, and paying like a local.</li>
        <li><strong>eSIM &amp; Data:</strong> choosing and activating the right data plan before you arrive.</li>
        <li><strong>Verkehr:</strong> booking high-speed trains, using ride-hailing, and getting around cities.</li>
        <li><strong>Trip Planning:</strong> city guides, packing, cash, food safety, local apps, and first-trip checklists.</li>
      </ul>

      <h2>Editorial Standards</h2>
      <p>
        ChinaTripBox is not a government website, visa agency, telecom provider, payment company, or
        bank. We publish independent travel information based on official sources where available,
        product documentation, traveler experience, and regular content reviews. You can read more
        about our process in our <a href="/de/editorial-policy/">editorial policy</a> and
        <a href="/authors/chinatripbox-editorial-team/">editorial team profile</a>.
      </p>

      <h2>How We Stay Free</h2>
      <p>
        This site is supported by advertising and affiliate partnerships. When you use some of the
        links on our site, we may earn a commission at no extra cost to you. This never influences
        which products we recommend. Our guidance is based on what genuinely helps travelers.
      </p>

      <h2>Get in Touch</h2>
      <p>
        Spotted something out of date or have a question we haven't answered? Head to our
        <a href="/de/contact/">contact page</a>. We read every message.
      </p>
    </article>
  </main>
  <Footer />
</BaseLayout>
