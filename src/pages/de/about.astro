---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Über ChinaTripBox';
const description =
  'ChinaTripBox bietet praktische China-Reiseführer und 1-zu-1-Hilfe für ausländische Besucher. Erstellt von einem Team mit Wurzeln bei Tujia, Airbnb, Ctrip, Meituan und Alibaba.';
---
<!-- KI-unterstutzt erstellter Inhalt, von muttersprachlichem Redakteur gepruft -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-12">
    <article class="prose-content article-body">

      <!-- Hero -->
      <div class="mb-10 text-center">
        <img src="/images/logo-wordmark.png?v=2" alt="ChinaTripBox" class="mx-auto h-10 w-auto" />
        <h1 class="mt-5 text-3xl font-bold text-gray-900">Über uns</h1>
        <p class="mx-auto mt-2 max-w-xl text-base leading-relaxed text-gray-600">
          Praktische Ressourcen und Dienstleistungen für China-Reisen — erstellt von einem Team erfahrener Travel-Tech-Veteranen.
        </p>
      </div>

      <!-- What We Do -->
      <h2 class="mt-10 text-xl font-semibold text-gray-900">Was wir tun</h2>
      <p class="mt-3">
        ChinaTripBox bietet kostenlose, praktische China-Reiseführer und Tools — zu den Themen
        Zahlungen, Internetzugang, Transport, Visa und Alltagslogistik — damit ausländische
        Besucher die tatsächlichen Probleme beim Reisen nach China lösen können.
      </p>
      <p>
        Wenn kostenlose Reiseführer und Tools nicht ausreichen, bieten wir auch persönliche
        1-zu-1-Unterstützung an. Ob Reiseplanung, Fehlerbehebung bei der Zahlungseinrichtung
        oder komplexe Fragen zu Visa und Transport: Eine echte Person arbeitet mit Ihrer
        konkreten Situation, um gezielte Beratung zu bieten.
      </p>

      <!-- Who We Are -->
      <h2 class="mt-10 text-xl font-semibold text-gray-900">Wer wir sind</h2>
      <p class="mt-3">
        Ein professionelles Team mit strengen redaktionellen Standards. Die Kernmitglieder von ChinaTripBox
        kommen von <strong>Tujia</strong>, <strong>Airbnb</strong>, <strong>Ctrip</strong>,
        <strong>Meituan</strong> und <strong>Alibaba</strong> — mit Erfahrung in gemeinschaftlichen Unterkünften,
        OTA, Lifestyle-Dienstleistungen und E-Commerce.
      </p>

      <!-- Team Card -->
      <div class="mt-6 flex flex-col gap-6 rounded-xl border border-brand-100 bg-brand-50 p-6 sm:flex-row">
        <div class="h-20 w-20 flex-shrink-0 overflow-hidden rounded-full border-2 border-brand-400">
          <img src="/images/howie.jpg" alt="Howie" class="h-full w-full object-cover" />
        </div>
        <div class="flex-1">
          <p class="font-semibold text-brand-700">Gründer &mdash; Howie</p>
          <p class="mt-2 text-sm leading-relaxed text-gray-700">
            Howie war ein Gründungsmitglied des Teams von <strong>Tujia (途家网)</strong>, Chinas
            größter Plattform für Ferienunterkünfte, unterstützt von Sequoia Capital, Ctrip und HomeAway
            mit einer Finanzierung von über 400 Millionen US-Dollar.
          </p>
          <p class="mt-2 text-sm leading-relaxed text-gray-700">
            Über Tujia hinaus umfassen die Hintergründe unseres Kernteams Airbnb China, Produkt-
            und Betriebsbereiche bei Ctrip, die Hotel- und Reisesparte von Meituan sowie Fliggy von Alibaba.
            Gemeinsam verfügen wir über mehr als fünfzehn Jahre praktische Erfahrung im chinesischen
            Travel-Tech-Ökosystem — von Zahlungen und Transport bis hin zu Unterkünften und
            lokalen Lifestyle-Dienstleistungen.
          </p>
        </div>
      </div>

      <!-- Our Approach -->
      <h2 class="mt-10 text-xl font-semibold text-gray-900">Unser Ansatz</h2>
      <p class="mt-3">
        Wir arbeiten als schlankes, KI-gestütztes Content- und Service-Studio, in dem sich kostenlose Ressourcen
        und kostenpflichtige Dienstleistungen gegenseitig ergänzen.
      </p>
      <ol class="mt-4 list-inside list-decimal space-y-3 text-gray-700">
        <li>
          <strong>Kostenlose Ressourcen zeigen Fachkompetenz.</strong> Reiseführer, Tools und Checker
          ermöglichen es Besuchern, häufige Probleme selbst zu lösen, und zeigen zugleich die Qualität
          unserer Arbeit.
        </li>
        <li>
          <strong>KI hilft uns zu skalieren und aktuell zu bleiben.</strong> Wir nutzen KI, um regulatorische
          Änderungen zu verfolgen, Inhalte zu optimieren und Informationen nahezu in Echtzeit korrekt zu halten.
        </li>
        <li>
          <strong>Persönlicher 1-zu-1-Service für komplexe Fälle.</strong> Wenn Selbstbedienung nicht
          ausreicht, bietet eine echte Person maßgeschneiderte Beratung auf Grundlage Ihrer konkreten Situation.
        </li>
      </ol>

      <!-- What We Cover -->
      <h2 class="mt-10 text-xl font-semibold text-gray-900">Was wir abdecken</h2>
      <p class="mt-3">
        <strong>Kostenlose Ressourcen</strong> &mdash; Payment Checker, Visa-Free Checker, Trip Planner,
        App Availability Checker und Schritt-für-Schritt-Anleitungen.
      </p>
      <p>
        <strong>Kostenpflichtige Dienstleistungen</strong> &mdash; 1-zu-1-Überprüfung des Reiseplans, Unterstützung bei der Zahlungseinrichtung,
        Beratung zu Visa und Transport sowie individuelle Reiseplanung.
      </p>

      <!-- Why Trust Us -->
      <h2 class="mt-10 text-xl font-semibold text-gray-900">Warum Sie uns vertrauen können</h2>
      <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2">
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
          <p class="font-semibold text-brand-600">Professionelles Team</p>
          <p class="mt-1 text-sm text-gray-600">Die Kernmitglieder kommen von Tujia, Airbnb, Ctrip, Meituan und Alibaba.</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
          <p class="font-semibold text-brand-600">Sorgfältige Prüfung</p>
          <p class="mt-1 text-sm text-gray-600">KI verbessert die Effizienz, aber jeder Reiseführer und jeder Plan wird von einem Branchenprofi geprüft.</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
          <p class="font-semibold text-brand-600">Personalisierter Service</p>
          <p class="mt-1 text-sm text-gray-600">Über 15 Jahre Travel-Tech-Erfahrung an vorderster Front in China, mit maßgeschneiderten Lösungen.</p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
          <p class="font-semibold text-brand-600">Immer aktuell</p>
          <p class="mt-1 text-sm text-gray-600">Regeln ändern sich schnell. Unser KI-Workflow verfolgt und aktualisiert Inhalte nahezu in Echtzeit.</p>
        </div>
      </div>

      <!-- Contact -->
      <h2 class="mt-10 text-xl font-semibold text-gray-900">Kontakt aufnehmen</h2>
      <p class="mt-3">
        Haben Sie Fragen, Korrekturen oder ein Reiseszenario, bei dem Sie Hilfe brauchen?
        <a href="/contact/" class="text-brand-600 hover:underline">Kontaktieren Sie uns</a>, und wir melden uns bei Ihnen.
      </p>

    </article>
  </main>
  <Footer />
</BaseLayout>