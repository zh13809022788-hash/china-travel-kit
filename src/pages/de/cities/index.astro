---
import { getCollection } from 'astro:content';
import { getCategoryLabel } from "../../../i18n/categories";
import { CITY_GUIDES, type CityGuideEntry } from "../../../data/cityGuideData";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import CoverImage from "../../../components/CoverImage.astro";
import ChinaMap from "../../../components/ChinaMap.astro";
import AdSlot from "../../../components/AdSlot.astro";

const allPosts = await getCollection('posts');

// Finde heraus, welche Stadtfuhrer veroffentlichte Beitrage haben
const postMap = new Map<string, typeof allPosts[0]>();
for (const post of allPosts) {
  for (const guide of CITY_GUIDES) {
    if (post.slug === guide.slug || post.slug.includes(guide.slug)) {
      postMap.set(guide.slug, post);
    }
  }
}

// Zeige nur Stadte an, die einen veroffentlichten Stadtfuhrer-Beitrag haben
const activeGuides = CITY_GUIDES.filter((g) => postMap.has(g.slug));
const activeSlugs = new Set(activeGuides.map((g) => g.slug));

// Kartenkoordinaten mit korrekten href-Links
const mapCities = CITY_GUIDES.map((g) => ({
  name: g.name,
  x: g.mapX,
  y: g.mapY,
  href: postMap.has(g.slug) ? `#${g.name.toLowerCase().replace(/[^a-z]/g, '')}` : '',
}));

// Stadtkarten nach Name sortiert
const cities = [...activeGuides].sort((a, b) => a.name.localeCompare(b.name));

// Alle stadtebezogenen Beitrage (nach Titel sortiert)
const cityPosts = allPosts
  .filter((post) => activeSlugs.has(post.slug) || post.data.tags?.some((t: string) =>
    [...activeSlugs].some((s) => s.includes(t) || t.includes(s))
  ))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const title = 'China-Stadtfuhrer fur auslandische Besucher';
const description = `Plane praktische Stadtstopps in China mit Reisefuhrern fur ${activeGuides.map((g) => g.name).join(', ')}.`;

const routes = [
  {
    name: 'Erste China-Reise, 8-10 Tage',
    plan: 'Shanghai 3 Tage, Hangzhou 2 Tage, Beijing 4 Tage',
    fit: 'Die beste Balance aus einfacher Ankunft, klassischer Landschaft und bedeutender Geschichte.',
  },
  {
    name: 'Essen und entspanntes Tempo, 7-9 Tage',
    plan: 'Chengdu 4 Tage, Beijing oder Shanghai 3-4 Tage',
    fit: 'Gut fur Reisende, die Pandas, Teehause, Hotpot und eine grosse internationale Drehscheibenstadt wollen.',
  },
  {
    name: 'Winterflucht, 6-10 Tage',
    plan: 'Sanya 4-6 Tage, Shanghai 2-3 Tage',
    fit: 'Am besten, wenn Nordchina kalt ist und du eine einfache Kombination aus Strand und Stadt willst.',
  },
  {
    name: 'Entdeckung des Sudens, 10-12 Tage',
    plan: 'Guangzhou 3 Tage, Guilin 3 Tage, Shanghai 4 Tage',
    fit: 'Ideal fur Feinschmecker, malerische Landschaften und ein entspanntes Tempo durch Sudchina.',
  },
  {
    name: 'Alte Hauptstadte, 10-12 Tage',
    plan: 'Beijing 4 Tage, Xi\'an 3 Tage, Nanjing 2 Tage, Shanghai 3 Tage',
    fit: 'Geschichtsorientierte Route durch Chinas kaiserliche Hauptstadte mit Hochgeschwindigkeitszug-Verbindungen.',
  },
];

const faqItems = [
  {
    question: 'Welche Stadt in China ist fur auslandische Erstbesucher am einfachsten?',
    answer:
      'Shanghai ist normalerweise die einfachste erste Stadt, weil Flughafen, Metro-Beschilderung, Hotels, Restaurants und internationale Dienstleistungen dort am auslanderfreundlichsten sind. Beijing ist weiterhin gut handhabbar, erfordert aber mehr Vorausbuchung und eine sorgfaltigere Tagesplanung.',
  },
  {
    question: 'Wie viele chinesische Stadte sollte ich auf einer Reise besuchen?',
    answer:
      'Fur eine erste Reise von 8-10 Tagen reichen zwei oder drei Stadte aus. China ist gross, und Flughafentransfers, Bahnhofe, Sicherheitskontrollen und Hotelwechsel konnen mehr Zeit in Anspruch nehmen als erwartet. Wahlen Sie eine Ankunftsstadt, einen kulturellen oder landschaftlichen Stopp und eine optionale Verlangerung.',
  },
  {
    question: 'Welche Stadt eignet sich am besten fur einen langeren Aufenthalt in China?',
    answer:
      'Shanghai ist als Basis fur einen langeren Aufenthalt am einfachsten, wenn es um Dienstleistungen und Englischabdeckung geht, Chengdu ist starker bei niedrigeren Kosten und entspanntem Leben, und Hangzhou bietet einen Mittelweg mit Landschaft und einer starken Tech-Wirtschaft. Sanya eignet sich gut fur Winteraufenthalte statt fur ganzjahriges Stadtleben.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
const locale = 'en';
---
<!-- KI-unterstutzt erstellter Inhalt, von muttersprachlichem Redakteur gepruft -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Stadteplanung</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="city-shanghai" alt="Skyline von Shanghai und der Bund in der Dammerung als Sinnbild fur Stadtereisen in China" loading="eager" />

    <ChinaMap cities={mapCities} />

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3" aria-labelledby="city-shortcuts">
      <h2 id="city-shortcuts" class="sr-only">Stadtkurzverweise</h2>
      {cities.map((city) => (
        <a href={city.slug ? `/posts/${city.slug}/` : '#'} class="card block hover:no-underline scroll-mt-20" id={city.name.toLowerCase().replace(/[^a-z]/g, '')}>
          <h3 class="text-xl font-bold text-gray-950">{city.name}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{city.desc}</p>
          <dl class="mt-4 grid gap-2 text-sm text-gray-700">
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Empfohlene Aufenthaltsdauer</dt>
              <dd class="text-right">{city.days}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Beste Jahreszeit</dt>
              <dd class="text-right">{city.bestSeason}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Einfachheit fur Besucher</dt>
              <dd class="text-right">{city.difficulty}</dd>
            </div>
          </dl>
          <span class="mt-3 inline-block text-sm font-semibold text-brand-700">Stadtfuhrer offnen →</span>
        </a>
      ))}
    </section>

    <section class="mt-12" aria-labelledby="compare-cities">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Stadtevergleich</p>
          <h2 id="compare-cities">Welche Stadt in China solltest du wahlen?</h2>
        </div>
      </div>
      <div class="mt-6 overflow-hidden rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
          <thead class="bg-gray-50 text-xs font-semibold uppercase tracking-wide text-gray-600">
            <tr>
              <th class="px-4 py-3">Stadt</th>
              <th class="px-4 py-3">Warum hinfahren</th>
              <th class="px-4 py-3">Empfohlene Aufenthaltsdauer</th>
              <th class="px-4 py-3">Beste Jahreszeit</th>
              <th class="px-4 py-3">Einfachheit</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {cities.map((city) => (
              <tr>
                <th class="px-4 py-4 font-bold text-gray-950">
                  <a href={`/posts/${city.slug}/`} class="text-brand-700 hover:text-brand-800">{city.name}</a>
                </th>
                <td class="px-4 py-4 leading-6 text-gray-700">{city.whyGo}</td>
                <td class="px-4 py-4 text-gray-700">{city.days}</td>
                <td class="px-4 py-4 text-gray-700">{city.bestSeason}</td>
                <td class="px-4 py-4 text-gray-700">{city.difficulty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-12 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]" aria-labelledby="route-ideas">
      <div>
        <p class="section-kicker">Routenplanung</p>
        <h2 id="route-ideas" class="mt-2 text-3xl font-bold text-gray-950">Praktische Stadtekombinationen</h2>
        <p class="mt-3 leading-7 text-gray-600">
          Eine gute China-Reiseroute funktioniert normalerweise besser, wenn die Stadte unterschiedliche Rollen haben. Nutze Shanghai als einfachen Ankunftsort, Beijing fur Geschichte, Hangzhou fur Landschaft, Chengdu fur Essen und Zugang zu Westchina und
          Sanya fur eine Pause bei warmem Wetter. Vermeide es, einer kurzen Reise zu viele Fluge oder Umstiege an Bahnhofen hinzuzufugen.
        </p>
      </div>
      <div class="grid gap-4">
        {routes.map((route) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-lg font-bold text-gray-950">{route.name}</h3>
            <p class="mt-2 font-semibold text-brand-700">{route.plan}</p>
            <p class="mt-2 text-sm leading-6 text-gray-600">{route.fit}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Alle stadtebezogenen Reisefuhrer</p>
            <h2>Stadtartikel und lokaler Verkehr</h2>
          </div>
        </div>
        <div class="mt-6 grid gap-5 md:grid-cols-2">
          {cityPosts.map((post) => (
            <a href={`/posts/${post.slug}/`} class="card block hover:no-underline">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
              <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <p class="section-kicker">Bevor du eine Stadt auswählst</p>
        <h2 class="mt-1 text-xl font-bold text-gray-950">Prufe die Logistik-Grundlagen</h2>
        <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
          <li><a href="/payment/" class="font-semibold text-brand-700">Zahlungen:</a> richte Alipay, WeChat Pay und Bargeld als Reserve ein, bevor du in kleinere Stadte reist.</li>
          <li><a href="/esim/" class="font-semibold text-brand-700">Internet:</a> wahlen Sie eSIM, Roaming oder eine lokale SIM, bevor Sie sich auf Karten und Ubersetzung verlassen.</li>
          <li><a href="/transport/" class="font-semibold text-brand-700">Verkehr:</a> vergleiche Zuge, Flughafentransfers, DiDi und Metro-QR-Codes.</li>
          <li><a href="/tools/best-time-to-visit/" class="font-semibold text-brand-700">Zeitpunkt:</a> prufe Wetter, Feiertage und Besucherdruck nach Monat.</li>
        </ul>
      </aside>
    </section>

    <section class="mt-12" aria-labelledby="city-faq">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Stadt-FAQ</p>
          <h2 id="city-faq">Haufige Fragen zur Stadteplanung in China</h2>
        </div>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {faqItems.map((item) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-base font-bold text-gray-950">{item.question}</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">{item.answer}</p>
          </article>
        ))}
      </div>
    </section>

    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  </main>
  <Footer />
</BaseLayout>