---
import { getCollection } from 'astro:content';
import BlogPost from '../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { data } = post;

// Zuordnung der Affiliate-CTA nach Kategorie
const affiliateByCategory: Record<string, { title: string; description: string; buttonText: string }> = {
  payment: {
    title: 'Zahlungssetup für die Reise',
    description: 'Hol dir eine Prepaid-Reisekarte, die in China reibungslos mit Alipay und WeChat Pay funktioniert.',
    buttonText: 'Jetzt starten',
  },
  esim: {
    title: 'Empfohlene China eSIM',
    description: 'Überspringe die Warteschlange am Flughafen — aktiviere einen Highspeed-Datentarif, bevor du landest.',
    buttonText: 'Tarife ansehen',
  },
  transport: {
    title: 'Züge & Fahrten einfach buchen',
    description: 'Reserviere Hochgeschwindigkeitszug-Tickets und Flughafentransfers auf Englisch, ganz ohne Aufwand.',
    buttonText: 'Jetzt buchen',
  },
};

const affiliate = affiliateByCategory[data.category];
const allPosts = await getCollection('posts');
const zhTwPosts = await getCollection('posts-zh-tw');
const jaPosts = await getCollection('posts-ja');
const koPosts = await getCollection('posts-ko');
const ruPosts = await getCollection('posts-ru');
const frPosts = await getCollection('posts-fr');
const dePosts = await getCollection('posts-de');
const esPosts = await getCollection('posts-es');
const alternates: Record<string, string> = { en: `/posts/${post.slug}/` };
if (zhTwPosts.some((candidate) => candidate.slug === post.slug)) alternates['zh-TW'] = `/zh-tw/posts/${post.slug}/`;
if (jaPosts.some((candidate) => candidate.slug === post.slug)) alternates.ja = `/ja/posts/${post.slug}/`;
if (koPosts.some((candidate) => candidate.slug === post.slug)) alternates.ko = `/ko/posts/${post.slug}/`;
if (ruPosts.some((candidate) => candidate.slug === post.slug)) alternates.ru = `/ru/posts/${post.slug}/`;
if (frPosts.some((candidate) => candidate.slug === post.slug)) alternates.fr = `/fr/posts/${post.slug}/`;
if (dePosts.some((candidate) => candidate.slug === post.slug)) alternates.de = `/de/posts/${post.slug}/`;
if (esPosts.some((candidate) => candidate.slug === post.slug)) alternates.es = `/es/posts/${post.slug}/`;
const related = allPosts
  .filter((candidate) => candidate.slug !== post.slug)
  .map((candidate) => {
    const sharedTags = candidate.data.tags.filter((tag) => data.tags.includes(tag)).length;
    const categoryMatch = candidate.data.category === data.category ? 2 : 0;
    const cityMatch =
      ['beijing', 'shanghai', 'chengdu', 'hangzhou', 'sanya'].some(
        (city) => post.slug.includes(city) && candidate.slug.includes(city)
      )
        ? 3
        : 0;
    return { candidate, score: sharedTags + categoryMatch + cityMatch };
  })
  .filter((item) => item.score > 0)
  .sort((a, b) => b.score - a.score || b.candidate.data.pubDate.valueOf() - a.candidate.data.pubDate.valueOf())
  .slice(0, 4)
  .map(({ candidate }) => ({
    title: candidate.data.title,
    description: candidate.data.description,
    href: `/posts/${candidate.slug}/`,
  }));
---
<!-- KI-unterstutzt erstellter Inhalt, von muttersprachlichem Redakteur gepruft -->


<BlogPost
  title={data.title}
  description={data.description}
  pubDate={data.pubDate}
  category={data.category}
  tags={data.tags}
  faqs={data.faqs}
  cover={data.cover}
  coverAlt={data.coverAlt}
  related={related}
  alternates={alternates}
  affiliate={affiliate}
>
  <Content />
</BlogPost>