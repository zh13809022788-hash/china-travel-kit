---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import AffiliateCta from '../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../config';
import ToolSchema from '../../components/ToolSchema.astro';

const title = 'RMB Currency Converter for China Travelers';
const description =
  'Convert your home currency to Chinese yuan (RMB) and back, and see what everyday things cost in China so you can price-check on the spot.';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Tool</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">RMB Currency Converter</h1>
<p class="mt-4 max-w-3xl text-lg leading-8 text-gray-600">
  Use this converter to check current exchange rates between your home currency and Chinese Yuan (RMB/CNY). The reference prices below give you a sense of common costs: a bowl of noodles costs around 15-25 RMB, a metro ride 3-7 RMB, and a mid-range hotel 200-500 RMB per night. China is predominantly a cashless society — Alipay and WeChat Pay are accepted everywhere from street vendors to luxury hotels. For the best exchange rates, use your home bank’s international debit card at Chinese bank ATMs, or exchange currency at local banks rather than airports or hotels.
</p>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- Converter -->
    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-6">
      <div class="grid gap-4 sm:grid-cols-[1fr_auto_1fr] sm:items-end">
        <label class="flex flex-col text-sm">
          <span class="mb-1 font-medium text-gray-700">Your currency</span>
          <div class="flex gap-2">
            <select id="currency" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
              <option value="USD">USD ($)</option>
              <option value="EUR">EUR (€)</option>
              <option value="GBP">GBP (£)</option>
              <option value="AUD">AUD (A$)</option>
              <option value="CAD">CAD (C$)</option>
              <option value="JPY">JPY (¥)</option>
              <option value="SGD">SGD (S$)</option>
            </select>
            <input id="foreign-amount" type="number" min="0" value="100"
              class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
          </div>
        </label>
        <div class="hidden pb-2 text-center text-gray-400 sm:block">⇄</div>
        <label class="flex flex-col text-sm">
          <span class="mb-1 font-medium text-gray-700">Chinese yuan (RMB)</span>
          <input id="rmb-amount" type="number" min="0"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
        </label>
      </div>
      <p id="rate-line" class="mt-3 text-sm text-gray-500"></p>
      <p class="mt-1 text-xs text-gray-400">
        Rates are approximate references for planning, not live market rates. Check your bank or a live
        converter for the exact rate at the time of your transaction.
      </p>
    </div>

    <!-- What things cost -->
    <section class="mt-8">
      <h2 class="text-xl font-bold text-gray-900">What Things Cost in China</h2>
      <p class="mt-1 text-sm text-gray-500">Typical prices in RMB, with your currency shown for reference.</p>
      <div id="cost-grid" class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3"></div>
    </section>

    <AffiliateCta
      title="Skip the Exchange Counter"
      description="Link a no-FX-fee card to Alipay or WeChat Pay and pay at the real rate, with no cash exchange markup."
      buttonText="See Payment Setup"
      placeholder={AFFILIATE_LINKS.payment}
    />
      <ToolSchema
      name="RMB Currency Converter"
      description="Convert your currency to yuan and back and see what everyday things cost in China"
      url="https://www.chinatripbox.com/tools/currency-converter/"
    />
  </main>
  <Footer />
</BaseLayout>

<script>
  // Approximate reference rates: 1 unit of currency = X RMB.
  const ratesToRmb: Record<string, number> = {
    USD: 7.2,
    EUR: 7.8,
    GBP: 9.1,
    AUD: 4.7,
    CAD: 5.2,
    JPY: 0.048,
    SGD: 5.3,
  };
  const symbols: Record<string, string> = {
    USD: '$', EUR: '€', GBP: '£', AUD: 'A$', CAD: 'C$', JPY: '¥', SGD: 'S$',
  };

  const commonCosts: { label: string; rmb: number }[] = [
    { label: 'Bottle of water', rmb: 2 },
    { label: 'Metro ride', rmb: 4 },
    { label: 'Street food snack', rmb: 10 },
    { label: 'Coffee (café)', rmb: 30 },
    { label: 'Casual restaurant meal', rmb: 45 },
    { label: 'Short DiDi / taxi ride', rmb: 25 },
    { label: 'High-speed rail (1–2 hr)', rmb: 250 },
    { label: 'Museum / attraction ticket', rmb: 60 },
    { label: 'Mid-range hotel / night', rmb: 450 },
  ];

  const currencyEl = document.getElementById('currency') as HTMLSelectElement;
  const foreignEl = document.getElementById('foreign-amount') as HTMLInputElement;
  const rmbEl = document.getElementById('rmb-amount') as HTMLInputElement;
  const rateLine = document.getElementById('rate-line');
  const costGrid = document.getElementById('cost-grid');

  function rate() {
    return ratesToRmb[currencyEl.value];
  }
  function sym() {
    return symbols[currencyEl.value];
  }

  function fromForeign() {
    const v = Number(foreignEl.value) || 0;
    rmbEl.value = (v * rate()).toFixed(2);
    updateMeta();
  }
  function fromRmb() {
    const v = Number(rmbEl.value) || 0;
    foreignEl.value = (v / rate()).toFixed(2);
    updateMeta();
  }

  function updateMeta() {
    if (rateLine) {
      rateLine.textContent = `Reference rate: 1 ${currencyEl.value} ≈ ¥${rate().toFixed(2)} RMB`;
    }
    if (costGrid) {
      costGrid.innerHTML = commonCosts
        .map((c) => `
          <div class="card">
            <span class="text-sm text-gray-500">${c.label}</span>
            <div class="mt-1 flex items-baseline gap-2">
              <span class="text-xl font-bold text-gray-900">¥${c.rmb}</span>
              <span class="text-sm text-brand-600">≈ ${sym()}${(c.rmb / rate()).toFixed(2)}</span>
            </div>
          </div>`)
        .join('');
    }
  }

  foreignEl.addEventListener('input', fromForeign);
  rmbEl.addEventListener('input', fromRmb);
  currencyEl.addEventListener('change', fromForeign);

  fromForeign();
</script>
