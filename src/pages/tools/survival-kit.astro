---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ShowToLocal from '../../components/ShowToLocal.astro';
import SurvivalChecklist from '../../components/SurvivalChecklist.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import survivalKits from '../../data/survival-kits.json';

const title = 'China Survival Kit: Translation Cards and Trip Checklists';
const description =
  'Interactive China survival kits for foreign visitors: full-screen translation cards, arrival setup checklists, food allergy cards, and local communication tools.';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Survival kit</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-950 md:text-4xl">China Survival Kit</h1>
<p class="mt-4 max-w-3xl text-lg leading-8 text-gray-600">
  Our China Survival Kit helps you prepare for your trip with confidence. It includes interactive checklists covering every step of pre-departure preparation: visa application, travel insurance, payment setup (Alipay/WeChat Pay), eSIM or SIM card purchase, accommodation booking, and packing essentials. The phrase card section lets you show Chinese text to locals for common situations like ordering food, asking directions, and negotiating taxi fares. You can also add custom cards with your own phrases. Everything is saved in your browser, so you can return to it anytime during your trip without creating an account.
</p>
      <p class="mt-3 text-lg leading-8 text-gray-600">
        Use full-screen translation cards and saved checklists for the moments when reading a long guide is too slow:
        airport arrival, hotel check-in, taxis, restaurants, allergies, and first-day setup.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="#arrival" class="btn-primary">Start with arrival</a>
        <a href="#food" class="btn-outline">Open food cards</a>
      </div>
    </header>

    <section class="mt-8 grid gap-4 md:grid-cols-3">
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Full-screen cards</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Tap a card and show large Chinese text to a driver, hotel desk, or restaurant staff.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Saved checklists</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Checklist progress is stored in your browser so you can close and return later.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Context AI entry</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Use the floating helper to open ChinaTripBox travel help with a topic-aware prompt.</p>
      </div>
    </section>

    <div class="mt-10 grid gap-8">
      {survivalKits.map((kit) => (
        <section id={kit.slug} class="grid gap-5 rounded-xl border border-gray-200 bg-gray-50 p-5">
          <div class="max-w-3xl">
            <p class="section-kicker">{kit.slug} kit</p>
            <h2 class="mt-1 text-2xl font-bold text-gray-950">{kit.title}</h2>
            <p class="mt-2 text-sm leading-6 text-gray-600">{kit.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {kit.related_paths.map((path) => (
                <a href={path} class="rounded-full border border-gray-200 bg-white px-3 py-1.5 text-xs font-semibold text-brand-700 hover:border-brand-300 hover:no-underline">
                  Related guide
                </a>
              ))}
            </div>
          </div>
          <div class="grid gap-5 lg:grid-cols-[1fr_0.85fr]">
            <ShowToLocal themeId={kit.theme_id} tools={kit.tools} />
            <SurvivalChecklist themeId={kit.theme_id} steps={kit.checklist_steps} />
          </div>
        </section>
      ))}
    </div>
      <ToolSchema
      name="China Survival Kit"
      description="Full-screen translation cards and saved checklists for arrival, restaurants, hotels and local communication"
      url="https://www.chinatripbox.com/tools/survival-kit/"
    />
  </main>
  <Footer />
</BaseLayout>
