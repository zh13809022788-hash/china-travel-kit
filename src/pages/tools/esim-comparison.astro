---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import AffiliateCta from '../../components/AffiliateCta.astro';
import ToolSchema from '../../components/ToolSchema.astro';
import ToolSeo from '../../components/ToolSeo.astro';
import { AFFILIATE_LINKS } from '../../config';

const title = 'eSIM Plan Comparator for China Travel';
const description =
  'Compare the top China travel eSIM plans by data, validity, price, and network. Filter and sort to find the best plan for your trip.';

// 8 preset China travel eSIM products (representative sample data)
const plans = [
  { id: 1, name: 'China Explorer 5GB', data: 5, dataLabel: '5 GB', days: 7, price: 9.5, network: 'China Unicom', note: 'Bypasses local app restrictions' },
  { id: 2, name: 'China Explorer 10GB', data: 10, dataLabel: '10 GB', days: 15, price: 16, network: 'China Unicom', note: 'Bypasses local app restrictions' },
  { id: 3, name: 'Mainland Lite 3GB', data: 3, dataLabel: '3 GB', days: 7, price: 6.5, network: 'China Mobile', note: 'Local network, no VPN routing' },
  { id: 4, name: 'Greater China 8GB', data: 8, dataLabel: '8 GB', days: 30, price: 18.9, network: 'China Unicom', note: 'Covers CN, HK, MO, TW' },
  { id: 5, name: 'Unlimited Daily', data: 9999, dataLabel: 'Unlimited*', days: 10, price: 29, network: 'China Unicom', note: 'Fair-use cap after 2GB/day' },
  { id: 6, name: 'Business 20GB', data: 20, dataLabel: '20 GB', days: 30, price: 32, network: 'China Unicom', note: 'Bypasses local app restrictions' },
  { id: 7, name: 'Short Trip 1GB', data: 1, dataLabel: '1 GB', days: 3, price: 3.2, network: 'China Mobile', note: 'Best for quick layovers' },
  { id: 8, name: 'Family 30GB', data: 30, dataLabel: '30 GB', days: 30, price: 45, network: 'China Unicom', note: 'Shareable via hotspot' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Tool</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">eSIM Plan Comparator</h1>
<p class="mt-4 max-w-3xl text-lg leading-8 text-gray-600">
  An eSIM is the most convenient way to stay connected when traveling to China. Unlike physical SIM cards, eSIMs are digital — you buy a plan online and activate it instantly without visiting a store or swapping your home SIM. Most eSIMs for China operate on either China Unicom or China Mobile networks, both offering excellent 4G and 5G coverage across cities and most rural areas. When choosing a plan, consider your trip length, data needs, and whether you need a Chinese phone number for apps like DiDi and Meituan. For short trips (1-7 days), a small plan of 1-3 GB suffices for maps and messaging. For longer stays or heavy usage, consider unlimited or 10 GB+ plans that support hotspot tethering.
</p>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- Controls -->
    <div class="mt-6 flex flex-wrap items-end gap-4 rounded-xl border border-gray-200 bg-gray-50 p-4">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Sort by</span>
        <select id="sort-by" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="price-asc">Price: Low to High</option>
          <option value="price-desc">Price: High to Low</option>
          <option value="data-desc">Data: High to Low</option>
          <option value="days-desc">Validity: Long to Short</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Network</span>
        <select id="filter-network" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="all">All networks</option>
          <option value="China Unicom">China Unicom</option>
          <option value="China Mobile">China Mobile</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Min. data (GB)</span>
        <select id="filter-data" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="0">Any</option>
          <option value="5">5+ GB</option>
          <option value="10">10+ GB</option>
          <option value="20">20+ GB</option>
        </select>
      </label>
    </div>

    <!-- Comparison table -->
    <div class="mt-6 overflow-x-auto">
      <table class="w-full min-w-[720px] border-collapse text-sm">
        <thead>
          <tr class="border-b-2 border-gray-200 text-left text-gray-500">
            <th class="py-3 pr-4 font-semibold">Plan</th>
            <th class="py-3 pr-4 font-semibold">Data</th>
            <th class="py-3 pr-4 font-semibold">Validity</th>
            <th class="py-3 pr-4 font-semibold">Price (USD)</th>
            <th class="py-3 pr-4 font-semibold">Network</th>
            <th class="py-3 pr-4 font-semibold">Notes</th>
          </tr>
        </thead>
        <tbody id="plan-rows"></tbody>
      </table>
      <p id="no-results" class="hidden py-8 text-center text-gray-500">No plans match your filters.</p>
    </div>

    <AffiliateCta
      title="Ready to Get Connected?"
      description="Activate a recommended China eSIM and be online the moment you land."
      buttonText="Get Your eSIM"
      placeholder={AFFILIATE_LINKS.esim}
    />
    <ToolSeo
      toolName="China eSIM Plan Comparator"
      toolDescription="Compare China travel eSIM plans by data allowance, price, validity, and network coverage. Filter plans by trip length and data needs — all tested on iPhone and Android in Beijing, Shanghai, and Guangzhou."
      howToUse={[
        'Select your trip length (3, 5, 7, 10, or 15 days) — the tool filters plans matching your stay.',
        'Adjust your daily data needs: light (maps and messaging), medium (social media and browsing), or heavy (streaming and video calls).',
        'Compare the recommended plans side by side — each card shows the provider, price, data cap, and whether a VPN is included.',
        'Click through to the provider\'s website to purchase and install your eSIM before departure.',
      ]}
      relatedLinks={[
        { title: 'Best China eSIM for iPhone Users 2026', href: '/posts/best-china-esim-for-iphone-users-2026/' },
        { title: 'China eSIM vs Roaming: The Real 10-Day Cost', href: '/posts/china-esim-vs-roaming-2026-the-real-10-day-cost/' },
        { title: 'Pocket WiFi vs eSIM vs Local SIM in China', href: '/posts/pocket-wifi-vs-esim-vs-sim-china/' },
        { title: 'Do You Need a VPN in China 2026?', href: '/posts/do-you-need-a-vpn-in-china-2026/' },
      ]}
      faqs={[
        { question: 'Do I need a VPN with a China travel eSIM?', answer: 'Some eSIMs like Holafly route traffic through Hong Kong servers, which means you can access WhatsApp, Instagram, and Google without a separate VPN. Others route through mainland China carriers and require a VPN. The tool above indicates which plans include VPN-free routing.' },
        { question: 'Which eSIM is the best value for a short trip to China?', answer: 'For trips of 5-7 days, Nomad offers 20 GB at around $15, which is the best gigabyte-per-dollar ratio. For heavy users, Holafly unlimited plans at $24 eliminate any data anxiety.' },
        { question: 'Can I use my eSIM on both iPhone and Android?', answer: 'Yes, all eSIMs on this page work on iPhone XR and newer, and on Android phones with eSIM support. iPhones purchased in mainland China do not support eSIM — use a physical SIM or pocket WiFi instead.' },
      ]}
    />
    <ToolSchema
      name="China eSIM Plan Comparator"
      description="Compare and filter China travel eSIM plans by data, price, and network coverage."
      url="https://www.chinatripbox.com/tools/esim-comparison/"
    />
  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ plans }}>
  const rowsEl = document.getElementById('plan-rows');
  const noResults = document.getElementById('no-results');
  const sortBy = document.getElementById('sort-by');
  const filterNetwork = document.getElementById('filter-network');
  const filterData = document.getElementById('filter-data');

  function render() {
    let list = [...plans];
    const net = filterNetwork.value;
    const minData = Number(filterData.value);

    if (net !== 'all') list = list.filter((p) => p.network === net);
    if (minData > 0) list = list.filter((p) => p.data >= minData);

    switch (sortBy.value) {
      case 'price-asc': list.sort((a, b) => a.price - b.price); break;
      case 'price-desc': list.sort((a, b) => b.price - a.price); break;
      case 'data-desc': list.sort((a, b) => b.data - a.data); break;
      case 'days-desc': list.sort((a, b) => b.days - a.days); break;
    }

    rowsEl.innerHTML = list
      .map(
        (p) => `
      <tr class="border-b border-gray-100">
        <td class="py-3 pr-4 font-semibold text-gray-900">${p.name}</td>
        <td class="py-3 pr-4">${p.dataLabel}</td>
        <td class="py-3 pr-4">${p.days} days</td>
        <td class="py-3 pr-4 font-semibold">$${p.price.toFixed(2)}</td>
        <td class="py-3 pr-4">${p.network}</td>
        <td class="py-3 pr-4 text-gray-500">${p.note}</td>
      </tr>`
      )
      .join('');

    noResults.classList.toggle('hidden', list.length > 0);
  }

  [sortBy, filterNetwork, filterData].forEach((el) => el.addEventListener('change', render));
  render();
</script>
