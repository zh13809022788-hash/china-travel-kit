        <div><dt class="text-gray-500">What to pack</dt><dd class="text-gray-700">${info.pack}</dd></div>
      </dl>`;
  }

  cityEl.addEventListener('change', render);
  monthEl.addEventListener('change', render);
  render();
</script>
