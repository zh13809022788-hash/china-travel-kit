  const ratingStyle = {
    great: { cls: 'border-green-200 bg-green-50', badge: 'bg-green-600', label: 'Great time to visit' },
    good: { cls: 'border-teal-200 bg-teal-50', badge: 'bg-teal-600', label: 'Good time to visit' },
    ok: { cls: 'border-amber-200 bg-amber-50', badge: 'bg-amber-500', label: 'Doable, with trade-offs' },
    tough: { cls: 'border-red-200 bg-red-50', badge: 'bg-red-500', label: 'Challenging conditions' },
  } as const;

  const monthNames = ['January', 'February', 'March', 'April', 'May', 'June', 'July', 'August', 'September', 'October', 'November', 'December'];

  const cityEl = document.getElementById('city') as HTMLSelectElement;
  const monthEl = document.getElementById('month') as HTMLSelectElement;
  const card = document.getElementById('result-card');

  function render() {
    if (!card) return;
    const city = cityEl.value;
    const m = Number(monthEl.value);
    const info = data[city][m];
    const style = ratingStyle[info.rating];

    card.className = `card border ${style.cls}`;
    card.innerHTML = `
      <div class="flex items-center justify-between gap-3">
        <h2 class="text-xl font-bold text-gray-900">${city} in ${monthNames[m]}</h2>
        <span class="whitespace-nowrap rounded-full px-3 py-0.5 text-xs font-semibold text-white ${style.badge}">${style.label}</span>
      </div>
      <dl class="mt-4 space-y-3 text-sm">
