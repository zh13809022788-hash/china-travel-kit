---
import { getCollection } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts-zh-tw');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { data } = post;

const affiliateByCategory: Record<string, { title: string; description: string; buttonText: string }> = {
  payment: {
    title: '行前付款設定',
    description: '準備一張可搭配 Alipay 與 WeChat Pay 使用的旅遊付款卡，抵達中國後更安心。',
    buttonText: '開始設定',
  },
  esim: {
    title: '推薦中國 eSIM',
    description: '不用在機場排隊，出發前先啟用高速上網方案。',
    buttonText: '查看方案',
  },
  transport: {
    title: '輕鬆預訂火車與接送',
    description: '用英文預訂高鐵票與機場接送，少一點溝通壓力。',
    buttonText: '立即預訂',
  },
};

const affiliate = affiliateByCategory[data.category];
const allPosts = await getCollection('posts-zh-tw');
const related = allPosts
  .filter((candidate) => candidate.slug !== post.slug)
  .map((candidate) => {
    const sharedTags = candidate.data.tags.filter((tag) => data.tags.includes(tag)).length;
    const categoryMatch = candidate.data.category === data.category ? 2 : 0;
    const cityMatch =
      ['beijing', 'shanghai', 'chengdu', 'hangzhou', 'sanya'].some(
        (city) => post.slug.includes(city) && candidate.slug.includes(city)
      )
        ? 3
        : 0;
    return { candidate, score: sharedTags + categoryMatch + cityMatch };
  })
  .filter((item) => item.score > 0)
  .sort((a, b) => b.score - a.score || b.candidate.data.pubDate.valueOf() - a.candidate.data.pubDate.valueOf())
  .slice(0, 4)
  .map(({ candidate }) => ({
    title: candidate.data.title,
    description: candidate.data.description,
    href: `/zh-tw/posts/${candidate.slug}/`,
  }));
---

<BlogPost
  title={data.title}
  description={data.description}
  pubDate={data.pubDate}
  category={data.category}
  tags={data.tags}
  faqs={data.faqs}
  cover={data.cover}
  coverAlt={data.coverAlt}
  related={related}
  locale="zh-TW"
  alternates={{ en: `/posts/${post.slug}/`, 'zh-TW': `/zh-tw/posts/${post.slug}/` }}
  affiliate={affiliate}
>
  <Content />
</BlogPost>
