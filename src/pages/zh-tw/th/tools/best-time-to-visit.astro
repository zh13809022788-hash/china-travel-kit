---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import AdSlot from '../../../../components/AdSlot.astro';
import AffiliateCta from '../../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../../config';

const title = '造訪中國的最佳時間 - 城市與月份規劃工具';
const description =
  '按月份查看中國主要城市的天氣、人潮與行李建議。規劃造訪北京、上海、西安、成都、廣州和哈爾濱的最佳時間。';

const cities = ['北京', '上海', '西安', '成都', '廣州', '哈爾濱'];
const months = ['1月', '2月', '3月', '4月', '5月', '6月', '7月', '8月', '9月', '10月', '11月', '12月'];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="zh-TW">
  <Header locale="zh-TW" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">工具</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">造訪中國的最佳時間</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">城市</span>
        <select id="city" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {cities.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">旅行月份</span>
        <select id="month" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {months.map((m, i) => <option value={i}>{m}</option>)}
        </select>
      </label>
    </div>

    <div id="result" class="mt-6">
      <div class="card" id="result-card"></div>
    </div>

    <!-- 旅遊旺季提醒 -->
    <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
      <strong>避開人潮：</strong>中國公共假期，尤其是春節（1月下旬或2月）、勞動節（5月初）以及國慶節／黃金週（10月第一週），
      會帶來龐大的國內旅遊人潮。火車與飯店常會售罄，價格也會飆升。請提早預訂，或避開這些日期安排行程。
    </div>

    <AffiliateCta
      title="提早預訂火車與飯店"
      description="熱門路線在旺季很快售罄。提前鎖定高鐵車票與住宿。"
      buttonText="查看預訂選項"
      placeholder={AFFILIATE_LINKS.transport}
    />
  </main>
  <Footer />
</BaseLayout>

