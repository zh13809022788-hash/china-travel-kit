const title = "中國長住：外國人完整指南（2026）";
const description =
  '打算在中國停留 1 至 6 個月？本指南涵蓋長期住宿、簽證規則、每月生活成本，以及給慢旅行者與外籍人士的日常生活建議。';
const url = '/long-stay/';
const datePublished = '2026-07-09';

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Long Stay' },
];

const toc = [
  { id: 'short-vs-long', label: '短期旅行 vs. 長住' },
