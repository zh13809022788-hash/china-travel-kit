---

import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const CATEGORY = 'esim';
const posts = (await getCollection('posts-zh-tw'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = '中國 eSIM 與網路使用指南：落地立即連線';
const description = '比較並設定最適合中國旅遊的 eSIM 數據方案。一下飛機就能上網，無需更換實體 SIM 卡。';

const connectionChoices = [
  {
    title: 'eSIM',
    desc: '如果你的手機支援 eSIM，且希望在落地前就先準備好行動數據，這通常是多數短期旅遊最合適的選擇。',
  },
  {
    title: '國際漫遊',
    desc: '可作為接收銀行簡訊，以及抵達後第一小時連線的備用方案，但如果數據用量較大，費用通常偏高。',
  },
  {
    title: '口袋 Wi-Fi 或當地 SIM 卡',
    desc: '如果是多人同行、停留時間較長，或手機無法安裝旅遊 eSIM，這類方案就值得納入考量。',
  },
];

const internetTools = [
  { href: '/zh-tw/tools/esim-comparison/', title: 'eSIM 方案比較工具', desc: '比較旅遊數據方案、可用天數，以及各自適合的使用情境。' },
  { href: '/zh-tw/tools/app-availability-checker/', title: '應用程式可用性檢查工具', desc: '確認常見應用程式在中國是否可用，並事先準備替代方案。' },
  { href: '/zh-tw/posts/internet-access-china-apps-that-work-2026/', title: '中國上網攻略', desc: '出發前先了解應用程式使用情況、VPN 預期，以及實用設定方式。' },
];
---
import { getCategoryLabel } from '../../../i18n/categories.ts';


<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="zh-TW">
  <Header locale="zh-TW" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">eSIM 網路連線</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">eSIM 與行動數據上網指南</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="hub-esim" alt="中國旅遊可選擇的行動網路與數據連線方式" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="jingxuan-esim">
      <h2 id="jingxuan-esim" class="sr-only">精選上網指南</h2>
      <a href="/zh-tw/posts/best-esim-for-china-travel-2026/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">2026 最值得推薦的 eSIM</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">比較 Airalo、Holafly、Nomad 在中國旅遊時可選擇的方案</p>
      </a>
      <a href="/zh-tw/posts/china-esim-vs-roaming-2026-the-real-10-day-cost/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">eSIM 與國際漫遊比較</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">旅客 10 天實際花費對照</p>
      </a>
      <a href="/zh-tw/posts/do-you-need-a-vpn-in-china-2026/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">2026 VPN 使用指南</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">旅客現在在中國還需要 VPN 嗎？</p>
      </a>
      <a href="/zh-tw/posts/pocket-wifi-vs-esim-vs-sim-china/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">口袋 Wi-Fi 與 eSIM 比較</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">一次比較所有上網連線方案</p>
      </a>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[1fr_340px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">挑選適合你的中國上網方案</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          對多數旅客來說，最穩妥的做法通常是準備一個主要數據方案，再搭配一個備用方案，以應付抵達第一天的銀行、地圖、翻譯與叫車需求。
        </p>
        <div class="mt-5 grid gap-3">
          {connectionChoices.map((choice) => (
            <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
              <h3 class="text-sm font-bold text-gray-900">{choice.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{choice.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">實用工具</h2>
        <div class="mt-4 grid gap-3">
          {internetTools.map((tool) => (
            <a href={tool.href} class="rounded-lg border border-brand-100 bg-white p-4 hover:border-brand-200 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-900 hover:text-brand-700">{tool.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{tool.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/zh-tw/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{getCategoryLabel(post.data.category, locale)}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">指南即將上線。</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>