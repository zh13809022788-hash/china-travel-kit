---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ShowToLocal from '../../../components/ShowToLocal.astro';
import SurvivalChecklist from '../../../components/SurvivalChecklist.astro';
import ContextAiBubble from '../../../components/ContextAiBubble.astro';
import survivalKits from '../../../data/survival-kits.json';

const title = '中國旅行生存工具包：翻譯卡與行程清單';
const description =
  '為外國旅客準備的互動式中國旅行生存工具包：全螢幕翻譯卡、抵達設定清單、食物過敏卡與本地溝通工具。';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="zh-TW">
  <Header locale="zh-TW" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">生存工具包</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-950 md:text-4xl">中國旅行生存工具包</h1>
      <p class="mt-3 text-lg leading-8 text-gray-600">
        在不適合慢慢閱讀長篇指南的時候，使用全螢幕翻譯卡與已儲存清單：機場抵達、飯店入住、計程車、餐廳、過敏需求與第一天設定。
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="#arrival" class="btn-primary">從抵達開始</a>
        <a href="#food" class="btn-outline">開啟食物卡</a>
      </div>
    </header>

    <section class="mt-8 grid gap-4 md:grid-cols-3">
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">全螢幕卡片</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">點選卡片，向司機、飯店櫃檯或餐廳人員顯示大型中文文字。</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">已儲存清單</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">清單進度會儲存在你的瀏覽器中，因此可以關閉頁面後稍後再回來。</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">情境 AI 入口</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">使用浮動助手開啟 ChinaTripBox 旅遊協助，並自動帶入符合主題的提示。</p>
      </div>
    </section>

    <div class="mt-10 grid gap-8">
      {survivalKits.map((kit) => (
        <section id={kit.slug} class="grid gap-5 rounded-xl border border-gray-200 bg-gray-50 p-5">
          <div class="max-w-3xl">
            <p class="section-kicker">{kit.slug} 工具包</p>
            <h2 class="mt-1 text-2xl font-bold text-gray-950">{kit.title}</h2>
            <p class="mt-2 text-sm leading-6 text-gray-600">{kit.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {kit.related_paths.map((path) => (
                <a href={path} class="rounded-full border border-gray-200 bg-white px-3 py-1.5 text-xs font-semibold text-brand-700 hover:border-brand-300 hover:no-underline">
                  相關指南
                </a>
              ))}
            </div>
          </div>
          <div class="grid gap-5 lg:grid-cols-[1fr_0.85fr]">
            <ShowToLocal themeId={kit.theme_id} tools={kit.tools} />
            <SurvivalChecklist themeId={kit.theme_id} steps={kit.checklist_steps} />
          </div>
        </section>
      ))}
    </div>
  </main>
  <ContextAiBubble defaultPrompt="Help me use the China survival 工具包 for arrival, restaurants, translation cards, and checklist preparation." />
  <Footer />
</BaseLayout>
