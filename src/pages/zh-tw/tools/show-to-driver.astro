---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';

const title = '給司機看：中文地址卡';
const description =
  '在手機上建立大型中文訊息卡，可給計程車司機、飯店人員看，也可用於在中國問路。無需登入、無需安裝 App，也不儲存個人資料。';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="zh-TW">
  <Header locale="zh-TW" />
  <main class="container-page py-8 md:py-10">
    <header class="max-w-3xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">工具</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">給司機看</h1>
      <p class="mt-3 text-lg text-gray-600">
        產生大型中文卡片，可用於計程車、叫車上車點、飯店櫃檯與問路。所有操作都在你的瀏覽器中完成。
      </p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
      <div class="rounded-xl border border-gray-200 bg-gray-50 p-5">
        <div class="grid gap-4">
          <label class="flex flex-col text-sm">
            <span class="mb-1 font-medium text-gray-700">中文地址或地點名稱</span>
            <textarea
              id="destination"
              rows="4"
              class="rounded-lg border border-gray-300 px-3 py-2 text-base"
              placeholder="貼上來自 Amap、Trip.com、飯店訂單或朋友提供的中文地址。"
            ></textarea>
            <span class="mt-1 text-xs text-gray-500">
              最佳效果：貼上中文名稱或地址。只有英文的地點名稱，當地司機可能較難辨識。
            </span>
          </label>

          <label class="flex flex-col text-sm">
            <span class="mb-1 font-medium text-gray-700">可選備註</span>
            <select id="note" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
              <option value="route">請按照導航帶我到這個地址。</option>
              <option value="pickup">我在這裡等您，請在 App 內打電話或傳訊息給我。</option>
              <option value="hotel">請幫我到這家飯店，必要時請聯絡櫃檯。</option>
              <option value="stop">如果安全且合法，請在這裡停車。</option>
              <option value="receipt">如果可以，請給我收據。</option>
            </select>
          </label>

          <label class="flex flex-col text-sm">
            <span class="mb-1 font-medium text-gray-700">給司機的補充資訊</span>
            <input
              id="extra"
              class="rounded-lg border border-gray-300 px-3 py-2 text-base"
              placeholder="門號、飯店大廳、上車點、行李等。"
            />
          </label>

          <div class="grid gap-3 sm:grid-cols-2">
            <button id="generate-btn" class="btn-primary">產生卡片</button>
            <button
              id="clear-btn"
              class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:border-brand-400"
            >
              清除
            </button>
          </div>
        </div>

        <div class="mt-5 rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
          此工具不會叫車，也不會聯絡司機。遇到緊急情況時，請先聯絡當地緊急服務或你的飯店。
        </div>
      </div>

      <section class="min-w-0">
        <div id="driver-card" class="rounded-xl border border-gray-900 bg-white p-5 shadow-sm">
          <div class="flex items-center justify-between gap-3 border-b border-gray-200 pb-3">
            <div>
              <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">出示這個畫面</p>
              <h2 class="text-lg font-bold text-gray-900">給司機看的中文小條</h2>
            </div>
            <span class="rounded-full bg-green-50 px-3 py-1 text-xs font-semibold text-green-700">
              可離線使用
            </span>
          </div>

          <div class="py-5">
            <p id="main-line" class="text-center text-2xl font-black leading-tight text-gray-950 sm:text-4xl">
              請幫我去這個地址
            </p>
            <p
              id="address-line"
              class="mt-5 whitespace-pre-wrap break-words text-center text-4xl font-black leading-tight text-gray-950 sm:text-6xl"
            >
              在左側輸入地址
            </p>
            <p id="note-line" class="mt-5 text-center text-2xl font-bold leading-snug text-gray-900 sm:text-3xl">
              請按照導航路線行駛，謝謝。
            </p>
            <p id="extra-line" class="mt-4 hidden whitespace-pre-wrap break-words text-center text-xl font-semibold text-gray-800 sm:text-2xl"></p>
          </div>

          <div class="grid gap-3 border-t border-gray-200 pt-4 sm:grid-cols-3">
            <button id="copy-btn" class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:border-brand-400">
              複製文字
            </button>
            <button id="fullscreen-btn" class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:border-brand-400">
              全螢幕
            </button>
            <a href="/zh-tw/travel-help/" class="rounded-lg border border-brand-200 px-4 py-2 text-center text-sm font-semibold text-brand-700 hover:border-brand-400">
              詢問 AI 協助
            </a>
          </div>
        </div>

        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          <button data-quick="請問這個地址怎麼走？謝謝。" class="quick rounded-lg border border-gray-300 px-4 py-3 text-left text-sm font-medium text-gray-700 hover:border-brand-400">
            詢問路線
          </button>
          <button data-quick="我不會說中文，請用翻譯軟體和我溝通，謝謝。" class="quick rounded-lg border border-gray-300 px-4 py-3 text-left text-sm font-medium text-gray-700 hover:border-brand-400">
            我不會說中文
          </button>
          <button data-quick="請在安全合法的地方停車，謝謝。" class="quick rounded-lg border border-gray-300 px-4 py-3 text-left text-sm font-medium text-gray-700 hover:border-brand-400">
            安全停車
          </button>
          <button data-quick="如果找不到我，請在叫車軟體裡傳訊息。" class="quick rounded-lg border border-gray-300 px-4 py-3 text-left text-sm font-medium text-gray-700 hover:border-brand-400">
            在 App 裡傳訊息給我
          </button>
        </div>
      </section>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  #driver-card:fullscreen {
    display: flex;
    min-height: 100vh;
    width: 100vw;
    flex-direction: column;
    justify-content: center;
    border-radius: 0;
    border: 0;
    padding: 6vw;
  }
</style>

<script>
  const noteMap: Record<string, string> = {
    route: '請按照導航路線行駛，謝謝。',
    pickup: '我在這裡等您，請在叫車軟體裡聯絡我。',
    hotel: '請幫我到這家飯店，必要時請聯絡飯店櫃檯。',
    stop: '請在安全合法的地方停車，謝謝。',
    receipt: '如果可以的話，請給我發票或收據，謝謝。',
  };

  const destination = document.getElementById('destination') as HTMLTextAreaElement | null;
  const note = document.getElementById('note') as HTMLSelectElement | null;
  const extra = document.getElementById('extra') as HTMLInputElement | null;
  const mainLine = document.getElementById('main-line');
  const addressLine = document.getElementById('address-line');
  const noteLine = document.getElementById('note-line');
  const extraLine = document.getElementById('extra-line');
  const card = document.getElementById('driver-card');
  const copyBtn = document.getElementById('copy-btn');
  const fullscreenBtn = document.getElementById('fullscreen-btn');
  const generateBtn = document.getElementById('generate-btn');
  const clearBtn = document.getElementById('clear-btn');
  const quickButtons = document.querySelectorAll<HTMLButtonElement>('.quick');

  function cardText() {
    const address = destination?.value.trim() || '在左側輸入地址';
    const noteText = noteMap[note?.value || 'route'];
    const extraText = extra?.value.trim();
    return [
      '請幫我去這個地址：',
      address,
      noteText,
      extraText ? `補充說明：${extraText}` : '',
    ].filter(Boolean).join('\n');
  }

  function render() {
    const address = destination?.value.trim();
    const extraText = extra?.value.trim();
    if (mainLine) mainLine.textContent = '請幫我去這個地址：';
    if (addressLine) addressLine.textContent = address || '在左側輸入地址';
    if (noteLine) noteLine.textContent = noteMap[note?.value || 'route'];
    if (extraLine) {
      extraLine.textContent = extraText ? `補充說明：${extraText}` : '';
      extraLine.classList.toggle('hidden', !extraText);
    }
  }

  generateBtn?.addEventListener('click', () => {
    render();
    card?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  [destination, note, extra].forEach((el) => el?.addEventListener('input', render));

  clearBtn?.addEventListener('click', () => {
    if (destination) destination.value = '';
    if (extra) extra.value = '';
    if (note) note.value = 'route';
    render();
  });

  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(cardText());
      copyBtn.textContent = '已複製';
      window.setTimeout(() => {
        copyBtn.textContent = '複製文字';
      }, 1400);
    } catch {
      copyBtn.textContent = '複製失敗';
    }
  });

  fullscreenBtn?.addEventListener('click', async () => {
    if (!card) return;
    if (!document.fullscreenElement) {
      await card.requestFullscreen?.();
      fullscreenBtn.textContent = 'Exit 全螢幕';
    } else {
      await document.exitFullscreen?.();
      fullscreenBtn.textContent = '全螢幕';
    }
  });

  document.addEventListener('fullscreenchange', () => {
    if (!fullscreenBtn) return;
    fullscreenBtn.textContent = document.fullscreenElement ? 'Exit 全螢幕' : '全螢幕';
  });

  quickButtons.forEach((button) => {
    button.addEventListener('click', () => {
      if (!extra) return;
      extra.value = button.dataset.quick || '';
      render();
      card?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  render();
</script>
