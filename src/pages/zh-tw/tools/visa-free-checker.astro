---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'China 免簽與過境檢查器';
const description =
  '根據你的國籍和旅行類型，檢查你是否可以免簽進入 China、使用 240 小時過境免簽，或需要申請簽證。';

const lastReviewed = '2026年7月13日';

// Representative policy data for 2026. This is guidance, not legal advice;
// travelers must confirm with an embassy before booking.
const countries = [
  '美國', '英國', '加拿大', '澳洲', '德國',
  '法國', '義大利', '西班牙', '荷蘭', '日本', '韓國',
  '新加坡', '馬來西亞', '泰國', '巴西', '紐西蘭',
  '瑞士', '愛爾蘭', '挪威', '其他',
];
---

<BaseLayout locale="zh-TW" title={`${title} | ChinaTripBox`} description={description}>
  <Header locale="zh-TW" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">工具</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">免簽與過境檢查器</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <p class="mt-3 text-sm text-gray-500">
        最後審閱：{lastReviewed}。此檢查工具是規劃輔助工具，不是官方資格判定。
      </p>
    </header>

    <AdSlot format="banner" />

    <!-- Input controls -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">您的護照國籍</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">旅行型別</span>
        <select id="trip" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="tourism">旅遊 / 參觀</option>
          <option value="business">商務</option>
          <option value="transit">只是途經另一個國家</option>
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="check-btn" class="btn-primary w-full sm:w-auto">檢查我的資格</button>
      </div>
    </div>

    <!-- Result -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>
      <p class="mt-3 text-xs text-gray-400">
        政策經常變化，並取決於您的具體情況。在預訂旅行前，請務必向China大使館或領事館核實。本工具僅提供一般指導。
      </p>

      <AffiliateCta
        title="規劃行程的其他準備"
        description="在抵達 China 前先安排好網路、付款和交通。"
        buttonText="查看旅行必備準備"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6" aria-labelledby="official-sources">
      <h2 id="official-sources" class="text-xl font-bold text-gray-950">預訂前請查證官方來源</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        免簽國家列表、入境口岸、允許的旅行區域以及航空公司登機檢查可能會發生變化。請將官方政府和航空公司的規定視為最終標準。
      </p>
      <ul class="mt-4 grid gap-2 text-sm leading-6 text-gray-700">
        <li><a href="https://en.nia.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">國家移民管理局</a> 用於邊境檢查和過境豁免的更新。</li>
        <li><a href="https://english.www.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">國務院資訊門戶</a> 用於英語政策公告。</li>
        <li><a href="https://www.mfa.gov.cn/eng/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">外交部</a> 以及 China 大使館或領事館網站上的護照相關規定。</li>
      </ul>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">如何避免免籤錯誤</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          最常見的錯誤是將普通的免簽入境與免簽過境混淆。正常的往返行程和第三國的中途停留並不是同一個行程。航空公司在登機前會檢查證件，所以誤解可能會在你到達China之前就阻止你的旅行。
        </p>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-gray-600">
          <li><strong class="text-gray-900">先檢查護照國籍。</strong> 居住國家和信用卡賬單國家並不決定免籤資格。</li>
          <li><strong class="text-gray-900">與過境分開入境。</strong> 中轉通常需要確認前往第三國或地區的後續行程。</li>
          <li><strong class="text-gray-900">確認入境港口。</strong> 交通政策取決於指定的港口和允許的旅行區域。</li>
          <li><strong class="text-gray-900">隨時準備好證明。</strong> 航空公司和邊境官員可能會要求提供下一程機票、酒店、行程或邀請詳情。</li>
        </ul>
      </div>
      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">計劃剩下的到達安排</h2>
        <div class="mt-4 grid gap-3">
          <a href="/zh-tw/posts/china-visa-free-entry-transit-guide-2026/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">閱讀完整的免籤指南</a>
          <a href="/zh-tw/posts/first-24-hours-in-china-arrival-checklist/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">使用到達清單</a>
          <a href="/zh-tw/posts/airport-to-city-transport-beijing-shanghai-guangzhou/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">安排機場交通</a>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  type TripKey = 'tourism' | 'business' | 'transit';

  // Nationalities eligible for the 30-day unilateral visa-free entry (2026 program).
  const visaFree30 = new Set([
    '德國', '法國', '義大利', '西班牙', '荷蘭', '瑞士',
    '愛爾蘭', '挪威', '日本', '韓國', '巴西', '紐西蘭',
    '馬來西亞', '泰國', '澳洲',
  ]);

  // Nationalities eligible for 240-hour (10-day) visa-free transit through
  // designated ports when travelling onward to a third country/region.
  const transit240 = new Set([
    '美國', '英國', '加拿大', '澳洲', '德國',
    '法國', '義大利', '西班牙', '荷蘭', '日本', '韓國',
    '新加坡', '瑞士', '愛爾蘭', '挪威', '巴西', '紐西蘭',
  ]);

  interface Verdict {
    tone: 'good' | 'warn' | 'info';
    heading: string;
    body: string;
    points: string[];
  }

  function evaluate(country: string, trip: TripKey): Verdict {
    const has30 = visaFree30.has(country);
    const hasTransit = transit240.has(country);

    if (trip === 'transit') {
      if (hasTransit) {
        return {
          tone: 'good',
          heading: '你很可能符合 240 小時過境免簽資格',
          body: `持 ${country} 護照經 China 前往第三國時，若從符合資格的口岸入境，通常可免簽停留最長 240 小時（10 天）。`,
          points: [
            '你必須持有 240 小時內前往第三國或地區的已確認後續機票。',
            '入境和出境必須經由指定過境口岸（多數主要國際機場符合資格）。',
            '通常只能在入境省份或指定區域內活動，請查證該口岸的具體規定。',
          ],
        };
      }
      return {
        tone: 'warn',
        heading: '你的國籍可能不適用過境免簽',
        body: `依據我們的資料，${country} 不在標準 240 小時過境免簽名單中。若符合條件，你仍可能適用一般免簽入境；否則可能需要申請過境（G）簽證。`,
        points: [
          '先確認你的國籍是否適用一般免簽入境。',
          '若不適用，請在出發前申請合適的簽證。',
        ],
      };
    }

    // tourism or business
    if (has30) {
      return {
        tone: 'good',
        heading: '你很可能符合 30 天免簽入境資格',
        body: `持 ${country} 護照者，依目前單方面免簽政策，通常可因觀光、商務、探親或過境免簽進入 China 最長 30 天。`,
        points: [
          '你的護照應至少有 6 個月有效期並有空白頁。',
          '準備好後續/回程交通和住宿證明，以備移民官查驗。',
          '30 天通常按每次入境計算，預訂前請確認最新口徑。',
        ],
      };
    }
    if (hasTransit) {
      return {
        tone: 'info',
        heading: '可能需要簽證，但過境免簽或許可用',
        body: `${country} 不在我們的 30 天觀光/商務免簽名單中，因此一般需要簽證。不過，如果你只是經 China 前往第三國，可能可改用 240 小時過境免簽。`,
        points: [
          '若是專程造訪，請提前申請 L（旅遊）或 M（商務）簽證。',
          '若是前往其他地方途中的中停，可能符合 240 小時過境免簽；可將「旅行類型」切換為過境再檢查。',
        ],
      };
    }
    return {
      tone: 'warn',
      heading: '很可能需要簽證',
      body: `依據我們的資料，${country} 護照持有人進行此類行程時，一般需要簽證才能進入 China。請在出發前透過 China 大使館、領事館或授權簽證中心申請。`,
      points: [
        '請在出發前預留充足時間申請 L（旅遊）或 M（商務）簽證。',
        '通常需要邀請函或行程、飯店預訂與回程機票等資料。',
      ],
    };
  }

  const toneStyles: Record<Verdict['tone'], string> = {
    good: 'border-green-200 bg-green-50',
    warn: 'border-amber-200 bg-amber-50',
    info: 'border-blue-200 bg-blue-50',
  };
  const toneBadge: Record<Verdict['tone'], string> = {
    good: 'bg-green-600 text-white',
    warn: 'bg-amber-500 text-white',
    info: 'bg-blue-600 text-white',
  };
  const toneLabel: Record<Verdict['tone'], string> = {
    good: '可能符合資格',
    warn: '可能需要簽證',
    info: '取決於你的行程',
  };

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;
  const tripEl = document.getElementById('trip') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const v = evaluate(countryEl.value, tripEl.value as TripKey);
    card.className = `card border ${toneStyles[v.tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[v.tone]}">${toneLabel[v.tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${v.heading}</h2>
      <p class="mt-2 text-gray-700">${v.body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${v.points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>

