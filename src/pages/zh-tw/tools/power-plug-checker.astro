---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'China Power Plug & Voltage Checker';
const description =
  'Find out if you need a plug adapter or voltage converter for China based on your home country. China uses 220V and plug types A, C, and I.';

const countries = [
  'United States', 'United Kingdom', 'Canada', 'Australia', 'Germany',
  'France', 'Italy', 'Spain', 'Netherlands', 'Japan', 'South Korea',
  'Singapore', 'India', 'Brazil', 'New Zealand', 'Switzerland',
  'South Africa', 'United Arab Emirates', 'Other',
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="zh-TW">
  <Header locale="zh-TW" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Tool</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Power Plug & Voltage Checker</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-6">
      <label class="flex flex-col text-sm sm:max-w-sm">
        <span class="mb-1 font-medium text-gray-700">Traveling from</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <button id="check-btn" class="btn-primary mt-4 w-full sm:w-auto">Check What I Need</button>
    </div>

    <!-- Reference: China's own standard -->
    <div class="mt-6 grid gap-4 sm:grid-cols-3">
      <div class="card"><dt class="text-sm text-gray-500">Voltage</dt><dd class="text-2xl font-bold text-gray-900">220 V</dd></div>
      <div class="card"><dt class="text-sm text-gray-500">Frequency</dt><dd class="text-2xl font-bold text-gray-900">50 Hz</dd></div>
      <div class="card"><dt class="text-sm text-gray-500">Plug types</dt><dd class="text-2xl font-bold text-gray-900">A · C · I</dd></div>
    </div>

    <!-- Result -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>

      <AffiliateCta
        title="Get a Universal China Adapter"
        description="A compact all-in-one travel adapter that fits China's sockets and charges multiple devices at once."
        buttonText="View Recommended Adapter"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  // Each country's domestic voltage and the plug types it uses.
  const data: Record<string, { volts: number; plugs: string[] }> = {
    'United States': { volts: 120, plugs: ['A', 'B'] },
    'Canada': { volts: 120, plugs: ['A', 'B'] },
    'Japan': { volts: 100, plugs: ['A', 'B'] },
    'Brazil': { volts: 127, plugs: ['C', 'N'] },
    'United Kingdom': { volts: 230, plugs: ['G'] },
    'Australia': { volts: 230, plugs: ['I'] },
    'New Zealand': { volts: 230, plugs: ['I'] },
    'Germany': { volts: 230, plugs: ['C', 'F'] },
    'France': { volts: 230, plugs: ['C', 'E'] },
    'Italy': { volts: 230, plugs: ['C', 'F', 'L'] },
    'Spain': { volts: 230, plugs: ['C', 'F'] },
    'Netherlands': { volts: 230, plugs: ['C', 'F'] },
    'Switzerland': { volts: 230, plugs: ['C', 'J'] },
    'South Korea': { volts: 220, plugs: ['C', 'F'] },
    'Singapore': { volts: 230, plugs: ['G'] },
    'India': { volts: 230, plugs: ['C', 'D', 'M'] },
    'South Africa': { volts: 230, plugs: ['C', 'D', 'M', 'N'] },
    'United Arab Emirates': { volts: 230, plugs: ['C', 'D', 'G'] },
    'Other': { volts: 0, plugs: [] },
  };

  // China accepts plug types A, C, and I.
  const CHINA_PLUGS = ['A', 'C', 'I'];
  const CHINA_VOLTS = 220;

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const country = countryEl.value;
    const info = data[country];

    let heading: string, body: string, tone: 'good' | 'warn' | 'info';
    const points: string[] = [];

    if (!info || info.volts === 0) {
      tone = 'info';
      heading = 'Check your specific plug and voltage';
      body = 'We don\'t have data for your selection. Look at the label on your charger — if it reads "100–240V", you only need a plug adapter for China\'s type A, C, or I sockets.';
      points.push('China uses 220V, 50Hz with plug types A, C, and I.');
      points.push('Most phone and laptop chargers are dual-voltage (100–240V) and just need a plug adapter.');
    } else {
      const plugMatch = info.plugs.some((p) => CHINA_PLUGS.includes(p));
      const voltMatch = Math.abs(info.volts - CHINA_VOLTS) <= 20;

      if (plugMatch && voltMatch) {
        tone = 'good';
        heading = 'You probably don\'t need an adapter';
        body = `${country} uses compatible plug types (${info.plugs.join(', ')}) and a similar voltage (${info.volts}V). Your plugs should fit China's sockets directly.`;
        points.push('Double-check each plug — bring one adapter just in case a socket is a tight fit.');
      } else if (!plugMatch && voltMatch) {
        tone = 'warn';
        heading = 'You need a plug adapter (but not a voltage converter)';
        body = `${country} runs on a similar voltage (${info.volts}V), so your devices are safe. But your plug type (${info.plugs.join(', ')}) doesn't fit China's sockets — pack a plug adapter.`;
        points.push('A simple, cheap plug adapter for type A/C/I is all you need.');
        points.push('No bulky voltage converter required.');
      } else if (plugMatch && !voltMatch) {
        tone = 'warn';
        heading = 'Watch your voltage on single-voltage devices';
        body = `Your plugs (${info.plugs.join(', ')}) may fit, but ${country}'s voltage (${info.volts}V) differs from China's 220V.`;
        points.push('Phones, laptops, and cameras labeled 100–240V are fine anywhere.');
        points.push('Single-voltage items (some hair dryers, straighteners) need a voltage converter or should be left at home.');
      } else {
        tone = 'warn';
        heading = 'You need a plug adapter — and check voltage';
        body = `${country} uses different plugs (${info.plugs.join(', ')}) and a different voltage (${info.volts}V) than China's 220V. Bring a plug adapter for type A/C/I.`;
        points.push('Dual-voltage chargers (100–240V) only need the plug adapter.');
        points.push('Single-voltage high-wattage devices also need a voltage converter — or buy a local equivalent instead.');
      }
    }

    const toneStyles = {
      good: 'border-green-200 bg-green-50',
      warn: 'border-amber-200 bg-amber-50',
      info: 'border-blue-200 bg-blue-50',
    } as const;
    const toneBadge = {
      good: 'bg-green-600 text-white',
      warn: 'bg-amber-500 text-white',
      info: 'bg-blue-600 text-white',
    } as const;
    const toneLabel = { good: 'No adapter needed', warn: 'Adapter needed', info: 'Check your charger' } as const;

    card.className = `card border ${toneStyles[tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[tone]}">${toneLabel[tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${heading}</h2>
      <p class="mt-2 text-gray-700">${body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
