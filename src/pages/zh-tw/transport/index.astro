---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const CATEGORY = 'transport';
const posts = (await getCollection('posts-zh-tw'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'China 交通指南：高鐵、叫車與城市移動';
const description =
  '了解外國旅客如何預訂 China 高鐵票、使用 DiDi 叫車，以及搭乘城市公共交通。';

const transportPaths = [
  { href: '/zh-tw/posts/china-high-speed-rail-guide-foreigners/', title: '長途列車', desc: '用於城市之間的行程規劃、座位等級、護照進站與車站時間安排。' },
  { href: '/zh-tw/posts/airport-to-city-transport-beijing-shanghai-guangzhou/', title: '機場抵達', desc: '比較地鐵、計程車、叫車與機場鐵路，完成進城第一趟交通。' },
  { href: '/zh-tw/posts/didi-china-foreign-tourists-guide/', title: '叫車服務', desc: '設定 DiDi、使用翻譯後的上車點定位，並減少司機來電溝通阻力。' },
  { href: '/zh-tw/posts/shanghai-metro-for-foreigners-tickets-qr-codes-transfers/', title: '地鐵系統', desc: '以上海為例，了解 QR 車票、轉乘與尖峰時段搭乘習慣。' },
];
import { getCategoryLabel } from '../../../i18n/categories';
const locale = 'zh-tw';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="zh-TW">
  <Header locale="zh-TW" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">交通</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">China 交通指南</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="hub-transport" alt="China 的現代高鐵與鐵路系統" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-transport">
      <h2 id="featured-transport" class="sr-only">精選交通指南</h2>
      <a href="/zh-tw/posts/china-high-speed-rail-guide-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">高鐵指南</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">訂票、選擇座位等級、熟悉車站動線</p>
      </a>
      <a href="/zh-tw/posts/book-china-train-tickets-12306-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">12306 火車訂票</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">使用外國護照的逐步指南</p>
      </a>
      <a href="/zh-tw/posts/didi-china-foreign-tourists-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">DiDi 叫車</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">如何使用 China 的叫車應用程式</p>
      </a>
      <a href="/zh-tw/posts/airport-to-city-transport-beijing-shanghai-guangzhou/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">機場交通</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">北京、上海、廣州指南</p>
      </a>
    </section>

    <section class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4" aria-labelledby="transport-paths">
      <h2 id="transport-paths" class="sr-only">交通規劃路線</h2>
      {transportPaths.map((path) => (
        <a href={path.href} class="card block hover:no-underline">
          <h3 class="text-lg font-bold text-gray-950">{path.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{path.desc}</p>
        </a>
      ))}
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/zh-tw/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{getCategoryLabel(post.data.category, locale)}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">指南即將上線。</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>
