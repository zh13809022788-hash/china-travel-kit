---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'China 旅行幫助';
const description =
  '透過AI輔助分診和可選人工幫助，一對一地詢問China有關付款、eSIM、交通、App和第一天設定的旅行問題。';

const quickPrompts = [
  '我的 Alipay 或 WeChat Pay 無法綁卡。',
  '我需要這趟旅行的 eSIM 和 App 存取方案。',
  '我需要從機場到飯店的交通協助。',
  '我不確定該帶多少現金。',
];

const supportAreas = [
  '付款設定：Alipay、WeChat Pay、卡片、費用與現金備用',
  '連線方式：eSIM、漫遊、受 VPN 影響的 App，以及抵達機場後的行動數據',
  '交通：機場路線、地鐵、DiDi、計程車與高鐵基礎',
  'App 使用：翻譯、外送、地圖、叫車與截圖判讀',
  '行程準備：第一天清單、城市別準備與實際下一步',
  '人工升級：需要來回補充情境的複雜案例',
];

const safetyRules = [
  '請勿傳送護照照片、完整卡號、密碼、PIN 或一次性驗證碼。',
  '請勿要求任何人替你登入帳戶或完成身分驗證。',
  '請勿將此功能用於法律、移民、醫療、銀行或緊急建議。',
  '重要規則請向官方來源、航空公司、銀行、電信商或 App 營運方確認。',
];
---

<BaseLayout locale="zh-TW" title={`${title} | ChinaTripBox`} description={description}>
  <Header locale="zh-TW" />
  <main>
    <section class="border-b border-gray-200 bg-white">
      <div class="container-page grid gap-8 py-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <div>
          <p class="section-kicker">一對一旅行支援</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            在 China 放慢你的腳步之前，先問一個旅行問題
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            從免費的 AI 獲取實用的 China 旅行問題幫助。如果您的問題需要人工判斷、截圖或多次交流的上下文，請將其轉化為評論請求。
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#travel-help-chat" class="btn-primary">發起請求</a>
            <a href="/zh-tw/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-outline">使用出行前檢查表</a>
            <a href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Travel%20Help%20Request" class="btn-outline">
              直接傳送電子郵件
            </a>
          </div>
        </div>

        <aside class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">試行狀態</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">先由 AI 回覆，必要時再人工審閱</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            免費的答案由 AI 生成。在我們測試工作流程時，經過人工稽核的旅行幫助仍透過電子郵件傳送。
          </p>
          <dl class="mt-5 grid gap-3 text-sm">
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">最適合</dt>
              <dd class="font-semibold text-gray-900">實用行程安排</dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">響應路徑</dt>
              <dd class="font-semibold text-gray-900">AI + 電子郵件跟進</dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">付款</dt>
              <dd class="font-semibold text-gray-900">未啟用</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <section id="travel-help-chat" class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
          <div class="border-b border-gray-200 bg-gray-50 px-5 py-4">
          <p class="section-kicker">免費AI旅遊幫助</p>
            <h2 class="mt-1 text-2xl font-bold text-gray-950">旅遊服務檯</h2>
          </div>

          <div class="grid gap-0 md:grid-cols-[minmax(0,1fr)_280px]">
            <div class="flex min-h-[560px] flex-col">
              <div id="chat-log" class="flex-1 space-y-4 overflow-y-auto p-5" aria-live="polite">
                <div class="max-w-[88%] rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-700">
                  <strong class="block text-gray-950">ChinaTripBox 幫助</strong>
                  告訴我們你正在嘗試做什麼，你在旅行中的位置，以及已經發生了什麼。AI 助手將建議下一步操作，並在需要人工審查時提示。
                </div>
              </div>

              <div class="border-t border-gray-200 p-4">
                <div class="mb-3 flex flex-wrap gap-2">
                  {quickPrompts.map((prompt) => (
                    <button
                      type="button"
                      class="quick-prompt rounded-full border border-gray-200 bg-white px-3 py-1.5 text-left text-xs font-medium text-gray-700 hover:border-brand-300 hover:bg-brand-50"
                      data-prompt={prompt}
                    >
                      {prompt}
                    </button>
                  ))}
                </div>
                <form id="travel-help-form" class="grid gap-3">
                  <label class="sr-only" for="help-message">你的旅行問題</label>
                  <textarea
                    id="help-message"
                    name="message"
                    rows="5"
                    class="w-full resize-y rounded-lg border border-gray-300 px-4 py-3 text-sm leading-6 text-gray-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
                    placeholder="範例：我明天抵達上海。我的 Mastercard 無法綁定 WeChat Pay，但 Alipay 可以用。我還能搭地鐵、叫 DiDi 和點外送嗎？"
                    required
                  ></textarea>
                  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <p id="form-status" class="text-sm text-gray-500">避免敏感的個人資料。</p>
                    <button id="help-submit" type="submit" class="btn-primary">問 AI</button>
                  </div>
                </form>
              </div>
            </div>

            <aside class="border-t border-gray-200 bg-gray-50 p-5 md:border-l md:border-t-0">
              <h3 class="text-lg font-bold text-gray-950">請求詳情</h3>
              <div class="mt-4 grid gap-4">
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  旅程階段
                  <select id="trip-stage" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                    <option>出發前</option>
                    <option>在機場</option>
                    <option>已在 China</option>
                    <option>長期停留規劃</option>
                  </select>
                </label>
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  主要主題
                  <select id="help-topic" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                    <option>付款 App</option>
                    <option>網路與 eSIM</option>
                    <option>交通路線</option>
                    <option>美食、外送或本地 App</option>
                    <option>一般行程準備</option>
                  </select>
                </label>
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  城市或路線
                  <input
                    id="help-location"
                    class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700"
                    placeholder="Shanghai, Beijing, airport to hotel..."
                  />
                </label>
              </div>

              <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-4">
                <p class="text-sm font-bold text-gray-950">人工升級</p>
                <p class="mt-2 text-sm leading-6 text-gray-700">
                  當簡單指南不足時使用此工具。所準備的電子郵件包括您的主題、階段、地點和問題，以便他人能夠在有上下文的情況下回復。
                </p>
              </div>

              <a
                id="email-request-link"
                href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Travel%20Help%20Request"
                class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:border-brand-600 hover:text-brand-600 hover:no-underline"
              >
                準備電子郵件請求
              </a>
            </aside>
          </div>
        </div>

        <aside class="space-y-6">
          <section class="rounded-lg border border-gray-200 bg-white p-5">
            <p class="section-kicker">範圍</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">這可以幫助什麼</h2>
            <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
              {supportAreas.map((area) => (
                <li class="border-b border-gray-100 pb-3 last:border-b-0 last:pb-0">{area}</li>
              ))}
            </ul>
          </section>

          <section class="rounded-lg border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">安全規則</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">不要提供敏感資料</h2>
            <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
              {safetyRules.map((rule) => (
                <li>{rule}</li>
              ))}
            </ul>
          </section>
        </aside>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <div class="card">
          <p class="section-kicker">步驟 1</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">描述問題</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            分享城市、App、路線、截止日期，以及你已經嘗試過的內容。
          </p>
        </div>
        <div class="card">
          <p class="section-kicker">步驟2</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">取得下一步建議</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            該頁面提供了實用的第一響應，並指向相關指南。
          </p>
        </div>
        <div class="card">
          <p class="section-kicker">步驟 3</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">透過電子郵件升級</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            如需一對一幫助，請傳送已準備好的電子郵件並私下繼續交流。
          </p>
        </div>
      </section>

      <section class="mt-10 rounded-lg border border-gray-200 bg-white p-5 md:p-6">
        <p class="section-kicker">自助優先</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950">回答常見首次旅行問題的指南</h2>
        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <a href="/zh-tw/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">首次 China 旅行計劃者</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">在你仍在安排付款、資料、交通和你的第一到達日時使用此項。</p>
          </a>
          <a href="/zh-tw/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">出發前設定清單</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">在你飛行前，檢查Alipay、WeChat Pay、eSIM、DiDi、火車票、翻譯、地址和現金備用。</p>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('travel-help-form') as HTMLFormElement | null;
  const message = document.getElementById('help-message') as HTMLTextAreaElement | null;
  const chatLog = document.getElementById('chat-log');
  const status = document.getElementById('form-status');
  const stage = document.getElementById('trip-stage') as HTMLSelectElement | null;
  const topic = document.getElementById('help-topic') as HTMLSelectElement | null;
  const locationInput = document.getElementById('help-location') as HTMLInputElement | null;
  const emailLink = document.getElementById('email-request-link') as HTMLAnchorElement | null;
  const submitButton = document.getElementById('help-submit') as HTMLButtonElement | null;

  const guideLinks: Record<string, { label: string; href: string }> = {
    '付款 App': { label: '付款設定指南', href: '/zh-tw/payment/' },
    '網路與 eSIM': { label: 'eSIM 指南', href: '/zh-tw/esim/' },
    '交通路線': { label: '交通指南', href: '/zh-tw/transport/' },
    '美食、外送或本地 App': {
      label: '外送指南',
      href: '/zh-tw/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    },
    '一般行程準備': { label: '工具頁', href: '/zh-tw/tools/' },
  };

  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char] ?? char);

  const updateEmailLink = () => {
    if (!emailLink) return;
    const selectedStage = stage?.value ?? '出發前';
    const selectedTopic = topic?.value ?? '一般行程準備';
    const place = locationInput?.value.trim() || '未指定';
    const question = message?.value.trim() || '';
    const body = [
      'ChinaTripBox 旅行協助請求',
      '',
      `行程階段：${selectedStage}`,
      `主要主題：${selectedTopic}`,
      `城市或路線：${place}`,
      '',
      '問題：',
      question,
      '',
      '我了解不應包含護照照片、完整銀行卡號、密碼、PIN 或一次性驗證碼。',
    ].join('\n');

    emailLink.href = `mailto:zh13809022788@gmail.com?subject=${encodeURIComponent(
      `旅行協助：${selectedTopic}`,
    )}&body=${encodeURIComponent(body)}`;
  };

  const addBubble = (content: string, fromUser = false) => {
    if (!chatLog) return null;
    const wrapper = document.createElement('div');
    wrapper.className = fromUser
      ? 'ml-auto max-w-[88%] rounded-lg bg-brand-600 p-4 text-sm leading-6 text-white'
      : 'max-w-[88%] rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-700';
    wrapper.innerHTML = content;
    chatLog.appendChild(wrapper);
    chatLog.scrollTop = chatLog.scrollHeight;
    return wrapper;
  };

  const formatAiAnswer = (value: string) =>
    escapeHtml(value)
      .replace(/\n{3,}/g, '\n\n')
      .replace(/\n/g, '<br>');

  const buildReply = (question: string) => {
    const selectedTopic = topic?.value ?? '一般行程準備';
    const selectedStage = stage?.value ?? '出發前';
    const place = locationInput?.value.trim();
    const guide = guideLinks[selectedTopic] ?? guideLinks['一般行程準備'];
    const needsHuman =
      /screenshot|photo|declin|failed|stuck|urgent|tomorrow|today|passport|verification|identity|hotel|route/i.test(
        question,
      );

    const placeLine = place
      ? `因為這涉及 <strong>${escapeHtml(place)}</strong>，寄信時請附上準確的機場、車站、飯店區域、App 名稱與日期。`
      : '在送出一對一協助前，請補上城市、機場、車站、飯店區域或 App 名稱。';

    const escalation = needsHuman
      ? '這個問題可能需要更多情境或來回確認，適合升級為人工跟進。'
      : '這個問題可先從指南中確認；如果指南不符合你的具體情況，再使用人工跟進。';

    return `
      <strong class="block text-gray-950">建議下一步</strong>
      <span class="block mt-1">主題：${escapeHtml(selectedTopic)}。階段：${escapeHtml(selectedStage)}。</span>
      <span class="block mt-2">${placeLine}</span>
      <span class="block mt-2">先查看 <a href="${guide.href}" class="font-semibold text-brand-700">${guide.label}</a>；如果仍需要一對一協助，再使用準備好的電子郵件按鈕。</span>
      <span class="block mt-2">${escalation}</span>
    `;
  };

  document.querySelectorAll<HTMLButtonElement>('.quick-prompt').forEach((button) => {
    button.addEventListener('click', () => {
      if (!message) return;
      message.value = button.dataset.prompt ?? '';
      message.focus();
      updateEmailLink();
    });
  });

  [message, stage, topic, locationInput].forEach((element) => {
    element?.addEventListener('input', updateEmailLink);
    element?.addEventListener('change', updateEmailLink);
  });

  const requestAiAnswer = async (question: string) => {
    const response = await fetch('/api/travel-help', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({
        message: question,
        stage: stage?.value ?? '出發前',
        topic: topic?.value ?? '一般行程準備',
        location: locationInput?.value.trim() ?? '',
      }),
    });

    const data = await response.json() as { answer?: string; error?: string };
    if (!response.ok || !data.answer) {
      throw new Error(data.error || 'AI 助手暫時無法使用。');
    }
    return data.answer;
  };

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const question = message?.value.trim() ?? '';
    if (!question) {
      if (status) status.textContent = '請先輸入你的問題。';
      return;
    }
    addBubble(escapeHtml(question), true);
    const thinking = addBubble('AI 正在檢查你的旅行問題...');
    if (status) status.textContent = '正在詢問 AI 旅行協助...';
    if (submitButton) submitButton.disabled = true;

    try {
      const answer = await requestAiAnswer(question);
      if (thinking) {
        thinking.innerHTML = `
          <strong class="block text-gray-950">AI 旅行協助</strong>
          <span class="mt-2 block">${formatAiAnswer(answer)}</span>
          <span class="mt-3 block text-xs text-gray-500">複雜的帳戶、付款、簽證、法律、醫療或緊急問題，請向官方服務方確認或要求人工審閱。</span>
        `;
      }
      if (status) status.textContent = 'AI 回答已完成。如需人工審閱，請使用電子郵件。';
    } catch {
      if (thinking) thinking.innerHTML = buildReply(question);
      if (status) status.textContent = 'AI 暫時無法使用，已準備本機備用回覆。';
    } finally {
      if (submitButton) submitButton.disabled = false;
    }
    updateEmailLink();
  });

  updateEmailLink();
</script>
