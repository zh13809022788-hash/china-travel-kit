---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import Header from "../../../../components/Header.astro";
import Footer from "../../../../components/Footer.astro";
import AdSlot from "../../../../components/AdSlot.astro";
import AffiliateCta from "../../../../components/AffiliateCta.astro";
import { AFFILIATE_LINKS } from "../../../../config";

const title = '中國電源插頭與電壓檢查器';
const description =
  '根據你的居住國家，查看前往中國是否需要插頭轉接器或電壓轉換器。中國使用 220V，以及 A、C、I 型插頭。';

const countries = [
  'United States', 'United Kingdom', 'Canada', 'Australia', 'Germany',
  'France', 'Italy', 'Spain', 'Netherlands', 'Japan', 'South Korea',
  'Singapore', 'India', 'Brazil', 'New Zealand', 'Switzerland',
  'South Africa', 'United Arab Emirates', 'Other',
];
---
<!-- AI輔助生成內容，經母語者審校 -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="zh-TW">
  <Header locale="zh-TW" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">工具</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">電源插頭與電壓檢查器</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-6">
      <label class="flex flex-col text-sm sm:max-w-sm">
        <span class="mb-1 font-medium text-gray-700">出發地</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <button id="check-btn" class="btn-primary mt-4 w-full sm:w-auto">檢查我需要準備什麼</button>
    </div>

    <!-- Reference: China's own standard -->
    <div class="mt-6 grid gap-4 sm:grid-cols-3">
      <div class="card"><dt class="text-sm text-gray-500">電壓</dt><dd class="text-2xl font-bold text-gray-900">220 V</dd></div>
      <div class="card"><dt class="text-sm text-gray-500">頻率</dt><dd class="text-2xl font-bold text-gray-900">50 Hz</dd></div>
      <div class="card"><dt class="text-sm text-gray-500">插頭類型</dt><dd class="text-2xl font-bold text-gray-900">A · C · I</dd></div>
    </div>

    <!-- Result -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>

      <AffiliateCta
        title="選購中國通用轉接器"
        description="輕巧的一體式旅行轉接器，適用於中國插座，還能同時為多台裝置充電。"
        buttonText="查看推薦轉接器"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  // Each country's domestic voltage and the plug types it uses.
  const data: Record<string, { volts: number; plugs: string[] }> = {
    'United States': { volts: 120, plugs: ['A', 'B'] },
    'Canada': { volts: 120, plugs: ['A', 'B'] },
    'Japan': { volts: 100, plugs: ['A', 'B'] },
    'Brazil': { volts: 127, plugs: ['C', 'N'] },
    'United Kingdom': { volts: 230, plugs: ['G'] },
    'Australia': { volts: 230, plugs: ['I'] },
    'New Zealand': { volts: 230, plugs: ['I'] },
    'Germany': { volts: 230, plugs: ['C', 'F'] },
    'France': { volts: 230, plugs: ['C', 'E'] },
    'Italy': { volts: 230, plugs: ['C', 'F', 'L'] },
    'Spain': { volts: 230, plugs: ['C', 'F'] },
    'Netherlands': { volts: 230, plugs: ['C', 'F'] },
    'Switzerland': { volts: 230, plugs: ['C', 'J'] },
    'South Korea': { volts: 220, plugs: ['C', 'F'] },
    'Singapore': { volts: 230, plugs: ['G'] },
    'India': { volts: 230, plugs: ['C', 'D', 'M'] },
    'South Africa': { volts: 230, plugs: ['C', 'D', 'M', 'N'] },
    'United Arab Emirates': { volts: 230, plugs: ['C', 'D', 'G'] },
    'Other': { volts: 0, plugs: [] },
  };

  // China accepts plug types A, C, and I.
  const CHINA_PLUGS = ['A', 'C', 'I'];
  const CHINA_VOLTS = 220;

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const country = countryEl.value;
    const info = data[country];

    let heading: string, body: string, tone: 'good' | 'warn' | 'info';
    const points: string[] = [];

    if (!info || info.volts === 0) {
      tone = 'info';
      heading = '請確認你的插頭與電壓規格';
      body = '我們目前沒有你所選項目的資料。請查看你的充電器標籤，若標示為 "100–240V"，你只需要適用於中國 A、C 或 I 型插座的插頭轉接器。';
      points.push('中國使用 220V、50Hz，以及 A、C、I 型插頭。');
      points.push('大多數手機與筆電充電器都是雙電壓（100–240V），只需要插頭轉接器。');
    } else {
      const plugMatch = info.plugs.some((p) => CHINA_PLUGS.includes(p));
      const voltMatch = Math.abs(info.volts - CHINA_VOLTS) <= 20;

      if (plugMatch && voltMatch) {
        tone = 'good';
        heading = '你可能不需要轉接器';
        body = `${country} 使用相容的插頭類型（${info.plugs.join(', ')}），且電壓也相近（${info.volts}V）。你的插頭應該可以直接插入中國的插座。`;
        points.push('仍建議逐一確認每個插頭，並備一個轉接器，以防插座較緊不好插。');
      } else if (!plugMatch && voltMatch) {
        tone = 'warn';
        heading = '你需要插頭轉接器（但不需要電壓轉換器）';
        body = `${country} 使用相近的電壓（${info.volts}V），因此你的裝置可以安全使用。不過你的插頭類型（${info.plugs.join(', ')}）不適用於中國插座，記得攜帶插頭轉接器。`;
        points.push('你只需要一個簡單、便宜且支援 A/C/I 型的插頭轉接器。');
        points.push('不需要笨重的電壓轉換器。');
      } else if (plugMatch && !voltMatch) {
        tone = 'warn';
        heading = '單一電壓裝置請特別留意電壓';
        body = `你的插頭（${info.plugs.join(', ')}）可能可以使用，但 ${country} 的電壓（${info.volts}V）與中國的 220V 不同。`;
        points.push('標示 100–240V 的手機、筆電與相機，通常在任何地方都能使用。');
        points.push('單一電壓裝置（例如某些吹風機、離子夾）需要電壓轉換器，或建議直接不要攜帶。');
      } else {
        tone = 'warn';
        heading = '你需要插頭轉接器，並請確認電壓';
        body = `${country} 使用的插頭（${info.plugs.join(', ')}）與電壓（${info.volts}V）都不同於中國的 220V。請攜帶適用於 A/C/I 型的插頭轉接器。`;
        points.push('雙電壓充電器（100–240V）只需要插頭轉接器。');
        points.push('單一電壓的高功率裝置還需要電壓轉換器，或者改在當地購買對應產品。');
      }
    }

    const toneStyles = {
      good: 'border-green-200 bg-green-50',
      warn: 'border-amber-200 bg-amber-50',
      info: 'border-blue-200 bg-blue-50',
    } as const;
    const toneBadge = {
      good: 'bg-green-600 text-white',
      warn: 'bg-amber-500 text-white',
      info: 'bg-blue-600 text-white',
    } as const;
    const toneLabel = { good: '不需要轉接器', warn: '需要轉接器', info: '請檢查充電器' } as const;

    card.className = `card border ${toneStyles[tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[tone]}">${toneLabel[tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${heading}</h2>
      <p class="mt-2 text-gray-700">${body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>