---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = '中國旅行資源中心';
const description =
  '為外國旅客整理的中國旅行實用入口：付款、eSIM、火車、簽證、城市指南、工具，以及第一次前往中國的行前規劃。';

const resourceGroups = [
  {
    title: '如果你只有 30 分鐘',
    description: '提供給需要快速完成基本準備的旅客，一條最精簡的閱讀路線。',
    links: [
      { href: '/zh-tw/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: '出發前設定清單' },
      { href: '/zh-tw/tools/survival-kit/', title: '中國旅行生存卡與清單' },
      { href: '/zh-tw/tools/payment-checker/', title: '檢查你的付款備援方案' },
      { href: '/zh-tw/tools/visa-free-checker/', title: '查詢免簽入境或過境資格' },
      { href: '/zh-tw/posts/china-high-speed-rail-guide-foreigners/', title: '了解火車訂票與進站流程' },
    ],
  },
  {
    title: '第一次去中國：從這裡開始',
    description: '從「我要去中國」到可以實際執行的抵達方案，先處理最關鍵的事情。',
    links: [
      { href: '/zh-tw/trip-planner/', title: '免費中國行程規劃工具' },
      { href: '/zh-tw/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/', title: '第一次到中國的行程規劃指南' },
      { href: '/zh-tw/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: '去中國前要先設定什麼' },
      { href: '/zh-tw/posts/china-visa-free-entry-transit-guide-2026/', title: '中國免簽入境與過境指南' },
      { href: '/zh-tw/tools/best-time-to-visit/', title: '什麼時候最適合去中國' },
      { href: '/zh-tw/posts/what-to-pack-for-china-a-season-by-season-checklist/', title: '中國旅行打包清單' },
    ],
  },
  {
    title: '付款與現金',
    description: '行動支付、現金備援、外卡綁定，以及日常結帳時可能遇到的問題。',
    links: [
      { href: '/zh-tw/posts/how-to-pay-in-china-tourist-guide/', title: '外國旅客在中國怎麼付款' },
      { href: '/zh-tw/posts/alipay-foreign-credit-card-step-by-step/', title: '用外國信用卡設定 Alipay' },
      { href: '/zh-tw/posts/wechat-pay-foreign-visitors-guide/', title: '外國旅客 WeChat Pay 指南' },
      { href: '/zh-tw/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: '出發前付款與應用程式設定清單' },
      { href: '/zh-tw/tools/payment-checker/', title: '付款相容性檢查工具' },
    ],
  },
  {
    title: '網路與應用程式',
    description: '保持連線、選擇 eSIM，並在抵達前確認哪些應用程式可以使用。',
    links: [
      { href: '/zh-tw/posts/best-esim-for-china-travel-2026/', title: '中國旅行 eSIM 選擇' },
      { href: '/zh-tw/posts/china-esim-vs-roaming-2026-the-real-10-day-cost/', title: '中國 eSIM 與漫遊費用比較' },
      { href: '/zh-tw/posts/internet-access-china-apps-that-work-2026/', title: '中國上網與可用應用程式指南' },
      { href: '/zh-tw/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/', title: '第一次旅行的 eSIM 與應用程式準備' },
      { href: '/zh-tw/tools/app-availability-checker/', title: '我的應用程式在中國可以用嗎？' },
    ],
  },
  {
    title: '交通與城市指南',
    description: '火車、地鐵、機場、市區叫車，以及實用的城市行程規劃。',
    links: [
      { href: '/zh-tw/cities/', title: '中國城市指南入口' },
      { href: '/zh-tw/posts/china-high-speed-rail-guide-foreigners/', title: '外國旅客中國高鐵指南' },
      { href: '/zh-tw/posts/book-china-train-tickets-12306-foreigners/', title: '外國人如何用 12306 訂火車票' },
      { href: '/zh-tw/posts/didi-china-foreign-tourists-guide/', title: '外國旅客如何使用 DiDi' },
      { href: '/zh-tw/posts/airport-to-city-transport-beijing-shanghai-guangzhou/', title: '機場到市區交通指南' },
    ],
  },
  {
    title: '美食、禮儀與日常生活',
    description: '餐廳點餐、小費、外送應用程式、街頭小吃，以及能降低現場摩擦的實用習慣。',
    links: [
      { href: '/zh-tw/food/', title: '中國美食與用餐入口' },
      { href: '/zh-tw/posts/ordering-food-in-china-without-chinese-meituan-ele-me/', title: '不會中文怎麼在中國點餐叫外送' },
      { href: '/zh-tw/posts/chengdu-street-food-safety-spice-levels-what-to-order/', title: '成都街頭小吃安全與辣度指南' },
      { href: '/zh-tw/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/', title: '中國小費：什麼時候需要給' },
    ],
  },
  {
    title: '長住與遠端工作',
    description: '如果行程是以週或月來計算，先確認簽證、住宿、付款和工作工具是否可靠。',
    links: [
      { href: '/zh-tw/long-stay/', title: '中國長住指南' },
      { href: '/zh-tw/digital-nomads/', title: '中國數位遊民指南' },
      { href: '/zh-tw/digital-nomads/visa/', title: '數位遊民中國簽證指南' },
      { href: '/zh-tw/digital-nomads/payment/', title: '長住付款設定' },
    ],
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="zh-TW">
  <Header locale="zh-TW" />
  <main class="container-page py-10">
    <section class="max-w-3xl">
      <p class="section-kicker">資源中心</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </section>

    <section class="mt-10 grid gap-5 md:grid-cols-2">
      {resourceGroups.map((group) => (
        <article class="card">
          <h2 class="text-xl font-bold text-gray-950">{group.title}</h2>
          <p class="mt-2 text-sm leading-6 text-gray-600">{group.description}</p>
          <ul class="mt-5 grid gap-3">
            {group.links.map((link) => (
              <li>
                <a href={link.href} class="font-semibold text-brand-700 hover:text-brand-800">
                  {link.title}
                </a>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>