---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';

const seriesSlug = 'history-of-china';
const posts = (await getCollection('posts-zh-tw'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'History of China — Ancient Sites & Stories for Travelers';
const description = 'Explore China\'s historical sites as a foreign traveler: the Great Wall, Terracotta Army, Forbidden City, Silk Road, ancient capitals, and water towns — decoded with the stories behind what you see.';

const relatedTools = [
  { href: '/zh-tw/posts/china-visa-free-entry-transit-guide-2026/', title: 'Visa & entry guide', desc: 'Visa-free transit and entry requirements' },
  { href: '/zh-tw/posts/china-high-speed-rail-guide-foreigners/', title: 'High-speed rail guide', desc: 'Trains to historical sites across China' },
  { href: '/zh-tw/posts/book-china-train-tickets-12306-foreigners/', title: 'Book train tickets', desc: '12306 guide for foreign passport holders' },
];

const relatedCities = [
  { href: '/zh-tw/posts/beijing-city-guide-for-foreigners/', title: 'Beijing', desc: 'Forbidden City, Great Wall, Temple of Heaven' },
  { href: '/zh-tw/posts/hangzhou-city-guide-for-foreigners/', title: 'Hangzhou', desc: 'Ancient capital of the Southern Song' },
  { href: '/zh-tw/posts/chengdu-city-guide-for-foreigners/', title: 'Chengdu', desc: 'Three Kingdoms heritage and ancient streets' },
];

const otherSeries = [
  { href: '/zh-tw/series/food-of-china/', title: 'Food of China' },
  { href: '/zh-tw/series/culture-of-china/', title: 'Culture of China' },
  { href: '/zh-tw/series/nature-of-china/', title: 'Nature of China' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="zh-TW">
  <Header locale="zh-TW" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Content Series</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Articles</p>
            <h2>History of China series</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/zh-tw/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{post.data.category}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">Articles in this series are being prepared. Check back soon.</p>
        )}
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Practical tools</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Plan your visit</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">City guides</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Historic cities</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">More series</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>
