---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = '找不到頁面';
const description = '您請求的 ChinaTripBox 頁面無法找到。';
---
<!-- AI輔助生成內容，經母語者審校 -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description} noindex>
  <Header />
  <main class="container-page py-16">
    <section class="mx-auto max-w-2xl">
      <p class="section-kicker">404</p>
      <h1 class="mt-2 text-4xl font-bold text-gray-950">找不到頁面</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">
        此頁面可能已移動，或網址可能不正確。請從指南總覽開始，或使用下方的規劃工具。
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/" class="btn-primary">回到首頁</a>
        <a href="/resources/" class="btn-outline">從這裡開始</a>
        <a href="/tools/" class="btn-outline">開啟工具</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>