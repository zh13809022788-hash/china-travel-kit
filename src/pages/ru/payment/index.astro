---
import { getCollection } from 'astro:content';
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import AdSlot from "../../../components/AdSlot.astro";
import CoverImage from "../../../components/CoverImage.astro";

const CATEGORY = 'payment';
const posts = (await getCollection('posts'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Путеводители по платежам в China — Alipay, WeChat Pay и иностранные карты';
const description =
  'Пошаговые руководства по оплате в China для иностранных путешественников: настройте Alipay и WeChat Pay, привяжите международные карты и избегайте распространенных ошибок.';

const prioritySteps = [
  'Установите Alipay и WeChat до отъезда, затем пройдите подтверждение личности, пока у вас еще есть доступ к вашему домашнему банку и номеру телефона.',
  'Привяжите как минимум одну карту Visa или Mastercard, а затем держите вторую карту другого эмитента в качестве запасной.',
  'Носите с собой небольшую сумму наличных в RMB для такси, маленьких магазинов и ситуаций, когда подтверждение кошелька или авторизация карты не срабатывает.',
];

const paymentTools = [
  { href: '/tools/payment-checker/', title: 'Проверка совместимости способов оплаты', desc: 'Проверьте поддержку карт, типичные лимиты и комиссии для Alipay и WeChat Pay.' },
  { href: '/tools/budget-cash-estimator/', title: 'Оценка бюджета и наличных', desc: 'Оцените расходы на поездку и сколько запасных наличных стоит взять с собой.' },
  { href: '/tools/currency-converter/', title: 'Конвертер валют RMB', desc: 'Переводите цены в юани и понимайте повседневные расходы.' },
];
import { getCategoryLabel } from "../../../i18n/categories";
const locale = 'en';
---
<!-- Контент создан с помощью ИИ, проверен носителем языка -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Платежи</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Путеводители по платежам</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-how-to-pay" alt="Настройка мобильных платежей со смартфоном, на котором показаны способы оплаты для поездки в China" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-payment">
      <h2 id="featured-payment" class="sr-only">Рекомендуемые путеводители по платежам</h2>
      <a href="/posts/alipay-foreign-credit-card-step-by-step/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Настройка Alipay</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Пошаговое руководство по установке Alipay и привязке иностранной кредитной карты</p>
      </a>
      <a href="/posts/wechat-pay-foreign-visitors-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">WeChat Pay</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Полное руководство по настройке и использованию для иностранных посетителей</p>
      </a>
      <a href="/posts/alipay-vs-wechat-pay-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Alipay или WeChat Pay</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Какое платежное приложение вам стоит использовать в 2026 году?</p>
      </a>
      <a href="/posts/how-to-pay-in-china-tourist-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Полный путеводитель по платежам</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Все, что вам нужно знать об оплате в China как туристу</p>
      </a>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[1fr_340px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">Начните с надежной настройки платежей</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          В China в первую очередь преобладают платежи по QR-коду. Удобная для туриста настройка обычно означает один основной кошелек, один резервный кошелек, два варианта карты и небольшую сумму наличных на случай исключений.
        </p>
        <ol class="mt-5 space-y-3 text-sm leading-6 text-gray-600">
          {prioritySteps.map((step, index) => (
            <li class="flex gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand-50 text-xs font-bold text-brand-700">{index + 1}</span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Инструменты для платежей</h2>
        <div class="mt-4 grid gap-3">
          {paymentTools.map((tool) => (
            <a href={tool.href} class="rounded-lg border border-brand-100 bg-white p-4 hover:border-brand-200 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-900 hover:text-brand-700">{tool.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{tool.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{getCategoryLabel(post.data.category, locale)}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">Путеводители скоро появятся.</p>}
    </section>
  
    <section class="mt-12 rounded-lg border border-gray-200 bg-gray-50 p-6">
      <h2 class="text-xl font-bold text-gray-950">Похожие путеводители по платежам</h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <a href="/posts/alipay-foreign-credit-card-step-by-step/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Руководство по настройке Alipay</p>
          <p class="mt-1 text-sm text-gray-600">Пошагово: привяжите иностранную Visa или Mastercard к Alipay</p>
        </a>
        <a href="/posts/link-a-foreign-visa-or-mastercard-to-wechat-pay-in-china/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Настройка WeChat Pay</p>
          <p class="mt-1 text-sm text-gray-600">Подключите свою иностранную карту к WeChat Pay за несколько минут</p>
        </a>
        <a href="/posts/how-to-pay-in-china-tourist-guide/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Обзор способов оплаты</p>
          <p class="mt-1 text-sm text-gray-600">QR-коды, наличные и карты: что и где работает</p>
        </a>
        <a href="/posts/can-you-still-use-cash-in-china-as-a-foreigner-in-2026/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Использование наличных в China</p>
          <p class="mt-1 text-sm text-gray-600">Когда и где наличные все еще принимают в 2026 году</p>
        </a>
      </div>
    </section>
</main>
  <Footer />
</BaseLayout>