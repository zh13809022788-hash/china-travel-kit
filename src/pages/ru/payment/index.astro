---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const CATEGORY = 'payment';
const posts = (await getCollection('posts-ru'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Оплата в Китае: Alipay, WeChat Pay и иностранные карты';
const description =
  'Пошаговые гиды по оплате в Китае для иностранных гостей: настройка Alipay и WeChat Pay, привязка карт и частые ошибки.';

const prioritySteps = [
  'Установите Alipay и WeChat ещё до вылета, а затем пройдите проверку личности, пока у вас есть доступ к вашему банку и номеру телефона в своей стране.',
  'Привяжите как минимум одну карту Visa или Mastercard, а вторую карту другого банка держите как запасной вариант.',
  'Носите с собой немного наличных в юанях для такси, маленьких магазинов и случаев, когда не проходит проверка кошелька или авторизация карты.',
];

const paymentTools = [
  { href: '/ru/tools/payment-checker/', title: 'Проверка совместимости способов оплаты', desc: 'Проверьте поддержку карт, типичные лимиты и комиссии для Alipay и WeChat Pay.' },
  { href: '/ru/tools/budget-cash-estimator/', title: 'Калькулятор бюджета и наличных', desc: 'Оцените расходы в поездке и сколько наличных стоит взять про запас.' },
  { href: '/ru/tools/currency-converter/', title: 'Конвертер валют в юани', desc: 'Переводите цены в юани и лучше понимайте повседневные расходы.' },
];
import { getCategoryLabel } from '../../../i18n/categories';
const locale = 'ru';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Оплата</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Гиды по оплате в Китае</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-how-to-pay" alt="Настройка мобильной оплаты: смартфон с платёжными способами для поездки в Китай" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-payment">
      <h2 id="featured-payment" class="sr-only">Рекомендуемые гиды по оплате</h2>
      <a href="/ru/posts/alipay-foreign-credit-card-step-by-step/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Настройка Alipay</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Пошаговое руководство по установке Alipay и привязке иностранной банковской карты</p>
      </a>
      <a href="/ru/posts/wechat-pay-foreign-visitors-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">WeChat Pay</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Полное руководство по настройке и использованию для иностранных гостей</p>
      </a>
      <a href="/ru/posts/alipay-vs-wechat-pay-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Alipay или WeChat Pay</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Какое платёжное приложение выбрать в 2026 году?</p>
      </a>
      <a href="/ru/posts/how-to-pay-in-china-tourist-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Полный гид по оплате</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Всё, что нужно знать туристу об оплате в Китае</p>
      </a>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[1fr_340px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">Начните с надёжной платёжной схемы</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          В Китае почти везде в приоритете оплата по QR-коду. Удобная схема для туриста обычно включает один основной кошелёк, один запасной кошелёк, две карты и немного наличных на исключительные случаи.
        </p>
        <ol class="mt-5 space-y-3 text-sm leading-6 text-gray-600">
          {prioritySteps.map((step, index) => (
            <li class="flex gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand-50 text-xs font-bold text-brand-700">{index + 1}</span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Инструменты по оплате</h2>
        <div class="mt-4 grid gap-3">
          {paymentTools.map((tool) => (
            <a href={tool.href} class="rounded-lg border border-brand-100 bg-white p-4 hover:border-brand-200 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-900 hover:text-brand-700">{tool.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{tool.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/ru/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{getCategoryLabel(post.data.category, locale)}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('ru-RU', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">Гиды скоро появятся.</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>