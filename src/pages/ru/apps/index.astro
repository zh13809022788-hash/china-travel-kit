---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CoverImage from '../../../components/CoverImage.astro';
import AdSlot from '../../../components/AdSlot.astro';

const title = 'Важные приложения для Китая: ссылки и веб-версии';
const description = 'Полный список приложений, которые нужны в Китае: WeChat, Alipay, DiDi, Baidu Maps, Meituan, 12306, VPN и другие. Для каждого приложения указаны ссылки на App Store, Google Play и H5-версию, которая работает без установки.';

const appGroups = [
  {
    category: 'Оплата и кошелек',
    apps: [
      {
        name: 'Alipay',
        desc: 'Главный мобильный кошелек в Китае. Привяжите зарубежную Visa или Mastercard, платите по QR-коду в магазинах, ресторанах, такси и у уличных продавцов.',
        android: 'https://play.google.com/store/apps/details?id=com.eg.android.AlipayGphone',
        ios: 'https://apps.apple.com/app/alipay/id333206289',
        h5: null,
        note: 'Настройка занимает 10-15 минут. Нужен паспорт для проверки.',
        guide: '/ru/posts/alipay-foreign-credit-card-step-by-step/',
      },
      {
        name: 'WeChat',
        desc: 'Суперприложение Китая. Используется для чатов, звонков, ленты Moments и WeChat Pay. Большинство китайцев пользуются им каждый день.',
        android: 'https://play.google.com/store/apps/details?id=com.tencent.mm',
        ios: 'https://apps.apple.com/app/wechat/id414478124',
        h5: 'https://web.wechat.com/',
        note: 'Для WeChat Pay нужна привязанная карта. Сам WeChat работает и без оплаты.',
        guide: '/ru/posts/link-a-foreign-visa-or-mastercard-to-wechat-pay-in-china/',
      },
    ],
  },
  {
    category: 'Транспорт и вызов такси',
    apps: [
      {
        name: 'DiDi',
        desc: 'Китайский аналог Uber. Заказ такси и частных машин. Поддерживает английский интерфейс. Оплата через Alipay или WeChat Pay.',
        android: 'https://play.google.com/store/apps/details?id=com.didi.sdk',
        ios: 'https://apps.apple.com/app/didi/id1164272094',
        h5: 'https://www.didiglobal.com/',
        note: 'H5-версия работает в браузере или в мини-программе WeChat. Для разовых поездок этого обычно достаточно.',
        guide: '/ru/posts/didi-china-foreign-tourists-guide/',
      },
      {
        name: 'Транспортная мини-программа в Alipay',
        desc: 'Внутри Alipay используйте транспортную мини-программу для сканирования QR-кодов в метро и автобусах в большинстве крупных городов.',
        android: null,
        ios: null,
        h5: null,
        note: 'Откройте Alipay -> значок «Транспорт». Отдельная установка не нужна.',
        guide: '/ru/transport/',
      },
      {
        name: '12306',
        desc: 'Официальное приложение китайских железных дорог для бронирования билетов на поезда. Интерфейс только на китайском, требуется верификация. Альтернатива: Trip.com.',
        android: 'https://play.google.com/store/apps/details?id=com.cars.blaili',
        ios: 'https://apps.apple.com/app/12306/id564757494',
        h5: 'https://www.12306.cn/',
        note: 'Сложно для иностранцев. Используйте Trip.com, если не хотите разбираться с верификацией.',
        guide: '/ru/posts/book-china-train-tickets-12306-foreigners/',
      },
      {
        name: 'Trip.com (Ctrip)',
        desc: 'Удобное приложение на английском для бронирования поездов, рейсов и отелей. Принимает иностранные карты напрямую.',
        android: 'https://play.google.com/store/apps/details?id=com.ctrip',
        ios: 'https://apps.apple.com/app/trip-com/id1612956441',
        h5: 'https://www.trip.com/',
        note: 'Лучшая альтернатива 12306 для билетов на поезд. Комиссия выше, но пользоваться проще.',
        guide: null,
      },
    ],
  },
  {
    category: 'Навигация и карты',
    apps: [
      {
        name: 'Baidu Maps',
        desc: 'Самая подробная карта Китая. Пошаговая навигация, общественный транспорт, поиск ресторанов. Только на китайском, но очень полезна для ориентации.',
        android: 'https://play.google.com/store/apps/details?id=com.baidu.BaiduMap',
        ios: 'https://apps.apple.com/app/baidu-maps/id452186370',
        h5: 'https://map.baidu.com/',
        note: 'Google Maps заблокирован в Китае. Для навигации обычно нужны Baidu или Amap.',
        guide: null,
      },
      {
        name: 'Amap (Gaode)',
        desc: 'Альтернатива Baidu Maps. Многие местные предпочитают Amap. Лучше подходит для такси, пробок в реальном времени и отзывов о ресторанах.',
        android: 'https://play.google.com/store/apps/details?id=com.autonavi.minimap',
        ios: 'https://apps.apple.com/app/amap/id461703208',
        h5: 'https://ditu.amap.com/',
        note: 'И Baidu, и Amap работают. Выберите одно приложение для навигации и вызова такси.',
        guide: null,
      },
      {
        name: 'Google Maps',
        desc: 'Частично работает в Китае для просмотра, но полноценная навигация и пробки ненадежны. Используйте для планирования заранее.',
        android: null,
        ios: null,
        h5: 'https://maps.google.com/',
        note: 'Для пошаговой навигации в Китае без VPN обычно не подходит.',
        guide: '/ru/posts/do-you-need-a-vpn-in-china-2026/',
      },
    ],
  },
  {
    category: 'Еда и рестораны',
    apps: [
      {
        name: 'Meituan',
        desc: 'Доставка еды, бронирование ресторанов, билеты в кино, бронирование отелей. Только на китайском. Для оплаты используйте встроенные мини-программы Alipay.',
        android: 'https://play.google.com/store/apps/details?id=com.sankuai.meituan',
        ios: 'https://apps.apple.com/app/meituan/id423924287',
        h5: 'https://waimai.meituan.com/',
        note: 'H5-доставка еды работает в браузере. Оплата проходит через Alipay при оформлении заказа.',
        guide: '/ru/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
      },
      {
        name: 'Ele.me',
        desc: 'Сервис доставки еды от Alibaba. Похож на Meituan и тоже работает через Alipay.',
        android: 'https://play.google.com/store/apps/details?id=me.ele',
        ios: 'https://apps.apple.com/app/ele-me/id532785356',
        h5: 'https://www.ele.me/',
        note: 'И Meituan, и Ele.me работают. Попробуйте оба, чтобы охватить больше ресторанов.',
        guide: '/ru/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
      },
      {
        name: 'Dianping',
        desc: 'Китайский аналог Yelp. Отзывы о ресторанах, рейтинги, фото. Помогает найти хорошие местные заведения. Только на китайском.',
        android: 'https://play.google.com/store/apps/details?id=com.dianping.v1',
        ios: 'https://apps.apple.com/app/dianping/id416896465',
        h5: 'https://www.dianping.com/',
        note: 'Используйте поиск по фото, чтобы посмотреть, как выглядит блюдо до заказа.',
        guide: '/ru/food/',
      },
    ],
  },
  {
    category: 'Связь и VPN',
    apps: [
      {
        name: 'VPN (установите до поездки)',
        desc: 'Установите VPN до выезда. ExpressVPN, NordVPN и Astrill работают в Китае. Бесплатные VPN обычно блокируются.',
        android: null,
        ios: null,
        h5: null,
        note: 'ОБЯЗАТЕЛЬНО: установите и проверьте до прилета. Активируйте еще дома.',
        guide: '/ru/posts/do-you-need-a-vpn-in-china-2026/',
      },
      {
        name: 'Google Translate',
        desc: 'Перевод через камеру для меню, вывесок и документов. Скачайте офлайн-пакет китайского языка заранее.',
        android: 'https://play.google.com/store/apps/details?id=com.google.android.apps.translate',
        ios: 'https://apps.apple.com/app/google-translate/id414706506',
        h5: 'https://translate.google.com/',
        note: 'Лучше всего работает для перевода по фото. Скачайте офлайн-пакет до поездки.',
        guide: '/ru/tools/survival-kit/',
      },
    ],
  },
  {
    category: 'Бронирование путешествий',
    apps: [
      {
        name: 'Trip.com (отели)',
        desc: 'Лучший вариант для бронирования отелей с иностранными картами. Широкий выбор. Английский интерфейс.',
        android: null,
        ios: null,
        h5: 'https://www.trip.com/hotels/',
        note: 'Также работает для рейсов и поездов. Все в одном месте.',
        guide: null,
      },
      {
        name: 'Fliggy (Alitrip)',
        desc: 'Платформа для путешествий от Alibaba. Доступна внутри приложения Alipay. Подходит для внутренних поездок.',
        android: null,
        ios: null,
        h5: 'https://www.fliggy.com/',
        note: 'Оплата через Alipay. Отдельная загрузка не нужна.',
        guide: null,
      },
    ],
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Мобильные приложения</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">Важные приложения для Китая</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-internet-apps" alt="Смартфон с иконками необходимых приложений для поездки по Китаю" loading="eager" />

    <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-5 text-sm leading-6 text-amber-900">
      <strong>Перед выездом:</strong> установите эти приложения по Wi-Fi до перелета. Некоторые магазины приложений и сервисы из Китая могут быть недоступны. Скачайте офлайн-пакеты перевода и VPN-приложения заранее.
    </div>

    <AdSlot format="banner" />

    {appGroups.map((group) => (
      <section class="mt-12" aria-labelledby={group.category.replace(/\s+/g, '-').toLowerCase()}>
        <h2 id={group.category.replace(/\s+/g, '-').toLowerCase()} class="text-2xl font-bold text-gray-950">{group.category}</h2>
        <div class="mt-5 grid gap-5 md:grid-cols-2">
          {group.apps.map((app) => (
            <article class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
              <h3 class="text-lg font-bold text-gray-950">{app.name}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{app.desc}</p>

              <div class="mt-4 flex flex-wrap gap-2">
                {app.ios && (
                  <a href={app.ios} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md bg-gray-900 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-gray-700">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
                    Открыть в App Store
                  </a>
                )}
                {app.android && (
                  <a href={app.android} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md bg-green-700 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-green-600">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M18.33 8.7c-.55-.96-1.1-1.91-1.66-2.86l.32-.32c.18-.18.36-.36.54-.54.77-.77.77-1.53 0-2.3-.74-.74-1.52-.74-2.26 0-.36.36-.72.72-1.08 1.08l-.1.1A7.83 7.83 0 0 0 12 3.5c-1.1 0-2.15.2-3.12.61l-.1-.1c-.36-.36-.72-.72-1.08-1.08-.74-.74-1.52-.74-2.26 0-.77.77-.77 1.53 0 2.3.18.18.36.36.54.54l.32.32C5.2 6.8 4.64 7.75 4.08 8.7c-.55.95-1.09 1.9-1.64 2.86h15.53c-.55-.96-1.1-1.91-1.64-2.86M7.75 5.75c-.4 0-.72-.33-.72-.72s.32-.72.72-.72c.4 0 .72.33.72.72s-.32.72-.72.72m8.2 0c-.4 0-.72-.33-.72-.72s.32-.72.72-.72c.4 0 .72.33.72.72s-.32.72-.72.72M6.3 13.36v4.58c0 .66.53 1.2 1.2 1.2h.7c.66 0 1.2-.54 1.2-1.2v-4.58c0-.66-.54-1.2-1.2-1.2h-.7c-.67 0-1.2.54-1.2 1.2m8.72 0v4.58c0 .66.53 1.2 1.2 1.2h.7c.66 0 1.2-.54 1.2-1.2v-4.58c0-.66-.54-1.2-1.2-1.2h-.7c-.67 0-1.2.54-1.2 1.2"/></svg>
                    Открыть в Google Play
                  </a>
                )}
                {app.h5 && (
                  <a href={app.h5} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-gray-700 transition-colors hover:bg-gray-50">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                    Открыть веб-версию
                  </a>
                )}
              </div>

              {app.note && (
                <p class="mt-3 text-xs leading-5 text-gray-500"><span class="font-semibold">Примечание:</span> {app.note}</p>
              )}
              {app.guide && (
                <a href={app.guide} class="mt-2 inline-block text-xs font-semibold text-brand-700 hover:text-brand-800">Читать подробный гид &rarr;</a>
              )}
            </article>
          ))}
        </div>
      </section>
    ))}

    <section class="mt-12 rounded-lg border border-gray-200 p-6">
      <h2 class="text-xl font-bold text-gray-950">H5-версии без установки</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        Многие сервисы Китая имеют <strong>веб-версии (H5)</strong>, которые работают прямо в браузере телефона или внутри мини-программ WeChat/Alipay. Это удобно для коротких поездок, когда не хочется загружать больше 10 приложений. Основные:
      </p>
      <div class="mt-4 grid gap-3 text-sm sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">DiDi</strong> - <span class="text-gray-600">www.didiglobal.com (англоязычная версия)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Baidu Maps</strong> - <span class="text-gray-600">map.baidu.com (только китайский)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Веб-версия WeChat</strong> - <span class="text-gray-600">web.wechat.com (только сообщения)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Meituan</strong> - <span class="text-gray-600">waimai.meituan.com (доставка еды)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Dianping</strong> - <span class="text-gray-600">dianping.com (поиск ресторанов)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Мини-программы Alipay</strong> - <span class="text-gray-600">Все внутри Alipay (без отдельной установки)</span></div>
      </div>
      <p class="mt-4 text-xs text-gray-500">
        <strong>Веб-версии в большинстве случаев работают без VPN</strong>. Приложения лучше скачать и подготовить заранее, еще дома, по Wi-Fi.
      </p>
    </section>

    <section class="mt-10 text-center">
      <p class="text-sm text-gray-500">Ссылки на магазины приложений ведут на официальные страницы. Доступность и цены зависят от региона и ограничений сервиса.</p>
    </section>
  </main>
  <Footer />
</BaseLayout>