---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import CoverImage from "../../../components/CoverImage.astro";
import AdSlot from "../../../components/AdSlot.astro";

const title = 'Основные приложения для поездки в Китай: ссылки для скачивания и веб-альтернативы';
const description = 'Полный каталог приложений, которые понадобятся вам в Китае — WeChat, Alipay, DiDi, Baidu Maps, Meituan, 12306, VPN и другие. Для каждого приложения есть ссылки на загрузку в App Store / Google Play и H5-веб-версии, которые работают без установки.';

const appGroups = [
  {
    category: 'Платежи и кошелек',
    apps: [
      {
        name: 'Alipay',
        desc: 'Самый распространенный мобильный кошелек в Китае. Привяжите иностранную карту Visa или Mastercard и оплачивайте покупки по QR-коду в магазинах, ресторанах, такси и уличных лавках.',
        android: 'https://play.google.com/store/apps/details?id=com.eg.android.AlipayGphone',
        ios: 'https://apps.apple.com/app/alipay/id333206289',
        h5: null,
        note: 'Настройка занимает 10–15 минут. Для подтверждения личности нужен паспорт.',
        guide: '/posts/alipay-foreign-credit-card-step-by-step/',
      },
      {
        name: 'WeChat',
        desc: 'Китайское суперприложение. Используйте его для переписки, звонков, Moments (социальная лента) и WeChat Pay. Большинство китайцев пользуются им каждый день буквально для всего.',
        android: 'https://play.google.com/store/apps/details?id=com.tencent.mm',
        ios: 'https://apps.apple.com/app/wechat/id414478124',
        h5: 'https://web.wechat.com/',
        note: 'Для WeChat Pay нужна привязанная карта. Сам WeChat работает для переписки и без настройки.',
        guide: '/posts/link-a-foreign-visa-or-mastercard-to-wechat-pay-in-china/',
      },
    ],
  },
  {
    category: 'Транспорт и заказ поездок',
    apps: [
      {
        name: 'DiDi',
        desc: 'Китайский аналог Uber. Заказывайте такси и частные автомобили. Поддерживается интерфейс на английском. Оплата через Alipay или WeChat Pay.',
        android: 'https://play.google.com/store/apps/details?id=com.didi.sdk',
        ios: 'https://apps.apple.com/app/didi/id1164272094',
        h5: 'https://www.didiglobal.com/',
        note: 'Версия H5 работает в браузере или как мини-программа в WeChat. Для редких поездок приложение не нужно.',
        guide: '/posts/didi-china-foreign-tourists-guide/',
      },
      {
        name: 'Alipay Transport Mini-Program',
        desc: 'Внутри Alipay используйте транспортную мини-программу, чтобы сканировать QR-коды в метро и автобусах большинства крупных городов.',
        android: null,
        ios: null,
        h5: null,
        note: 'Откройте Alipay → значок "Transport". Отдельная установка не требуется.',
        guide: '/transport/',
      },
      {
        name: '12306',
        desc: 'Официальное приложение железных дорог Китая для бронирования билетов на поезд. Интерфейс только на китайском, требуется подтверждение личности. Альтернатива: используйте Trip.com.',
        android: 'https://play.google.com/store/apps/details?id=com.cars.blaili',
        ios: 'https://apps.apple.com/app/12306/id564757494',
        h5: 'https://www.12306.cn/',
        note: 'Для иностранцев непросто. Используйте Trip.com (на английском, без лишних сложностей с подтверждением).',
        guide: '/posts/book-china-train-tickets-12306-foreigners/',
      },
      {
        name: 'Trip.com (Ctrip)',
        desc: 'Удобное для англоязычных пользователей приложение для бронирования поездов, авиабилетов и отелей. Напрямую принимает иностранные карты.',
        android: 'https://play.google.com/store/apps/details?id=com.ctrip',
        ios: 'https://apps.apple.com/app/trip-com/id1612956441',
        h5: 'https://www.trip.com/',
        note: 'Лучшая альтернатива 12306 для покупки железнодорожных билетов. Сервисный сбор выше, но пользоваться намного проще.',
        guide: null,
      },
    ],
  },
  {
    category: 'Навигация и карты',
    apps: [
      {
        name: 'Baidu Maps',
        desc: 'Самая подробная карта Китая. Пошаговая навигация, маршруты общественного транспорта, поиск ресторанов. Только на китайском, но пользоваться можно с помощью жестов.',
        android: 'https://play.google.com/store/apps/details?id=com.baidu.BaiduMap',
        ios: 'https://apps.apple.com/app/baidu-maps/id452186370',
        h5: 'https://map.baidu.com/',
        note: 'Google Maps заблокирован в Китае. Для навигации нужен Baidu или Amap.',
        guide: null,
      },
      {
        name: 'Amap (Gaode)',
        desc: 'Альтернатива Baidu Maps. Многие местные предпочитают Amap. Лучше подходит для навигации такси, отслеживания трафика в реальном времени и отзывов о ресторанах.',
        android: 'https://play.google.com/store/apps/details?id=com.autonavi.minimap',
        ios: 'https://apps.apple.com/app/amap/id461703208',
        h5: 'https://ditu.amap.com/',
        note: 'Работают и Baidu, и Amap. Выберите одно. Amap обычно точнее для вызова такси.',
        guide: null,
      },
      {
        name: 'Google Maps',
        desc: 'В Китае частично работает для просмотра карт, но навигация и данные о трафике в реальном времени ненадежны. Подходит для планирования до поездки.',
        android: null,
        ios: null,
        h5: 'https://maps.google.com/',
        note: 'Без VPN не будет работать для пошаговой навигации в Китае.',
        guide: '/posts/do-you-need-a-vpn-in-china-2026/',
      },
    ],
  },
  {
    category: 'Еда и рестораны',
    apps: [
      {
        name: 'Meituan',
        desc: 'Доставка еды, бронирование ресторанов, билеты в кино, бронирование отелей. Только на китайском. Для помощи на английском используйте мини-программу внутри Alipay.',
        android: 'https://play.google.com/store/apps/details?id=com.sankuai.meituan',
        ios: 'https://apps.apple.com/app/meituan/id423924287',
        h5: 'https://waimai.meituan.com/',
        note: 'Доставка еды через H5 работает в браузере. Оплатить можно через Alipay при доставке.',
        guide: '/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
      },
      {
        name: 'Ele.me',
        desc: 'Приложение для доставки еды (принадлежит Alibaba). Похоже на Meituan. Можно заказывать еду через Alipay.',
        android: 'https://play.google.com/store/apps/details?id=me.ele',
        ios: 'https://apps.apple.com/app/ele-me/id532785356',
        h5: 'https://www.ele.me/',
        note: 'Работают и Meituan, и Ele.me. Попробуйте оба, чтобы получить лучший выбор ресторанов.',
        guide: '/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
      },
      {
        name: 'Dianping',
        desc: 'Китайский аналог Yelp. Отзывы о ресторанах, рейтинги, фотографии. Помогает находить хорошие местные заведения. Только на китайском.',
        android: 'https://play.google.com/store/apps/details?id=com.dianping.v1',
        ios: 'https://apps.apple.com/app/dianping/id416896465',
        h5: 'https://www.dianping.com/',
        note: 'Используйте поиск по фото — можно увидеть, как выглядят блюда, еще до заказа.',
        guide: '/food/',
      },
    ],
  },
  {
    category: 'Связь и VPN',
    apps: [
      {
        name: 'VPN (выберите один до поездки)',
        desc: 'Установите VPN ДО отъезда. ExpressVPN, NordVPN и Astrill работают в Китае. Большинство бесплатных VPN заблокированы.',
        android: null,
        ios: null,
        h5: null,
        note: 'КРАЙНЕ ВАЖНО: установите и проверьте до прибытия. Активируйте после приземления.',
        guide: '/posts/do-you-need-a-vpn-in-china-2026/',
      },
      {
        name: 'Google Translate',
        desc: 'Перевод через камеру для меню, вывесок и документов. Загрузите офлайн-пакет Chinese(Simplified).',
        android: 'https://play.google.com/store/apps/details?id=com.google.android.apps.translate',
        ios: 'https://apps.apple.com/app/google-translate/id414706506',
        h5: 'https://translate.google.com/',
        note: 'Лучший инструмент для перевода. Загрузите офлайн-пакет до поездки.',
        guide: '/tools/survival-kit/',
      },
    ],
  },
  {
    category: 'Бронирование поездок',
    apps: [
      {
        name: 'Trip.com (Hotels)',
        desc: 'Лучший вариант для бронирования отелей иностранными картами. Широкий выбор. Интерфейс на английском.',
        android: null,
        ios: null,
        h5: 'https://www.trip.com/hotels/',
        note: 'Также подходит для авиабилетов и поездов. Универсальный сервис.',
        guide: null,
      },
      {
        name: 'Fliggy (Alitrip)',
        desc: 'Платформа для бронирования поездок от Alibaba. Находится внутри приложения Alipay. Подходит для внутренних авиарейсов.',
        android: null,
        ios: null,
        h5: 'https://www.fliggy.com/',
        note: 'Оплата через Alipay. Отдельно скачивать ничего не нужно.',
        guide: null,
      },
    ],
  },
];
---
<!-- Контент создан с помощью ИИ, проверен носителем языка -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header>
      <p class="section-kicker">Мобильные приложения</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">Основные приложения для Китая</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-internet-apps" alt="Смартфон с иконками основных приложений для поездки в Китай" loading="eager" />

    <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-5 text-sm leading-6 text-amber-900">
      <strong>Перед поездкой:</strong> Установите эти приложения по WiFi до вылета. Некоторые магазины приложений в Китае работают медленно или блокируются. Загрузите дома офлайн-пакеты перевода и VPN-приложения.
    </div>

    <AdSlot format="banner" />

    {appGroups.map((group) => (
      <section class="mt-12" aria-labelledby={group.category.replace(/\s+/g, '-').toLowerCase()}>
        <h2 id={group.category.replace(/\s+/g, '-').toLowerCase()} class="text-2xl font-bold text-gray-950">{group.category}</h2>
        <div class="mt-5 grid gap-5 md:grid-cols-2">
          {group.apps.map((app) => (
            <article class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
              <h3 class="text-lg font-bold text-gray-950">{app.name}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{app.desc}</p>

              <div class="mt-4 flex flex-wrap gap-2">
                {app.ios && (
                  <a href={app.ios} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md bg-gray-900 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-gray-700">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
                    App Store
                  </a>
                )}
                {app.android && (
                  <a href={app.android} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md bg-green-700 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-green-600">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M18.33 8.7c-.55-.96-1.1-1.91-1.66-2.86l.32-.32c.18-.18.36-.36.54-.54.77-.77.77-1.53 0-2.3-.74-.74-1.52-.74-2.26 0-.36.36-.72.72-1.08 1.08l-.1.1A7.83 7.83 0 0 0 12 3.5c-1.1 0-2.15.2-3.12.61l-.1-.1c-.36-.36-.72-.72-1.08-1.08-.74-.74-1.52-.74-2.26 0-.77.77-.77 1.53 0 2.3.18.18.36.36.54.54l.32.32C5.2 6.8 4.64 7.75 4.08 8.7c-.55.95-1.09 1.9-1.64 2.86h15.53c-.55-.96-1.1-1.91-1.64-2.86M7.75 5.75c-.4 0-.72-.33-.72-.72s.32-.72.72-.72c.4 0 .72.33.72.72s-.32.72-.72.72m8.2 0c-.4 0-.72-.33-.72-.72s.32-.72.72-.72c.4 0 .72.33.72.72s-.32.72-.72.72M6.3 13.36v4.58c0 .66.53 1.2 1.2 1.2h.7c.66 0 1.2-.54 1.2-1.2v-4.58c0-.66-.54-1.2-1.2-1.2h-.7c-.67 0-1.2.54-1.2 1.2m8.72 0v4.58c0 .66.53 1.2 1.2 1.2h.7c.66 0 1.2-.54 1.2-1.2v-4.58c0-.66-.54-1.2-1.2-1.2h-.7c-.67 0-1.2.54-1.2 1.2"/></svg>
                    Google Play
                  </a>
                )}
                {app.h5 && (
                  <a href={app.h5} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-gray-700 transition-colors hover:bg-gray-50">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                    Открыть веб-версию
                  </a>
                )}
              </div>

              {app.note && (
                <p class="mt-3 text-xs leading-5 text-gray-500"><span class="font-semibold">Совет:</span> {app.note}</p>
              )}
              {app.guide && (
                <a href={app.guide} class="mt-2 inline-block text-xs font-semibold text-brand-700 hover:text-brand-800">Читать инструкцию по настройке &rarr;</a>
              )}
            </article>
          ))}
        </div>
      </section>
    ))}

    <section class="mt-12 rounded-lg border border-gray-200 p-6">
      <h2 class="text-xl font-bold text-gray-950">H5-веб-приложения — скачивание не нужно</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        У многих китайских сервисов есть <strong>веб-версии (H5)</strong>, которые работают прямо в браузере телефона или внутри мини-программ WeChat/Alipay. Это отличный вариант для краткосрочных путешественников, которые не хотят захламлять телефон 10+ приложениями. Вот основные:
      </p>
      <div class="mt-4 grid gap-3 text-sm sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">DiDi</strong> — <span class="text-gray-600">www.didiglobal.com (доступен английский)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Baidu Maps</strong> — <span class="text-gray-600">map.baidu.com (только китайский)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">WeChat Web</strong> — <span class="text-gray-600">web.wechat.com (только сообщения)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Meituan</strong> — <span class="text-gray-600">waimai.meituan.com (доставка еды)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Dianping</strong> — <span class="text-gray-600">dianping.com (поиск ресторанов)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Alipay Mini-Programs</strong> — <span class="text-gray-600">Все внутри Alipay (без дополнительной установки)</span></div>
      </div>
      <p class="mt-4 text-xs text-gray-500">
        <strong>Веб-версии в большинстве случаев работают без VPN</strong>. Приложения лучше скачать дома по WiFi до прибытия.
      </p>
    </section>

    <section class="mt-10 text-center">
      <p class="text-sm text-gray-500">Ссылки на магазины приложений ведут на официальные страницы. Цены и доступность могут зависеть от региональных ограничений.</p>
    </section>
  </main>
  <Footer />
</BaseLayout>