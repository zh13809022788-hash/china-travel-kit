---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CoverImage from '../../../components/CoverImage.astro';
import AdSlot from '../../../components/AdSlot.astro';

const title = 'Важные приложения для Китая: ссылки и веб-версии';
const description = 'A complete directory of apps you need in China — WeChat, Alipay, DiDi, Baidu Maps, Meituan, 12306, VPN and more. Every app includes App Store / Google Play download links and H5 web versions that work without installing.';

const appGroups = [
  {
    category: 'Оплата & Wallet',
    apps: [
      {
        name: 'Alipay',
        desc: 'The most accepted mobile wallet in China. Link a foreign Visa or Mastercard, pay by QR code at shops, restaurants, taxis, and street vendors.',
        android: 'https://play.google.com/store/apps/details?id=com.eg.android.AlipayGphone',
        ios: 'https://apps.apple.com/app/alipay/id333206289',
        h5: null,
        note: 'Setup takes 10-15 min. Need passport for verification.',
        guide: '/ru/posts/alipay-foreign-credit-card-step-by-step/',
      },
      {
        name: 'WeChat',
        desc: 'China\'s super app. Use it for messaging, calls, Moments (social feed), and WeChat Pay. Most Chinese people use this daily for everything.',
        android: 'https://play.google.com/store/apps/details?id=com.tencent.mm',
        ios: 'https://apps.apple.com/app/wechat/id414478124',
        h5: 'https://web.wechat.com/',
        note: 'WeChat Pay needs a linked card. WeChat itself works for messaging without setup.',
        guide: '/ru/posts/link-a-foreign-visa-or-mastercard-to-wechat-pay-in-china/',
      },
    ],
  },
  {
    category: 'Транспорт & Ride-Hailing',
    apps: [
      {
        name: 'DiDi',
        desc: 'China\'s Uber. Book taxis and private cars. Supports English interface. Can pay with Alipay or WeChat Pay.',
        android: 'https://play.google.com/store/apps/details?id=com.didi.sdk',
        ios: 'https://apps.apple.com/app/didi/id1164272094',
        h5: 'https://m.didiglobal.com/',
        note: 'H5 version works in browser or WeChat mini-program. No app needed for occasional rides.',
        guide: '/ru/posts/didi-china-foreign-tourists-guide/',
      },
      {
        name: 'Alipay Транспорт Mini-Program',
        desc: 'Within Alipay, use the transport mini-program to scan QR codes for city metro and buses in most major cities.',
        android: null,
        ios: null,
        h5: null,
        note: 'Open Alipay → "Транспорт" icon. No separate install needed.',
        guide: '/ru/transport/',
      },
      {
        name: '12306',
        desc: 'Official China Railway app for booking train tickets. Chinese-only interface, needs verification. Alternative: use Trip.com.',
        android: 'https://play.google.com/store/apps/details?id=com.cars.blaili',
        ios: 'https://apps.apple.com/app/12306/id564757494',
        h5: 'https://www.12306.cn/',
        note: 'Tricky for foreigners. Use Trip.com (English, no verification hassle).',
        guide: '/ru/posts/book-china-train-tickets-12306-foreigners/',
      },
      {
        name: 'Trip.com (Ctrip)',
        desc: 'English-friendly app for booking trains, flights, and hotels. Accepts foreign cards directly.',
        android: 'https://play.google.com/store/apps/details?id=com.ctrip',
        ios: 'https://apps.apple.com/app/trip-com/id1612956441',
        h5: 'https://www.trip.com/',
        note: 'Best alternative to 12306 for train tickets. Higher service fee but much easier.',
        guide: null,
      },
    ],
  },
  {
    category: 'Navigation & Maps',
    apps: [
      {
        name: 'Baidu Maps',
        desc: 'Most detailed China map. Turn-by-turn navigation, public transit routing, restaurant search. Chinese-only but usable with gestures.',
        android: 'https://play.google.com/store/apps/details?id=com.baidu.BaiduMap',
        ios: 'https://apps.apple.com/app/baidu-maps/id452186370',
        h5: 'https://map.baidu.com/',
        note: 'Google Maps is blocked in China. Need Baidu or Amap for navigation.',
        guide: null,
      },
      {
        name: 'Amap (Gaode)',
        desc: 'Alternative to Baidu Maps. Many locals prefer Amap. Better for taxi navigation, live traffic, and restaurant reviews.',
        android: 'https://play.google.com/store/apps/details?id=com.autonavi.minimap',
        ios: 'https://apps.apple.com/app/amap/id461703208',
        h5: 'https://ditu.amap.com/',
        note: 'Both Baidu and Amap work. Pick one. Amap tends to be more accurate for taxi hailing.',
        guide: null,
      },
      {
        name: 'Google Maps',
        desc: 'Works partially in China for browsing but navigation and real-time traffic are unreliable. Good for pre-trip planning.',
        android: null,
        ios: null,
        h5: 'https://maps.google.com/',
        note: 'Will not work for turn-by-turn navigation in China without VPN.',
        guide: '/ru/posts/do-you-need-a-vpn-in-china-2026/',
      },
    ],
  },
  {
    category: 'Food & Dining',
    apps: [
      {
        name: 'Meituan',
        desc: 'Food delivery, restaurant booking, movie tickets, hotel booking. Chinese-only. Use inside Alipay mini-program for English help.',
        android: 'https://play.google.com/store/apps/details?id=com.sankuai.meituan',
        ios: 'https://apps.apple.com/app/meituan/id423924287',
        h5: 'https://waimai.meituan.com/',
        note: 'H5 food delivery works in browser. Pay with Alipay at delivery.',
        guide: '/ru/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
      },
      {
        name: 'Ele.me',
        desc: 'Food delivery app (owned by Alibaba). Similar to Meituan. Can order food with Alipay.',
        android: 'https://play.google.com/store/apps/details?id=me.ele',
        ios: 'https://apps.apple.com/app/ele-me/id532785356',
        h5: 'https://www.ele.me/',
        note: 'Both Meituan and Ele.me work. Try both for best restaurant coverage.',
        guide: '/ru/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
      },
      {
        name: 'Dianping',
        desc: 'Yelp of China. Restaurant reviews, ratings, photos. Helps find good local eateries. Chinese-only.',
        android: 'https://play.google.com/store/apps/details?id=com.dianping.v1',
        ios: 'https://apps.apple.com/app/dianping/id416896465',
        h5: 'https://www.dianping.com/',
        note: 'Use the photo search feature — see what dishes look like before ordering.',
        guide: '/ru/food/',
      },
    ],
  },
  {
    category: 'Communication & VPN',
    apps: [
      {
        name: 'VPN (choose one before travel)',
        desc: 'Install a VPN BEFORE you leave. ExpressVPN, NordVPN, and Astrill work in China. Free VPNs mostly blocked.',
        android: null,
        ios: null,
        h5: null,
        note: 'ESSENTIAL: Install and test before arriving. Activate when you land.',
        guide: '/ru/posts/do-you-need-a-vpn-in-china-2026/',
      },
      {
        name: 'Google Translate',
        desc: 'Camera translation for menus, signs, and documents. Download Chinese(Simplified) offline pack.',
        android: 'https://play.google.com/store/apps/details?id=com.google.android.apps.translate',
        ios: 'https://apps.apple.com/app/google-translate/id414706506',
        h5: 'https://translate.google.com/',
        note: 'Best translation tool. Download offline pack before trip.',
        guide: '/ru/tools/survival-kit/',
      },
    ],
  },
  {
    category: 'Travel Booking',
    apps: [
      {
        name: 'Trip.com (Hotels)',
        desc: 'Best for booking hotels with foreign cards. Wide coverage. English interface.',
        android: null,
        ios: null,
        h5: 'https://www.trip.com/hotels/',
        note: 'Also works for flights and trains. One-stop shop.',
        guide: null,
      },
      {
        name: 'Fliggy (Alitrip)',
        desc: 'Alibaba\'s travel booking platform. Inside Alipay app. Good for domestic flights.',
        android: null,
        ios: null,
        h5: 'https://www.fliggy.com/',
        note: 'Can pay with Alipay. No separate download needed.',
        guide: null,
      },
    ],
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Mobile apps</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">Важные приложения для Китая</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-internet-apps" alt="Smartphone with essential China travel apps icons" loading="eager" />

    <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-5 text-sm leading-6 text-amber-900">
      <strong>Before you go:</strong> Install these apps on WiFi before departure. Some app stores are slow or blocked from within China. Download offline translation packs and VPN apps at home.
    </div>

    <AdSlot format="banner" />

    {appGroups.map((group) => (
      <section class="mt-12" aria-labelledby={group.category.replace(/\s+/g, '-').toLowerCase()}>
        <h2 id={group.category.replace(/\s+/g, '-').toLowerCase()} class="text-2xl font-bold text-gray-950">{group.category}</h2>
        <div class="mt-5 grid gap-5 md:grid-cols-2">
          {group.apps.map((app) => (
            <article class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
              <h3 class="text-lg font-bold text-gray-950">{app.name}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{app.desc}</p>

              <div class="mt-4 flex flex-wrap gap-2">
                {app.ios && (
                  <a href={app.ios} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md bg-gray-900 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-gray-700">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
                    App Store
                  </a>
                )}
                {app.android && (
                  <a href={app.android} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md bg-green-700 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-green-600">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M18.33 8.7c-.55-.96-1.1-1.91-1.66-2.86l.32-.32c.18-.18.36-.36.54-.54.77-.77.77-1.53 0-2.3-.74-.74-1.52-.74-2.26 0-.36.36-.72.72-1.08 1.08l-.1.1A7.83 7.83 0 0 0 12 3.5c-1.1 0-2.15.2-3.12.61l-.1-.1c-.36-.36-.72-.72-1.08-1.08-.74-.74-1.52-.74-2.26 0-.77.77-.77 1.53 0 2.3.18.18.36.36.54.54l.32.32C5.2 6.8 4.64 7.75 4.08 8.7c-.55.95-1.09 1.9-1.64 2.86h15.53c-.55-.96-1.1-1.91-1.64-2.86M7.75 5.75c-.4 0-.72-.33-.72-.72s.32-.72.72-.72c.4 0 .72.33.72.72s-.32.72-.72.72m8.2 0c-.4 0-.72-.33-.72-.72s.32-.72.72-.72c.4 0 .72.33.72.72s-.32.72-.72.72M6.3 13.36v4.58c0 .66.53 1.2 1.2 1.2h.7c.66 0 1.2-.54 1.2-1.2v-4.58c0-.66-.54-1.2-1.2-1.2h-.7c-.67 0-1.2.54-1.2 1.2m8.72 0v4.58c0 .66.53 1.2 1.2 1.2h.7c.66 0 1.2-.54 1.2-1.2v-4.58c0-.66-.54-1.2-1.2-1.2h-.7c-.67 0-1.2.54-1.2 1.2"/></svg>
                    Google Play
                  </a>
                )}
                {app.h5 && (
                  <a href={app.h5} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-gray-700 transition-colors hover:bg-gray-50">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                    Open Web Version
                  </a>
                )}
              </div>

              {app.note && (
                <p class="mt-3 text-xs leading-5 text-gray-500"><span class="font-semibold">Tip:</span> {app.note}</p>
              )}
              {app.guide && (
                <a href={app.guide} class="mt-2 inline-block text-xs font-semibold text-brand-700 hover:text-brand-800">Read setup guide &rarr;</a>
              )}
            </article>
          ))}
        </div>
      </section>
    ))}

    <section class="mt-12 rounded-lg border border-gray-200 p-6">
      <h2 class="text-xl font-bold text-gray-950">H5 Web Apps — No Download Needed</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        Many China services have <strong>web-based (H5) versions</strong> that work directly in your phone browser or inside WeChat/Alipay mini-programs. These are great for short-term travelers who don't want to clutter their phone with 10+ apps. Key ones:
      </p>
      <div class="mt-4 grid gap-3 text-sm sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">DiDi</strong> — <span class="text-gray-600">m.didiglobal.com (English available)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Baidu Maps</strong> — <span class="text-gray-600">map.baidu.com (Chinese only)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">WeChat Web</strong> — <span class="text-gray-600">web.wechat.com (messaging only)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Meituan</strong> — <span class="text-gray-600">waimai.meituan.com (food delivery)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Dianping</strong> — <span class="text-gray-600">dianping.com (restaurant search)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Alipay Mini-Programs</strong> — <span class="text-gray-600">Everything inside Alipay (no extra install)</span></div>
      </div>
      <p class="mt-4 text-xs text-gray-500">
        <strong>Web versions work without a VPN</strong> in most cases. For app downloads, install before arrival on home WiFi.
      </p>
    </section>

    <section class="mt-10 text-center">
      <p class="text-sm text-gray-500">App store links open official pages. Prices and availability subject to regional restrictions.</p>
    </section>
  </main>
  <Footer />
</BaseLayout>
