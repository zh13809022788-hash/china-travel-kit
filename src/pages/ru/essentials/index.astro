---
import { getCollection } from 'astro:content';
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import AdSlot from "../../../components/AdSlot.astro";
import CoverImage from "../../../components/CoverImage.astro";

const CATEGORY = 'essentials';
const posts = (await getCollection('posts'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Путеводители по планированию поездки в ChinaTripBox — визы, сроки и основы';
const description =
  'Планируйте поездку в Китай уверенно: визы и правила въезда, лучшее время для посещения, что взять с собой, безопасность и всё, что нужно уладить до вылета.';
import { getCategoryLabel } from "../../../i18n/categories";
const locale = 'en';
---
<!-- Контент создан с помощью ИИ, проверен носителем языка -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header>
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Планирование поездки</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Путеводители по планированию поездки</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="hub-essentials" alt="Предметы первой необходимости и снаряжение для планирования поездки в Китай" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{getCategoryLabel(post.data.category, locale)}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">Путеводители скоро появятся.</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>