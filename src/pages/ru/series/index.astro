---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const title = 'Серии материалов о Китае';
const description = 'Откройте для себя Китай через пять тематических серий: еда, история, современная жизнь, природа и культура. Эти подборки помогают лучше понять страну и подготовиться к поездке.';

const seriesList = [
  {
    href: '/ru/series/food-of-china/',
    title: 'Еда Китая',
    desc: 'От уличных лавок до банкетных столов: гастрономическое путешествие по региональным кухням, хотпоту, завтракам и блюдам, ради которых стоит ехать через весь город.',
    icon: 'Еда и напитки',
  },
  {
    href: '/ru/series/history-of-china/',
    title: 'История Китая',
    desc: 'Древние места и сюжеты, понятные путешественнику: Великая китайская стена, Терракотовая армия, Запретный город, Шёлковый путь и исторический контекст увиденного.',
    icon: 'История',
  },
  {
    href: '/ru/series/modern-china/',
    title: 'Современный Китай',
    desc: 'То, что чаще всего удивляет иностранцев: безналичная повседневность, скоростные поезда, масштаб мегаполисов, супераппы и технологии в обычной жизни.',
    icon: 'Современность',
  },
  {
    href: '/ru/series/nature-of-china/',
    title: 'Природа Китая',
    desc: 'Горы как из фильма, карстовые пейзажи, бирюзовые озёра и тибетские плато: самые впечатляющие природные регионы Китая с полезным туристическим контекстом.',
    icon: 'Природа',
  },
  {
    href: '/ru/series/culture-of-china/',
    title: 'Культура Китая',
    desc: 'Чайная культура, Праздник весны, понятия лица и гуаньси, каллиграфия, кунг-фу и зодиак — для тех, кто хочет увидеть в Китае больше, чем набор достопримечательностей.',
    icon: 'Культура',
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Серии материалов</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <section class="mt-10 grid gap-5 md:grid-cols-2">
      {seriesList.map((s) => (
        <a href={s.href} class="card block hover:no-underline">
          <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{s.icon}</span>
          <h2 class="mt-2 text-xl font-bold text-gray-950">{s.title}</h2>
          <p class="mt-2 text-sm leading-6 text-gray-600">{s.desc}</p>
          <span class="mt-4 inline-flex text-sm font-semibold text-brand-700">Открыть серию</span>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>
