---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const title = 'Серия материалов о путешествиях по China';
const description = 'Откройте для себя China через пять тематических серий: еда, история, современная жизнь, природа и культура. Каждая из них создана, чтобы вдохновлять иностранных путешественников и давать им полезную информацию.';

const seriesList = [
  {
    href: '/ru/series/food-of-china/',
    title: 'Еда China',
    desc: 'От уличных лавок до банкетных залов: гастрономическое путешествие иностранца по восьми великим кухням, региональным завтракам, стилям хотпота и блюдам, ради которых стоит пересечь весь город.',
    icon: 'Еда и напитки',
  },
  {
    href: '/ru/series/history-of-china/',
    title: 'История China',
    desc: 'Древние места, объясненные для путешественников: Великая стена, Терракотовая армия, Запретный город, Шелковый путь и истории о том, на что вы на самом деле смотрите.',
    icon: 'История',
  },
  {
    href: '/ru/series/modern-china/',
    title: 'Современная China',
    desc: 'То, что больше всего удивляет иностранцев: улицы без наличных, самые быстрые поезда в мире, масштаб мегаполисов, супераппы и повседневные технологии, которые сегодня определяют жизнь в China.',
    icon: 'Современная жизнь',
  },
  {
    href: '/ru/series/nature-of-china/',
    title: 'Природа China',
    desc: 'Горы как в «Аватаре», сказочные озера, карстовые ландшафты и Тибетское плато: самые впечатляющие природные места China с практическими гидами для иностранных гостей.',
    icon: 'Природа',
  },
  {
    href: '/ru/series/culture-of-china/',
    title: 'Культура China',
    desc: 'Чайная церемония, Праздник весны, понятия лица и гуаньси, каллиграфия, кунг-фу и зодиак: культурные традиции для путешественников, которые хотят выйти за рамки поверхностного туризма.',
    icon: 'Культура',
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Серия материалов</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <section class="mt-10 grid gap-5 md:grid-cols-2">
      {seriesList.map((s) => (
        <a href={s.href} class="card block hover:no-underline">
          <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{s.icon}</span>
          <h2 class="mt-2 text-xl font-bold text-gray-950">{s.title}</h2>
          <p class="mt-2 text-sm leading-6 text-gray-600">{s.desc}</p>
          <span class="mt-4 inline-flex text-sm font-semibold text-brand-700">Открыть серию</span>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>
