---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';

const seriesSlug = 'culture-of-china';
const posts = (await getCollection('posts-ru'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Культура Китая: традиции и обычаи для путешественников';
const description = 'Познакомьтесь с культурой Китая глазами иностранного путешественника: чайная церемония, Праздник весны, понятия лица и гуаньси, каллиграфия, кунг-фу, китайский зодиак и традиции, которые формируют повседневную жизнь в Китае.';

const relatedTools = [
  { href: '/ru/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/', title: 'Чаевые и этикет', desc: 'Когда уместно оставлять чаевые, когда нет и почему' },
  { href: '/ru/posts/what-to-pack-for-china-a-season-by-season-checklist/', title: 'Что взять на праздники', desc: 'Что стоит взять с собой в сезон праздников' },
  { href: '/ru/posts/how-to-pay-in-china-tourist-guide/', title: 'Как платить в Китае', desc: 'Способы оплаты в праздничный сезон' },
];

const relatedCities = [
  { href: '/ru/posts/beijing-city-guide-for-foreigners/', title: 'Пекин', desc: 'Императорская культура и жизнь в хутунах' },
  { href: '/ru/posts/hangzhou-city-guide-for-foreigners/', title: 'Ханчжоу', desc: 'Чайная культура и наследие озера Сиху' },
  { href: '/ru/posts/chengdu-city-guide-for-foreigners/', title: 'Чэнду', desc: 'Культура чайных домов и неспешный ритм жизни' },
];

const otherSeries = [
  { href: '/ru/series/food-of-china/', title: 'Кухня Китая' },
  { href: '/ru/series/history-of-china/', title: 'История Китая' },
  { href: '/ru/series/modern-china/', title: 'Современный Китай' },
];
import { getCategoryLabel } from '../../../i18n/categories';
const locale = 'ru';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Серия материалов</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Статьи</p>
            <h2>Серия «Культура Китая»</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/ru/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">Материалы этой серии готовятся. Загляните немного позже.</p>
        )}
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Полезные материалы</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Путешествуйте с пониманием местной культуры</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Путеводители по городам</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Города с богатой культурой</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Другие серии</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>