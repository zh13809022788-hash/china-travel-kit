---
import { getCollection } from 'astro:content';
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import AdSlot from "../../../components/AdSlot.astro";

const seriesSlug = 'history-of-china';
const posts = (await getCollection('posts'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'История Китая — древние места и истории для путешественников';
const description = 'Исследуйте исторические места Китая глазами иностранного путешественника: Великая китайская стена, Терракотовая армия, Запретный город, Шёлковый путь, древние столицы и водные города — с историями, которые помогают понять увиденное.';

const relatedTools = [
  { href: '/posts/china-visa-free-entry-transit-guide-2026/', title: 'Гид по визам и въезду', desc: 'Безвизовый транзит и требования для въезда' },
  { href: '/posts/china-high-speed-rail-guide-foreigners/', title: 'Гид по скоростным железным дорогам', desc: 'Поезда к историческим местам по всему Китаю' },
  { href: '/posts/book-china-train-tickets-12306-foreigners/', title: 'Забронировать билеты на поезд', desc: 'Гид по 12306 для владельцев иностранных паспортов' },
];

const relatedCities = [
  { href: '/posts/beijing-city-guide-for-foreigners/', title: 'Beijing', desc: 'Запретный город, Великая китайская стена, Храм Неба' },
  { href: '/posts/hangzhou-city-guide-for-foreigners/', title: 'Hangzhou', desc: 'Древняя столица Южной Сун' },
  { href: '/posts/chengdu-city-guide-for-foreigners/', title: 'Chengdu', desc: 'Наследие Троецарствия и древние улицы' },
];

const otherSeries = [
  { href: '/series/food-of-china/', title: 'Кухня Китая' },
  { href: '/series/culture-of-china/', title: 'Культура Китая' },
  { href: '/series/nature-of-china/', title: 'Природа Китая' },
];
import { getCategoryLabel } from "../../../i18n/categories";
const locale = 'en';
---
<!-- Контент создан с помощью ИИ, проверен носителем языка -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Серия материалов</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Статьи</p>
            <h2>Серия «История Китая»</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">Статьи этой серии готовятся. Загляните снова в ближайшее время.</p>
        )}
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Практические инструменты</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Спланируйте поездку</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Гиды по городам</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Исторические города</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Другие серии</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>