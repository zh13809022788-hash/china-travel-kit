---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';

const seriesSlug = 'nature-of-china';
const posts = (await getCollection('posts-ru'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Природа Китая — пейзажи и дикие места';
const description = 'Откройте природные чудеса Китая глазами иностранного путешественника: горы Аватара в Чжанцзяцзе, сказочные озёра Цзючжайгоу, море облаков Хуаншаня, карстовые пики Гуйлиня и Тибетское плато.';

const relatedTools = [
  { href: '/ru/posts/what-to-pack-for-china-a-season-by-season-checklist/', title: 'Чек-лист для сборов', desc: 'Снаряжение для поездок на природу по сезонам' },
  { href: '/ru/posts/china-visa-free-entry-transit-guide-2026/', title: 'Гид по визе и въезду', desc: 'Разрешения и правила въезда в удалённые регионы' },
  { href: '/ru/trip-planner/', title: 'Планировщик поездки', desc: 'Соберите маршрут по природным местам Китая' },
];

const relatedCities = [
  { href: '/ru/posts/sanya-city-guide-for-foreigners/', title: 'Санья', desc: 'Тропические пляжи и дождевые леса' },
  { href: '/ru/posts/hangzhou-city-guide-for-foreigners/', title: 'Ханчжоу', desc: 'Западное озеро и чайные холмы' },
  { href: '/ru/posts/chengdu-city-guide-for-foreigners/', title: 'Чэнду', desc: 'Ворота к западным горам и пандам' },
];

const otherSeries = [
  { href: '/ru/series/history-of-china/', title: 'История Китая' },
  { href: '/ru/series/culture-of-china/', title: 'Культура Китая' },
  { href: '/ru/series/food-of-china/', title: 'Еда Китая' },
];
import { getCategoryLabel } from '../../../i18n/categories';
const locale = 'ru';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Серия материалов</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Статьи</p>
            <h2>Серия «Природа Китая»</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/ru/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">Статьи в этой серии пока готовятся. Загляните позже.</p>
        )}
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Полезные инструменты</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Спланируйте поездку</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Города-гейты</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Города для старта</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Другие серии</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>