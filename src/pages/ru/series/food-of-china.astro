---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';

const seriesSlug = 'food-of-china';
const posts = (await getCollection('posts-ru'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Еда Китая — кулинарное путешествие иностранца';
const description = 'Познакомьтесь с гастрономической культурой Китая глазами иностранного путешественника: восемь великих кухонь, региональные виды хот-пота, безопасность уличной еды, димсамы, завтраки, вегетарианские варианты и блюда, ради которых стоит ехать через весь город.';

const relatedTools = [
  { href: '/ru/posts/ordering-food-in-china-without-chinese-meituan-ele-me/', title: 'Заказывать еду без китайского', desc: 'Настройка Meituan и Ele.me для иностранцев' },
  { href: '/ru/posts/how-to-pay-in-china-tourist-guide/', title: 'Как платить в Китае', desc: 'Alipay, WeChat Pay и наличные при оплате еды' },
  { href: '/ru/food/', title: 'Гайды по еде и ресторанам', desc: 'Все материалы о еде на ChinaTripBox' },
];

const relatedCities = [
  { href: '/ru/posts/chengdu-city-guide-for-foreigners/', title: 'Чэнду', desc: 'Столица сычуаньской кухни' },
  { href: '/ru/posts/beijing-city-guide-for-foreigners/', title: 'Пекин', desc: 'Утка по-пекински и северная кухня' },
  { href: '/ru/posts/shanghai-city-guide-for-foreigners/', title: 'Шанхай', desc: 'Сяолунбао и гастрономические сочетания' },
];

const otherSeries = [
  { href: '/ru/series/history-of-china/', title: 'История Китая' },
  { href: '/ru/series/culture-of-china/', title: 'Культура Китая' },
  { href: '/ru/series/modern-china/', title: 'Современный Китай' },
];
import { getCategoryLabel } from '../../../i18n/categories';
const locale = 'ru';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Серия материалов</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Статьи</p>
            <h2>Серия «Еда Китая»</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/ru/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">Материалы этой серии готовятся. Загляните чуть позже.</p>
        )}
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Практические материалы</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Как хорошо поесть в Китае</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Гиды по городской еде</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Где поесть</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Другие серии</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>