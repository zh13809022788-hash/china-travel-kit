---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const CATEGORY = 'transport';
const posts = (await getCollection('posts-ru'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Транспорт в Китае: поезда, такси и передвижение по стране';
const description =
  'Как бронировать билеты на скоростные поезда, пользоваться DiDi и общественным транспортом в Китае.';

const transportPaths = [
  { href: '/ru/posts/china-high-speed-rail-guide-foreigners/', title: 'Поезда на дальние расстояния', desc: 'Подойдёт для планирования поездок между городами, выбора класса места, ввода паспортных данных и расчёта времени на вокзале.' },
  { href: '/ru/posts/airport-to-city-transport-beijing-shanghai-guangzhou/', title: 'Как добраться из аэропорта', desc: 'Сравните метро, такси, DiDi и аэроэкспресс для первой поездки в город.' },
  { href: '/ru/posts/didi-china-foreign-tourists-guide/', title: 'Заказ поездок через приложение', desc: 'Настройте DiDi, используйте переведённые точки посадки и сократите сложности при звонках от водителя.' },
  { href: '/ru/posts/shanghai-metro-for-foreigners-tickets-qr-codes-transfers/', title: 'Системы метро', desc: 'Разберитесь с QR-билетами, пересадками и поведением в часы пик на примере шанхайского метро.' },
];
import { getCategoryLabel } from '../../../i18n/categories';
const locale = 'ru';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Транспорт</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Транспорт в Китае</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="hub-transport" alt="Современный скоростной поезд и железнодорожная система в Китае" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-transport">
      <h2 id="featured-transport" class="sr-only">Рекомендуемые гиды по транспорту</h2>
      <a href="/ru/posts/china-high-speed-rail-guide-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Гид по скоростным поездам</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Как купить билеты, выбрать класс и сориентироваться на вокзале</p>
      </a>
      <a href="/ru/posts/book-china-train-tickets-12306-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Бронирование билетов в 12306</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Пошаговая инструкция для иностранцев с паспортом</p>
      </a>
      <a href="/ru/posts/didi-china-foreign-tourists-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Поездки через DiDi</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Как пользоваться китайским сервисом заказа поездок</p>
      </a>
      <a href="/ru/posts/airport-to-city-transport-beijing-shanghai-guangzhou/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Трансфер из аэропорта</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Гиды по Пекину, Шанхаю и Гуанчжоу</p>
      </a>
    </section>

    <section class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4" aria-labelledby="transport-paths">
      <h2 id="transport-paths" class="sr-only">Маршруты планирования транспорта</h2>
      {transportPaths.map((path) => (
        <a href={path.href} class="card block hover:no-underline">
          <h3 class="text-lg font-bold text-gray-950">{path.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{path.desc}</p>
        </a>
      ))}
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/ru/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{getCategoryLabel(post.data.category, locale)}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('ru-RU', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">Гиды скоро появятся.</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>