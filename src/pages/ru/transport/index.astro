---
import { getCollection } from 'astro:content';
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import AdSlot from "../../../components/AdSlot.astro";
import CoverImage from "../../../components/CoverImage.astro";

const CATEGORY = 'transport';
const posts = (await getCollection('posts'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Транспортные гиды по Китаю — поезда, заказ поездок и передвижение по городу';
const description =
  'Узнайте, как бронировать билеты на скоростные поезда, пользоваться сервисом заказа поездок Didi и ориентироваться в общественном транспорте Китая как иностранному туристу.';

const transportPaths = [
  { href: '/posts/china-high-speed-rail-guide-foreigners/', title: 'Междугородние поезда', desc: 'Используйте это руководство для планирования поездок между городами, выбора класса мест, ввода паспортных данных и расчета времени на вокзале.' },
  { href: '/posts/airport-to-city-transport-beijing-shanghai-guangzhou/', title: 'Трансфер из аэропорта', desc: 'Сравните метро, такси, заказ поездок и аэроэкспресс для первой поездки в город.' },
  { href: '/posts/didi-china-foreign-tourists-guide/', title: 'Заказ поездок', desc: 'Настройте DiDi, используйте переведенные точки посадки и сократите необходимость созваниваться с водителем.' },
  { href: '/posts/shanghai-metro-for-foreigners-tickets-qr-codes-transfers/', title: 'Системы метро', desc: 'Узнайте о QR-билетах, пересадках и привычках в часы пик на примере Shanghai.' },
];
import { getCategoryLabel } from "../../../i18n/categories";
const locale = 'en';
---
<!-- Контент создан с помощью ИИ, проверен носителем языка -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Транспорт</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">Транспортные гиды</h1>
      <p class="mt-4 max-w-3xl text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <div class="mt-6">
      <CoverImage name="hub-transport" alt="Современный скоростной поезд и железнодорожная система в Китае" loading="lazy" />
    </div>

    <div class="mt-8 max-w-3xl space-y-4 text-lg leading-8 text-gray-600">
      <p>
        В Китае одна из самых передовых и разветвленных транспортных сетей в мире, поэтому путешествовать как между городами, так и внутри них удивительно удобно. Главная жемчужина этой системы — сеть скоростных железных дорог, крупнейшая на планете, которая соединяет большинство крупных городов поездами, развивающими скорость до 350 км/ч. Поездка из Beijing в Shanghai занимает всего 4,5 часа, а из Beijing в Xian — около 4 часов. Поезда делятся на категории G (скоростные), D (быстрые) и K/T (обычные), при этом поезда категории G считаются самыми комфортными и популярными для дальних поездок. Билеты можно бронировать через официальное приложение 12306 или через Trip.com для бронирования на английском языке.
      </p>
      <p>
        Внутри городов метро работает эффективно, стоит недорого и удобно для туристов, а в крупных городах, таких как Beijing, Shanghai, Guangzhou и Shenzhen, есть указатели на английском языке. DiDi (китайский аналог Uber) отлично работает для иностранцев — просто скачайте приложение и привяжите Alipay или WeChat Pay. Такси широко доступны, но общение на английском может быть затруднено, поэтому полезно иметь адреса, записанные по-китайски. Для дальних расстояний также хорошим вариантом будут внутренние авиарейсы: крупные авиакомпании, такие как China Southern, Air China и China Eastern, предлагают конкурентные цены. Для полноценного опыта лучше всего сочетать скоростные поезда для поездок между регионами с метро и DiDi для местного транспорта.
      </p>
    </div>

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-transport">
      <h2 id="featured-transport" class="sr-only">Рекомендуемые транспортные гиды</h2>
      <a href="/posts/china-high-speed-rail-guide-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Гид по скоростным поездам</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Бронирование билетов, выбор классов, навигация по вокзалам</p>
      </a>
      <a href="/posts/book-china-train-tickets-12306-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Бронирование билетов на поезд в 12306</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Пошаговое руководство с иностранным паспортом</p>
      </a>
      <a href="/posts/didi-china-foreign-tourists-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Заказ поездок в DiDi</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Как пользоваться китайским сервисом заказа поездок иностранному туристу</p>
      </a>
      <a href="/posts/airport-to-city-transport-beijing-shanghai-guangzhou/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Трансфер из аэропорта</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Гиды по Beijing, Shanghai и Guangzhou</p>
      </a>
    </section>

    <section class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4" aria-labelledby="transport-paths">
      <h2 id="transport-paths" class="sr-only">Маршруты планирования транспорта</h2>
      {transportPaths.map((path) => (
        <a href={path.href} class="card block hover:no-underline">
          <h3 class="text-lg font-bold text-gray-950">{path.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{path.desc}</p>
        </a>
      ))}
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{getCategoryLabel(post.data.category, locale)}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">Гиды скоро появятся.</p>}
    </section>

    <section class="mt-12 rounded-lg border border-gray-200 bg-gray-50 p-6">
      <h2 class="text-xl font-bold text-gray-950">Основные транспортные гиды</h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <a href="/posts/china-high-speed-rail-guide-foreigners/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Гид по скоростным поездам</p>
          <p class="mt-1 text-sm text-gray-600">Классы мест, советы по бронированию и навигация по вокзалам</p>
        </a>
        <a href="/posts/book-china-train-tickets-12306-foreigners/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Бронирование билетов на поезд</p>
          <p class="mt-1 text-sm text-gray-600">Пошаговое руководство по 12306 с иностранным паспортом</p>
        </a>
        <a href="/posts/didi-china-foreign-tourists-guide/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Заказ поездок в DiDi</p>
          <p class="mt-1 text-sm text-gray-600">Как пользоваться китайским сервисом заказа поездок иностранному туристу</p>
        </a>
        <a href="/posts/shanghai-metro-for-foreigners-tickets-qr-codes-transfers/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Гид по метро Shanghai</p>
          <p class="mt-1 text-sm text-gray-600">QR-коды, билеты и советы по пересадкам</p>
        </a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>