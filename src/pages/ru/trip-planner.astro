---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';

const title = 'Бесплатный планировщик поездки в Китай';
const description =
  'Составьте практичный первоначальный план первой поездки в Китай с рекомендациями по оплате, eSIM, транспорту, настройке приложений, наличным и чек-листу на первый день.';

const needOptions = [
  { value: 'payment', label: 'Настройка оплаты' },
  { value: 'esim', label: 'eSIM и интернет' },
  { value: 'transport', label: 'Аэропорт и поезда' },
  { value: 'hotel', label: 'Логика выбора района отеля' },
  { value: 'apps', label: 'Приложения и перевод' },
  { value: 'cash', label: 'Запасной вариант с наличными' },
  { value: 'visa', label: 'Безвизовый въезд' },
  { value: 'food', label: 'Еда и доставка' },
];
---
<!-- Контент создан с помощью ИИ, проверен носителем языка -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main>
    <section class="border-b border-gray-200 bg-white">
      <div class="container-page grid gap-8 py-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <div>
          <p class="section-kicker">Бесплатный инструмент для планирования</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Составьте практичный план прибытия в Китай до вылета
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Получите первоначальный план по оплате, данным eSIM, транспорту из аэропорта, настройке приложений,
            запасному варианту с наличными и ритму на каждый день. Он работает в вашем браузере и не сохраняет ваши ответы.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#planner" class="btn-primary">Начать планирование</a>
            <a href="/travel-help/" class="btn-outline">Запросить помощь по поездке</a>
            <a href="/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">Прочитать гид для новичков</a>
          </div>
        </div>

        <aside class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="section-kicker">Лучше всего подходит для</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Подготовки для первого визита</h2>
          <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
            <li>Готовность к оплате до прибытия</li>
            <li>Выбор eSIM, роуминга и доступа к приложениям</li>
            <li>Планирование первого маршрута из аэропорта в город</li>
            <li>Простая структура поездки по городам</li>
          </ul>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <AdSlot format="banner" />

      <section id="planner" class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <form id="trip-planner-form" class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm md:p-6">
          <div class="border-b border-gray-200 pb-5">
            <p class="section-kicker">Детали поездки</p>
            <h2 class="mt-2 text-2xl font-bold text-gray-950">Расскажите, что вам уже известно</h2>
          </div>

          <div class="mt-6 grid gap-5 md:grid-cols-2">
            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Страна или регион проживания
              <input id="home-country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="United States, UK, Singapore..." />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Город прибытия
              <select id="arrival-city" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Shanghai</option>
                <option>Beijing</option>
                <option>Guangzhou</option>
                <option>Shenzhen</option>
                <option>Chengdu</option>
                <option>Hangzhou</option>
                <option>Другой город</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800 md:col-span-2">
              Города назначения
              <input id="destination-cities" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="Shanghai, Hangzhou, Beijing" />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Продолжительность поездки
              <select id="trip-length" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option value="3">3 дня</option>
                <option value="5">5 дней</option>
                <option value="7" selected>7 дней</option>
                <option value="10">10 дней</option>
                <option value="14">14 дней</option>
                <option value="21">21 день или больше</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Цель поездки
              <select id="trip-purpose" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Туризм</option>
                <option>Бизнес</option>
                <option>Длительное пребывание</option>
                <option>Цифровой кочевник</option>
                <option>Семейный визит</option>
                <option>Транзит</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Диапазон бюджета
              <select id="budget-range" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Эконом</option>
                <option selected>Комфорт</option>
                <option>Премиум</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Стиль поездки
              <select id="travel-style" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Эффективный</option>
                <option>Экономный</option>
                <option selected>Комфорт</option>
                <option>Семейный</option>
                <option>Бизнес</option>
                <option>С акцентом на еду</option>
              </select>
            </label>
          </div>

          <fieldset class="mt-6">
            <legend class="text-sm font-semibold text-gray-800">С чем вам нужна помощь?</legend>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              {needOptions.map((option) => (
                <label class="flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-700">
                  <input class="h-4 w-4 rounded border-gray-300 text-brand-600" type="checkbox" name="needs" value={option.value} checked={['payment', 'esim', 'transport', 'apps'].includes(option.value)} />
                  {option.label}
                </label>
              ))}
            </div>
          </fieldset>

          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p id="planner-status" class="text-sm text-gray-500">Аккаунт или конфиденциальные данные не нужны.</p>
            <button class="btn-primary" type="submit">Сгенерировать план</button>
          </div>
        </form>

        <aside class="space-y-6">
          <section class="rounded-lg border border-gray-200 bg-white p-5">
            <p class="section-kicker">Путь к расширенной помощи</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Нужна проверка человеком?</h2>
            <p class="mt-3 text-sm leading-6 text-gray-600">
              Если ваш маршрут, тайминг, схема оплаты или первый день кажутся рискованными, отправьте сгенерированный
              план по email и запросите список исправлений, проверенный человеком.
            </p>
            <a id="planner-email-link" class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:border-brand-600 hover:text-brand-600 hover:no-underline" href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Trip%20Review%20Request">
              Подготовить email для проверки
            </a>
          </section>

          <section class="rounded-lg border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Ограничения</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Используйте это как помощь в планировании</h2>
            <p class="mt-3 text-sm leading-6 text-gray-700">
              Этот инструмент не является юридической, иммиграционной, медицинской, банковской консультацией или советом на случай чрезвычайной ситуации. Проверяйте
              важные правила въезда, авиакомпаний, отелей, карт, телеком-операторов и приложений по официальным источникам.
            </p>
          </section>
        </aside>
      </section>

      <section id="plan-output" class="mt-10 hidden rounded-lg border border-brand-100 bg-brand-50 p-5 md:p-6" aria-live="polite">
        <div class="border-b border-brand-100 pb-4">
          <p class="section-kicker">Сгенерированный план</p>
          <h2 class="mt-2 text-2xl font-bold text-gray-950">Черновик подготовки вашей поездки в Китай</h2>
        </div>
        <div id="plan-content" class="mt-5 grid gap-5"></div>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <a href="/payment/" class="card block hover:no-underline">
          <p class="section-kicker">Оплата</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Подготовьте Alipay и WeChat Pay</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Настройте как минимум один кошелёк и один резервный способ оплаты до прибытия.</p>
        </a>
        <a href="/esim/" class="card block hover:no-underline">
          <p class="section-kicker">Интернет</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Выберите схему с eSIM или роумингом</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Убедитесь, что в первый день вы сможете загружать карты, переводить, писать сообщения и вызывать машину.</p>
        </a>
        <a href="/transport/" class="card block hover:no-underline">
          <p class="section-kicker">Транспорт</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Спланируйте свой первый маршрут</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Заранее узнайте маршрут из аэропорта в отель и когда лучше использовать метро, такси, DiDi или поезд.</p>
        </a>
      </section>

      <section class="mt-10 rounded-lg border border-gray-200 bg-white p-5 md:p-6">
        <p class="section-kicker">Перед использованием планировщика</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950">Прочитайте инструкции по подготовке, если это ваша первая поездка в Китай</h2>
        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <a href="/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Планировщик поездки в Китай для тех, кто едет впервые</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Используйте тот же порядок планирования, что и в этом инструменте: интернет, оплата, маршрут из аэропорта, приложения, порядок городов и чек-лист на первый день.</p>
          </a>
          <a href="/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Что нужно настроить перед поездкой в Китай</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Практичный чек-лист перед выездом для Alipay, WeChat Pay, eSIM, DiDi, билетов на поезд, карт и запасного варианта с наличными.</p>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('trip-planner-form') as HTMLFormElement | null;
  const output = document.getElementById('plan-output');
  const content = document.getElementById('plan-content');
  const status = document.getElementById('planner-status');
  const emailLink = document.getElementById('planner-email-link') as HTMLAnchorElement | null;

  const getValue = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null)?.value.trim() || '';
  const selectedNeeds = () =>
    Array.from(document.querySelectorAll<HTMLInputElement>('input[name="needs"]:checked')).map((input) => input.value);
  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char] ?? char);

  const splitCities = (value: string, arrival: string) => {
    const typed = value
      .split(',')
      .map((city) => city.trim())
      .filter(Boolean);
    const cities = typed.length ? typed : [arrival];
    return Array.from(new Set(cities));
  };

  const list = (items: string[]) => `<ul class="mt-3 grid gap-2 text-sm leading-6 text-gray-700">${items.map((item) => `<li>${item}</li>`).join('')}</ul>`;
  const panel = (title: string, items: string[]) => `
    <section class="rounded-lg border border-gray-200 bg-white p-5">
      <h3 class="text-lg font-bold text-gray-950">${title}</h3>
      ${list(items)}
    </section>
  `;

  const buildPlan = () => {
    const home = getValue('home-country') || 'ваша страна проживания';
    const arrival = getValue('arrival-city') || 'Shanghai';
    const cities = splitCities(getValue('destination-cities'), arrival);
    const days = Number(getValue('trip-length') || '7');
    const purpose = getValue('trip-purpose') || 'Туризм';
    const budget = getValue('budget-range') || 'Комфорт';
    const style = getValue('travel-style') || 'Комфорт';
    const needs = selectedNeeds();
    const perCity = Math.max(1, Math.floor(days / Math.max(1, cities.length)));

    const preDeparture = [
      `Установите Alipay, WeChat, DiDi, приложение для перевода и офлайн-карту до выезда из ${escapeHtml(home)}.`,
      needs.includes('payment')
        ? 'Привяжите одну иностранную карту Visa или Mastercard к Alipay и попробуйте пройти небольшую проверку до вылета.'
        : 'Сделайте схему оплаты простой: один мобильный кошелёк, одна физическая карта и немного наличных RMB.',
      needs.includes('esim')
        ? 'Купите и активируйте eSIM или тариф с роумингом до вылета, а затем сохраните QR-код в офлайне.'
        : 'Убедитесь, что по прибытии на вашем телефоне будет интернет, прежде чем полагаться на карты или вызов машины.',
      'Сохраните адрес отеля на английском и китайском языках, а также ближайшую станцию метро.',
    ];

    const payment = [
      'Основной вариант: Alipay с иностранной картой, потому что для приезжих это обычно самый практичный первый кошелёк.',
      'Резервный вариант: WeChat Pay, если карта успешно привязывается, плюс одна физическая карта Visa или Mastercard.',
      budget === 'Budget'
        ? 'Резерв наличных: возьмите небольшую сумму в RMB для уличных точек, залогов или проблем с картой/кошельком.'
        : 'Резерв наличных: держите достаточно RMB на такси, перекус и один простой приём пищи на случай, если мобильная оплата не сработает.',
      'Не рассчитывайте на Apple Pay или Google Pay как на основной способ оплаты в материковом Китае.',
    ];

    const internet = [
      'Для коротких поездок туристическая eSIM обычно является самым простым вариантом, если ваш телефон поддерживает eSIM.',
      'Для более долгого пребывания или активного использования интернета сравните до прибытия варианты роуминга, eSIM, карманного WiFi и местной SIM-карты.',
      'Проверьте мобильный интернет до выхода из аэропорта, потому что от него зависят платёжные приложения, вызов машины, перевод и карты.',
      'Сохраните информацию об отеле и транспорте офлайн на случай, если первое подключение будет нестабильным.',
    ];

    const transport = [
      `Первый маршрут: спланируйте путь из аэропорта или с вокзала ${escapeHtml(arrival)} до отеля до приземления.`,
      'Используйте метро для предсказуемых городских маршрутов, DiDi для поездок от двери до двери, а скоростную железную дорогу для перемещений между городами.',
      needs.includes('transport')
        ? 'В дни поездок на поезде по возможности бронируйте заранее и следите, чтобы паспортные данные совпадали с данными на платформе продажи билетов.'
        : 'Избегайте слишком плотных пересадок в один день между международными рейсами и дальними поездами.',
      'Держите наготове карточку с адресом на китайском для такси или стойки регистрации в отеле.',
    ];

    const dayPlan = cities.map((city, index) => {
      const start = index * perCity + 1;
      const end = index === cities.length - 1 ? days : Math.min(days, start + perCity - 1);
      return `Дни ${start}-${end}: ${escapeHtml(city)} — сделайте первую половину дня легче, подтвердите оплату/интернет, затем группируйте места по районам.`;
    });

    const mistakes = [
      'Не откладывайте настройку всех приложений, карт и тарифного плана до прибытия.',
      'Не планируйте насыщенный день осмотра достопримечательностей сразу после дальнего перелёта.',
      'Не полагайтесь только на один способ оплаты.',
      purpose === 'Business'
        ? 'Для деловой поездки закладывайте дополнительное время на трафик, проверки безопасности, счета и доступ в здания.'
        : 'Для туристической поездки оставляйте один гибкий блок каждые два или три дня на случай погоды, толпы или усталости.',
      style === 'Food-focused'
        ? 'Для поездок с акцентом на еду сохраняйте названия ресторанов на китайском и проверяйте часы работы, прежде чем ехать через весь город.'
        : 'Держите простой резервный план по еде рядом с вашим отелем.',
    ];

    const html = [
      panel('Чек-лист перед выездом', preDeparture),
      panel('Настройка оплаты и наличных', payment),
      panel('Настройка интернета и приложений', internet),
      panel('Транспорт и первый день', transport),
      panel('Простая структура по дням', dayPlan),
      panel('Предупреждения о типичных ошибках', mistakes),
    ].join('');

    const emailBody = [
      'ChinaTripBox Trip Review Request',
      '',
      `Home country or region: ${home}`,
      `Arrival city: ${arrival}`,
      `Destination cities: ${cities.join(', ')}`,
      `Trip length: ${days} days`,
      `Purpose: ${purpose}`,
      `Budget: ${budget}`,
      `Style: ${style}`,
      `Needs: ${needs.join(', ') || 'not specified'}`,
      '',
      'Please review my China trip setup for payment, eSIM, transport, timing, and first-day mistakes.',
    ].join('\n');

    if (emailLink) {
      emailLink.href = `mailto:zh13809022788@gmail.com?subject=${encodeURIComponent(
        'ChinaTripBox Trip Review Request',
      )}&body=${encodeURIComponent(emailBody)}`;
    }

    return html;
  };

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!content || !output) return;
    content.innerHTML = buildPlan();
    output.classList.remove('hidden');
    output.scrollIntoView({ behavior: 'smooth', block: 'start' });
    if (status) status.textContent = 'План сгенерирован. Вы можете изменить ответы и создать его заново в любое время.';
  });
</script>