---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'Помощь в поездке по China';
const description =
  'Задавайте индивидуальные вопросы о поездке в China: оплата, eSIM, транспорт, приложения и подготовка первого дня с первичной сортировкой AI и необязательной помощью человека.';

const quickPrompts = [
  'Моя карта не привязывается к Alipay или WeChat Pay.',
  'Мне нужен план eSIM и доступа к приложениям для поездки.',
  'Мне нужна помощь с маршрутом из аэропорта до отеля.',
  'Я не уверен, сколько наличных взять.',
];

const supportAreas = [
  'Настройка оплаты: Alipay, WeChat Pay, карты, комиссии и запас наличных',
  'Связь: eSIM, роуминг, приложения, чувствительные к VPN, и интернет при прибытии в аэропорт',
  'Транспорт: маршруты из аэропорта, метро, DiDi, такси и основы скоростных поездов',
  'Использование приложений: перевод, доставка еды, карты, вызов машины и скриншоты',
  'Подготовка поездки: чек-лист первого дня, подготовка по городам и практические следующие шаги',
  'Передача человеку: сложные случаи, где нужен контекст и переписка',
];

const safetyRules = [
  'Не отправляйте фотографии паспорта, полные номера карт, пароли, PIN-коды или одноразовые коды.',
  'Не просите никого входить в ваши аккаунты или проходить проверку личности за вас.',
  'Не используйте это для юридических, иммиграционных, медицинских, банковских или экстренных консультаций.',
  'Проверяйте важные правила у официальных источников, авиакомпаний, банков, операторов связи или операторов приложений.',
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main>
    <section class="border-b border-gray-200 bg-white">
      <div class="container-page grid gap-8 py-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <div>
          <p class="section-kicker">Индивидуальная поддержка в поездке</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Задайте вопрос о поездке в China, пока он не замедлил вас
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Начните с бесплатной помощи AI по практическим проблемам поездки в China. Если вопрос
            требует человеческой оценки, скриншотов или уточняющей переписки, превратите его в запрос на проверку.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#travel-help-chat" class="btn-primary">Начать запрос</a>
            <a href="/ru/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-outline">Использовать чек-лист перед поездкой</a>
            <a href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Travel%20Help%20Request" class="btn-outline">
              Написать напрямую
            </a>
          </div>
        </div>

        <aside class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Пилотный статус</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Сначала AI, затем проверка человеком</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Бесплатные ответы генерируются AI. Помощь по поездке с проверкой человеком пока
            направляется через email, пока мы тестируем процесс.
          </p>
          <dl class="mt-5 grid gap-3 text-sm">
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">Лучше всего для</dt>
              <dd class="font-semibold text-gray-900">Практической подготовки поездки</dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">Путь ответа</dt>
              <dd class="font-semibold text-gray-900">AI + продолжение по email</dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">Оплата</dt>
              <dd class="font-semibold text-gray-900">Не активно</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <section id="travel-help-chat" class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
          <div class="border-b border-gray-200 bg-gray-50 px-5 py-4">
          <p class="section-kicker">Бесплатная помощь AI в поездке</p>
            <h2 class="mt-1 text-2xl font-bold text-gray-950">Служба помощи в поездке</h2>
          </div>

          <div class="grid gap-0 md:grid-cols-[minmax(0,1fr)_280px]">
            <div class="flex min-h-[560px] flex-col">
              <div id="chat-log" class="flex-1 space-y-4 overflow-y-auto p-5" aria-live="polite">
                <div class="max-w-[88%] rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-700">
                  <strong class="block text-gray-950">Помощь ChinaTripBox</strong>
                  Расскажите, что вы пытаетесь сделать, на каком этапе поездки находитесь и что уже
                  произошло. Помощник AI предложит следующие шаги и отметит, когда лучше проверка человеком.
                </div>
              </div>

              <div class="border-t border-gray-200 p-4">
                <div class="mb-3 flex flex-wrap gap-2">
                  {quickPrompts.map((prompt) => (
                    <button
                      type="button"
                      class="quick-prompt rounded-full border border-gray-200 bg-white px-3 py-1.5 text-left text-xs font-medium text-gray-700 hover:border-brand-300 hover:bg-brand-50"
                      data-prompt={prompt}
                    >
                      {prompt}
                    </button>
                  ))}
                </div>
                <form id="travel-help-form" class="grid gap-3">
                  <label class="sr-only" for="help-message">Ваш вопрос о поездке</label>
                  <textarea
                    id="help-message"
                    name="message"
                    rows="5"
                    class="w-full resize-y rounded-lg border border-gray-300 px-4 py-3 text-sm leading-6 text-gray-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
                    placeholder="Пример: я прилетаю в Shanghai завтра. Моя Mastercard не привязывается к WeChat Pay, но Alipay работает. Смогу ли я пользоваться метро, DiDi и доставкой еды?"
                    required
                  ></textarea>
                  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <p id="form-status" class="text-sm text-gray-500">Не указывайте чувствительные персональные данные.</p>
                    <button id="help-submit" type="submit" class="btn-primary">Спросить AI</button>
                  </div>
                </form>
              </div>
            </div>

            <aside class="border-t border-gray-200 bg-gray-50 p-5 md:border-l md:border-t-0">
              <h3 class="text-lg font-bold text-gray-950">Детали запроса</h3>
              <div class="mt-4 grid gap-4">
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  Этап поездки
                  <select id="trip-stage" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                    <option>До выезда</option>
                    <option>В аэропорту</option>
                    <option>Уже в China</option>
                    <option>Планирование длительного пребывания</option>
                  </select>
                </label>
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  Основная тема
                  <select id="help-topic" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                    <option>Платёжные приложения</option>
                    <option>Интернет и eSIM</option>
                    <option>Транспортный маршрут</option>
                    <option>Еда, доставка или местные приложения</option>
                    <option>Общая подготовка поездки</option>
                  </select>
                </label>
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  Город или маршрут
                  <input
                    id="help-location"
                    class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700"
                    placeholder="Shanghai, Beijing, аэропорт до отеля..."
                  />
                </label>
              </div>

              <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-4">
                <p class="text-sm font-bold text-gray-950">Передача человеку</p>
                <p class="mt-2 text-sm leading-6 text-gray-700">
                  Используйте это, когда простого руководства недостаточно. Подготовленный email
                  включает тему, этап, место и вопрос, чтобы человек мог ответить с учётом контекста.
                </p>
              </div>

              <a
                id="email-request-link"
                href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Travel%20Help%20Request"
                class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:border-brand-600 hover:text-brand-600 hover:no-underline"
              >
                Подготовить email-запрос
              </a>
            </aside>
          </div>
        </div>

        <aside class="space-y-6">
          <section class="rounded-lg border border-gray-200 bg-white p-5">
            <p class="section-kicker">Область помощи</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">С чем это может помочь</h2>
            <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
              {supportAreas.map((area) => (
                <li class="border-b border-gray-100 pb-3 last:border-b-0 last:pb-0">{area}</li>
              ))}
            </ul>
          </section>

          <section class="rounded-lg border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Правила безопасности</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Не отправляйте чувствительные данные</h2>
            <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
              {safetyRules.map((rule) => (
                <li>{rule}</li>
              ))}
            </ul>
          </section>
        </aside>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <div class="card">
          <p class="section-kicker">Шаг 1</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Опишите проблему</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Укажите город, приложение, маршрут, срок и то, что вы уже пробовали.
          </p>
        </div>
        <div class="card">
          <p class="section-kicker">Шаг 2</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Получите следующий шаг</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Страница даёт практичный первый ответ и направляет к подходящим руководствам.
          </p>
        </div>
        <div class="card">
          <p class="section-kicker">Шаг 3</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Передайте вопрос по email</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Для индивидуальной помощи отправьте подготовленный email и продолжите разговор приватно.
          </p>
        </div>
      </section>

      <section class="mt-10 rounded-lg border border-gray-200 bg-white p-5 md:p-6">
        <p class="section-kicker">Сначала самообслуживание</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950">Руководства, отвечающие на частые вопросы первой поездки</h2>
        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <a href="/ru/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Планировщик первой поездки в China</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Используйте его, если вы ещё настраиваете оплату, интернет, транспорт и первый день прибытия.</p>
          </a>
          <a href="/ru/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Чек-лист подготовки перед выездом</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Проверьте Alipay, WeChat Pay, eSIM, DiDi, билеты на поезд, перевод, адреса и запас наличных до вылета.</p>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('travel-help-form') as HTMLFormElement | null;
  const message = document.getElementById('help-message') as HTMLTextAreaElement | null;
  const chatLog = document.getElementById('chat-log');
  const status = document.getElementById('form-status');
  const stage = document.getElementById('trip-stage') as HTMLSelectElement | null;
  const topic = document.getElementById('help-topic') as HTMLSelectElement | null;
  const locationInput = document.getElementById('help-location') as HTMLInputElement | null;
  const emailLink = document.getElementById('email-request-link') as HTMLAnchorElement | null;
  const submitButton = document.getElementById('help-submit') as HTMLButtonElement | null;

  const guideLinks: Record<string, { label: string; href: string }> = {
    'Платёжные приложения': { label: 'руководства по настройке оплаты', href: '/ru/payment/' },
    'Интернет и eSIM': { label: 'руководства по eSIM', href: '/ru/esim/' },
    'Транспортный маршрут': { label: 'руководства по транспорту', href: '/ru/transport/' },
    'Еда, доставка или местные приложения': {
      label: 'руководства по доставке еды',
      href: '/ru/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    },
    'Общая подготовка поездки': { label: 'страницы инструментов', href: '/ru/tools/' },
  };

  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char] ?? char);

  const updateEmailLink = () => {
    if (!emailLink) return;
    const selectedStage = stage?.value ?? 'До выезда';
    const selectedTopic = topic?.value ?? 'Общая подготовка поездки';
    const place = locationInput?.value.trim() || 'Не указано';
    const question = message?.value.trim() || '';
    const body = [
      'Запрос помощи в поездке ChinaTripBox',
      '',
      `Этап поездки: ${selectedStage}`,
      `Основная тема: ${selectedTopic}`,
      `Город или маршрут: ${place}`,
      '',
      'Вопрос:',
      question,
      '',
      'Я понимаю, что не следует включать фотографии паспорта, полные номера банковских карт, пароли, PIN-коды или одноразовые коды.',
    ].join('\n');

    emailLink.href = `mailto:zh13809022788@gmail.com?subject=${encodeURIComponent(
      `Помощь в поездке: ${selectedTopic}`,
    )}&body=${encodeURIComponent(body)}`;
  };

  const addBubble = (content: string, fromUser = false) => {
    if (!chatLog) return null;
    const wrapper = document.createElement('div');
    wrapper.className = fromUser
      ? 'ml-auto max-w-[88%] rounded-lg bg-brand-600 p-4 text-sm leading-6 text-white'
      : 'max-w-[88%] rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-700';
    wrapper.innerHTML = content;
    chatLog.appendChild(wrapper);
    chatLog.scrollTop = chatLog.scrollHeight;
    return wrapper;
  };

  const formatAiAnswer = (value: string) =>
    escapeHtml(value)
      .replace(/\n{3,}/g, '\n\n')
      .replace(/\n/g, '<br>');

  const buildReply = (question: string) => {
    const selectedTopic = topic?.value ?? 'Общая подготовка поездки';
    const selectedStage = stage?.value ?? 'До выезда';
    const place = locationInput?.value.trim();
    const guide = guideLinks[selectedTopic] ?? guideLinks['Общая подготовка поездки'];
    const needsHuman =
      /screenshot|photo|declin|failed|stuck|urgent|tomorrow|today|passport|verification|identity|hotel|route/i.test(
        question,
      );

    const placeLine = place
      ? `Поскольку это связано с <strong>${escapeHtml(place)}</strong>, укажите в email точный аэропорт, станцию, район отеля, название приложения и дату.`
      : 'Добавьте город, аэропорт, станцию, район отеля или название приложения перед отправкой запроса на индивидуальную помощь.';

    const escalation = needsHuman
      ? 'Похоже, этот вопрос подходит для передачи человеку, потому что может потребоваться контекст или уточняющие проверки.'
      : 'Возможно, сначала достаточно руководства; используйте передачу человеку, если руководство не совпадает с вашей конкретной ситуацией.';

    return `
      <strong class="block text-gray-950">Рекомендуемый следующий шаг</strong>
      <span class="block mt-1">Тема: ${escapeHtml(selectedTopic)}. Этап: ${escapeHtml(selectedStage)}.</span>
      <span class="block mt-2">${placeLine}</span>
      <span class="block mt-2">Начните с <a href="${guide.href}" class="font-semibold text-brand-700">${guide.label}</a>, затем используйте кнопку подготовленного email, если всё ещё нужна индивидуальная помощь.</span>
      <span class="block mt-2">${escalation}</span>
    `;
  };

  document.querySelectorAll<HTMLButtonElement>('.quick-prompt').forEach((button) => {
    button.addEventListener('click', () => {
      if (!message) return;
      message.value = button.dataset.prompt ?? '';
      message.focus();
      updateEmailLink();
    });
  });

  [message, stage, topic, locationInput].forEach((element) => {
    element?.addEventListener('input', updateEmailLink);
    element?.addEventListener('change', updateEmailLink);
  });

  const requestAiAnswer = async (question: string) => {
    const response = await fetch('/api/travel-help', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({
        message: question,
        stage: stage?.value ?? 'До выезда',
        topic: topic?.value ?? 'Общая подготовка поездки',
        location: locationInput?.value.trim() ?? '',
      }),
    });

    const data = await response.json() as { answer?: string; error?: string };
    if (!response.ok || !data.answer) {
      throw new Error(data.error || 'Помощник AI недоступен.');
    }
    return data.answer;
  };

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const question = message?.value.trim() ?? '';
    if (!question) {
      if (status) status.textContent = 'Сначала добавьте вопрос.';
      return;
    }
    addBubble(escapeHtml(question), true);
    const thinking = addBubble('AI проверяет ваш вопрос о поездке...');
    if (status) status.textContent = 'Запрос к AI-помощнику по поездке...';
    if (submitButton) submitButton.disabled = true;

    try {
      const answer = await requestAiAnswer(question);
      if (thinking) {
        thinking.innerHTML = `
          <strong class="block text-gray-950">Помощь AI в поездке</strong>
          <span class="mt-2 block">${formatAiAnswer(answer)}</span>
          <span class="mt-3 block text-xs text-gray-500">Для сложных вопросов аккаунта, оплаты, визы, юридических, медицинских или экстренных ситуаций проверяйте информацию у официального поставщика или запросите проверку человеком.</span>
        `;
      }
      if (status) status.textContent = 'Ответ AI готов. Используйте email, если нужна проверка человеком.';
    } catch {
      if (thinking) thinking.innerHTML = buildReply(question);
      if (status) status.textContent = 'AI недоступен, поэтому подготовлен локальный запасной ответ.';
    } finally {
      if (submitButton) submitButton.disabled = false;
    }
    updateEmailLink();
  });

  updateEmailLink();
</script>
