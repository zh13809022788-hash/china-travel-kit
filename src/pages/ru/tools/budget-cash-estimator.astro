---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Калькулятор бюджета поездки и суммы наличных для Китая';
const description =
  'Оцените дневной бюджет и рекомендуемую сумму наличных для поездки в Китай с учетом длительности, формата путешествия и уровня города. Получите наглядную разбивку в юанях и долларах США.';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Инструмент</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Калькулятор бюджета и наличных</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- Поля ввода -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Длительность поездки (ночей)</span>
        <input id="nights" type="number" min="1" max="60" value="7"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Количество путешественников</span>
        <input id="travelers" type="number" min="1" max="10" value="1"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Формат поездки</span>
        <select id="style" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="budget">Экономный (хостелы, уличная еда, метро)</option>
          <option value="mid" selected>Средний (отели 3–4★, кафе и рестораны)</option>
          <option value="comfort">Комфортный (отели 4–5★, такси, хорошие рестораны)</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Категория города</span>
        <select id="tier" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="tier1">Города 1-го уровня (Пекин, Шанхай, Шэньчжэнь)</option>
          <option value="tier2" selected>Города 2-го уровня (Чэнду, Сиань, Ханчжоу)</option>
          <option value="tier3">Небольшие города и поселки</option>
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="calc-btn" class="btn-primary w-full sm:w-auto">Рассчитать бюджет</button>
      </div>
    </div>

    <!-- Результаты -->
    <div id="result" class="mt-6 hidden">
      <div class="grid gap-5 md:grid-cols-2">
        <div class="card" id="budget-card"></div>
        <div class="card" id="cash-card"></div>
      </div>
      <div class="card mt-5" id="breakdown-card"></div>
      <p class="mt-3 text-xs text-gray-400">
        Расчеты примерные и не включают международные перелеты. Фактические траты зависят от сезона,
        курса валют и ваших привычек. В расчетах используется ориентировочный курс: 7,2 RMB за 1 USD.
      </p>

      <AffiliateCta
        title="Платите как местные и не теряйте деньги на комиссиях"
        description="Подключите удобный способ оплаты для поездки, чтобы почти везде обходиться без наличных."
        buttonText="Посмотреть способы оплаты"
        placeholder={AFFILIATE_LINKS.payment}
      />
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  type StyleKey = 'budget' | 'mid' | 'comfort';
  type TierKey = 'tier1' | 'tier2' | 'tier3';

  const USD_RATE = 7.2; // RMB за USD, ориентировочно

  // Ежедневные расходы на человека в RMB, без проживания.
  const dailySpend: Record<StyleKey, { food: number; transport: number; activities: number; misc: number }> = {
    budget: { food: 80, transport: 30, activities: 40, misc: 30 },
    mid: { food: 180, transport: 70, activities: 100, misc: 60 },
    comfort: { food: 400, transport: 200, activities: 220, misc: 130 },
  };

  // Стоимость проживания за ночь в RMB за номер, из расчета до 2 человек в номере.
  const lodging: Record<StyleKey, number> = {
    budget: 150,
    mid: 450,
    comfort: 1100,
  };

  // Коэффициент стоимости в зависимости от категории города.
  const tierMult: Record<TierKey, number> = {
    tier1: 1.25,
    tier2: 1.0,
    tier3: 0.8,
  };

  const rmb = (n: number) => `¥${Math.round(n).toLocaleString()}`;
  const usd = (n: number) => `$${Math.round(n / USD_RATE).toLocaleString()}`;

  const btn = document.getElementById('calc-btn');
  const result = document.getElementById('result');
  const budgetCard = document.getElementById('budget-card');
  const cashCard = document.getElementById('cash-card');
  const breakdownCard = document.getElementById('breakdown-card');

  const nightsEl = document.getElementById('nights') as HTMLInputElement;
  const travelersEl = document.getElementById('travelers') as HTMLInputElement;
  const styleEl = document.getElementById('style') as HTMLSelectElement;
  const tierEl = document.getElementById('tier') as HTMLSelectElement;

  function calc() {
    if (!budgetCard || !cashCard || !breakdownCard || !result) return;

    const nights = Math.max(1, Math.min(60, Number(nightsEl.value) || 1));
    const travelers = Math.max(1, Math.min(10, Number(travelersEl.value) || 1));
    const style = styleEl.value as StyleKey;
    const tier = tierEl.value as TierKey;
    const mult = tierMult[tier];

    const spend = dailySpend[style];
    const perPersonDaily = (spend.food + spend.transport + spend.activities + spend.misc) * mult;

    // Проживание: один номер на каждые 2 путешественника, с округлением вверх.
    const rooms = Math.ceil(travelers / 2);
    const lodgingTotal = lodging[style] * mult * rooms * nights;

    const spendTotal = perPersonDaily * travelers * nights;
    const grandTotal = spendTotal + lodgingTotal;

    // Рекомендуемая сумма наличных: около 10–15% повседневных расходов, но в разумных пределах.
    const dailyCashFloat = Math.min(perPersonDaily * 0.15 * travelers, 200 * travelers);
    const cashRecommended = Math.min(dailyCashFloat * nights, 2000 + 100 * travelers);

    budgetCard.innerHTML = `
      <h3 class="text-lg font-bold text-gray-900">Примерный общий бюджет</h3>
      <p class="mt-2 text-3xl font-bold text-brand-600">${rmb(grandTotal)}</p>
      <p class="text-sm text-gray-500">≈ ${usd(grandTotal)} для ${travelers} чел. на ${nights} ноч.</p>
      <dl class="mt-4 space-y-2 text-sm">
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Проживание</dt><dd class="font-medium text-gray-900">${rmb(lodgingTotal)}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Повседневные расходы</dt><dd class="font-medium text-gray-900">${rmb(spendTotal)}</dd></div>
        <div class="flex justify-between gap-4 border-t border-gray-100 pt-2"><dt class="text-gray-700 font-semibold">На одного человека</dt><dd class="font-semibold text-gray-900">${rmb(grandTotal / travelers)}</dd></div>
      </dl>`;

    cashCard.innerHTML = `
      <h3 class="text-lg font-bold text-gray-900">Сколько наличных взять с собой</h3>
      <p class="mt-2 text-3xl font-bold text-gray-900">${rmb(cashRecommended)}</p>
      <p class="text-sm text-gray-500">≈ ${usd(cashRecommended)} наличными в RMB</p>
      <p class="mt-4 text-sm text-gray-600">
        В Китае почти везде платят телефоном: в большинстве случаев вам подойдут Alipay или WeChat Pay,
        привязанные к иностранной банковской карте. Наличные стоит брать как запасной вариант для такси без QR-оплаты,
        маленьких торговых точек в сельской местности и автоматов, которые принимают только купюры. Удобнее всего мелкие номиналы: ¥10, ¥20 и ¥50.
      </p>`;

    breakdownCard.innerHTML = `
      <h3 class="text-lg font-bold text-gray-900">Ежедневные расходы <span class="text-sm font-normal text-gray-500">(на человека)</span></h3>
      <dl class="mt-4 grid gap-3 sm:grid-cols-4 text-sm">
        <div><dt class="text-gray-500">Еда</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.food * mult)}</dd></div>
        <div><dt class="text-gray-500">Местный транспорт</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.transport * mult)}</dd></div>
        <div><dt class="text-gray-500">Развлечения</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.activities * mult)}</dd></div>
        <div><dt class="text-gray-500">Прочие расходы</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.misc * mult)}</dd></div>
      </dl>`;

    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  btn?.addEventListener('click', calc);
</script>