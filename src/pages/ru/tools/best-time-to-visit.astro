---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import AffiliateCta from '../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../config';

const title = 'Лучшее время для поездки в Китай — планировщик по городам и месяцам';
const description =
  'Узнайте о погоде, количестве туристов и о том, что взять с собой, в крупнейших городах Китая по месяцам. Спланируйте лучшее время для поездки в Beijing, Shanghai, Xi\'an, Chengdu, Guangzhou и Harbin.';

const cities = ['Beijing', 'Shanghai', "Xi'an", 'Chengdu', 'Guangzhou', 'Harbin'];
const months = ['Янв', 'Фев', 'Мар', 'Апр', 'Май', 'Июн', 'Июл', 'Авг', 'Сен', 'Окт', 'Ноя', 'Дек'];
---
<!-- Контент создан с помощью ИИ, проверен носителем языка -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Инструмент</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Лучшее время для поездки в Китай</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Город</span>
        <select id="city" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {cities.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Месяц поездки</span>
        <select id="month" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {months.map((m, i) => <option value={i}>{m}</option>)}
        </select>
      </label>
    </div>

    <div id="result" class="mt-6">
      <div class="card" id="result-card"></div>
    </div>

    <!-- Travel-season warning note -->
    <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
      <strong>Избегайте толп:</strong> государственные праздники в Китае — особенно Китайский Новый год
      (конец января/февраль), День труда (начало мая) и Национальный день / Золотая неделя (первая неделя октября)
      — вызывают огромный внутренний туристический поток. Билеты на поезда и номера в отелях быстро раскупаются, а цены резко растут. Бронируйте сильно заранее или
      планируйте поездку в обход этих дат.
    </div>

    <AffiliateCta
      title="Бронируйте поезда и отели заранее"
      description="В высокий сезон популярные маршруты быстро распродаются. Заранее забронируйте билеты на скоростные поезда и жильё."
      buttonText="Посмотреть варианты бронирования"
      placeholder={AFFILIATE_LINKS.transport}
    />
  </main>
  <Footer />
</BaseLayout>

