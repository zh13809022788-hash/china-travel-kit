---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';
import FaqSection from '../../../components/FaqSection.astro';

const title = 'Оплата Card Compatibility Checker for China';
const description =
  'Check whether your credit card works with Alipay and WeChat Pay in China. See support status, limits, fees, and how to set up by nationality and card network.';

const nationalities = [
  'United States', 'United Kingdom', 'Canada', 'Australia',
  'Germany', 'France', 'Japan', 'Singapore', 'Other',
];
const cardNetworks = ['Visa', 'Mastercard', 'Amex', 'Discover'];

const nextSteps = [
  { href: '/ru/posts/alipay-foreign-credit-card-step-by-step/', title: 'Set up Alipay with a foreign card' },
  { href: '/ru/posts/link-a-foreign-visa-or-mastercard-to-wechat-pay-in-china/', title: 'Link Visa or Mastercard to WeChat Pay' },
  { href: '/ru/posts/can-you-still-use-cash-in-china-as-a-foreigner-in-2026/', title: 'Know when cash still helps' },
  { href: '/ru/payment/', title: 'See all China payment guides' },
];

const faqItems = [
  {
    question: 'Will every foreign Visa or Mastercard work in China?',
    answer:
      'No. Visa and Mastercard are the safest starting point for Alipay and WeChat Pay, but individual banks can still block verification, reject online wallet binding, or flag China transactions. Keep a second card and a small cash backup.',
  },
  {
    question: 'Should tourists set up both Alipay and WeChat Pay?',
    answer:
      'Yes, if possible. Alipay is often easier for visitors to set up, while WeChat Pay can be useful for mini programs, restaurants, and local services. Having both reduces the chance of being stuck at a merchant.',
  },
  {
    question: 'How much cash should I bring if mobile payment works?',
    answer:
      'Bring enough small notes for airport transport, backup meals, and small shops, but do not rely on cash alone. Many places prefer QR payment, and some staff may not have change ready.',
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Tool</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Оплата Compatibility Checker</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <section class="mt-6 grid gap-4 md:grid-cols-3" aria-label="What this payment checker helps with">
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">Check wallet support</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">See whether your card network is a good fit for Alipay and WeChat Pay.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">Plan around limits</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Review common transaction limits and fees before you make larger purchases.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">Build a backup plan</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Know when to carry cash, switch cards, or prepare both payment apps.</p>
      </div>
    </section>

    <AdSlot format="banner" />

    <!-- Input controls -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Your nationality</span>
        <select id="nationality" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {nationalities.map((n) => <option value={n}>{n}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Card network</span>
        <select id="network" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {cardNetworks.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="check-btn" class="btn-primary w-full sm:w-auto">Check Compatibility</button>
      </div>
    </div>

    <!-- Results -->
    <div id="result" class="mt-6 hidden">
      <div class="grid gap-5 md:grid-cols-2">
        <div class="card" id="alipay-card"></div>
        <div class="card" id="wechat-card"></div>
      </div>

      <AffiliateCta
        title="Set Up a Travel-Ready Card"
        description="Get a prepaid travel card that reliably links with Alipay and WeChat Pay for your China trip."
        buttonText="View Recommended Card"
        placeholder={AFFILIATE_LINKS.payment}
      />
    </div>

    <section class="mt-12 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">How to use this checker</h2>
        <ol class="mt-4 space-y-3 text-sm leading-6 text-gray-600">
          <li><strong class="text-gray-900">1. Choose your passport or residence country.</strong> This helps frame common bank and verification issues.</li>
          <li><strong class="text-gray-900">2. Choose your card network.</strong> Visa and Mastercard are usually the best first choices for China travel wallets.</li>
          <li><strong class="text-gray-900">3. Prepare at least one fallback.</strong> Bring a second card, install both payment apps, and keep small cash for edge cases.</li>
        </ol>
        <p class="mt-4 text-sm leading-6 text-gray-600">
          Оплата rules, wallet verification, and issuer risk checks can change. Treat the result as practical trip planning guidance, then confirm any large transaction limits inside Alipay, WeChat Pay, and your card issuer before departure.
        </p>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Next payment steps</h2>
        <div class="mt-4 grid gap-3">
          {nextSteps.map((item) => (
            <a href={item.href} class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">
              {item.title}
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6" aria-labelledby="payment-checker-seo">
      <h2 id="payment-checker-seo" class="text-2xl font-bold text-gray-900">What this checker can and cannot tell you</h2>
      <p class="mt-3 text-sm leading-6 text-gray-600">
        This tool is designed for pre-departure planning. It helps you think through card network,
        wallet support, likely fee points, and backup methods before you are standing at a China
        checkout counter. It cannot guarantee that your individual bank will approve every payment.
      </p>
      <div class="mt-5 overflow-x-auto rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200 text-sm">
          <thead class="bg-gray-50 text-left text-gray-700">
            <tr>
              <th class="px-4 py-3 font-semibold">Risk</th>
              <th class="px-4 py-3 font-semibold">Why it happens</th>
              <th class="px-4 py-3 font-semibold">Best backup</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 bg-white text-gray-600">
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">Card binding fails</td>
              <td class="px-4 py-3">Issuer blocks wallet verification or 3-D Secure fails.</td>
              <td class="px-4 py-3">Try another Visa/Mastercard from a different bank.</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">Large payment rejected</td>
              <td class="px-4 py-3">Wallet, merchant, or issuer limit triggers a review.</td>
              <td class="px-4 py-3">Split payment, use physical card, or ask hotel/merchant for options.</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">No signal at checkout</td>
              <td class="px-4 py-3">Weak mobile data, no roaming, or app cannot load.</td>
              <td class="px-4 py-3">Use the other wallet, merchant Wi-Fi, or small cash backup.</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-sm leading-6 text-gray-600">
        For the strongest setup, read the full <a href="/ru/posts/how-to-pay-in-china-tourist-guide/" class="font-semibold">China tourist payment guide</a>,
        compare <a href="/ru/posts/alipay-vs-wechat-pay-foreigners/" class="font-semibold">Alipay vs WeChat Pay</a>,
        and keep a small RMB backup using our <a href="/ru/posts/how-much-cash-to-bring-to-china/" class="font-semibold">cash guide</a>.
      </p>
    </section>

    <FaqSection items={faqItems} title="Оплата checker FAQ" />
  </main>
  <Footer />
</BaseLayout>

<script>
  type NetworkKey = 'Visa' | 'Mastercard' | 'Amex' | 'Discover';

  // Static compatibility matrix (representative guidance)
  const matrix: Record<NetworkKey, {
    alipay: { status: string; single: string; daily: string; fee: string; how: string };
    wechat: { status: string; single: string; daily: string; fee: string; how: string };
  }> = {
    Visa: {
      alipay: { status: 'Supported', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% over 200 RMB', how: 'Add card in Alipay Wallet, verify passport' },
      wechat: { status: 'Supported', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% over 200 RMB', how: 'Add card in WeChat Wallet, verify passport' },
    },
    Mastercard: {
      alipay: { status: 'Supported', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% over 200 RMB', how: 'Add card in Alipay Wallet, verify passport' },
      wechat: { status: 'Supported', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% over 200 RMB', how: 'Add card in WeChat Wallet, verify passport' },
    },
    Amex: {
      alipay: { status: 'Partially supported', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% over 200 RMB', how: 'Amex works in Alipay in most cases; keep a Visa/MC backup' },
      wechat: { status: 'Limited', single: 'Varies', daily: 'Varies', fee: '~3% over 200 RMB', how: 'Support is inconsistent; prefer Visa/Mastercard on WeChat' },
    },
    Discover: {
      alipay: { status: 'Limited', single: 'Varies', daily: 'Varies', fee: 'Varies', how: 'Acceptance is limited; a Visa/Mastercard is strongly recommended' },
      wechat: { status: 'Not recommended', single: '—', daily: '—', fee: '—', how: 'Use a Visa or Mastercard instead' },
    },
  };

  const statusColor = (status: string) => {
    if (/^supported/i.test(status)) return 'text-green-700 bg-green-50 border-green-200';
    if (/partial|limited/i.test(status)) return 'text-amber-700 bg-amber-50 border-amber-200';
    return 'text-red-700 bg-red-50 border-red-200';
  };

  function cardHtml(wallet: string, d: { status: string; single: string; daily: string; fee: string; how: string }) {
    return `
      <h3 class="text-lg font-bold text-gray-900">${wallet}</h3>
      <span class="mt-2 inline-block rounded-full border px-3 py-0.5 text-xs font-semibold ${statusColor(d.status)}">${d.status}</span>
      <dl class="mt-4 space-y-2 text-sm">
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Single transaction</dt><dd class="font-medium text-gray-900">${d.single}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Daily limit</dt><dd class="font-medium text-gray-900">${d.daily}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Processing fee</dt><dd class="font-medium text-gray-900">${d.fee}</dd></div>
        <div class="pt-2 text-gray-600"><dt class="text-gray-500">How to set up</dt><dd class="mt-1">${d.how}</dd></div>
      </dl>`;
  }

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const networkEl = document.getElementById('network') as HTMLSelectElement;
  const alipayCard = document.getElementById('alipay-card');
  const wechatCard = document.getElementById('wechat-card');

  btn?.addEventListener('click', () => {
    const net = networkEl.value as NetworkKey;
    const data = matrix[net];
    if (!data || !alipayCard || !wechatCard || !result) return;
    alipayCard.innerHTML = cardHtml('Alipay', data.alipay);
    wechatCard.innerHTML = cardHtml('WeChat Pay', data.wechat);
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
