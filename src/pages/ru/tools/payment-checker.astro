---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';
import FaqSection from '../../../components/FaqSection.astro';

const title = 'Проверка совместимости банковской карты для оплаты в China';
const description =
  'Проверьте, будет ли ваша кредитная карта работать с Alipay и WeChat Pay в China. Узнайте статус поддержки, лимиты, комиссии и настройку по гражданству и платёжной сети.';

const nationalities = [
  'США', 'Великобритания', 'Канада', 'Австралия',
  'Германия', 'Франция', 'Япония', 'Сингапур', 'Другое',
];
const cardNetworks = ['Visa', 'Mastercard', 'Amex', 'Discover'];

const nextSteps = [
  { href: '/ru/posts/alipay-foreign-credit-card-step-by-step/', title: 'Настроить Alipay с иностранной картой' },
  { href: '/ru/posts/link-a-foreign-visa-or-mastercard-to-wechat-pay-in-china/', title: 'Привязать Visa или Mastercard к WeChat Pay' },
  { href: '/ru/posts/can-you-still-use-cash-in-china-as-a-foreigner-in-2026/', title: 'Понять, когда наличные всё ещё помогают' },
  { href: '/ru/payment/', title: 'Смотреть все руководства по оплате в China' },
];

const faqItems = [
  {
    question: 'Будет ли любая иностранная Visa или Mastercard работать в China?',
    answer:
      'Нет. Visa и Mastercard — самый надёжный старт для Alipay и WeChat Pay, но отдельные банки всё равно могут блокировать проверку, отклонять привязку к онлайн-кошельку или помечать операции в China как рискованные. Держите вторую карту и небольшой запас наличных.',
  },
  {
    question: 'Стоит ли туристам настроить и Alipay, и WeChat Pay?',
    answer:
      'Да, если возможно. Alipay часто проще настроить посетителям, а WeChat Pay полезен для мини-программ, ресторанов и местных сервисов. Наличие обоих снижает риск застрять у продавца без подходящего способа оплаты.',
  },
  {
    question: 'Сколько наличных взять, если мобильная оплата работает?',
    answer:
      'Возьмите достаточно мелких купюр для транспорта из аэропорта, запасных приёмов пищи и небольших магазинов, но не полагайтесь только на наличные. Во многих местах предпочитают оплату по QR, а у персонала может не быть сдачи.',
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Инструмент</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Проверка совместимости оплаты</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <section class="mt-6 grid gap-4 md:grid-cols-3" aria-label="С чем помогает этот чекер оплаты">
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">Проверьте поддержку кошельков</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Узнайте, подходит ли сеть вашей карты для Alipay и WeChat Pay.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">Учитывайте лимиты</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Проверьте типичные лимиты операций и комиссии перед крупными покупками.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">Подготовьте запасной план</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Поймите, когда брать наличные, менять карту или готовить оба платёжных приложения.</p>
      </div>
    </section>

    <AdSlot format="banner" />

    <!-- Input controls -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Ваше гражданство</span>
        <select id="nationality" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {nationalities.map((n) => <option value={n}>{n}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Платёжная сеть карты</span>
        <select id="network" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {cardNetworks.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="check-btn" class="btn-primary w-full sm:w-auto">Проверить совместимость</button>
      </div>
    </div>

    <!-- Results -->
    <div id="result" class="mt-6 hidden">
      <div class="grid gap-5 md:grid-cols-2">
        <div class="card" id="alipay-card"></div>
        <div class="card" id="wechat-card"></div>
      </div>

      <AffiliateCta
        title="Подготовьте карту для поездки"
        description="Получите предоплаченную туристическую карту, которую можно надёжно привязать к Alipay и WeChat Pay для поездки в China."
        buttonText="Посмотреть рекомендуемую карту"
        placeholder={AFFILIATE_LINKS.payment}
      />
    </div>

    <section class="mt-12 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">Как пользоваться этим чекером</h2>
        <ol class="mt-4 space-y-3 text-sm leading-6 text-gray-600">
          <li><strong class="text-gray-900">1. Выберите страну паспорта или проживания.</strong> Это помогает учесть типичные проблемы банков и проверки.</li>
          <li><strong class="text-gray-900">2. Выберите платёжную сеть карты.</strong> Visa и Mastercard обычно лучший первый выбор для туристических кошельков в China.</li>
          <li><strong class="text-gray-900">3. Подготовьте хотя бы один запасной вариант.</strong> Возьмите вторую карту, установите оба платёжных приложения и держите немного наличных на крайние случаи.</li>
        </ol>
        <p class="mt-4 text-sm leading-6 text-gray-600">
          Правила оплаты, проверка кошельков и риск-контроль эмитента могут меняться. Используйте результат как практическую подсказку для планирования, а перед вылетом проверьте лимиты крупных операций в Alipay, WeChat Pay и у эмитента вашей карты.
        </p>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Следующие шаги по оплате</h2>
        <div class="mt-4 grid gap-3">
          {nextSteps.map((item) => (
            <a href={item.href} class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">
              {item.title}
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6" aria-labelledby="payment-checker-seo">
      <h2 id="payment-checker-seo" class="text-2xl font-bold text-gray-900">Что этот чекер может и не может сказать</h2>
      <p class="mt-3 text-sm leading-6 text-gray-600">
        Этот инструмент предназначен для планирования до выезда. Он помогает заранее продумать
        платёжную сеть карты, поддержку кошельков, возможные комиссии и запасные способы оплаты,
        прежде чем вы окажетесь у кассы в China. Он не может гарантировать, что конкретный банк
        одобрит каждый платёж.
      </p>
      <div class="mt-5 overflow-x-auto rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200 text-sm">
          <thead class="bg-gray-50 text-left text-gray-700">
            <tr>
              <th class="px-4 py-3 font-semibold">Риск</th>
              <th class="px-4 py-3 font-semibold">Почему это происходит</th>
              <th class="px-4 py-3 font-semibold">Лучший запасной вариант</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 bg-white text-gray-600">
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">Не удаётся привязать карту</td>
              <td class="px-4 py-3">Эмитент блокирует проверку кошелька или не проходит 3-D Secure.</td>
              <td class="px-4 py-3">Попробуйте другую Visa/Mastercard от другого банка.</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">Крупный платёж отклонён</td>
              <td class="px-4 py-3">Срабатывает лимит кошелька, продавца или эмитента.</td>
              <td class="px-4 py-3">Разделите платёж, используйте физическую карту или спросите у отеля/продавца варианты.</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">Нет связи у кассы</td>
              <td class="px-4 py-3">Слабый мобильный интернет, нет роуминга или приложение не загружается.</td>
              <td class="px-4 py-3">Используйте другой кошелёк, Wi-Fi продавца или небольшой запас наличных.</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-sm leading-6 text-gray-600">
        Для самой надёжной подготовки прочитайте полное <a href="/ru/posts/how-to-pay-in-china-tourist-guide/" class="font-semibold">руководство по оплате для туристов в China</a>,
        сравните <a href="/ru/posts/alipay-vs-wechat-pay-foreigners/" class="font-semibold">Alipay и WeChat Pay</a>
        и держите небольшой запас RMB с помощью нашего <a href="/ru/posts/how-much-cash-to-bring-to-china/" class="font-semibold">руководства по наличным</a>.
      </p>
    </section>

    <FaqSection items={faqItems} title="FAQ по чекеру оплаты" />
  </main>
  <Footer />
</BaseLayout>

<script>
  type NetworkKey = 'Visa' | 'Mastercard' | 'Amex' | 'Discover';

  // Static compatibility matrix (representative guidance)
  const matrix: Record<NetworkKey, {
    alipay: { status: string; single: string; daily: string; fee: string; how: string };
    wechat: { status: string; single: string; daily: string; fee: string; how: string };
  }> = {
    Visa: {
      alipay: { status: 'Поддерживается', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% свыше 200 RMB', how: 'Добавьте карту в кошелёк Alipay и подтвердите паспорт' },
      wechat: { status: 'Поддерживается', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% свыше 200 RMB', how: 'Добавьте карту в кошелёк WeChat и подтвердите паспорт' },
    },
    Mastercard: {
      alipay: { status: 'Поддерживается', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% свыше 200 RMB', how: 'Добавьте карту в кошелёк Alipay и подтвердите паспорт' },
      wechat: { status: 'Поддерживается', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% свыше 200 RMB', how: 'Добавьте карту в кошелёк WeChat и подтвердите паспорт' },
    },
    Amex: {
      alipay: { status: 'Частично поддерживается', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% свыше 200 RMB', how: 'Amex в большинстве случаев работает в Alipay; держите запасную Visa/MC' },
      wechat: { status: 'Ограниченная поддержка', single: 'Зависит от случая', daily: 'Зависит от случая', fee: '~3% свыше 200 RMB', how: 'Поддержка нестабильна; для WeChat лучше использовать Visa/Mastercard' },
    },
    Discover: {
      alipay: { status: 'Ограниченная поддержка', single: 'Зависит от случая', daily: 'Зависит от случая', fee: 'Зависит от случая', how: 'Приём ограничен; настоятельно рекомендуется Visa/Mastercard' },
      wechat: { status: 'Не рекомендуется', single: '—', daily: '—', fee: '—', how: 'Вместо этого используйте Visa или Mastercard' },
    },
  };

  const statusColor = (status: string) => {
    if (/^поддерживается/i.test(status)) return 'text-green-700 bg-green-50 border-green-200';
    if (/частично|ограниченная/i.test(status)) return 'text-amber-700 bg-amber-50 border-amber-200';
    return 'text-red-700 bg-red-50 border-red-200';
  };

  function cardHtml(wallet: string, d: { status: string; single: string; daily: string; fee: string; how: string }) {
    return `
      <h3 class="text-lg font-bold text-gray-900">${wallet}</h3>
      <span class="mt-2 inline-block rounded-full border px-3 py-0.5 text-xs font-semibold ${statusColor(d.status)}">${d.status}</span>
      <dl class="mt-4 space-y-2 text-sm">
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Одна операция</dt><dd class="font-medium text-gray-900">${d.single}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Дневной лимит</dt><dd class="font-medium text-gray-900">${d.daily}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Комиссия обработки</dt><dd class="font-medium text-gray-900">${d.fee}</dd></div>
        <div class="pt-2 text-gray-600"><dt class="text-gray-500">Как настроить</dt><dd class="mt-1">${d.how}</dd></div>
      </dl>`;
  }

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const networkEl = document.getElementById('network') as HTMLSelectElement;
  const alipayCard = document.getElementById('alipay-card');
  const wechatCard = document.getElementById('wechat-card');

  btn?.addEventListener('click', () => {
    const net = networkEl.value as NetworkKey;
    const data = matrix[net];
    if (!data || !alipayCard || !wechatCard || !result) return;
    alipayCard.innerHTML = cardHtml('Alipay', data.alipay);
    wechatCard.innerHTML = cardHtml('WeChat Pay', data.wechat);
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
