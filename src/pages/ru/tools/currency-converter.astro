---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import AffiliateCta from '../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../config';

const title = 'Конвертер валют RMB для путешественников в China';
const description =
  'Конвертируйте свою местную валюту в китайские юани (RMB) и обратно, а также смотрите, сколько стоят повседневные вещи в China, чтобы сравнивать цены прямо на месте.';
---
<!-- Контент создан с помощью ИИ, проверен носителем языка -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Инструмент</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Конвертер валют RMB</h1>
<p class="mt-4 max-w-3xl text-lg leading-8 text-gray-600">
  Используйте этот конвертер, чтобы проверять текущие обменные курсы между вашей местной валютой и китайским юанем (RMB/CNY). Справочные цены ниже помогут вам понять типичные расходы: тарелка лапши стоит около 15–25 RMB, поездка на метро — 3–7 RMB, а номер в отеле среднего уровня — 200–500 RMB за ночь. China в основном является безналичным обществом — Alipay и WeChat Pay принимаются повсюду, от уличных торговцев до роскошных отелей. Чтобы получить лучший обменный курс, используйте международную дебетовую карту вашего банка в банкоматах китайских банков или обменивайте валюту в местных банках, а не в аэропортах или отелях.
</p>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- Converter -->
    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-6">
      <div class="grid gap-4 sm:grid-cols-[1fr_auto_1fr] sm:items-end">
        <label class="flex flex-col text-sm">
          <span class="mb-1 font-medium text-gray-700">Ваша валюта</span>
          <div class="flex gap-2">
            <select id="currency" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
              <option value="USD">USD ($)</option>
              <option value="EUR">EUR (€)</option>
              <option value="GBP">GBP (£)</option>
              <option value="AUD">AUD (A$)</option>
              <option value="CAD">CAD (C$)</option>
              <option value="JPY">JPY (¥)</option>
              <option value="SGD">SGD (S$)</option>
            </select>
            <input id="foreign-amount" type="number" min="0" value="100"
              class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
          </div>
        </label>
        <div class="hidden pb-2 text-center text-gray-400 sm:block">⇄</div>
        <label class="flex flex-col text-sm">
          <span class="mb-1 font-medium text-gray-700">Китайский юань (RMB)</span>
          <input id="rmb-amount" type="number" min="0"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
        </label>
      </div>
      <p id="rate-line" class="mt-3 text-sm text-gray-500"></p>
      <p class="mt-1 text-xs text-gray-400">
        Курсы являются приблизительными справочными значениями для планирования, а не актуальными рыночными курсами. Уточняйте точный курс в вашем банке или в онлайн-конвертере на момент проведения операции.
      </p>
    </div>

    <!-- What things cost -->
    <section class="mt-8">
      <h2 class="text-xl font-bold text-gray-900">Сколько стоят вещи в China</h2>
      <p class="mt-1 text-sm text-gray-500">Типичные цены в RMB, с отображением вашей валюты для справки.</p>
      <div id="cost-grid" class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3"></div>
    </section>

    <AffiliateCta
      title="Пропустите обменный пункт"
      description="Привяжите карту без комиссии за конвертацию к Alipay или WeChat Pay и платите по реальному курсу, без наценки при обмене наличных."
      buttonText="Посмотреть настройку оплаты"
      placeholder={AFFILIATE_LINKS.payment}
    />
  </main>
  <Footer />
</BaseLayout>

<script>
  // Approximate reference rates: 1 unit of currency = X RMB.
  const ratesToRmb: Record<string, number> = {
    USD: 7.2,
    EUR: 7.8,
    GBP: 9.1,
    AUD: 4.7,
    CAD: 5.2,
    JPY: 0.048,
    SGD: 5.3,
  };
  const symbols: Record<string, string> = {
    USD: '$', EUR: '€', GBP: '£', AUD: 'A$', CAD: 'C$', JPY: '¥', SGD: 'S$',
  };

  const commonCosts: { label: string; rmb: number }[] = [
    { label: 'Бутылка воды', rmb: 2 },
    { label: 'Поездка на метро', rmb: 4 },
    { label: 'Перекус уличной едой', rmb: 10 },
    { label: 'Кофе (кафе)', rmb: 30 },
    { label: 'Ужин в обычном ресторане', rmb: 45 },
    { label: 'Короткая поездка на DiDi / такси', rmb: 25 },
    { label: 'Высокоскоростная железная дорога (1–2 ч)', rmb: 250 },
    { label: 'Билет в музей / на достопримечательность', rmb: 60 },
    { label: 'Отель среднего уровня / ночь', rmb: 450 },
  ];

  const currencyEl = document.getElementById('currency') as HTMLSelectElement;
  const foreignEl = document.getElementById('foreign-amount') as HTMLInputElement;
  const rmbEl = document.getElementById('rmb-amount') as HTMLInputElement;
  const rateLine = document.getElementById('rate-line');
  const costGrid = document.getElementById('cost-grid');

  function rate() {
    return ratesToRmb[currencyEl.value];
  }
  function sym() {
    return symbols[currencyEl.value];
  }

  function fromForeign() {
    const v = Number(foreignEl.value) || 0;
    rmbEl.value = (v * rate()).toFixed(2);
    updateMeta();
  }
  function fromRmb() {
    const v = Number(rmbEl.value) || 0;
    foreignEl.value = (v / rate()).toFixed(2);
    updateMeta();
  }

  function updateMeta() {
    if (rateLine) {
      rateLine.textContent = `Справочный курс: 1 ${currencyEl.value} ≈ ¥${rate().toFixed(2)} RMB`;
    }
    if (costGrid) {
      costGrid.innerHTML = commonCosts
        .map((c) => `
          <div class="card">
            <span class="text-sm text-gray-500">${c.label}</span>
            <div class="mt-1 flex items-baseline gap-2">
              <span class="text-xl font-bold text-gray-900">¥${c.rmb}</span>
              <span class="text-sm text-brand-600">≈ ${sym()}${(c.rmb / rate()).toFixed(2)}</span>
            </div>
          </div>`)
        .join('');
    }
  }

  foreignEl.addEventListener('input', fromForeign);
  rmbEl.addEventListener('input', fromRmb);
  currencyEl.addEventListener('change', fromForeign);

  fromForeign();
</script>