---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import AdSlot from "../../../components/AdSlot.astro";
import AffiliateCta from "../../../components/AffiliateCta.astro";
import { AFFILIATE_LINKS } from "../../../config";

const title = 'Проверка вилок и напряжения в Китае';
const description =
  'Узнайте, нужен ли вам переходник для вилки или преобразователь напряжения для Китая в зависимости от страны, из которой вы приезжаете. В Китае используются 220V и типы вилок A, C и I.';

const countries = [
  'United States', 'United Kingdom', 'Canada', 'Australia', 'Germany',
  'France', 'Italy', 'Spain', 'Netherlands', 'Japan', 'South Korea',
  'Singapore', 'India', 'Brazil', 'New Zealand', 'Switzerland',
  'South Africa', 'United Arab Emirates', 'Other',
];
---
<!-- Контент создан с помощью ИИ, проверен носителем языка -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Инструмент</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Проверка вилок и напряжения</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-6">
      <label class="flex flex-col text-sm sm:max-w-sm">
        <span class="mb-1 font-medium text-gray-700">Путешествуете из</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <button id="check-btn" class="btn-primary mt-4 w-full sm:w-auto">Проверить, что мне нужно</button>
    </div>

    <!-- Reference: China's own standard -->
    <div class="mt-6 grid gap-4 sm:grid-cols-3">
      <div class="card"><dt class="text-sm text-gray-500">Напряжение</dt><dd class="text-2xl font-bold text-gray-900">220 V</dd></div>
      <div class="card"><dt class="text-sm text-gray-500">Частота</dt><dd class="text-2xl font-bold text-gray-900">50 Hz</dd></div>
      <div class="card"><dt class="text-sm text-gray-500">Типы вилок</dt><dd class="text-2xl font-bold text-gray-900">A · C · I</dd></div>
    </div>

    <!-- Result -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>

      <AffiliateCta
        title="Купите универсальный переходник для Китая"
        description="Компактный универсальный дорожный переходник, который подходит к китайским розеткам и позволяет одновременно заряжать несколько устройств."
        buttonText="Посмотреть рекомендуемый переходник"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  // Each country's domestic voltage and the plug types it uses.
  const data: Record<string, { volts: number; plugs: string[] }> = {
    'United States': { volts: 120, plugs: ['A', 'B'] },
    'Canada': { volts: 120, plugs: ['A', 'B'] },
    'Japan': { volts: 100, plugs: ['A', 'B'] },
    'Brazil': { volts: 127, plugs: ['C', 'N'] },
    'United Kingdom': { volts: 230, plugs: ['G'] },
    'Australia': { volts: 230, plugs: ['I'] },
    'New Zealand': { volts: 230, plugs: ['I'] },
    'Germany': { volts: 230, plugs: ['C', 'F'] },
    'France': { volts: 230, plugs: ['C', 'E'] },
    'Italy': { volts: 230, plugs: ['C', 'F', 'L'] },
    'Spain': { volts: 230, plugs: ['C', 'F'] },
    'Netherlands': { volts: 230, plugs: ['C', 'F'] },
    'Switzerland': { volts: 230, plugs: ['C', 'J'] },
    'South Korea': { volts: 220, plugs: ['C', 'F'] },
    'Singapore': { volts: 230, plugs: ['G'] },
    'India': { volts: 230, plugs: ['C', 'D', 'M'] },
    'South Africa': { volts: 230, plugs: ['C', 'D', 'M', 'N'] },
    'United Arab Emirates': { volts: 230, plugs: ['C', 'D', 'G'] },
    'Other': { volts: 0, plugs: [] },
  };

  // China accepts plug types A, C, and I.
  const CHINA_PLUGS = ['A', 'C', 'I'];
  const CHINA_VOLTS = 220;

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const country = countryEl.value;
    const info = data[country];

    let heading: string, body: string, tone: 'good' | 'warn' | 'info';
    const points: string[] = [];

    if (!info || info.volts === 0) {
      tone = 'info';
      heading = 'Проверьте конкретно вашу вилку и напряжение';
      body = 'У нас нет данных по вашему выбору. Посмотрите на маркировку вашего зарядного устройства: если указано "100–240V", вам нужен только переходник для китайских розеток типа A, C или I.';
      points.push('В Китае используются 220V, 50Hz и типы вилок A, C и I.');
      points.push('Большинство зарядных устройств для телефонов и ноутбуков поддерживают два диапазона напряжения (100–240V), и им нужен только переходник.');
    } else {
      const plugMatch = info.plugs.some((p) => CHINA_PLUGS.includes(p));
      const voltMatch = Math.abs(info.volts - CHINA_VOLTS) <= 20;

      if (plugMatch && voltMatch) {
        tone = 'good';
        heading = 'Скорее всего, переходник вам не нужен';
        body = `В ${country} используются совместимые типы вилок (${info.plugs.join(', ')}) и схожее напряжение (${info.volts}V). Ваши вилки должны напрямую подходить к китайским розеткам.`;
        points.push('На всякий случай проверьте каждую вилку отдельно: возьмите один переходник, если розетка окажется тугой.');
      } else if (!plugMatch && voltMatch) {
        tone = 'warn';
        heading = 'Вам нужен переходник для вилки (но не преобразователь напряжения)';
        body = `В ${country} используется схожее напряжение (${info.volts}V), так что для ваших устройств это безопасно. Но ваш тип вилки (${info.plugs.join(', ')}) не подходит к китайским розеткам, поэтому возьмите переходник.`;
        points.push('Вам нужен только простой недорогой переходник для типа A/C/I.');
        points.push('Громоздкий преобразователь напряжения не требуется.');
      } else if (plugMatch && !voltMatch) {
        tone = 'warn';
        heading = 'Следите за напряжением у устройств с одним диапазоном';
        body = `Ваши вилки (${info.plugs.join(', ')}) могут подойти, но напряжение в ${country} (${info.volts}V) отличается от китайских 220V.`;
        points.push('Телефоны, ноутбуки и камеры с маркировкой 100–240V можно использовать где угодно.');
        points.push('Устройствам с одним диапазоном напряжения (например, некоторым фенам и выпрямителям) нужен преобразователь напряжения, либо их лучше оставить дома.');
      } else {
        tone = 'warn';
        heading = 'Вам нужен переходник для вилки — и нужно проверить напряжение';
        body = `В ${country} используются другие вилки (${info.plugs.join(', ')}) и другое напряжение (${info.volts}V), чем китайские 220V. Возьмите переходник для типа A/C/I.`;
        points.push('Зарядным устройствам с двумя диапазонами напряжения (100–240V) нужен только переходник.');
        points.push('Устройствам с одним диапазоном напряжения и высокой мощностью также нужен преобразователь напряжения — или лучше купить местный аналог.');
      }
    }

    const toneStyles = {
      good: 'border-green-200 bg-green-50',
      warn: 'border-amber-200 bg-amber-50',
      info: 'border-blue-200 bg-blue-50',
    } as const;
    const toneBadge = {
      good: 'bg-green-600 text-white',
      warn: 'bg-amber-500 text-white',
      info: 'bg-blue-600 text-white',
    } as const;
    const toneLabel = { good: 'Переходник не нужен', warn: 'Нужен переходник', info: 'Проверьте зарядное устройство' } as const;

    card.className = `card border ${toneStyles[tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[tone]}">${toneLabel[tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${heading}</h2>
      <p class="mt-2 text-gray-700">${body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>