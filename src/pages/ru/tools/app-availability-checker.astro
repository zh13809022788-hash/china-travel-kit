---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Будут ли мои приложения работать в Китае? Проверка доступности приложений';
const description =
  'Проверьте, работают ли Google, WhatsApp, Instagram и другие приложения в Китае без VPN, и узнайте, чем заменить каждый недоступный сервис.';

interface AppInfo {
  name: string;
  category: string;
  status: 'works' | 'blocked' | 'partial';
  note: string;
  alt?: string;
}

const apps: AppInfo[] = [
  { name: 'Поиск Google', category: 'Google', status: 'blocked', note: 'Без VPN не работает.', alt: 'Bing (работает) или Baidu' },
  { name: 'Google Maps', category: 'Google', status: 'partial', note: 'Открывается, но данные по материковому Китаю могут быть неточными или смещенными.', alt: 'Apple Maps, Amap или Baidu Maps' },
  { name: 'Gmail', category: 'Google', status: 'blocked', note: 'Без VPN не работает.', alt: 'Outlook или другой почтовый сервис не от Google' },
  { name: 'YouTube', category: 'Google', status: 'blocked', note: 'Без VPN не работает.', alt: 'Bilibili (местный сервис)' },
  { name: 'WhatsApp', category: 'Мессенджеры', status: 'blocked', note: 'Без VPN не работает.', alt: 'WeChat' },
  { name: 'Facebook', category: 'Соцсети', status: 'blocked', note: 'Без VPN не работает.', alt: 'WeChat Moments или RED' },
  { name: 'Instagram', category: 'Соцсети', status: 'blocked', note: 'Без VPN не работает.', alt: 'RED (Xiaohongshu)' },
  { name: 'X (Twitter)', category: 'Соцсети', status: 'blocked', note: 'Без VPN не работает.', alt: 'Weibo' },
  { name: 'Telegram', category: 'Мессенджеры', status: 'blocked', note: 'Без VPN не работает.', alt: 'WeChat' },
  { name: 'WeChat', category: 'Мессенджеры', status: 'works', note: 'Полностью работает. Это основной сервис в Китае.' },
  { name: 'Сервисы Apple (iMessage, App Store)', category: 'Apple', status: 'works', note: 'Работают без проблем.' },
  { name: 'Microsoft / Bing / Outlook', category: 'Microsoft', status: 'works', note: 'Работают без проблем.' },
  { name: 'Booking.com', category: 'Путешествия', status: 'works', note: 'Работает без проблем.' },
  { name: 'Airbnb', category: 'Путешествия', status: 'works', note: 'Работает без проблем.' },
  { name: 'Trip.com', category: 'Путешествия', status: 'works', note: 'Полностью работает и особенно удобен для поездов и отелей.' },
  { name: 'Alipay', category: 'Оплата', status: 'works', note: 'Полностью работает и поддерживает иностранные карты.' },
  { name: 'Uber', category: 'Транспорт', status: 'blocked', note: 'В материковом Китае не работает.', alt: 'DiDi' },
  { name: 'Netflix', category: 'Медиа', status: 'blocked', note: 'В материковом Китае недоступен.', alt: 'Местные стриминговые сервисы или загрузка контента заранее' },
  { name: 'Spotify', category: 'Медиа', status: 'blocked', note: 'В материковом Китае недоступен.', alt: 'QQ Music или заранее скачать музыку офлайн' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Инструмент</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Будут ли мои приложения работать в Китае?</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-4">
      <label class="flex flex-col text-sm sm:max-w-sm">
        <span class="mb-1 font-medium text-gray-700">Поиск по приложениям или фильтр</span>
        <input id="search" type="text" placeholder="например: WhatsApp, Google, Netflix"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <div class="mt-3 flex flex-wrap gap-2 text-sm">
        <button data-status="all" class="status-filter btn-primary px-3 py-1">Все</button>
        <button data-status="works" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">✅ Работает</button>
        <button data-status="partial" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">⚠️ Частично работает</button>
        <button data-status="blocked" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">🚫 Не работает</button>
      </div>
    </div>

    <div id="app-list" class="mt-6 grid gap-3 sm:grid-cols-2"></div>
    <p id="no-results" class="hidden py-8 text-center text-gray-500">Ничего не найдено.</p>

    <AffiliateCta
      title="Сохраните доступ к своим приложениям с туристической eSIM"
      description="Туристическая eSIM для Китая поможет обойти местные ограничения, чтобы привычные приложения оставались онлайн без отдельной настройки VPN."
      buttonText="Посмотреть варианты eSIM"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ apps }}>
  const listEl = document.getElementById('app-list');
  const noResults = document.getElementById('no-results');
  const searchEl = document.getElementById('search');
  const filters = document.querySelectorAll('.status-filter');
  let activeStatus = 'all';

  const badge = {
    works: { cls: 'bg-green-100 text-green-800', label: '✅ Работает' },
    partial: { cls: 'bg-amber-100 text-amber-800', label: '⚠️ Частично работает' },
    blocked: { cls: 'bg-red-100 text-red-800', label: '🚫 Не работает' },
  };

  function render() {
    const q = searchEl.value.trim().toLowerCase();
    const list = apps.filter((a) => {
      const matchStatus = activeStatus === 'all' || a.status === activeStatus;
      const matchQuery = !q || a.name.toLowerCase().includes(q) || a.category.toLowerCase().includes(q);
      return matchStatus && matchQuery;
    });

    listEl.innerHTML = list
      .map((a) => `
        <div class="card">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="font-bold text-gray-900">${a.name}</h3>
              <span class="text-xs text-gray-400">${a.category}</span>
            </div>
            <span class="whitespace-nowrap rounded-full px-2.5 py-0.5 text-xs font-semibold ${badge[a.status].cls}">${badge[a.status].label}</span>
          </div>
          <p class="mt-2 text-sm text-gray-600">${a.note}</p>
          ${a.alt ? `<p class="mt-1.5 text-sm"><span class="text-gray-500">Чем заменить:</span> <span class="font-medium text-brand-600">${a.alt}</span></p>` : ''}
        </div>`)
      .join('');

    noResults.classList.toggle('hidden', list.length > 0);
  }

  searchEl.addEventListener('input', render);
  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeStatus = btn.dataset.status;
      filters.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('btn-primary', on);
        ['rounded-lg', 'border', 'border-gray-300', 'font-medium', 'text-gray-700'].forEach((c) => b.classList.toggle(c, !on));
      });
      render();
    });
  });

  render();
</script>
