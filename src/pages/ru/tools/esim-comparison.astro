---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import AffiliateCta from '../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../config';

const title = 'Сравнение тарифов eSIM для поездки в China';
const description =
  'Сравните лучшие туристические тарифы eSIM для China по объему данных, сроку действия, цене и сети. Используйте фильтры и сортировку, чтобы подобрать лучший тариф для своей поездки.';

// 8 preset China travel eSIM products (representative sample data)
const plans = [
  { id: 1, name: 'China Explorer 5GB', data: 5, dataLabel: '5 GB', days: 7, price: 9.5, network: 'China Unicom', note: 'Обходит ограничения местных приложений' },
  { id: 2, name: 'China Explorer 10GB', data: 10, dataLabel: '10 GB', days: 15, price: 16, network: 'China Unicom', note: 'Обходит ограничения местных приложений' },
  { id: 3, name: 'Mainland Lite 3GB', data: 3, dataLabel: '3 GB', days: 7, price: 6.5, network: 'China Mobile', note: 'Локальная сеть, без маршрутизации через VPN' },
  { id: 4, name: 'Greater China 8GB', data: 8, dataLabel: '8 GB', days: 30, price: 18.9, network: 'China Unicom', note: 'Покрывает CN, HK, MO, TW' },
  { id: 5, name: 'Unlimited Daily', data: 9999, dataLabel: 'Unlimited*', days: 10, price: 29, network: 'China Unicom', note: 'Ограничение fair-use после 2 ГБ/день' },
  { id: 6, name: 'Business 20GB', data: 20, dataLabel: '20 GB', days: 30, price: 32, network: 'China Unicom', note: 'Обходит ограничения местных приложений' },
  { id: 7, name: 'Short Trip 1GB', data: 1, dataLabel: '1 GB', days: 3, price: 3.2, network: 'China Mobile', note: 'Лучший вариант для коротких пересадок' },
  { id: 8, name: 'Family 30GB', data: 30, dataLabel: '30 GB', days: 30, price: 45, network: 'China Unicom', note: 'Можно раздавать через hotspot' },
];
---
<!-- Контент создан с помощью ИИ, проверен носителем языка -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Инструмент</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Сравнение тарифов eSIM</h1>
<p class="mt-4 max-w-3xl text-lg leading-8 text-gray-600">
  eSIM — это самый удобный способ оставаться на связи во время поездки в China. В отличие от физических SIM-карт, eSIM является цифровой: вы покупаете тариф онлайн и активируете его мгновенно, без посещения магазина и замены своей основной SIM-карты. Большинство eSIM для China работают либо в сети China Unicom, либо China Mobile, и обе обеспечивают отличное покрытие 4G и 5G в городах и большинстве сельских районов. При выборе тарифа учитывайте продолжительность поездки, ваши потребности в интернете и то, нужен ли вам китайский номер телефона для таких приложений, как DiDi и Meituan. Для коротких поездок (1-7 дней) небольшого тарифа на 1-3 ГБ достаточно для карт и сообщений. Для более длительного пребывания или активного использования стоит рассмотреть безлимитные тарифы или тарифы на 10+ ГБ с поддержкой раздачи интернета.
</p>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- Controls -->
    <div class="mt-6 flex flex-wrap items-end gap-4 rounded-xl border border-gray-200 bg-gray-50 p-4">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Сортировать по</span>
        <select id="sort-by" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="price-asc">Цена: по возрастанию</option>
          <option value="price-desc">Цена: по убыванию</option>
          <option value="data-desc">Данные: от большего к меньшему</option>
          <option value="days-desc">Срок действия: от большего к меньшему</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Сеть</span>
        <select id="filter-network" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="all">Все сети</option>
          <option value="China Unicom">China Unicom</option>
          <option value="China Mobile">China Mobile</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Мин. объем данных (ГБ)</span>
        <select id="filter-data" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="0">Любой</option>
          <option value="5">5+ ГБ</option>
          <option value="10">10+ ГБ</option>
          <option value="20">20+ ГБ</option>
        </select>
      </label>
    </div>

    <!-- Comparison table -->
    <div class="mt-6 overflow-x-auto">
      <table class="w-full min-w-[720px] border-collapse text-sm">
        <thead>
          <tr class="border-b-2 border-gray-200 text-left text-gray-500">
            <th class="py-3 pr-4 font-semibold">Тариф</th>
            <th class="py-3 pr-4 font-semibold">Данные</th>
            <th class="py-3 pr-4 font-semibold">Срок действия</th>
            <th class="py-3 pr-4 font-semibold">Цена (USD)</th>
            <th class="py-3 pr-4 font-semibold">Сеть</th>
            <th class="py-3 pr-4 font-semibold">Примечания</th>
          </tr>
        </thead>
        <tbody id="plan-rows"></tbody>
      </table>
      <p id="no-results" class="hidden py-8 text-center text-gray-500">Нет тарифов, соответствующих вашим фильтрам.</p>
    </div>

    <AffiliateCta
      title="Готовы оставаться на связи?"
      description="Активируйте рекомендованную eSIM для China и выходите в интернет сразу после приземления."
      buttonText="Получить eSIM"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ plans }}>
  const rowsEl = document.getElementById('plan-rows');
  const noResults = document.getElementById('no-results');
  const sortBy = document.getElementById('sort-by');
  const filterNetwork = document.getElementById('filter-network');
  const filterData = document.getElementById('filter-data');

  function render() {
    let list = [...plans];
    const net = filterNetwork.value;
    const minData = Number(filterData.value);

    if (net !== 'all') list = list.filter((p) => p.network === net);
    if (minData > 0) list = list.filter((p) => p.data >= minData);

    switch (sortBy.value) {
      case 'price-asc': list.sort((a, b) => a.price - b.price); break;
      case 'price-desc': list.sort((a, b) => b.price - a.price); break;
      case 'data-desc': list.sort((a, b) => b.data - a.data); break;
      case 'days-desc': list.sort((a, b) => b.days - a.days); break;
    }

    rowsEl.innerHTML = list
      .map(
        (p) => `
      <tr class="border-b border-gray-100">
        <td class="py-3 pr-4 font-semibold text-gray-900">${p.name}</td>
        <td class="py-3 pr-4">${p.dataLabel}</td>
        <td class="py-3 pr-4">${p.days} дней</td>
        <td class="py-3 pr-4 font-semibold">$${p.price.toFixed(2)}</td>
        <td class="py-3 pr-4">${p.network}</td>
        <td class="py-3 pr-4 text-gray-500">${p.note}</td>
      </tr>`
      )
      .join('');

    noResults.classList.toggle('hidden', list.length > 0);
  }

  [sortBy, filterNetwork, filterData].forEach((el) => el.addEventListener('change', render));
  render();
</script>