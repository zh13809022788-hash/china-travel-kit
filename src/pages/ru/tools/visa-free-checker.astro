---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import AdSlot from "../../../components/AdSlot.astro";
import AffiliateCta from "../../../components/AffiliateCta.astro";
import { AFFILIATE_LINKS } from "../../../config";

const title = 'Проверка безвизового въезда и транзита в Китай';
const description =
  'Проверьте, можете ли вы въехать в Китай без визы, воспользоваться 240-часовым безвизовым транзитом или вам нужно подавать заявление в зависимости от вашего гражданства и типа поездки.';

const lastReviewed = '13 июля 2026 г.';

// Representative policy data for 2026. This is guidance, not legal advice;
// travelers must confirm with an embassy before booking.
const countries = [
  'United States', 'United Kingdom', 'Canada', 'Australia', 'Germany',
  'France', 'Italy', 'Spain', 'Netherlands', 'Japan', 'South Korea',
  'Singapore', 'Malaysia', 'Thailand', 'Brazil', 'New Zealand',
  'Switzerland', 'Ireland', 'Norway', 'Other',
];
---
<!-- Контент создан с помощью ИИ, проверен носителем языка -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Инструмент</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Проверка безвизового въезда и транзита</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <p class="mt-3 text-sm text-gray-500">
        Последняя проверка: {lastReviewed}. Этот инструмент помогает с планированием, но не является официальным решением о праве на въезд.
      </p>
    </header>

    <AdSlot format="banner" />

    <!-- Input controls -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Гражданство по паспорту</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Тип поездки</span>
        <select id="trip" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="tourism">Туризм / визит</option>
          <option value="business">Бизнес</option>
          <option value="transit">Только транзит в другую страну</option>
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="check-btn" class="btn-primary w-full sm:w-auto">Проверить право на въезд</button>
      </div>
    </div>

    <!-- Result -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>
      <p class="mt-3 text-xs text-gray-400">
        Правила часто меняются и зависят от ваших конкретных обстоятельств. Всегда уточняйте информацию
        в посольстве или консульстве Китая перед бронированием поездки. Этот инструмент предоставляет только общие рекомендации.
      </p>

      <AffiliateCta
        title="Спланируйте остальную часть поездки"
        description="Заранее решите вопросы со связью, оплатой и транспортом до прибытия в Китай."
        buttonText="Посмотреть всё необходимое для поездки"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6" aria-labelledby="official-sources">
      <h2 id="official-sources" class="text-xl font-bold text-gray-950">Официальные источники, которые нужно проверить перед бронированием</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        Списки стран с безвизовым режимом, пункты въезда, разрешённые зоны поездок и проверки посадки авиакомпаниями могут меняться.
        Считайте окончательными правила официальных государственных органов и авиакомпаний.
      </p>
      <ul class="mt-4 grid gap-2 text-sm leading-6 text-gray-700">
        <li><a href="https://en.nia.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">National Immigration Administration</a> для обновлений о пограничном контроле и транзитных исключениях.</li>
        <li><a href="https://english.www.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">Государственный информационный портал</a> для англоязычных объявлений об изменениях политики.</li>
        <li><a href="https://www.mfa.gov.cn/eng/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">Ministry of Foreign Affairs</a>, а также сайты посольств и консульств Китая, чтобы уточнить правила для конкретного паспорта.</li>
      </ul>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">Как избежать ошибок с безвизовым въездом</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          Самая распространённая ошибка — путать обычный безвизовый въезд с безвизовым транзитом.
          Обычная поездка туда и обратно и пересадка по пути в третью страну — это не один и тот же маршрут. Авиакомпании
          проверяют документы перед посадкой, поэтому недоразумение может сорвать поездку ещё до прибытия
          в Китай.
        </p>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-gray-600">
          <li><strong class="text-gray-900">Сначала проверьте гражданство по паспорту.</strong> Страна проживания и страна выставления счёта по карте не определяют право на безвизовый въезд.</li>
          <li><strong class="text-gray-900">Разделяйте въезд и транзит.</strong> Для транзита обычно требуется подтверждённый дальнейший выезд в третью страну или регион.</li>
          <li><strong class="text-gray-900">Подтвердите пункты въезда.</strong> Транзитные правила зависят от назначенных пунктов въезда и разрешённых зон поездок.</li>
          <li><strong class="text-gray-900">Держите подтверждения под рукой.</strong> Авиакомпания и сотрудники пограничного контроля могут запросить билет на дальнейший маршрут, бронь отеля, маршрут поездки или сведения о приглашении.</li>
        </ul>
      </div>
      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Спланируйте остальное по прибытии</h2>
        <div class="mt-4 grid gap-3">
          <a href="/posts/china-visa-free-entry-transit-guide-2026/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Прочитать полный гид по безвизовому въезду</a>
          <a href="/posts/first-24-hours-in-china-arrival-checklist/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Воспользоваться чек-листом по прибытии</a>
          <a href="/posts/airport-to-city-transport-beijing-shanghai-guangzhou/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Спланировать транспорт из аэропорта</a>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  type TripKey = 'tourism' | 'business' | 'transit';

  // Nationalities eligible for the 30-day unilateral visa-free entry (2026 program).
  const visaFree30 = new Set([
    'Germany', 'France', 'Italy', 'Spain', 'Netherlands', 'Switzerland',
    'Ireland', 'Norway', 'Japan', 'South Korea', 'Brazil', 'New Zealand',
    'Malaysia', 'Thailand', 'Australia',
  ]);

  // Nationalities eligible for 240-hour (10-day) visa-free transit through
  // designated ports when travelling onward to a third country/region.
  const transit240 = new Set([
    'United States', 'United Kingdom', 'Canada', 'Australia', 'Germany',
    'France', 'Italy', 'Spain', 'Netherlands', 'Japan', 'South Korea',
    'Singapore', 'Switzerland', 'Ireland', 'Norway', 'Brazil', 'New Zealand',
  ]);

  interface Verdict {
    tone: 'good' | 'warn' | 'info';
    heading: string;
    body: string;
    points: string[];
  }

  function evaluate(country: string, trip: TripKey): Verdict {
    const has30 = visaFree30.has(country);
    const hasTransit = transit240.has(country);

    if (trip === 'transit') {
      if (hasTransit) {
        return {
          tone: 'good',
          heading: 'Вы, вероятно, имеете право на 240-часовой безвизовый транзит',
          body: `Если у вас паспорт страны ${country} и вы следуете через Китай транзитом в третью страну, вы, как правило, можете находиться в стране до 240 часов (10 дней) без визы при въезде через подходящий пункт пропуска.`,
          points: [
            'У вас должен быть подтверждённый билет в третью страну или регион в пределах 240 часов.',
            'Въезд и выезд должны осуществляться через назначенные транзитные пункты (обычно подходят большинство крупных международных аэропортов).',
            'Обычно ваше перемещение ограничено провинцией или регионом въезда — уточняйте правила для конкретного пункта.',
          ],
        };
      }
      return {
        tone: 'warn',
        heading: 'Безвизовый транзит может не применяться к вашему гражданству',
        body: `${country} отсутствует в стандартном списке стран для 240-часового транзита в наших данных. Вы всё ещё можете иметь право на безвизовый въезд, если соответствуете условиям, либо вам может понадобиться транзитная виза (G).`,
        points: [
          'Проверьте, даёт ли ваше гражданство право на полный безвизовый въезд.',
          'Если нет, заранее оформите соответствующую визу перед поездкой.',
        ],
      };
    }

    // tourism or business
    if (has30) {
      return {
        tone: 'good',
        heading: 'Вы, вероятно, имеете право на 30-дневный безвизовый въезд',
        body: `Если у вас паспорт страны ${country}, вы, как правило, можете въехать в Китай без визы на срок до 30 дней для туризма, бизнеса, семейного визита или транзита в рамках текущей односторонней политики.`,
        points: [
          'Ваш паспорт должен быть действителен не менее 6 месяцев и иметь пустые страницы.',
          'Подготовьте подтверждение дальнейшей или обратной поездки и проживания для иммиграционного контроля.',
          '30 дней предоставляются на один въезд — уточняйте актуальный порядок подсчёта перед бронированием.',
        ],
      };
    }
    if (hasTransit) {
      return {
        tone: 'info',
        heading: 'Виза, скорее всего, нужна, но может помочь транзитное исключение',
        body: `${country} отсутствует в нашем списке 30-дневного безвизового въезда для туризма и бизнеса, поэтому виза обычно требуется. Однако если вы следуете транзитом в третью страну, вы можете воспользоваться 240-часовым безвизовым транзитом.`,
        points: [
          'Для целенаправленной поездки заранее оформите визу L (туристическую) или M (деловую).',
          'Для остановки по пути в другую страну вы можете подходить под 240-часовой транзит — переключите "Тип поездки" на Transit, чтобы проверить.',
        ],
      };
    }
    return {
      tone: 'warn',
      heading: 'Виза, скорее всего, требуется',
      body: `Согласно нашим данным, владельцам паспортов ${country}, как правило, требуется виза для въезда в Китай при таком типе поездки. Подайте заявление через посольство, консульство или авторизованный визовый центр Китая до поездки.`,
      points: [
        'Оформляйте визу L (туристическую) или M (деловую) заблаговременно до поездки.',
        'Обычно требуются приглашение или маршрут поездки, брони отелей и обратные билеты.',
      ],
    };
  }

  const toneStyles: Record<Verdict['tone'], string> = {
    good: 'border-green-200 bg-green-50',
    warn: 'border-amber-200 bg-amber-50',
    info: 'border-blue-200 bg-blue-50',
  };
  const toneBadge: Record<Verdict['tone'], string> = {
    good: 'bg-green-600 text-white',
    warn: 'bg-amber-500 text-white',
    info: 'bg-blue-600 text-white',
  };
  const toneLabel: Record<Verdict['tone'], string> = {
    good: 'Вероятно подходит',
    warn: 'Виза, вероятно, нужна',
    info: 'Зависит от вашего плана',
  };

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;
  const tripEl = document.getElementById('trip') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const v = evaluate(countryEl.value, tripEl.value as TripKey);
    card.className = `card border ${toneStyles[v.tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[v.tone]}">${toneLabel[v.tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${v.heading}</h2>
      <p class="mt-2 text-gray-700">${v.body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${v.points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>