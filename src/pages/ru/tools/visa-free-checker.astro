---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Проверка безвизового въезда и транзита в China';
const description =
  'Проверьте, можете ли вы въехать в China без визы, воспользоваться 240-часовым безвизовым транзитом или вам нужно подавать заявление с учётом гражданства и типа поездки.';

const lastReviewed = '13 июля 2026 г.';

// Репрезентативные данные о правилах на 2026 год. Это справочная информация, не юридическая консультация;
// путешественникам нужно подтверждать условия в посольстве до бронирования.
const countries = [
  'США', 'Великобритания', 'Канада', 'Австралия', 'Германия',
  'Франция', 'Италия', 'Испания', 'Нидерланды', 'Япония', 'Южная Корея',
  'Сингапур', 'Малайзия', 'Таиланд', 'Бразилия', 'Новая Зеландия',
  'Швейцария', 'Ирландия', 'Норвегия', 'Другое',
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Инструмент</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Проверка безвизового въезда и транзита</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <p class="mt-3 text-sm text-gray-500">
        Последняя проверка: {lastReviewed}. Этот чекер помогает планировать поездку, но не является официальным решением о праве на въезд.
      </p>
    </header>

    <AdSlot format="banner" />

    <!-- Input controls -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Гражданство по паспорту</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Тип поездки</span>
        <select id="trip" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="tourism">Туризм / посещение</option>
          <option value="business">Бизнес</option>
          <option value="transit">Только транзит в другую страну</option>
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="check-btn" class="btn-primary w-full sm:w-auto">Проверить право на въезд</button>
      </div>
    </div>

    <!-- Result -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>
      <p class="mt-3 text-xs text-gray-400">
        Правила часто меняются и зависят от ваших конкретных обстоятельств. Всегда уточняйте их в
        посольстве или консульстве China перед бронированием поездки. Этот инструмент даёт только общие рекомендации.
      </p>

      <AffiliateCta
        title="Спланируйте остальную часть поездки"
        description="Разберитесь с интернетом, оплатой и транспортом до прилёта в China."
        buttonText="Смотреть важное для поездки"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6" aria-labelledby="official-sources">
      <h2 id="official-sources" class="text-xl font-bold text-gray-950">Официальные источники для проверки перед бронированием</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        Списки безвизовых стран, пункты въезда, разрешённые зоны поездок и проверки авиакомпаний
        перед посадкой могут меняться. Официальные правила правительства и авиакомпаний являются решающими.
      </p>
      <ul class="mt-4 grid gap-2 text-sm leading-6 text-gray-700">
        <li><a href="https://en.nia.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">National Immigration Administration</a> — обновления по пограничному контролю и транзитным исключениям.</li>
        <li><a href="https://english.www.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">информационный портал Государственного совета</a> — объявления о правилах на английском языке.</li>
        <li><a href="https://www.mfa.gov.cn/eng/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">Ministry of Foreign Affairs</a> и сайты посольств или консульств China — правила для конкретного паспорта.</li>
      </ul>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">Как избежать ошибок с безвизовым въездом</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          Самая частая ошибка — путать обычный безвизовый въезд с безвизовым транзитом. Обычная
          поездка туда и обратно и остановка по пути в третью страну — не один и тот же маршрут.
          Авиакомпании проверяют документы до посадки, поэтому ошибка может остановить поездку ещё
          до прибытия в China.
        </p>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-gray-600">
          <li><strong class="text-gray-900">Сначала проверьте гражданство по паспорту.</strong> Страна проживания и страна выставления счёта по карте не определяют право на безвизовый въезд.</li>
          <li><strong class="text-gray-900">Разделяйте въезд и транзит.</strong> Для транзита обычно нужен подтверждённый дальнейший выезд в третью страну или регион.</li>
          <li><strong class="text-gray-900">Подтвердите пункты въезда.</strong> Транзитные правила зависят от назначенных портов и разрешённых зон поездок.</li>
          <li><strong class="text-gray-900">Держите подтверждения под рукой.</strong> Авиакомпания и пограничники могут запросить следующий билет, отель, маршрут или данные приглашения.</li>
        </ul>
      </div>
      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Спланируйте остальное прибытие</h2>
        <div class="mt-4 grid gap-3">
          <a href="/ru/posts/china-visa-free-entry-transit-guide-2026/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Прочитать полное руководство по безвизовому въезду</a>
          <a href="/ru/posts/first-24-hours-in-china-arrival-checklist/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Использовать чек-лист прибытия</a>
          <a href="/ru/posts/airport-to-city-transport-beijing-shanghai-guangzhou/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Спланировать транспорт из аэропорта</a>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  type TripKey = 'tourism' | 'business' | 'transit';

  // Nationalities eligible for the 30-day unilateral visa-free entry (2026 program).
  const visaFree30 = new Set([
    'Германия', 'Франция', 'Италия', 'Испания', 'Нидерланды', 'Швейцария',
    'Ирландия', 'Норвегия', 'Япония', 'Южная Корея', 'Бразилия', 'Новая Зеландия',
    'Малайзия', 'Таиланд', 'Австралия',
  ]);

  // Nationalities eligible for 240-hour (10-day) visa-free transit through
  // designated ports when travelling onward to a third country/region.
  const transit240 = new Set([
    'США', 'Великобритания', 'Канада', 'Австралия', 'Германия',
    'Франция', 'Италия', 'Испания', 'Нидерланды', 'Япония', 'Южная Корея',
    'Сингапур', 'Швейцария', 'Ирландия', 'Норвегия', 'Бразилия', 'Новая Зеландия',
  ]);

  interface Verdict {
    tone: 'good' | 'warn' | 'info';
    heading: string;
    body: string;
    points: string[];
  }

  function evaluate(country: string, trip: TripKey): Verdict {
    const has30 = visaFree30.has(country);
    const hasTransit = transit240.has(country);

    if (trip === 'transit') {
      if (hasTransit) {
        return {
          tone: 'good',
          heading: 'Скорее всего, вам доступен 240-часовой безвизовый транзит',
          body: `Как владелец паспорта ${country}, следующий через China в третью страну, вы обычно можете находиться до 240 часов (10 дней) без визы при въезде через подходящий порт.`,
          points: [
            'У вас должен быть подтверждённый следующий билет в третью страну или регион в пределах 240 часов.',
            'Въезд и выезд должны проходить через назначенные транзитные порты; большинство крупных международных аэропортов подходят.',
            'Обычно вы ограничены провинцией или регионом въезда — проверьте правила конкретного порта.',
          ],
        };
      }
      return {
        tone: 'warn',
        heading: 'Транзитное освобождение от визы может не применяться к вашему гражданству',
        body: `${country} отсутствует в нашем стандартном списке 240-часового транзита. Возможно, вам доступен обычный безвизовый въезд, если вы подходите, или потребуется транзитная виза (G).`,
        points: [
          'Проверьте, подходит ли ваше гражданство для полноценного безвизового въезда.',
          'Если нет, оформите подходящую визу до поездки.',
        ],
      };
    }

    // tourism or business
    if (has30) {
      return {
        tone: 'good',
        heading: 'Скорее всего, вам доступен 30-дневный безвизовый въезд',
        body: `Как владелец паспорта ${country}, по текущей односторонней политике вы обычно можете въехать в China без визы на срок до 30 дней для туризма, бизнеса, семейных визитов или транзита.`,
        points: [
          'Ваш паспорт должен быть действителен минимум 6 месяцев и иметь чистые страницы.',
          'Подготовьте подтверждение дальнейшего/обратного билета и проживания для пограничного контроля.',
          '30 дней считаются на один въезд — уточните актуальный порядок подсчёта перед бронированием.',
        ],
      };
    }
    if (hasTransit) {
      return {
        tone: 'info',
        heading: 'Скорее всего, нужна виза, но транзитное освобождение может помочь',
        body: `${country} отсутствует в нашем 30-дневном безвизовом списке для туризма/бизнеса, поэтому обычно требуется виза. Однако если вы следуете через China в третью страну, возможно, получится использовать 240-часовой безвизовый транзит.`,
        points: [
          'Для отдельной поездки заранее подайте заявление на визу L (туристическую) или M (деловую).',
          'Для остановки по пути в другую страну вам может подойти 240-часовой транзит — переключите «Тип поездки» на транзит для проверки.',
        ],
      };
    }
    return {
      tone: 'warn',
      heading: 'Скорее всего, требуется виза',
      body: `По нашим данным, владельцам паспорта ${country} для этого типа поездки обычно нужна виза для въезда в China. Подайте заявление через посольство, консульство или авторизованный визовый центр China до поездки.`,
      points: [
        'Подайте заявление на визу L (туристическую) или M (деловую) заблаговременно.',
        'Обычно требуются приглашение или маршрут, бронирования отелей и обратные билеты.',
      ],
    };
  }

  const toneStyles: Record<Verdict['tone'], string> = {
    good: 'border-green-200 bg-green-50',
    warn: 'border-amber-200 bg-amber-50',
    info: 'border-blue-200 bg-blue-50',
  };
  const toneBadge: Record<Verdict['tone'], string> = {
    good: 'bg-green-600 text-white',
    warn: 'bg-amber-500 text-white',
    info: 'bg-blue-600 text-white',
  };
  const toneLabel: Record<Verdict['tone'], string> = {
    good: 'Скорее всего, подходит',
    warn: 'Скорее всего, нужна виза',
    info: 'Зависит от плана',
  };

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;
  const tripEl = document.getElementById('trip') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const v = evaluate(countryEl.value, tripEl.value as TripKey);
    card.className = `card border ${toneStyles[v.tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[v.tone]}">${toneLabel[v.tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${v.heading}</h2>
      <p class="mt-2 text-gray-700">${v.body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${v.points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>

