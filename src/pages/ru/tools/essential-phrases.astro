---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import AdSlot from "../../../components/AdSlot.astro";
import AffiliateCta from "../../../components/AffiliateCta.astro";
import { AFFILIATE_LINKS } from "../../../config";

const title = 'Основные китайские фразы для путешественников';
const description =
  'Удобный список основных фраз на китайском языке для туристов в China — с пиньинем и английским переводом. Включает приветствия, оплату, транспорт, еду и экстренные ситуации.';

interface Phrase {
  en: string;
  zh: string;
  pinyin: string;
}
interface Group {
  id: string;
  label: string;
  icon: string;
  phrases: Phrase[];
}

const groups: Group[] = [
  {
    id: 'basics', label: 'Приветствия и основы', icon: '👋',
    phrases: [
      { en: 'Здравствуйте', zh: '你好', pinyin: 'nǐ hǎo' },
      { en: 'Спасибо', zh: '谢谢', pinyin: 'xièxie' },
      { en: 'Пожалуйста', zh: '不客气', pinyin: 'bú kèqi' },
      { en: 'Извините / Простите', zh: '对不起', pinyin: 'duìbuqǐ' },
      { en: 'Да / Верно', zh: '对', pinyin: 'duì' },
      { en: 'Нет / Не', zh: '不是', pinyin: 'bú shì' },
      { en: 'Я не понимаю', zh: '我不明白', pinyin: 'wǒ bù míngbái' },
      { en: 'Вы говорите по-английски?', zh: '你会说英语吗？', pinyin: 'nǐ huì shuō yīngyǔ ma?' },
    ],
  },
  {
    id: 'payment', label: 'Деньги и оплата', icon: '💳',
    phrases: [
      { en: 'Сколько это стоит?', zh: '多少钱？', pinyin: 'duōshao qián?' },
      { en: 'Можно использовать Alipay?', zh: '可以用支付宝吗？', pinyin: 'kěyǐ yòng zhīfùbǎo ma?' },
      { en: 'Можно использовать WeChat Pay?', zh: '可以用微信支付吗？', pinyin: 'kěyǐ yòng wēixìn zhīfù ma?' },
      { en: 'Слишком дорого', zh: '太贵了', pinyin: 'tài guì le' },
      { en: 'Можно оплатить картой?', zh: '可以刷卡吗？', pinyin: 'kěyǐ shuākǎ ma?' },
      { en: 'Я отсканирую ваш код', zh: '我扫你的码', pinyin: 'wǒ sǎo nǐ de mǎ' },
    ],
  },
  {
    id: 'transport', label: 'Как передвигаться', icon: '🚕',
    phrases: [
      { en: 'Где метро?', zh: '地铁站在哪里？', pinyin: 'dìtiě zhàn zài nǎlǐ?' },
      { en: 'Пожалуйста, отвезите меня по этому адресу', zh: '请带我去这个地址', pinyin: 'qǐng dài wǒ qù zhège dìzhǐ' },
      { en: 'Остановите здесь, пожалуйста', zh: '请在这里停', pinyin: 'qǐng zài zhèlǐ tíng' },
      { en: 'Железнодорожный вокзал', zh: '火车站', pinyin: 'huǒchē zhàn' },
      { en: 'Аэропорт', zh: '机场', pinyin: 'jīchǎng' },
      { en: 'Как добраться до...?', zh: '怎么去...？', pinyin: 'zěnme qù...?' },
    ],
  },
  {
    id: 'food', label: 'Еда и рестораны', icon: '🍜',
    phrases: [
      { en: 'Меню, пожалуйста', zh: '请给我菜单', pinyin: 'qǐng gěi wǒ càidān' },
      { en: 'Я вегетарианец / Я вегетарианка', zh: '我吃素', pinyin: 'wǒ chī sù' },
      { en: 'Не острое, пожалуйста', zh: '请不要辣', pinyin: 'qǐng búyào là' },
      { en: 'Воды, пожалуйста', zh: '请给我水', pinyin: 'qǐng gěi wǒ shuǐ' },
      { en: 'Счёт, пожалуйста', zh: '买单', pinyin: 'mǎidān' },
      { en: 'Очень вкусно', zh: '很好吃', pinyin: 'hěn hǎochī' },
    ],
  },
  {
    id: 'help', label: 'Помощь и экстренные ситуации', icon: '🆘',
    phrases: [
      { en: 'Помогите!', zh: '救命！', pinyin: 'jiùmìng!' },
      { en: 'Где туалет?', zh: '洗手间在哪里？', pinyin: 'xǐshǒujiān zài nǎlǐ?' },
      { en: 'Мне нужен врач', zh: '我需要看医生', pinyin: 'wǒ xūyào kàn yīshēng' },
      { en: 'Вызовите полицию', zh: '请报警', pinyin: 'qǐng bàojǐng' },
      { en: 'Я заблудился / Я заблудилась', zh: '我迷路了', pinyin: 'wǒ mílù le' },
      { en: 'Пожалуйста, запишите это', zh: '请写下来', pinyin: 'qǐng xiě xiàlái' },
    ],
  },
];
---
<!-- Контент создан с помощью ИИ, проверен носителем языка -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Инструмент</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Основные китайские фразы</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- Controls -->
    <div class="mt-6 flex flex-wrap items-center gap-3 print:hidden">
      <button data-filter="all" class="phrase-filter btn-primary text-sm">Все</button>
      {groups.map((g) => (
        <button data-filter={g.id} class="phrase-filter rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:border-brand-400">
          {g.icon} {g.label}
        </button>
      ))}
      <button id="print-btn" class="ml-auto rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:border-brand-400">
        🖨️ Печать / Сохранить PDF
      </button>
    </div>

    <!-- Phrase groups -->
    <div class="mt-6 space-y-8">
      {groups.map((g) => (
        <section class="phrase-group" data-group={g.id}>
          <h2 class="mb-3 text-xl font-bold text-gray-900">{g.icon} {g.label}</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            {g.phrases.map((p) => (
              <div class="card flex flex-col">
                <span class="text-sm text-gray-500">{p.en}</span>
                <span class="mt-1 text-2xl font-bold text-gray-900">{p.zh}</span>
                <span class="mt-0.5 text-sm italic text-brand-600">{p.pinyin}</span>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>

    <AffiliateCta
      title="Оставайтесь онлайн, чтобы переводить на ходу"
      description="Туристическая eSIM для China позволит приложениям для перевода и картам работать сразу после приземления."
      buttonText="Подключиться"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.phrase-filter');
  const sections = document.querySelectorAll<HTMLElement>('.phrase-group');
  const printBtn = document.getElementById('print-btn');

  const activeCls = ['btn-primary'];
  const idleCls = ['rounded-lg', 'border', 'border-gray-300', 'px-3', 'py-1.5', 'text-sm', 'font-medium', 'text-gray-700', 'hover:border-brand-400'];

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      sections.forEach((s) => {
        s.classList.toggle('hidden', filter !== 'all' && s.dataset.group !== filter);
      });
      buttons.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('btn-primary', on);
        idleCls.forEach((c) => b.classList.toggle(c, !on));
      });
    });
  });

  printBtn?.addEventListener('click', () => window.print());
</script>