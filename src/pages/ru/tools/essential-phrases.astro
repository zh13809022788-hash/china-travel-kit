---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Основные китайские фразы для путешественников';
const description =
  'Удобный список основных фраз на китайском языке для туристов в Китае, который можно распечатать. С пиньинем и переводом на русский. Включает приветствия, оплату, транспорт, еду и экстренные ситуации.';

interface Фраза {
  ru: string;
  zh: string;
  pinyin: string;
}
interface Группа {
  id: string;
  label: string;
  icon: string;
  phrases: Фраза[];
}

const groups: Группа[] = [
  {
    id: 'basics', label: 'Приветствия и основное', icon: '👋',
    phrases: [
      { ru: 'Здравствуйте', zh: '你好', pinyin: 'nǐ hǎo' },
      { ru: 'Спасибо', zh: '谢谢', pinyin: 'xièxie' },
      { ru: 'Пожалуйста', zh: '不客气', pinyin: 'bú kèqi' },
      { ru: 'Извините / Простите', zh: '对不起', pinyin: 'duìbuqǐ' },
      { ru: 'Да / Верно', zh: '对', pinyin: 'duì' },
      { ru: 'Нет / Не', zh: '不是', pinyin: 'bú shì' },
      { ru: 'Я не понимаю', zh: '我不明白', pinyin: 'wǒ bù míngbái' },
      { ru: 'Вы говорите по-английски?', zh: '你会说英语吗？', pinyin: 'nǐ huì shuō yīngyǔ ma?' },
    ],
  },
  {
    id: 'payment', label: 'Деньги и оплата', icon: '💳',
    phrases: [
      { ru: 'Сколько это стоит?', zh: '多少钱？', pinyin: 'duōshao qián?' },
      { ru: 'Можно оплатить через Alipay?', zh: '可以用支付宝吗？', pinyin: 'kěyǐ yòng zhīfùbǎo ma?' },
      { ru: 'Можно оплатить через WeChat Pay?', zh: '可以用微信支付吗？', pinyin: 'kěyǐ yòng wēixìn zhīfù ma?' },
      { ru: 'Слишком дорого', zh: '太贵了', pinyin: 'tài guì le' },
      { ru: 'Можно оплатить картой?', zh: '可以刷卡吗？', pinyin: 'kěyǐ shuākǎ ma?' },
      { ru: 'Я отсканирую ваш код', zh: '我扫你的码', pinyin: 'wǒ sǎo nǐ de mǎ' },
    ],
  },
  {
    id: 'transport', label: 'Как передвигаться', icon: '🚕',
    phrases: [
      { ru: 'Где находится метро?', zh: '地铁站在哪里？', pinyin: 'dìtiě zhàn zài nǎlǐ?' },
      { ru: 'Пожалуйста, отвезите меня по этому адресу', zh: '请带我去这个地址', pinyin: 'qǐng dài wǒ qù zhège dìzhǐ' },
      { ru: 'Остановите здесь, пожалуйста', zh: '请在这里停', pinyin: 'qǐng zài zhèlǐ tíng' },
      { ru: 'Железнодорожный вокзал', zh: '火车站', pinyin: 'huǒchē zhàn' },
      { ru: 'Аэропорт', zh: '机场', pinyin: 'jīchǎng' },
      { ru: 'Как добраться до...?', zh: '怎么去...？', pinyin: 'zěnme qù...?' },
    ],
  },
  {
    id: 'food', label: 'Еда и рестораны', icon: '🍜',
    phrases: [
      { ru: 'Меню, пожалуйста', zh: '请给我菜单', pinyin: 'qǐng gěi wǒ càidān' },
      { ru: 'Я вегетарианец / вегетарианка', zh: '我吃素', pinyin: 'wǒ chī sù' },
      { ru: 'Не острое, пожалуйста', zh: '请不要辣', pinyin: 'qǐng búyào là' },
      { ru: 'Воды, пожалуйста', zh: '请给我水', pinyin: 'qǐng gěi wǒ shuǐ' },
      { ru: 'Счёт, пожалуйста', zh: '买单', pinyin: 'mǎidān' },
      { ru: 'Очень вкусно', zh: '很好吃', pinyin: 'hěn hǎochī' },
    ],
  },
  {
    id: 'help', label: 'Помощь и экстренные случаи', icon: '🆘',
    phrases: [
      { ru: 'Помогите!', zh: '救命！', pinyin: 'jiùmìng!' },
      { ru: 'Где находится туалет?', zh: '洗手间在哪里？', pinyin: 'xǐshǒujiān zài nǎlǐ?' },
      { ru: 'Мне нужен врач', zh: '我需要看医生', pinyin: 'wǒ xūyào kàn yīshēng' },
      { ru: 'Вызовите полицию', zh: '请报警', pinyin: 'qǐng bàojǐng' },
      { ru: 'Я потерялся / потерялась', zh: '我迷路了', pinyin: 'wǒ mílù le' },
      { ru: 'Пожалуйста, напишите это', zh: '请写下来', pinyin: 'qǐng xiě xiàlái' },
    ],
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Инструмент</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Основные китайские фразы</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- Кнопки управления -->
    <div class="mt-6 flex flex-wrap items-center gap-3 print:hidden">
      <button data-filter="all" class="phrase-filter btn-primary text-sm">Все</button>
      {groups.map((g) => (
        <button data-filter={g.id} class="phrase-filter rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:border-brand-400">
          {g.icon} {g.label}
        </button>
      ))}
      <button id="print-btn" class="ml-auto rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:border-brand-400">
        🖨️ Печать / Сохранить как PDF
      </button>
    </div>

    <!-- Группы фраз -->
    <div class="mt-6 space-y-8">
      {groups.map((g) => (
        <section class="phrase-group" data-group={g.id}>
          <h2 class="mb-3 text-xl font-bold text-gray-900">{g.icon} {g.label}</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            {g.phrases.map((p) => (
              <div class="card flex flex-col">
                <span class="text-sm text-gray-500">{p.ru}</span>
                <span class="mt-1 text-2xl font-bold text-gray-900">{p.zh}</span>
                <span class="mt-0.5 text-sm italic text-brand-600">{p.pinyin}</span>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>

    <AffiliateCta
      title="Оставайтесь онлайн для перевода в дороге"
      description="Туристическая eSIM для Китая поможет переводчику и картам работать сразу после прилёта."
      buttonText="Подключиться"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script>
  const кнопки = document.querySelectorAll<HTMLButtonElement>('.phrase-filter');
  const секции = document.querySelectorAll<HTMLElement>('.phrase-group');
  const кнопкаПечати = document.getElementById('print-btn');

  const активныйКласс = ['btn-primary'];
  const обычныеКлассы = ['rounded-lg', 'border', 'border-gray-300', 'px-3', 'py-1.5', 'text-sm', 'font-medium', 'text-gray-700', 'hover:border-brand-400'];

  кнопки.forEach((кнопка) => {
    кнопка.addEventListener('click', () => {
      const фильтр = кнопка.dataset.filter;
      секции.forEach((секция) => {
        секция.classList.toggle('hidden', фильтр !== 'all' && секция.dataset.group !== фильтр);
      });
      кнопки.forEach((другаяКнопка) => {
        const активна = другаяКнопка === кнопка;
        другаяКнопка.classList.toggle('btn-primary', активна);
        обычныеКлассы.forEach((класс) => другаяКнопка.classList.toggle(класс, !активна));
      });
    });
  });

  кнопкаПечати?.addEventListener('click', () => window.print());
</script>
