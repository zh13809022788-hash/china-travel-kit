---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ShowToLocal from '../../components/ShowToLocal.astro';
import SurvivalChecklist from '../../components/SurvivalChecklist.astro';
import survivalKits from '../../data/survival-kits.json';

const title = 'Набор для выживания в China: карточки с переводом и чек-листы для поездки';
const description =
  'Интерактивные наборы для выживания в China для иностранных посетителей: полноэкранные карточки с переводом, чек-листы по подготовке к прибытию, карточки о пищевых аллергиях и инструменты для общения с местными.';
---
<!-- Контент создан с помощью ИИ, проверен носителем языка -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Набор для выживания</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-950 md:text-4xl">Набор для выживания в China</h1>
<p class="mt-4 max-w-3xl text-lg leading-8 text-gray-600">
  Наш набор для выживания в China поможет вам уверенно подготовиться к поездке. Он включает интерактивные чек-листы, охватывающие каждый этап подготовки перед выездом: оформление визы, туристическую страховку, настройку платежей (Alipay/WeChat Pay), покупку eSIM или SIM-карты, бронирование жилья и самые необходимые вещи для сборов. Раздел с карточками фраз позволяет показывать местным жителям китайский текст в распространённых ситуациях, например при заказе еды, просьбе подсказать дорогу и обсуждении стоимости поездки на такси. Вы также можете добавлять собственные карточки со своими фразами. Всё сохраняется в вашем браузере, поэтому вы можете возвращаться к этому в любое время во время поездки без создания аккаунта.
</p>
      <p class="mt-3 text-lg leading-8 text-gray-600">
        Используйте полноэкранные карточки с переводом и сохранённые чек-листы в моменты, когда читать длинный гид слишком долго:
        прибытие в аэропорт, заселение в отель, такси, рестораны, аллергии и подготовка в первый день.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="#arrival" class="btn-primary">Начать с прибытия</a>
        <a href="#food" class="btn-outline">Открыть карточки о еде</a>
      </div>
    </header>

    <section class="mt-8 grid gap-4 md:grid-cols-3">
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Полноэкранные карточки</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Нажмите на карточку и покажите крупный китайский текст водителю, сотруднику стойки отеля или персоналу ресторана.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Сохранённые чек-листы</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Прогресс по чек-листу сохраняется в вашем браузере, поэтому вы можете закрыть страницу и вернуться позже.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Контекстный вход в AI</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Используйте плавающий помощник, чтобы открыть туристическую помощь ChinaTripBox с подсказкой, учитывающей тему.</p>
      </div>
    </section>

    <div class="mt-10 grid gap-8">
      {survivalKits.map((kit) => (
        <section id={kit.slug} class="grid gap-5 rounded-xl border border-gray-200 bg-gray-50 p-5">
          <div class="max-w-3xl">
            <p class="section-kicker">{kit.slug} набор</p>
            <h2 class="mt-1 text-2xl font-bold text-gray-950">{kit.title}</h2>
            <p class="mt-2 text-sm leading-6 text-gray-600">{kit.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {kit.related_paths.map((path) => (
                <a href={path} class="rounded-full border border-gray-200 bg-white px-3 py-1.5 text-xs font-semibold text-brand-700 hover:border-brand-300 hover:no-underline">
                  Похожий гид
                </a>
              ))}
            </div>
          </div>
          <div class="grid gap-5 lg:grid-cols-[1fr_0.85fr]">
            <ShowToLocal themeId={kit.theme_id} tools={kit.tools} />
            <SurvivalChecklist themeId={kit.theme_id} steps={kit.checklist_steps} />
          </div>
        </section>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>