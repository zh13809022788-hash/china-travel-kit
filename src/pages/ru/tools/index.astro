---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import AdSlot from "../../../components/AdSlot.astro";
import { TOOLS as tools } from "../../../config";

const title = 'Бесплатные инструменты для путешествия по Китаю: виза, оплата, eSIM, бюджет, карточки для водителей и фразы';
const description =
  'Бесплатные интерактивные инструменты для планирования поездки в Китай: проверка безвизового въезда, совместимости платёжных карт, вариантов eSIM, бюджета поездки, денежного резерва, электрических вилок, китайских фраз и адресных карточек для водителей такси.';

const toolUseCases = [
  {
    title: 'Перед бронированием авиабилетов',
    text: 'Используйте проверку безвизового въезда, планировщик лучшего времени для поездки и калькулятор бюджета, прежде чем окончательно выбрать даты и города.',
    links: [
      { href: '/tools/visa-free-checker/', label: 'Проверка безвизового въезда' },
      { href: '/tools/best-time-to-visit/', label: 'Лучшее время для поездки' },
      { href: '/tools/budget-cash-estimator/', label: 'Калькулятор бюджета' },
    ],
  },
  {
    title: 'Перед отъездом',
    text: 'Используйте инструменты для оплаты, eSIM, приложений, вилок и фраз, пока у вас ещё есть время решить проблемы с настройкой дома.',
    links: [
      { href: '/tools/payment-checker/', label: 'Проверка оплаты' },
      { href: '/tools/esim-comparison/', label: 'Сравнение eSIM' },
      { href: '/tools/app-availability-checker/', label: 'Проверка приложений' },
    ],
  },
  {
    title: 'Уже на месте, в Китае',
    text: 'Используйте карточки для водителей, конвертацию валют и основные фразы, когда приложения, такси, меню или стойки регистрации вызывают путаницу.',
    links: [
      { href: '/tools/survival-kit/', label: 'Набор выживания' },
      { href: '/tools/show-to-driver/', label: 'Показать водителю' },
      { href: '/tools/currency-converter/', label: 'Конвертер RMB' },
      { href: '/tools/essential-phrases/', label: 'Основные фразы' },
    ],
  },
];

const toolsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  hasPart: tools.map((tool) => ({
    '@type': 'WebApplication',
    name: tool.title,
    description: tool.desc,
    applicationCategory: 'TravelApplication',
    url: new URL(tool.href, 'https://www.chinatripbox.com').toString(),
  })),
};
---
<!-- Контент создан с помощью ИИ, проверен носителем языка -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(toolsJsonLd)} />
  <Header />
  <main class="container-page py-12">
    <header class="max-w-2xl">
      <p class="section-kicker">Центр инструментов</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Бесплатные инструменты для путешествия по Китаю</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-primary">Использовать предвыездной чек-лист</a>
        <a href="/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">Читать гид для первой поездки</a>
      </div>
    </header>

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 lg:grid-cols-3" aria-labelledby="tool-use-cases-heading">
      <div class="lg:col-span-3">
        <h2 id="tool-use-cases-heading" class="text-2xl font-bold text-gray-950">Какой инструмент стоит использовать первым?</h2>
      </div>
      {toolUseCases.map((useCase) => (
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <h3 class="text-lg font-bold text-gray-950">{useCase.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{useCase.text}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {useCase.links.map((link) => (
              <a href={link.href} class="block rounded-lg border border-brand-200 bg-brand-50 px-4 py-2 text-sm font-semibold text-brand-700 hover:border-brand-300 hover:bg-brand-100 hover:no-underline">{link.label}</a>
            ))}
          </div>
        </div>
      ))}
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {tools.map((tool) => (
        <a href={tool.href} class="card block hover:no-underline">
          <div class="text-3xl">{tool.icon}</div>
          <h2 class="mt-3 text-lg font-bold text-gray-900">{tool.title}</h2>
          <p class="mt-1.5 text-sm text-gray-600">{tool.desc}</p>
          <span class="mt-3 inline-block text-sm font-semibold text-brand-600">Открыть инструмент →</span>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>