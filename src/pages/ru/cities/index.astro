---

import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CoverImage from '../../../components/CoverImage.astro';
import ChinaMap from '../../../components/ChinaMap.astro';
import AdSlot from '../../../components/AdSlot.astro';

const allPosts = await getCollection('posts-ru');
const cityNames = ['beijing', 'shanghai', 'chengdu', 'hangzhou', 'sanya', 'guangzhou', 'xian', 'chongqing', 'kunming', 'nanjing'];
const cityPosts = allPosts
  .filter((post) => cityNames.some((city) => post.slug.includes(city) || post.data.tags.includes(city)))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const title = 'Города Китая для иностранных путешественников';
const description = 'Планируйте поездки по городам Китая с практичными гидами по Пекину, Шанхаю, Гуанчжоу, Чэнду, Сианю, Ханчжоу, Чунцину и Санье: аэропорты, метро, еда, транспорт и удобные следующие шаги.';

const mapCities = [
  { name: 'Пекин', x: 470, y: 80, href: '#beijing' },
  { name: 'Сиань', x: 340, y: 155, href: '#xian' },
  { name: 'Нанкин', x: 490, y: 180, href: '' },
  { name: 'Шанхай', x: 540, y: 200, href: '#shanghai' },
  { name: 'Чэнду', x: 250, y: 220, href: '#chengdu' },
  { name: 'Ханчжоу', x: 520, y: 205, href: '#hangzhou' },
  { name: 'Чунцин', x: 310, y: 260, href: '#chongqing' },
  { name: 'Гуйлинь', x: 370, y: 300, href: '' },
  { name: 'Куньмин', x: 210, y: 335, href: '' },
  { name: 'Гуанчжоу', x: 400, y: 370, href: '#guangzhou' },
  { name: 'Шэньчжэнь', x: 430, y: 390, href: '' },
  { name: 'Санья', x: 360, y: 440, href: '#sanya' },
];

const cities = [
  {
    name: 'Пекин',
    slug: 'beijing',
    href: '/ru/posts/beijing-city-guide-for-foreigners/',
    desc: 'Лучший выбор для истории, хутунов, Великой китайской стены и первого знакомства с главными достопримечательностями Китая.',
    days: '4-5 дней',
    bestSeason: 'сентябрь-октябрь',
    difficulty: 'средне',
    whyGo: 'Императорское наследие, музеи и самый удобный доступ к Великой китайской стене.',
    next: '/ru/posts/beijing-daxing-airport-to-city-center-a-first-timer-s-guide/',
    nextLabel: 'Как добраться из аэропорта Дасин',
  },
  {
    name: 'Шанхай',
    slug: 'shanghai',
    href: '/ru/posts/shanghai-city-guide-for-foreigners/',
    desc: 'Лучший вариант для мягкого старта, международной еды, прогулок среди небоскребов и удобного метро.',
    days: '3-4 дня',
    bestSeason: 'март-май, октябрь-ноябрь',
    difficulty: 'легко',
    whyGo: 'Самый простой город для первого визита: удобно с метро, аэропортами, едой и сервисами для иностранцев.',
    next: '/ru/posts/shanghai-metro-for-foreigners-tickets-qr-codes-transfers/',
    nextLabel: 'Гид по метро Шанхая',
  },
  {
    name: 'Чэнду',
    slug: 'chengdu',
    href: '/ru/posts/chengdu-city-guide-for-foreigners/',
    desc: 'Лучший город для сычуаньской кухни, чайных, панд и более спокойного городского ритма.',
    days: '3-4 дня',
    bestSeason: 'март-июнь, сентябрь-ноябрь',
    difficulty: 'средне',
    whyGo: 'Панды, сычуаньская кухня, чайные дома, умеренные цены и удобная база для поездок по западному Китаю.',
    next: '/ru/posts/chengdu-street-food-safety-spice-levels-what-to-order/',
    nextLabel: 'Гид по уличной еде Чэнду',
  },
  {
    name: 'Сиань',
    slug: 'xian',
    href: '/ru/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/',
    desc: 'Лучший выбор для древней истории, Терракотовой армии, старых городских стен и глубокого знакомства с культурным наследием Китая.',
    days: '3-4 дня',
    bestSeason: 'март-май, сентябрь-ноябрь',
    difficulty: 'средне',
    whyGo: 'Терракотовая армия, древняя городская стена, мусульманский квартал и сильное ощущение исторического Китая.',
    next: '/ru/posts/china-high-speed-rail-guide-foreigners/',
    nextLabel: 'Гид по скоростным поездам из Сианя',
  },
  {
    name: 'Гуанчжоу',
    slug: 'guangzhou',
    href: '/ru/posts/airport-to-city-transport-beijing-shanghai-guangzhou/',
    desc: 'Лучший вариант для кантонской кухни, деловой энергии юга и удобного выхода в сторону Гонконга.',
    days: '3-4 дня',
    bestSeason: 'октябрь-декабрь, март-апрель',
    difficulty: 'средне',
    whyGo: 'Димсам, южная торговая атмосфера, Canton Tower и более теплый ритм по сравнению с Пекином и Шанхаем.',
    next: '/ru/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    nextLabel: 'Как разобраться с местной едой в Гуанчжоу',
  },
  {
    name: 'Чунцин',
    slug: 'chongqing',
    href: '/ru/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    desc: 'Лучший выбор для острого хот-пота, футуристичных видов, холмистого рельефа и речных панорам.',
    days: '3-4 дня',
    bestSeason: 'март-май, сентябрь-ноябрь',
    difficulty: 'сложнее',
    whyGo: 'Хот-пот, эффектные ночные виды, многоуровневый транспорт и по-настоящему необычная городская среда.',
    next: '/ru/food/',
    nextLabel: 'Гид по еде Чунцина',
  },
  {
    name: 'Ханчжоу',
    slug: 'hangzhou',
    href: '/ru/posts/hangzhou-city-guide-for-foreigners/',
    desc: 'Лучший город для Западного озера, зеленых пейзажей, спокойных выходных и аккуратного городского отдыха.',
    days: '2-3 дня',
    bestSeason: 'март-май, сентябрь-ноябрь',
    difficulty: 'легко-средне',
    whyGo: 'Западное озеро, чайные деревни, храмы и спокойное дополнение к Шанхаю на скоростном поезде.',
    next: '/ru/transport/',
    nextLabel: 'Планирование поездов и местного транспорта',
  },
  {
    name: 'Санья',
    slug: 'sanya',
    href: '/ru/posts/sanya-city-guide-for-foreigners/',
    desc: 'Лучший вариант для теплой зимы, курортного отдыха, пляжей и более медленного темпа поездки.',
    days: '3-5 дней',
    bestSeason: 'ноябрь-апрель',
    difficulty: 'средне',
    whyGo: 'Пляжный отдых в Китае, зимнее солнце, морепродукты и длинные сезонные остановки.',
    next: '/ru/posts/what-to-pack-for-china-a-season-by-season-checklist/',
    nextLabel: 'Что взять с собой по сезонам',
  },
];

const routes = [
  {
    name: 'Первая поездка в Китай, 8-10 дней',
    plan: 'Шанхай 3 дня, Ханчжоу 2 дня, Пекин 4 дня',
    fit: 'Хороший баланс удобного прилета, классических видов и ключевой исторической программы.',
  },
  {
    name: 'Еда и спокойный ритм, 7-8 дней',
    plan: 'Чэнду 4 дня, Пекин или Шанхай 3-4 дня',
    fit: 'Подходит тем, кто хочет панд, чайные, хот-пот и один крупный город для удобной логистики.',
  },
  {
    name: 'Зимний побег, 6-10 дней',
    plan: 'Санья 4-6 дней, Шанхай 2-4 дня',
    fit: 'Лучший вариант, когда на севере Китая холодно и хочется совместить пляж и большой город.',
  },
];

const faqItems = [
  {
    question: 'Какой город Китая самый удобный для первой поездки иностранца?',
    answer:
      'Чаще всего это Шанхай: аэропорты, метро, отели, рестораны и международные сервисы там понятнее всего для первого визита. Пекин тоже удобен, но обычно требует более тщательного планирования маршрута и бронирований.',
  },
  {
    question: 'Сколько городов стоит включать в одну поездку по Китаю?',
    answer:
      'Для первой поездки на 8-10 дней обычно достаточно двух или трех городов. Китай большой, а переезды, аэропорты, вокзалы и проверки безопасности отнимают больше времени, чем кажется на этапе планирования.',
  },
  {
    question: 'Какой город лучше подходит для более долгого пребывания в Китае?',
    answer:
      'Шанхай удобен за счет сервиса и общей понятности, Чэнду часто выигрывает по расходам и ритму жизни, а Ханчжоу предлагает сильный компромисс между природой, комфортом и современной городской средой. Санья лучше подходит для сезонной зимней остановки, а не для круглогодичной городской жизни.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---
import { getCategoryLabel } from '../../../i18n/categories.ts';


<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Планирование городов</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="city-shanghai" alt="Небоскребы Шанхая и набережная Вайтань на закате" loading="eager" />

    <ChinaMap cities={mapCities} />

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3" aria-labelledby="city-shortcuts">
      <h2 id="city-shortcuts" class="sr-only">Быстрый переход к городам</h2>
      {cities.map((city) => (
        <article class="card" id={city.slug}>
          <h3 class="text-xl font-bold text-gray-950">{city.name}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{city.desc}</p>
          <dl class="mt-4 grid gap-2 text-sm text-gray-700">
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Рекомендуемая остановка</dt>
              <dd class="text-right">{city.days}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Лучший сезон</dt>
              <dd class="text-right">{city.bestSeason}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Удобство для гостей</dt>
              <dd class="text-right">{city.difficulty}</dd>
            </div>
          </dl>
          <div class="mt-5 grid gap-2 text-sm font-semibold">
            <a href={city.href} class="text-brand-700 hover:text-brand-800">Открыть гид по городу</a>
            <a href={city.next} class="text-gray-700 hover:text-brand-700">{city.nextLabel}</a>
          </div>
        </article>
      ))}
    </section>

    <section class="mt-12" aria-labelledby="compare-cities">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Сравнение городов</p>
          <h2 id="compare-cities">Какой город Китая выбрать?</h2>
        </div>
      </div>
      <div class="mt-6 overflow-hidden rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
          <thead class="bg-gray-50 text-xs font-semibold uppercase tracking-wide text-gray-600">
            <tr>
              <th class="px-4 py-3">Город</th>
              <th class="px-4 py-3">Зачем ехать</th>
              <th class="px-4 py-3">Остановка</th>
              <th class="px-4 py-3">Лучший сезон</th>
              <th class="px-4 py-3">Удобство</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {cities.map((city) => (
              <tr>
                <th class="px-4 py-4 font-bold text-gray-950">
                  <a href={city.href} class="text-brand-700 hover:text-brand-800">{city.name}</a>
                </th>
                <td class="px-4 py-4 leading-6 text-gray-700">{city.whyGo}</td>
                <td class="px-4 py-4 text-gray-700">{city.days}</td>
                <td class="px-4 py-4 text-gray-700">{city.bestSeason}</td>
                <td class="px-4 py-4 text-gray-700">{city.difficulty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-12 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]" aria-labelledby="route-ideas">
      <div>
        <p class="section-kicker">Планирование маршрута</p>
        <h2 id="route-ideas" class="mt-2 text-3xl font-bold text-gray-950">Практичные комбинации городов</h2>
        <p class="mt-3 leading-7 text-gray-600">
          Сильный маршрут по Китаю обычно получается тогда, когда у каждого города есть своя роль. Используйте Шанхай как удобную точку прилета, Пекин для истории, Ханчжоу для пейзажей, Чэнду для еды и выхода в западный Китай, а Санью для теплого отдыха. Если поездка короткая, лучше избегать лишних перелетов и пересадок между вокзалами и аэропортами.
        </p>
      </div>
      <div class="grid gap-4">
        {routes.map((route) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-lg font-bold text-gray-950">{route.name}</h3>
            <p class="mt-2 font-semibold text-brand-700">{route.plan}</p>
            <p class="mt-2 text-sm leading-6 text-gray-600">{route.fit}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Все гиды по городам</p>
            <h2>Статьи о городах и местном транспорте</h2>
          </div>
        </div>
        <div class="mt-6 grid gap-5 md:grid-cols-2">
          {cityPosts.map((post) => (
            <a href={`/ru/posts/${post.slug}/`} class="card block hover:no-underline">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
              <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <p class="section-kicker">Перед выбором города</p>
        <h2 class="mt-1 text-xl font-bold text-gray-950">Проверьте логистику</h2>
        <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
          <li><a href="/ru/payment/" class="font-semibold text-brand-700">Оплата:</a> настройте Alipay, WeChat Pay и запас наличных до поездок в менее туристические города.</li>
          <li><a href="/ru/esim/" class="font-semibold text-brand-700">Интернет:</a> выберите eSIM, роуминг или местную SIM-карту до того, как будете полагаться на карты и переводчик.</li>
          <li><a href="/ru/transport/" class="font-semibold text-brand-700">Транспорт:</a> сравните поезда, трансферы из аэропорта, DiDi и QR-коды в метро.</li>
          <li><a href="/ru/tools/best-time-to-visit/" class="font-semibold text-brand-700">Время:</a> проверьте погоду, праздники и туристическую нагрузку по месяцам.</li>
        </ul>
      </aside>
    </section>

    <section class="mt-12" aria-labelledby="city-faq">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Частые вопросы по городам</p>
          <h2 id="city-faq">Частые вопросы о планировании городов Китая</h2>
        </div>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {faqItems.map((item) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-base font-bold text-gray-950">{item.question}</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">{item.answer}</p>
          </article>
        ))}
      </div>
    </section>

    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  </main>
  <Footer />
</BaseLayout>