---

import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CoverImage from '../../../components/CoverImage.astro';
import ChinaMap from '../../../components/ChinaMap.astro';
import AdSlot from '../../../components/AdSlot.astro';

const allPosts = await getCollection('posts-ru');
const cityNames = ['beijing', 'shanghai', 'chengdu', 'hangzhou', 'sanya', 'guangzhou', 'xian', 'chongqing', 'kunming', 'nanjing'];
const cityPosts = allPosts
  .filter((post) => cityNames.some((city) => post.slug.includes(city) || post.data.tags.includes(city)))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const title = 'Города Китая для иностранных гостей';
const description = 'Планируйте практичные остановки в городах Китая с гидами по Пекину, Шанхаю, Гуанчжоу, Чэнду, Сианю, Ханчжоу, Чунцину и Санье, а также дальнейшими шагами по аэропортам, метро, еде и транспорту.';

const mapCities = [
  { name: 'Beijing', x: 470, y: 80, href: '#beijing' },
  { name: 'Xi\'an', x: 340, y: 155, href: '#xian' },
  { name: 'Nanjing', x: 490, y: 180, href: '' },
  { name: 'Shanghai', x: 540, y: 200, href: '#shanghai' },
  { name: 'Chengdu', x: 250, y: 220, href: '#chengdu' },
  { name: 'Hangzhou', x: 520, y: 205, href: '#hangzhou' },
  { name: 'Chongqing', x: 310, y: 260, href: '#chongqing' },
  { name: 'Guilin', x: 370, y: 300, href: '' },
  { name: 'Kunming', x: 210, y: 335, href: '' },
  { name: 'Guangzhou', x: 400, y: 370, href: '#guangzhou' },
  { name: 'Shenzhen', x: 430, y: 390, href: '' },
  { name: 'Sanya', x: 360, y: 440, href: '#sanya' },
];

const cities = [
  {
    name: 'Beijing',
    href: '/ru/posts/beijing-city-guide-for-foreigners/',
    desc: 'Лучше всего для истории, хутунов, Великой стены и классического осмотра достопримечательностей для новичков.',
    days: '4–5 дней',
    bestSeason: 'Сентябрь – октябрь',
    difficulty: 'Средне',
    whyGo: 'Имперская история, музеи и самый лёгкий доступ к Великой стене.',
    next: '/ru/posts/beijing-daxing-airport-to-city-center-a-first-timer-s-guide/',
    nextLabel: 'Гид по трансферу из аэропорта Дасин',
  },
  {
    name: 'Shanghai',
    href: '/ru/posts/shanghai-city-guide-for-foreigners/',
    desc: 'Лучше всего для лёгкого прилёта, международной еды, прогулок у небоскрёбов и развитого метро.',
    days: '3–4 дня',
    bestSeason: 'Март – май, октябрь – ноябрь',
    difficulty: 'Легко',
    whyGo: 'Самая удобная первая остановка для метро, аэропортов, еды и англоязычного сервиса.',
    next: '/ru/posts/shanghai-metro-for-foreigners-tickets-qr-codes-transfers/',
    nextLabel: 'Гид по метро Шанхая',
  },
  {
    name: 'Chengdu',
    href: '/ru/posts/chengdu-city-guide-for-foreigners/',
    desc: 'Лучше всего для сычуаньской еды, неспешного ритма чайных, панд и более мягкого городского темпа.',
    days: '3–5 дней',
    bestSeason: 'Март – июнь, сентябрь – ноябрь',
    difficulty: 'Средне',
    whyGo: 'Панды, сычуаньская кухня, чайные, невысокие цены и поездки по западному Китаю.',
    next: '/ru/posts/chengdu-street-food-safety-spice-levels-what-to-order/',
    nextLabel: 'Гид по уличной еде Чэнду',
  },
  {
    name: 'Xi\'an',
    href: '/ru/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/',
    desc: 'Лучше всего для древней истории, Терракотовой армии, старых городских стен и приобщения к китайскому наследию.',
    days: '3–4 дня',
    bestSeason: 'Март – май, сентябрь – ноябрь',
    difficulty: 'Средне',
    whyGo: 'Терракотовая армия, древняя городская стена, Мусульманский квартал и глубокое ощущение истории Китая.',
    next: '/ru/posts/china-high-speed-rail-guide-foreigners/',
    nextLabel: 'Скоростной поезд в Сиань',
  },
  {
    name: 'Guangzhou',
    href: '/ru/posts/airport-to-city-transport-beijing-shanghai-guangzhou/',
    desc: 'Лучше всего для кантонской еды, энергии торгового города, южных ворот и лёгкого доступа в Гонконг.',
    days: '3–4 дня',
    bestSeason: 'Октябрь – декабрь, март – апрель',
    difficulty: 'Средне',
    whyGo: 'Кантонские димсамы, Академия клана Чэнь, Кантонская башня и более тёплая южная альтернатива Пекину и Шанхаю.',
    next: '/ru/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    nextLabel: 'Гид по кантонской еде',
  },
  {
    name: 'Chongqing',
    href: '/ru/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    desc: 'Лучше всего для сычуаньского хого, футуристического небоскрёбов, горного рельефа и круизов по Янцзы.',
    days: '3–4 дня',
    bestSeason: 'Март – май, сентябрь – ноябрь',
    difficulty: 'Сложно',
    whyGo: 'Чунцинское хого, Хунъядун, ночной небоскрёб, канатная дорога через Янцзы и уникальная вертикальная планировка города.',
    next: '/ru/food/',
    nextLabel: 'Гид по еде Чунцина',
  },
  {
    name: 'Hangzhou',
    href: '/ru/posts/hangzhou-city-guide-for-foreigners/',
    desc: 'Лучше всего для Западного озера, зелёных пейзажей, неспешного уикенда и аккуратного городского отдыха.',
    days: '2–3 дня',
    bestSeason: 'Март – май, сентябрь – ноябрь',
    difficulty: 'Легко – средне',
    whyGo: 'Западное озеро, чайные деревни, храмы и спокойное дополнение к Шанхаю на скоростном поезде.',
    next: '/ru/transport/',
    nextLabel: 'Планирование поездов и местного транспорта',
  },
  {
    name: 'Sanya',
    href: '/ru/posts/sanya-city-guide-for-foreigners/',
    desc: 'Лучше всего для тёплой зимней погоды, курортного отдыха, пляжного времени и поездок по Хайнаню.',
    days: '3–7 дней',
    bestSeason: 'Ноябрь – апрель',
    difficulty: 'Средне',
    whyGo: 'Пляжный отдых в Китае, зимнее солнце, морепродукты, курорты и длительные сезонные остановки.',
    next: '/ru/posts/what-to-pack-for-china-a-season-by-season-checklist/',
    nextLabel: 'Сезонный гид по упаковке',
  },
];

const routes = [
  {
    name: 'Первая поездка в Китай, 8–10 дней',
    plan: 'Шанхай 3 дня, Ханчжоу 2 дня, Пекин 4 дня',
    fit: 'Лучший баланс лёгкого прилёта, классических пейзажей и ключевой истории.',
  },
  {
    name: 'Еда и неспешный ритм, 7–9 дней',
    plan: 'Чэнду 4 дня, Пекин или Шанхай 3–4 дня',
    fit: 'Подходит путешественникам, которые хотят панд, чайных, хого и одного крупного города-ворот.',
  },
  {
    name: 'Зимний побег, 6–10 дней',
    plan: 'Санья 4–6 дней, Шанхай 2–3 дня',
    fit: 'Лучше всего, когда на севере Китая холодно и хочется простого сочетания пляжа и города.',
  },
];

const faqItems = [
  {
    question: 'Какой город Китая самый удобный для иностранных туристов-новичков?',
    answer:
      'Обычно самый лёгкий первый город — Шанхай, потому что аэропорты, указатели метро, отели, рестораны и международные сервисы максимально дружелюбны к иностранцам. Пекин тоже вполне доступен, но требует более раннего бронирования и более тщательного планирования маршрута.',
  },
  {
    question: 'Сколько городов Китая стоит посетить за одну поездку?',
    answer:
      'Для первой поездки на 8–10 дней достаточно двух-трёх городов. Китай большой, а трансферы из аэропорта, вокзалы, проверки безопасности и переезды между отелями могут занять больше времени, чем ожидалось. Выберите один город-ворот, одну культурную или живописную остановку и одно факультативное продолжение.',
  },
  {
    question: 'Какой город лучше всего подходит для длительного пребывания в Китае?',
    answer:
      'Шанхай — самый удобный вариант для длительного пребывания благодаря сервису и английской поддержке, Чэнду выгоднее по расходам и расслабленному образу жизни, а Ханчжоу предлагает компромисс с пейзажами и сильной технологической экономикой. Санья хороша для зимних остановок, а не для круглогодичной городской жизни.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---


<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Планирование городов</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="city-shanghai" alt="Небоскрёбы Шанхая и набережная Вайтань на закате, символ путешествий по городам Китая" loading="eager" />

    <ChinaMap cities={mapCities} />

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3" aria-labelledby="city-shortcuts">
      <h2 id="city-shortcuts" class="sr-only">Быстрый переход к городам</h2>
      {cities.map((city) => (
        <article class="card" id={city.name.toLowerCase().replace(/[^a-z]/g, '')}>
          <h3 class="text-xl font-bold text-gray-950">{city.name}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{city.desc}</p>
          <dl class="mt-4 grid gap-2 text-sm text-gray-700">
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Рекомендуемая остановка</dt>
              <dd class="text-right">{city.days}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Лучший сезон</dt>
              <dd class="text-right">{city.bestSeason}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Удобство для гостей</dt>
              <dd class="text-right">{city.difficulty}</dd>
            </div>
          </dl>
          <div class="mt-5 grid gap-2 text-sm font-semibold">
            <a href={city.href} class="text-brand-700 hover:text-brand-800">Открыть гид по городу</a>
            <a href={city.next} class="text-gray-700 hover:text-brand-700">{city.nextLabel}</a>
          </div>
        </article>
      ))}
    </section>

    <section class="mt-12" aria-labelledby="compare-cities">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Сравнение городов</p>
          <h2 id="compare-cities">Какой город Китая вам выбрать?</h2>
        </div>
      </div>
      <div class="mt-6 overflow-hidden rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
          <thead class="bg-gray-50 text-xs font-semibold uppercase tracking-wide text-gray-600">
            <tr>
              <th class="px-4 py-3">Город</th>
              <th class="px-4 py-3">Зачем ехать</th>
              <th class="px-4 py-3">Остановка</th>
              <th class="px-4 py-3">Лучший сезон</th>
              <th class="px-4 py-3">Удобство</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {cities.map((city) => (
              <tr>
                <th class="px-4 py-4 font-bold text-gray-950">
                  <a href={city.href} class="text-brand-700 hover:text-brand-800">{city.name}</a>
                </th>
                <td class="px-4 py-4 leading-6 text-gray-700">{city.whyGo}</td>
                <td class="px-4 py-4 text-gray-700">{city.days}</td>
                <td class="px-4 py-4 text-gray-700">{city.bestSeason}</td>
                <td class="px-4 py-4 text-gray-700">{city.difficulty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-12 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]" aria-labelledby="route-ideas">
      <div>
        <p class="section-kicker">Планирование маршрута</p>
        <h2 id="route-ideas" class="mt-2 text-3xl font-bold text-gray-950">Практичные комбинации городов</h2>
        <p class="mt-3 leading-7 text-gray-600">
          Сильный маршрут по Китаю обычно получается лучше, когда у каждого города своя роль. Используйте Шанхай как
          удобную точку прилёта, Пекин — для истории, Ханчжоу — для пейзажей, Чэнду — для еды и выхода в западный Китай, а
          Санью — для тёплого отдыха. Избегайте лишних перелётов и пересадок на вокзалах в короткой поездке.
        </p>
      </div>
      <div class="grid gap-4">
        {routes.map((route) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-lg font-bold text-gray-950">{route.name}</h3>
            <p class="mt-2 font-semibold text-brand-700">{route.plan}</p>
            <p class="mt-2 text-sm leading-6 text-gray-600">{route.fit}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Все гиды по городам</p>
            <h2>Статьи о городах и местный транспорт</h2>
          </div>
        </div>
        <div class="mt-6 grid gap-5 md:grid-cols-2">
          {cityPosts.map((post) => (
            <a href={`/ru/posts/${post.slug}/`} class="card block hover:no-underline">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{post.data.category}</span>
              <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <p class="section-kicker">Перед выбором города</p>
        <h2 class="mt-1 text-xl font-bold text-gray-950">Проверьте логистику</h2>
        <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
          <li><a href="/ru/payment/" class="font-semibold text-brand-700">Оплата:</a> настройте Alipay, WeChat Pay и запас наличных до поездок в небольшие города.</li>
          <li><a href="/ru/esim/" class="font-semibold text-brand-700">Интернет:</a> выберите eSIM, роуминг или местную SIM-карту, прежде чем полагаться на карты и переводчик.</li>
          <li><a href="/ru/transport/" class="font-semibold text-brand-700">Транспорт:</a> сравните поезда, трансферы из аэропорта, DiDi и QR-коды метро.</li>
          <li><a href="/ru/tools/best-time-to-visit/" class="font-semibold text-brand-700">Время:</a> проверьте погоду, праздники и наплыв туристов по месяцам.</li>
        </ul>
      </aside>
    </section>

    <section class="mt-12" aria-labelledby="city-faq">
      <div class="section-heading">
        <div>
          <p class="section-kicker">FAQ по городам</p>
          <h2 id="city-faq">Частые вопросы о планировании городов Китая</h2>
        </div>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {faqItems.map((item) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-base font-bold text-gray-950">{item.question}</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">{item.answer}</p>
          </article>
        ))}
      </div>
    </section>

    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  </main>
  <Footer />
</BaseLayout>
