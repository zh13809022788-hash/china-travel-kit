---
import { getCollection } from 'astro:content';
import { getCategoryLabel } from '../../i18n/categories';
import { CITY_GUIDES, type CityGuideEntry } from '../../data/cityGuideData';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CoverImage from '../../components/CoverImage.astro';
import ChinaMap from '../../components/ChinaMap.astro';
import AdSlot from '../../components/AdSlot.astro';

const allPosts = await getCollection('posts');

// Определяем, у каких путеводителей по городам есть опубликованные материалы
const postMap = new Map<string, typeof allPosts[0]>();
for (const post of allPosts) {
  for (const guide of CITY_GUIDES) {
    if (post.slug === guide.slug || post.slug.includes(guide.slug)) {
      postMap.set(guide.slug, post);
    }
  }
}

// Показываем только города, для которых есть опубликованный материал-путеводитель
const activeGuides = CITY_GUIDES.filter((g) => postMap.has(g.slug));
const activeSlugs = new Set(activeGuides.map((g) => g.slug));

// Координаты на карте с правильными ссылками href
const mapCities = CITY_GUIDES.map((g) => ({
  name: g.name,
  x: g.mapX,
  y: g.mapY,
  href: postMap.has(g.slug) ? `#${g.name.toLowerCase().replace(/[^a-z]/g, '')}` : '',
}));

// Карточки городов, отсортированные по названию
const cities = [...activeGuides].sort((a, b) => a.name.localeCompare(b.name));

// Все материалы, связанные с городами (отсортированы по заголовку)
const cityPosts = allPosts
  .filter((post) => activeSlugs.has(post.slug) || post.data.tags?.some((t: string) =>
    [...activeSlugs].some((s) => s.includes(t) || t.includes(s))
  ))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const title = 'Путеводители по городам Китая для иностранных путешественников';
const description = `Планируйте практичные остановки в городах Китая с путеводителями по ${activeGuides.map((g) => g.name).join(', ')}.`;

const routes = [
  {
    name: 'Первая поездка в Китай, 8–10 дней',
    plan: 'Shanghai 3 дня, Hangzhou 2 дня, Beijing 4 дня',
    fit: 'Лучший баланс удобного прибытия, классических пейзажей и ключевых исторических мест.',
  },
  {
    name: 'Еда и расслабленный темп, 7–9 дней',
    plan: 'Chengdu 4 дня, Beijing или Shanghai 3–4 дня',
    fit: 'Подходит путешественникам, которые хотят увидеть панд, чайные дома, попробовать хотпот и посетить один крупный город-ворота.',
  },
  {
    name: 'Побег от зимы, 6–10 дней',
    plan: 'Sanya 4–6 дней, Shanghai 2–3 дня',
    fit: 'Лучший вариант, когда на севере Китая холодно и вам хочется простого сочетания пляжа и города.',
  },
  {
    name: 'Открытие юга, 10–12 дней',
    plan: 'Guangzhou 3 дня, Guilin 3 дня, Shanghai 4 дня',
    fit: 'Отлично подходит для любителей еды, живописных ландшафтов и спокойного темпа путешествия по югу Китая.',
  },
  {
    name: 'Древние столицы, 10–12 дней',
    plan: 'Beijing 4 дня, Xi\'an 3 дня, Nanjing 2 дня, Shanghai 3 дня',
    fit: 'Маршрут для любителей истории по императорским столицам Китая с пересадками на скоростных поездах.',
  },
];

const faqItems = [
  {
    question: 'Какой город Китая самый удобный для иностранных путешественников, которые едут впервые?',
    answer:
      'Shanghai обычно является самым удобным первым городом, потому что аэропорты, указатели в метро, отели, рестораны и международные сервисы там лучше всего приспособлены для иностранцев. Beijing тоже вполне удобен, но требует более раннего бронирования и более тщательного планирования каждого дня.',
  },
  {
    question: 'Сколько китайских городов стоит посетить за одну поездку?',
    answer:
      'Для первой поездки на 8–10 дней достаточно двух или трёх городов. Китай большой, а трансферы в аэропорты, вокзалы, проверки безопасности и смена отелей могут занять больше времени, чем ожидается. Выберите один основной город прибытия, одну культурную или живописную остановку и один дополнительный пункт по желанию.',
  },
  {
    question: 'Какой город лучше всего подходит для более длительного пребывания в Китае?',
    answer:
      'Shanghai — самая удобная база для длительного пребывания с точки зрения сервисов и доступности английского языка, Chengdu лучше по более низким расходам и расслабленному образу жизни, а Hangzhou предлагает золотую середину с красивыми пейзажами и сильной технологической экономикой. Sanya хорошо подходит для зимнего пребывания, но не для круглогодичной городской жизни.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
const locale = 'en';
---
<!-- Контент создан с помощью ИИ, проверен носителем языка -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Планирование по городам</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="city-shanghai" alt="Панорама Shanghai и набережная Bund в сумерках, символизирующие путешествия по городам Китая" loading="eager" />

    <ChinaMap cities={mapCities} />

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3" aria-labelledby="city-shortcuts">
      <h2 id="city-shortcuts" class="sr-only">Быстрые переходы по городам</h2>
      {cities.map((city) => (
        <a href={city.slug ? `/posts/${city.slug}/` : '#'} class="card block hover:no-underline scroll-mt-20" id={city.name.toLowerCase().replace(/[^a-z]/g, '')}>
          <h3 class="text-xl font-bold text-gray-950">{city.name}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{city.desc}</p>
          <dl class="mt-4 grid gap-2 text-sm text-gray-700">
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Рекомендуемая продолжительность</dt>
              <dd class="text-right">{city.days}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Лучший сезон</dt>
              <dd class="text-right">{city.bestSeason}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Удобство для путешественников</dt>
              <dd class="text-right">{city.difficulty}</dd>
            </div>
          </dl>
          <span class="mt-3 inline-block text-sm font-semibold text-brand-700">Открыть путеводитель по городу →</span>
        </a>
      ))}
    </section>

    <section class="mt-12" aria-labelledby="compare-cities">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Сравнение городов</p>
          <h2 id="compare-cities">Какой город Китая вам выбрать?</h2>
        </div>
      </div>
      <div class="mt-6 overflow-hidden rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
          <thead class="bg-gray-50 text-xs font-semibold uppercase tracking-wide text-gray-600">
            <tr>
              <th class="px-4 py-3">Город</th>
              <th class="px-4 py-3">Зачем ехать</th>
              <th class="px-4 py-3">Рекомендуемая продолжительность</th>
              <th class="px-4 py-3">Лучший сезон</th>
              <th class="px-4 py-3">Удобство</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {cities.map((city) => (
              <tr>
                <th class="px-4 py-4 font-bold text-gray-950">
                  <a href={`/posts/${city.slug}/`} class="text-brand-700 hover:text-brand-800">{city.name}</a>
                </th>
                <td class="px-4 py-4 leading-6 text-gray-700">{city.whyGo}</td>
                <td class="px-4 py-4 text-gray-700">{city.days}</td>
                <td class="px-4 py-4 text-gray-700">{city.bestSeason}</td>
                <td class="px-4 py-4 text-gray-700">{city.difficulty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-12 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]" aria-labelledby="route-ideas">
      <div>
        <p class="section-kicker">Планирование маршрута</p>
        <h2 id="route-ideas" class="mt-2 text-3xl font-bold text-gray-950">Практичные сочетания городов</h2>
        <p class="mt-3 leading-7 text-gray-600">
          Хороший маршрут по Китаю обычно работает лучше, когда у городов разные роли. Используйте Shanghai как удобную
          точку прибытия, Beijing для истории, Hangzhou для пейзажей, Chengdu для еды и доступа к западному Китаю, а
          Sanya для тёплого отдыха. Старайтесь не добавлять слишком много перелётов или пересадок на вокзалах в короткую поездку.
        </p>
      </div>
      <div class="grid gap-4">
        {routes.map((route) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-lg font-bold text-gray-950">{route.name}</h3>
            <p class="mt-2 font-semibold text-brand-700">{route.plan}</p>
            <p class="mt-2 text-sm leading-6 text-gray-600">{route.fit}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Все материалы о городах</p>
            <h2>Статьи о городах и местном транспорте</h2>
          </div>
        </div>
        <div class="mt-6 grid gap-5 md:grid-cols-2">
          {cityPosts.map((post) => (
            <a href={`/posts/${post.slug}/`} class="card block hover:no-underline">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
              <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <p class="section-kicker">Перед выбором города</p>
        <h2 class="mt-1 text-xl font-bold text-gray-950">Проверьте логистическую базу</h2>
        <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
          <li><a href="/payment/" class="font-semibold text-brand-700">Платежи:</a> настройте Alipay, WeChat Pay и запасной вариант с наличными перед поездкой в небольшие города.</li>
          <li><a href="/esim/" class="font-semibold text-brand-700">Интернет:</a> выберите eSIM, роуминг или местную SIM-карту, прежде чем полагаться на карты и перевод.</li>
          <li><a href="/transport/" class="font-semibold text-brand-700">Транспорт:</a> сравните поезда, трансферы из аэропорта, DiDi и QR-коды для метро.</li>
          <li><a href="/tools/best-time-to-visit/" class="font-semibold text-brand-700">Время поездки:</a> проверьте погоду, праздники и уровень загруженности по месяцам.</li>
        </ul>
      </aside>
    </section>

    <section class="mt-12" aria-labelledby="city-faq">
      <div class="section-heading">
        <div>
          <p class="section-kicker">FAQ по городам</p>
          <h2 id="city-faq">Частые вопросы о планировании поездок по городам Китая</h2>
        </div>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {faqItems.map((item) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-base font-bold text-gray-950">{item.question}</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">{item.answer}</p>
          </article>
        ))}
      </div>
    </section>

    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  </main>
  <Footer />
</BaseLayout>