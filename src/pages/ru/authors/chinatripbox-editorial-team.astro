---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";

const title = 'Редакционная команда ChinaTripBox';
const description =
  'О редакционной команде ChinaTripBox, о том, как мы исследуем практические путеводители по Китаю, и о том, как читатели могут запросить исправления.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': new URL('/authors/chinatripbox-editorial-team/#person', Astro.site).toString(),
  name: title,
  url: new URL('/authors/chinatripbox-editorial-team/', Astro.site).toString(),
  affiliation: {
    '@type': 'Organization',
    name: 'ChinaTripBox',
    url: new URL('/', Astro.site).toString(),
  },
  knowsAbout: [
    'планирование поездки по Китаю',
    'мобильные платежи в Китае',
    'eSIM и доступ в интернет в Китае',
    'высокоскоростные железные дороги Китая',
    'логистика для иностранных посетителей в Китае',
  ],
};
---
<!-- Контент создан с помощью ИИ, проверен носителем языка -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-12">
    <article class="prose-content article-body">
      <p class="section-kicker">Автор</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-900">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>

      <h2>Редакционный фокус</h2>
      <p>
        Редакционная команда ChinaTripBox пишет практические путеводители для иностранных
        посетителей Китая, уделяя особое внимание настройке платежей, eSIM и доступу в интернет,
        высокоскоростным железным дорогам, заказу поездок, трансферам из аэропорта, планированию
        по городу, заказу еды и распространенным проблемам первой поездки.
      </p>

      <h2>Как мы создаем путеводители</h2>
      <p>
        Мы объединяем официальные источники, документацию поставщиков, справочные материалы
        приложений, вопросы читателей, отчеты путешественников и, где возможно, практические
        проверки. Для быстро меняющихся тем, таких как безвизовый въезд, лимиты платежей,
        доступность приложений и правила транспорта, мы считаем официальные страницы
        правительства или поставщика окончательным источником.
      </p>

      <h2>Исправления</h2>
      <p>
        Логистика поездок по Китаю меняется быстро. Если вы обнаружили устаревший шаг,
        изменившуюся политику, неработающую ссылку или отсутствующую важную оговорку, пожалуйста,
        отправьте URL страницы через нашу <a href="/contact/">страницу контактов</a>.
        Мы рассматриваем исправления и обновляем затронутые путеводители, когда доказательства
        однозначны.
      </p>

      <h2>Редакционная политика</h2>
      <p>
        Ознакомьтесь с нашей <a href="/editorial-policy/">редакционной политикой</a>, чтобы
        узнать подробнее об исследовании, обновлениях, раскрытии партнерских ссылок,
        независимости и ограничениях.
      </p>

      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    </article>
  </main>
  <Footer />
</BaseLayout>