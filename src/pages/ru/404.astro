---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'Страница не найдена';
const description = 'Страница не найдена — ChinaTripBox';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} noindex>
  <Header />
  <main class="container-page py-16">
    <section class="mx-auto max-w-2xl">
      <p class="section-kicker">404</p>
      <h1 class="mt-2 text-4xl font-bold text-gray-950">Страница не найдена</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">Похоже, страницу переместили, удалили или адрес был указан с ошибкой.</p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/ru/" class="btn-primary">На главную</a>
        <a href="/ru/resources/" class="btn-outline">Начать отсюда</a>
        <a href="/ru/tools/" class="btn-outline">Инструменты</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
