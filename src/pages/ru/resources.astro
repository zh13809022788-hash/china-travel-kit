---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'Ресурсы для поездки в Китай';
const description =
  'Практичный центр материалов для иностранных путешественников по Китаю: оплата, eSIM, поезда, визы, гиды по городам, полезные инструменты и ссылки для подготовки первой поездки.';

const resourceGroups = [
  {
    title: 'Если у вас есть только 30 минут',
    description: 'Короткий маршрут чтения для тех, кому нужно быстро подготовиться к поездке в Китай.',
    links: [
      { href: '/ru/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: 'Чек-лист подготовки перед вылетом' },
      { href: '/ru/tools/survival-kit/', title: 'Карточки и чек-листы для выживания в Китае' },
      { href: '/ru/tools/payment-checker/', title: 'Проверить запасной план по оплате' },
      { href: '/ru/tools/visa-free-checker/', title: 'Проверить безвизовый въезд или транзит' },
      { href: '/ru/posts/china-high-speed-rail-guide-foreigners/', title: 'Как бронировать поезда и проходить на вокзал' },
    ],
  },
  {
    title: 'Начните отсюда: подготовка к первой поездке',
    description: 'Самый короткий путь от мысли "я еду в Китай" до понятного плана на день прилёта.',
    links: [
      { href: '/ru/trip-planner/', title: 'Бесплатный планировщик поездки в Китай' },
      { href: '/ru/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/', title: 'Планировщик поездки в Китай для новичков' },
      { href: '/ru/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: 'Что настроить перед поездкой в Китай' },
      { href: '/ru/posts/china-visa-free-entry-transit-guide-2026/', title: 'Гид по безвизовому въезду и транзиту' },
      { href: '/ru/tools/best-time-to-visit/', title: 'Когда лучше ехать в Китай' },
      { href: '/ru/posts/what-to-pack-for-china-a-season-by-season-checklist/', title: 'Что взять с собой в Китай' },
    ],
  },
  {
    title: 'Оплата и деньги',
    description: 'Мобильные платежи, наличные на всякий случай, банковские карты и типичные проблемы на кассе.',
    links: [
      { href: '/ru/posts/how-to-pay-in-china-tourist-guide/', title: 'Как туристу платить в Китае' },
      { href: '/ru/posts/alipay-foreign-credit-card-step-by-step/', title: 'Как настроить Alipay с иностранной картой' },
      { href: '/ru/posts/wechat-pay-foreign-visitors-guide/', title: 'Гид по WeChat Pay для иностранных гостей' },
      { href: '/ru/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: 'Чек-лист по оплате и приложениям перед выездом' },
      { href: '/ru/tools/payment-checker/', title: 'Проверка совместимости способов оплаты' },
    ],
  },
  {
    title: 'Интернет и приложения',
    description: 'Как оставаться онлайн, выбрать eSIM и заранее понять, какие приложения будут работать.',
    links: [
      { href: '/ru/posts/best-esim-for-china-travel-2026/', title: 'Лучшая eSIM для поездки в Китай' },
      { href: '/ru/posts/china-esim-vs-roaming-2026-the-real-10-day-cost/', title: 'Сравнение eSIM и роуминга по стоимости' },
      { href: '/ru/posts/internet-access-china-apps-that-work-2026/', title: 'Интернет и приложения в Китае' },
      { href: '/ru/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/', title: 'Планирование первой поездки: eSIM и приложения' },
      { href: '/ru/tools/app-availability-checker/', title: 'Будут ли мои приложения работать в Китае?' },
    ],
  },
  {
    title: 'Транспорт и гиды по городам',
    description: 'Поезда, метро, аэропорты, такси через приложения и практическая логистика по городам.',
    links: [
      { href: '/ru/cities/', title: 'Центр гидов по городам Китая' },
      { href: '/ru/posts/china-high-speed-rail-guide-foreigners/', title: 'Гид по скоростным поездам Китая для иностранцев' },
      { href: '/ru/posts/book-china-train-tickets-12306-foreigners/', title: 'Как купить билеты на поезд через 12306' },
      { href: '/ru/posts/didi-china-foreign-tourists-guide/', title: 'Как пользоваться DiDi иностранному туристу' },
      { href: '/ru/posts/airport-to-city-transport-beijing-shanghai-guangzhou/', title: 'Как добраться из аэропорта в город' },
    ],
  },
  {
    title: 'Еда, этикет и повседневная жизнь',
    description: 'Рестораны, чаевые, доставка еды, уличная еда и бытовые привычки, которые помогают избежать лишних сложностей.',
    links: [
      { href: '/ru/food/', title: 'Раздел о еде и ресторанах в Китае' },
      { href: '/ru/posts/ordering-food-in-china-without-chinese-meituan-ele-me/', title: 'Как заказывать еду без знания китайского' },
      { href: '/ru/posts/chengdu-street-food-safety-spice-levels-what-to-order/', title: 'Безопасность уличной еды в Чэнду и уровень остроты' },
      { href: '/ru/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/', title: 'Чаевые в Китае: когда они уместны' },
    ],
  },
  {
    title: 'Долгие поездки и удалённая работа',
    description: 'Для поездок на недели и месяцы: легальность, жильё, оплата и надёжность рабочих инструментов.',
    links: [
      { href: '/ru/long-stay/', title: 'Гид по длительному пребыванию в Китае' },
      { href: '/ru/digital-nomads/', title: 'Гид по Китаю для цифровых кочевников' },
      { href: '/ru/digital-nomads/visa/', title: 'Визовый гид для цифровых кочевников' },
      { href: '/ru/digital-nomads/payment/', title: 'Настройка оплаты для долгого пребывания' },
    ],
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <section class="max-w-3xl">
      <p class="section-kicker">Центр ресурсов</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </section>

    <section class="mt-10 grid gap-5 md:grid-cols-2">
      {resourceGroups.map((group) => (
        <article class="card">
          <h2 class="text-xl font-bold text-gray-950">{group.title}</h2>
          <p class="mt-2 text-sm leading-6 text-gray-600">{group.description}</p>
          <ul class="mt-5 grid gap-3">
            {group.links.map((link) => (
              <li>
                <a href={link.href} class="font-semibold text-brand-700 hover:text-brand-800">
                  {link.title}
                </a>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>
