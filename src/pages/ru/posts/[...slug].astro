---
import { getCollection } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts-ru');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { data } = post;

const affiliateByCategory: Record<string, { title: string; description: string; buttonText: string }> = {
  payment: {
    title: 'Настройка оплаты',
    description: 'Подготовьте туристическую карту для Alipay и WeChat Pay заранее — в Китае будет спокойнее.',
    buttonText: 'Начать настройку',
  },
  esim: {
    title: 'Рекомендуемая eSIM для Китая',
    description: 'Не стойте в очереди в аэропорту. Активируйте высокоскоростной интернет до вылета.',
    buttonText: 'Смотреть тарифы',
  },
  transport: {
    title: 'Билеты на поезд и трансфер',
    description: 'Забронируйте билеты на скоростной поезд и трансфер из аэропорта на английском — меньше стресса.',
    buttonText: 'Забронировать',
  },
};

const affiliate = affiliateByCategory[data.category];
const allPosts = await getCollection('posts-ru');
const related = allPosts
  .filter((candidate) => candidate.slug !== post.slug)
  .map((candidate) => {
    const sharedTags = candidate.data.tags.filter((tag) => data.tags.includes(tag)).length;
    const categoryMatch = candidate.data.category === data.category ? 2 : 0;
    const cityMatch =
      ['beijing', 'shanghai', 'chengdu', 'hangzhou', 'sanya'].some(
        (city) => post.slug.includes(city) && candidate.slug.includes(city)
      )
        ? 3
        : 0;
    return { candidate, score: sharedTags + categoryMatch + cityMatch };
  })
  .filter((item) => item.score > 0)
  .sort((a, b) => b.score - a.score || b.candidate.data.pubDate.valueOf() - a.candidate.data.pubDate.valueOf())
  .slice(0, 4)
  .map(({ candidate }) => ({
    title: candidate.data.title,
    description: candidate.data.description,
    href: `/ru/posts/${candidate.slug}/`,
  }));
---

<BlogPost
  title={data.title}
  description={data.description}
  pubDate={data.pubDate}
  category={data.category}
  tags={data.tags}
  faqs={data.faqs}
  cover={data.cover}
  coverAlt={data.coverAlt}
  related={related}
  locale="ru"
  alternates={{ en: `/posts/${post.slug}/`, ru: `/ru/posts/${post.slug}/` }}
  affiliate={affiliate}
>
  <Content />
</BlogPost>
