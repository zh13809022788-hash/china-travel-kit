---
import { getCollection } from 'astro:content';
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import AdSlot from "../../../components/AdSlot.astro";
import CoverImage from "../../../components/CoverImage.astro";

const CATEGORY = 'esim';
const posts = (await getCollection('posts'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'eSIM и руководства по мобильному интернету — оставайтесь онлайн сразу по прилете';
const description =
  'Сравните и настройте лучшие тарифы eSIM для поездки в China. Подключитесь к интернету сразу после приземления, без необходимости менять физическую SIM-карту.';

const connectionChoices = [
  {
    title: 'eSIM',
    desc: 'Лучший вариант для большинства коротких поездок, если ваш телефон поддерживает eSIM и вы хотите, чтобы интернет был готов еще до посадки.',
  },
  {
    title: 'Roaming',
    desc: 'Полезен как запасной вариант для SMS от банка и подключения в первый час, но часто обходится дороже при активном использовании интернета.',
  },
  {
    title: 'Pocket Wi-Fi or local SIM',
    desc: 'Стоит рассмотреть для групп, более длительных поездок или телефонов, на которые нельзя установить туристические eSIM.',
  },
];

const internetTools = [
  { href: '/tools/esim-comparison/', title: 'Сравнение тарифов eSIM', desc: 'Сравните туристические тарифы на интернет, срок действия и предполагаемые сценарии использования.' },
  { href: '/tools/app-availability-checker/', title: 'Проверка доступности приложений', desc: 'Проверьте, работают ли в China популярные приложения и какие альтернативы стоит подготовить.' },
  { href: '/posts/internet-access-china-apps-that-work-2026/', title: 'Руководство по доступу в интернет', desc: 'Узнайте о доступности приложений, ожиданиях по VPN и практической настройке до прибытия.' },
];
import { getCategoryLabel } from "../../../i18n/categories";
const locale = 'en';
---
<!-- Контент создан с помощью ИИ, проверен носителем языка -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header>
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">eSIM</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">eSIM и руководства по мобильному интернету</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="hub-esim" alt="Варианты мобильной сети и подключения к интернету для поездки в China" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-esim">
      <h2 id="featured-esim" class="sr-only">Рекомендуемые руководства по интернету</h2>
      <a href="/posts/best-esim-for-china-travel-2026/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Лучшие eSIM 2026</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Сравните Airalo, Holafly, Nomad для поездки в China</p>
      </a>
      <a href="/posts/china-esim-vs-roaming-2026-the-real-10-day-cost/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">eSIM против роуминга</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Реальное сравнение стоимости на 10 дней для туристов</p>
      </a>
      <a href="/posts/do-you-need-a-vpn-in-china-2026/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Руководство по VPN 2026</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Нужен ли туристам VPN в China?</p>
      </a>
      <a href="/posts/pocket-wifi-vs-esim-vs-sim-china/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Pocket WiFi против eSIM</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Сравните все варианты подключения</p>
      </a>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[1fr_340px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">Выберите подходящий способ подключения к интернету в China</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          Самый надежный вариант для путешественников обычно включает один основной способ доступа к интернету плюс запасной вариант для банка, карт, перевода и вызова такси в первый день.
        </p>
        <div class="mt-5 grid gap-3">
          {connectionChoices.map((choice) => (
            <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
              <h3 class="text-sm font-bold text-gray-900">{choice.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{choice.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Инструменты для интернета</h2>
        <div class="mt-4 grid gap-3">
          {internetTools.map((tool) => (
            <a href={tool.href} class="rounded-lg border border-brand-100 bg-white p-4 hover:border-brand-200 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-900 hover:text-brand-700">{tool.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{tool.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{getCategoryLabel(post.data.category, locale)}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">Руководства скоро появятся.</p>}
    </section>
  
    <section class="mt-12 rounded-lg border border-gray-200 bg-gray-50 p-6">
      <h2 class="text-xl font-bold text-gray-950">Похожие руководства по интернету</h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <a href="/posts/best-esim-for-china-travel-2026/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Лучшие тарифы eSIM 2026</p>
          <p class="mt-1 text-sm text-gray-600">Сравните лучших провайдеров eSIM для поездки в China</p>
        </a>
        <a href="/posts/china-esim-vs-roaming-2026-the-real-10-day-cost/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Стоимость eSIM и роуминга</p>
          <p class="mt-1 text-sm text-gray-600">Реальное сравнение стоимости на 10 дней для путешественников в China</p>
        </a>
        <a href="/posts/do-you-need-a-vpn-in-china-2026/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Руководство по VPN для China</p>
          <p class="mt-1 text-sm text-gray-600">Нужен ли вам VPN? Какие из них работают в 2026 году?</p>
        </a>
        <a href="/posts/internet-access-china-apps-that-work-2026/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Руководство по доступу в интернет</p>
          <p class="mt-1 text-sm text-gray-600">Какие приложения работают в China без VPN</p>
        </a>
      </div>
    </section>
</main>
  <Footer />
</BaseLayout>