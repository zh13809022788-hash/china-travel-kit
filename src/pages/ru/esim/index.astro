---

import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const CATEGORY = 'esim';
const posts = (await getCollection('posts-ru'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'eSIM и интернет в Китае: связь сразу после прилёта';
const description = 'Сравните и выберите лучшие тарифы eSIM для поездки в Китай. Подключайтесь сразу после приземления без замены физической SIM-карты.';

const connectionChoices = [
  {
    title: 'eSIM',
    desc: 'Лучший вариант для большинства коротких поездок, если ваш телефон поддерживает eSIM и вы хотите получить интернет ещё до приземления.',
  },
  {
    title: 'Роуминг',
    desc: 'Полезен как запасной вариант для банковских SMS и подключения в первый час после прилёта, но при большом расходе трафика часто обходится дороже.',
  },
  {
    title: 'Карманный Wi‑Fi или местная SIM-карта',
    desc: 'Подходит для групп, длительных поездок или телефонов, которые не поддерживают установку туристических eSIM.',
  },
];

const internetTools = [
  { href: '/ru/tools/esim-comparison/', title: 'Сравнение тарифов eSIM', desc: 'Сравните туристические пакеты трафика, срок действия и подходящие сценарии использования.' },
  { href: '/ru/tools/app-availability-checker/', title: 'Проверка доступности приложений', desc: 'Проверьте, какие популярные приложения работают в Китае и какие альтернативы стоит подготовить заранее.' },
  { href: '/ru/posts/internet-access-china-apps-that-work-2026/', title: 'Гид по доступу в интернет', desc: 'Разберитесь с доступностью приложений, ожиданиями по VPN и практической подготовкой до поездки.' },
];
---


<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">eSIM</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Гиды по eSIM и мобильному интернету</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="hub-esim" alt="Варианты мобильной связи и доступа к интернету для поездки в Китай" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-esim">
      <h2 id="featured-esim" class="sr-only">Рекомендуемые гиды по интернету</h2>
      <a href="/ru/posts/best-esim-for-china-travel-2026/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Лучшая eSIM в 2026 году</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Сравнение Airalo, Holafly и Nomad для поездки в Китай</p>
      </a>
      <a href="/ru/posts/china-esim-vs-roaming-2026-the-real-10-day-cost/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">eSIM или роуминг</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Реальное сравнение расходов за 10 дней для туристов</p>
      </a>
      <a href="/ru/posts/do-you-need-a-vpn-in-china-2026/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Гид по VPN 2026</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Нужен ли туристам VPN в Китае?</p>
      </a>
      <a href="/ru/posts/pocket-wifi-vs-esim-vs-sim-china/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Pocket WiFi или eSIM</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Сравнение всех вариантов подключения</p>
      </a>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[1fr_340px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">Выберите подходящий вариант интернета в Китае</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          Самый надёжный вариант для путешественников обычно включает один основной способ выхода в интернет и резервный вариант для банковских SMS, карт, перевода и вызова такси в первый день поездки.
        </p>
        <div class="mt-5 grid gap-3">
          {connectionChoices.map((choice) => (
            <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
              <h3 class="text-sm font-bold text-gray-900">{choice.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{choice.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Полезные инструменты</h2>
        <div class="mt-4 grid gap-3">
          {internetTools.map((tool) => (
            <a href={tool.href} class="rounded-lg border border-brand-100 bg-white p-4 hover:border-brand-200 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-900 hover:text-brand-700">{tool.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{tool.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/ru/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{post.data.category}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('ru-RU', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">Гиды скоро появятся.</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>