---

import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const posts = (await getCollection('posts-ru'))
  .filter((p) => p.data.category === 'food' || p.data.tags.includes('tipping') || p.data.tags.includes('restaurants'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Еда, рестораны и этикет в Китае';
const description = 'Практичные гастрономические гиды по Китаю для иностранных гостей: доставка еды, безопасность уличной еды, уровни остроты, чаевые, ресторанный этикет и культура питания.';

const pathways = [
  {
    title: 'Заказать еду без знания китайского',
    desc: 'Настройте приложения доставки, сохраните адрес отеля и избегайте путаницы со звонками курьеров.',
    href: '/ru/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
  },
  {
    title: 'Безопасно есть уличную еду',
    desc: 'Ориентируйтесь на поток покупателей, видимый жар, привычки с водой и фразы про остроту, чтобы выбирать удачные точки.',
    href: '/ru/posts/chengdu-street-food-safety-spice-levels-what-to-order/',
  },
  {
    title: 'Разобраться в ресторанном этикете',
    desc: 'Поймите, когда чаевые не нужны, когда важен сервисный сбор и как устроены местные ресторанные нормы.',
    href: '/ru/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/',
  },
];

const cultureLinks = [
  {
    href: 'https://baijiu365.com/baijiu-101/',
    title: 'Байцзю: основы',
    desc: 'Полезная база, если на банкете или званом ужине подают национальный китайский крепкий напиток.',
  },
  {
    href: 'https://baijiu365.com/how-to-drink-baijiu/',
    title: 'Как вежливо пить байцзю',
    desc: 'Более подробный гид по тостам, небольшим порциям и тому, как держать темп на официальных застольях.',
  },
];
---


<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ru">
  <Header locale="ru" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Еда и рестораны</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-chengdu-food" alt="Острые сычуаньские блюда уличной еды на ночном рынке в Китае" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 md:grid-cols-3" aria-labelledby="food-pathways">
      <h2 id="food-pathways" class="sr-only">Маршруты планирования еды</h2>
      {pathways.map((item) => (
        <a href={item.href} class="card block hover:no-underline">
          <h3 class="text-lg font-bold text-gray-950">{item.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{item.desc}</p>
          <span class="mt-4 inline-flex text-sm font-semibold text-brand-700">Читать гид</span>
        </a>
      ))}
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Гиды</p>
            <h2>Статьи о еде и этикете</h2>
          </div>
        </div>
        <div class="mt-6 grid gap-5 md:grid-cols-2">
          {posts.map((post) => (
            <a href={`/ru/posts/${post.slug}/`} class="card block hover:no-underline">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{post.data.category}</span>
              <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
        <p class="section-kicker">Культурный контекст</p>
        <h2 class="mt-1 text-xl font-bold text-gray-950">Если на столе появляется байцзю</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          Для большинства туристических ужинов знания об алкоголе не нужны, но на банкетах, деловых
          ужинах и семейных застольях в сельской местности иногда бывают тосты с байцзю. Эти материалы
          помогут разобраться глубже, а ChinaTripBox по-прежнему сосредоточен на практической стороне поездки.
        </p>
        <div class="mt-5 grid gap-3">
          {cultureLinks.map((link) => (
            <a href={link.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-950">{link.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{link.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>