---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const title = 'Series de contenido sobre viajes por China';
const description = 'Explora China a través de cinco series temáticas: gastronomía, historia, vida moderna, naturaleza y cultura. Cada una está pensada para inspirar e informar a viajeros extranjeros.';

const seriesList = [
  {
    href: '/es/series/food-of-china/',
    title: 'Gastronomía de China',
    desc: 'De los puestos callejeros a los salones de banquetes: un recorrido culinario por las ocho grandes cocinas, los desayunos regionales, los distintos estilos de hot pot y los platos por los que merece la pena cruzar una ciudad.',
    icon: 'Comida y bebida',
  },
  {
    href: '/es/series/history-of-china/',
    title: 'Historia de China',
    desc: 'Lugares históricos explicados para viajeros: la Gran Muralla, el Ejército de Terracota, la Ciudad Prohibida, la Ruta de la Seda y el contexto de lo que estás viendo.',
    icon: 'Historia',
  },
  {
    href: '/es/series/modern-china/',
    title: 'China moderna',
    desc: 'Lo que más sorprende a muchos visitantes: calles donde manda el QR, algunos de los trenes más rápidos del mundo, megaciudades, superapps y la tecnología cotidiana que marca la vida en China hoy.',
    icon: 'Vida moderna',
  },
  {
    href: '/es/series/nature-of-china/',
    title: 'Naturaleza de China',
    desc: 'Montañas que recuerdan a Avatar, lagos de postal, paisajes kársticos y la meseta tibetana: algunos de los entornos naturales más espectaculares de China, con guías prácticas para visitantes extranjeros.',
    icon: 'Naturaleza',
  },
  {
    href: '/es/series/culture-of-china/',
    title: 'Cultura de China',
    desc: 'Ceremonia del té, Fiesta de Primavera, mianzi y guanxi, caligrafía, kung fu y zodiaco: tradiciones culturales explicadas para viajeros que quieren ir más allá de lo superficial.',
    icon: 'Cultura',
  },
];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Series de contenido</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <section class="mt-10 grid gap-5 md:grid-cols-2">
      {seriesList.map((s) => (
        <a href={s.href} class="card block hover:no-underline">
          <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{s.icon}</span>
          <h2 class="mt-2 text-xl font-bold text-gray-950">{s.title}</h2>
          <p class="mt-2 text-sm leading-6 text-gray-600">{s.desc}</p>
          <span class="mt-4 inline-flex text-sm font-semibold text-brand-700">Explorar serie</span>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>
