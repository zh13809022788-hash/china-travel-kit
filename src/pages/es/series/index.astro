---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";

const title = 'Serie de Contenido sobre Viajes por China';
const description = 'Explora China a traves de cinco series tematicas: comida, historia, vida moderna, naturaleza y cultura, cada una disenada para inspirar e informar a los viajeros extranjeros.';

const seriesList = [
  {
    href: '/series/food-of-china/',
    title: 'Comida de China',
    desc: 'Desde puestos callejeros hasta salones de banquetes, el viaje culinario de un extranjero a traves de las ocho grandes cocinas, desayunos regionales, estilos de hot pot y los platos por los que vale la pena cruzar una ciudad.',
    icon: 'Comida y Bebida',
  },
  {
    href: '/series/history-of-china/',
    title: 'Historia de China',
    desc: 'Sitios antiguos explicados para viajeros: la Gran Muralla, el Ejercito de Terracota, la Ciudad Prohibida, la Ruta de la Seda y las historias detras de lo que realmente estas viendo.',
    icon: 'Historia',
  },
  {
    href: '/series/modern-china/',
    title: 'China Moderna',
    desc: 'Lo que mas sorprende a los extranjeros: calles sin efectivo, los trenes mas rapidos del mundo, la escala de las megaciudades, las super apps y la tecnologia cotidiana que define la vida en China hoy.',
    icon: 'Vida Moderna',
  },
  {
    href: '/series/nature-of-china/',
    title: 'Naturaleza de China',
    desc: 'Montanas de Avatar, lagos de cuento de hadas, paisajes karsticos y la meseta tibetana: los sitios naturales mas espectaculares de China con guias practicas para visitantes extranjeros.',
    icon: 'Naturaleza',
  },
  {
    href: '/series/culture-of-china/',
    title: 'Cultura de China',
    desc: 'Ceremonia del te, Festival de Primavera, face y guanxi, caligrafia, kung fu y el zodiaco: tradiciones culturales explicadas para viajeros que quieren ir mas alla del turismo superficial.',
    icon: 'Cultura',
  },
];
import { getCategoryLabel } from "../../../i18n/categories";
const locale = 'en';
---
<!-- Contenido generado con asistencia de IA, revisado por redactor nativo -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Serie de Contenido</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <section class="mt-10 grid gap-5 md:grid-cols-2">
      {seriesList.map((s) => (
        <a href={s.href} class="card block hover:no-underline">
          <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{s.icon}</span>
          <h2 class="mt-2 text-xl font-bold text-gray-950">{s.title}</h2>
          <p class="mt-2 text-sm leading-6 text-gray-600">{s.desc}</p>
          <span class="mt-4 inline-flex text-sm font-semibold text-brand-700">Explorar serie</span>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>