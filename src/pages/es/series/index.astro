---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const title = 'Series de contenido sobre viajes por China';
const description = 'Explora China a traves de cinco series tematicas: gastronomia, historia, vida moderna, naturaleza y cultura; cada una pensada para inspirar e informar a viajeros extranjeros.';

const seriesList = [
  {
    href: '/es/series/food-of-china/',
    title: 'Gastronomia de China',
    desc: 'De los puestos callejeros a los salones de banquetes: un viaje culinario para extranjeros por las ocho grandes cocinas, desayunos regionales, estilos de hot pot y platos por los que vale la pena cruzar una ciudad.',
    icon: 'Comida y bebida',
  },
  {
    href: '/es/series/history-of-china/',
    title: 'Historia de China',
    desc: 'Sitios antiguos explicados para viajeros: la Gran Muralla, el Ejercito de Terracota, la Ciudad Prohibida, la Ruta de la Seda y las historias detras de lo que estas viendo.',
    icon: 'Historia',
  },
  {
    href: '/es/series/modern-china/',
    title: 'China moderna',
    desc: 'Lo que mas sorprende a los extranjeros: calles sin efectivo, los trenes mas rapidos del mundo, megaciudades, superapps y la tecnologia cotidiana que define la vida en China hoy.',
    icon: 'Vida moderna',
  },
  {
    href: '/es/series/nature-of-china/',
    title: 'Naturaleza de China',
    desc: 'Montanas de Avatar, lagos de cuento, paisajes karsticos y la meseta tibetana: los sitios naturales mas espectaculares de China con guias practicas para visitantes extranjeros.',
    icon: 'Naturaleza',
  },
  {
    href: '/es/series/culture-of-china/',
    title: 'Cultura de China',
    desc: 'Ceremonia del te, Fiesta de Primavera, mianzi y guanxi, caligrafia, kung fu y zodiaco: tradiciones culturales explicadas para viajeros que quieren ir mas alla del turismo superficial.',
    icon: 'Cultura',
  },
];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Series de contenido</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <section class="mt-10 grid gap-5 md:grid-cols-2">
      {seriesList.map((s) => (
        <a href={s.href} class="card block hover:no-underline">
          <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{s.icon}</span>
          <h2 class="mt-2 text-xl font-bold text-gray-950">{s.title}</h2>
          <p class="mt-2 text-sm leading-6 text-gray-600">{s.desc}</p>
          <span class="mt-4 inline-flex text-sm font-semibold text-brand-700">Explorar serie</span>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>