---

import BaseLayout from '../../../layouts/BaseLayout.astro';

import Header from '../../../components/Header.astro';

import Footer from '../../../components/Footer.astro';

import AdSlot from '../../../components/AdSlot.astro';

import { TOOLS as tools } from '../../../config';



const title = 'Herramientas gratuitas: visado, pagos, eSIM, presupuesto, tarjetas para taxis y frases';

const description =

  'Herramientas interactivas gratuitas para planificar tu viaje a China: comprueba la entrada sin visa, la compatibilidad de tarjetas de pago, las opciones de eSIM, el presupuesto del viaje, el respaldo en efectivo, los enchufes, las frases en chino y las tarjetas de dirección para taxistas.';



const toolUseCases = [

  {

    title: 'Antes de reservar vuelos',

    text: 'Usa el comprobador de entrada sin visa, el planificador de mejor época y el estimador de presupuesto antes de fijar fechas y ciudades.',

    links: [

      { href: '/es/tools/visa-free-checker/', label: 'Comprobador de entrada sin visa' },

      { href: '/es/tools/best-time-to-visit/', label: 'Mejor época para visitar' },

      { href: '/es/tools/budget-cash-estimator/', label: 'Estimador de presupuesto' },

    ],

  },

  {

    title: 'Antes de la salida',

    text: 'Usa las herramientas de pagos, eSIM, apps, enchufes y frases mientras aún tienes tiempo para solucionar problemas de configuración en casa.',

    links: [

      { href: '/es/tools/payment-checker/', label: 'Comprobador de pagos' },

      { href: '/es/tools/esim-comparison/', label: 'Comparador de eSIM' },

      { href: '/es/tools/app-availability-checker/', label: 'Comprobador de apps' },

    ],

  },

  {

    title: 'Ya en China',

    text: 'Usa las tarjetas para conductores, el conversor de moneda y las frases esenciales cuando las apps, los taxis, los menús o las recepciones del hotel se vuelvan confusos.',

    links: [

      { href: '/es/tools/survival-kit/', label: 'Kit de supervivencia' },

      { href: '/es/tools/show-to-driver/', label: 'Mostrar al conductor' },

      { href: '/es/tools/currency-converter/', label: 'Conversor de RMB' },

      { href: '/es/tools/essential-phrases/', label: 'Frases esenciales' },

    ],

  },

];



const toolsJsonLd = {

  '@context': 'https://schema.org',

  '@type': 'CollectionPage',

  name: title,

  description,

  hasPart: tools.map((tool) => ({

    '@type': 'WebApplication',

    name: tool.title,

    description: tool.desc,

    applicationCategory: 'TravelApplication',

    url: new URL(tool.href, 'https://www.chinatripbox.com').toString(),

  })),

};

---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">

  <script slot="head" type="application/ld+json" set:html={JSON.stringify(toolsJsonLd)} />

  <Header locale="es" />

  <main class="container-page py-12">

    <header class="max-w-2xl">

      <p class="section-kicker">Centro de herramientas</p>

      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Herramientas gratuitas para viajar a China</h1>

      <p class="mt-3 text-lg text-gray-600">{description}</p>

      <div class="mt-5 flex flex-wrap gap-3">

        <a href="/es/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-primary">Usar lista de verificación previa al viaje</a>

        <a href="/es/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">Leer planificador para principiantes</a>

      </div>

    </header>



    <AdSlot format="banner" />



    <section class="mt-8 grid gap-5 lg:grid-cols-3" aria-labelledby="tool-use-cases-heading">

      <div class="lg:col-span-3">

        <h2 id="tool-use-cases-heading" class="text-2xl font-bold text-gray-950">¿Qué herramienta deberías usar primero?</h2>

      </div>

      {toolUseCases.map((useCase) => (

        <article class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">

          <h3 class="text-lg font-bold text-gray-950">{useCase.title}</h3>

          <p class="mt-2 text-sm leading-6 text-gray-600">{useCase.text}</p>

          <div class="mt-4 flex flex-wrap gap-2">

            {useCase.links.map((link) => (

              <a href={link.href} class="rounded-full border border-gray-200 px-3 py-1.5 text-xs font-semibold text-brand-700 hover:border-brand-300 hover:bg-brand-50 hover:no-underline">{link.label}</a>

            ))}

          </div>

        </article>

      ))}

    </section>



    <section class="mt-8 grid gap-6 md:grid-cols-2">

      {tools.map((tool) => (

        <a href={tool.href} class="card block hover:no-underline">

          <div class="text-3xl">{tool.icon}</div>

          <h2 class="mt-3 text-lg font-bold text-gray-900">{tool.title}</h2>

          <p class="mt-1.5 text-sm text-gray-600">{tool.desc}</p>

          <span class="mt-3 inline-block text-sm font-semibold text-brand-600">Abrir herramienta →</span>

        </a>

      ))}

    </section>

  </main>

  <Footer />

</BaseLayout>