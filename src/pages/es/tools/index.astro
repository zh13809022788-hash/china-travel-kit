---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import AdSlot from "../../../components/AdSlot.astro";
import { TOOLS as tools } from "../../../config";

const title = 'Herramientas gratuitas para viajar a China: visa, pagos, eSIM, presupuesto, tarjetas para conductores y frases';
const description =
  'Herramientas interactivas gratuitas para planificar viajes a China: verifica la entrada sin visa, la compatibilidad de tarjetas de pago, las opciones de eSIM, el presupuesto del viaje, el efectivo de respaldo, los enchufes de corriente, frases en chino y tarjetas con direcciones para mostrar al taxista.';

const toolUseCases = [
  {
    title: 'Antes de reservar vuelos',
    text: 'Usa el verificador de entrada sin visa, el planificador de la mejor temporada y el estimador de presupuesto antes de fijar fechas y ciudades.',
    links: [
      { href: '/tools/visa-free-checker/', label: 'Verificador de entrada sin visa' },
      { href: '/tools/best-time-to-visit/', label: 'Mejor época para viajar' },
      { href: '/tools/budget-cash-estimator/', label: 'Estimador de presupuesto' },
    ],
  },
  {
    title: 'Antes de salir',
    text: 'Usa las herramientas de pagos, eSIM, apps, enchufes y frases mientras aún tienes tiempo de resolver problemas de configuración desde casa.',
    links: [
      { href: '/tools/payment-checker/', label: 'Verificador de pagos' },
      { href: '/tools/esim-comparison/', label: 'Comparador de eSIM' },
      { href: '/tools/app-availability-checker/', label: 'Verificador de apps' },
    ],
  },
  {
    title: 'Ya en China',
    text: 'Usa las tarjetas para conductores, la conversión de divisas y las frases esenciales cuando las apps, los taxis, los menús o las recepciones se vuelvan confusos.',
    links: [
      { href: '/tools/survival-kit/', label: 'Kit de supervivencia' },
      { href: '/tools/show-to-driver/', label: 'Mostrar al conductor' },
      { href: '/tools/currency-converter/', label: 'Conversor de RMB' },
      { href: '/tools/essential-phrases/', label: 'Frases esenciales' },
    ],
  },
];

const toolsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  hasPart: tools.map((tool) => ({
    '@type': 'WebApplication',
    name: tool.title,
    description: tool.desc,
    applicationCategory: 'TravelApplication',
    url: new URL(tool.href, 'https://www.chinatripbox.com').toString(),
  })),
};
---
<!-- Contenido generado con asistencia de IA, revisado por redactor nativo -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(toolsJsonLd)} />
  <Header />
  <main class="container-page py-12">
    <header>
      <p class="section-kicker">Centro de herramientas</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Herramientas gratuitas para viajar a China</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-primary">Usar lista previa al viaje</a>
        <a href="/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">Leer guía para quienes viajan por primera vez</a>
      </div>
    </header>

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 lg:grid-cols-3" aria-labelledby="tool-use-cases-heading">
      <div class="lg:col-span-3">
        <h2 id="tool-use-cases-heading" class="text-2xl font-bold text-gray-950">¿Qué herramienta deberías usar primero?</h2>
      </div>
      {toolUseCases.map((useCase) => (
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <h3 class="text-lg font-bold text-gray-950">{useCase.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{useCase.text}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {useCase.links.map((link) => (
              <a href={link.href} class="block rounded-lg border border-brand-200 bg-brand-50 px-4 py-2 text-sm font-semibold text-brand-700 hover:border-brand-300 hover:bg-brand-100 hover:no-underline">{link.label}</a>
            ))}
          </div>
        </div>
      ))}
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {tools.map((tool) => (
        <a href={tool.href} class="card block hover:no-underline">
          <div class="text-3xl">{tool.icon}</div>
          <h2 class="mt-3 text-lg font-bold text-gray-900">{tool.title}</h2>
          <p class="mt-1.5 text-sm text-gray-600">{tool.desc}</p>
          <span class="mt-3 inline-block text-sm font-semibold text-brand-600">Abrir herramienta →</span>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>