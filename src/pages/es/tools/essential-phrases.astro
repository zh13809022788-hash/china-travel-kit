---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Essential Chinese Phrases for Travelers';
const description =
  'A handy, printable list of essential Mandarin Chinese phrases for tourists in China — with pinyin and English. Covers greetings, payment, transport, food, and emergencies.';

interface Phrase {
  en: string;
  zh: string;
  pinyin: string;
}
interface Group {
  id: string;
  label: string;
  icon: string;
  phrases: Phrase[];
}

const groups: Group[] = [
  {
    id: 'basics', label: 'Greetings & Basics', icon: '👋',
    phrases: [
      { en: 'Hello', zh: '你好', pinyin: 'nǐ hǎo' },
      { en: 'Thank you', zh: '谢谢', pinyin: 'xièxie' },
      { en: "You're welcome", zh: '不客气', pinyin: 'bú kèqi' },
      { en: 'Sorry / Excuse me', zh: '对不起', pinyin: 'duìbuqǐ' },
      { en: 'Yes / Correct', zh: '对', pinyin: 'duì' },
      { en: 'No / Not', zh: '不是', pinyin: 'bú shì' },
      { en: 'I don\'t understand', zh: '我不明白', pinyin: 'wǒ bù míngbái' },
      { en: 'Do you speak English?', zh: '你会说英语吗？', pinyin: 'nǐ huì shuō yīngyǔ ma?' },
    ],
  },
  {
    id: 'payment', label: 'Money & Pagos', icon: '💳',
    phrases: [
      { en: 'How much is it?', zh: '多少钱？', pinyin: 'duōshao qián?' },
      { en: 'Can I use Alipay?', zh: '可以用支付宝吗？', pinyin: 'kěyǐ yòng zhīfùbǎo ma?' },
      { en: 'Can I use WeChat Pay?', zh: '可以用微信支付吗？', pinyin: 'kěyǐ yòng wēixìn zhīfù ma?' },
      { en: 'Too expensive', zh: '太贵了', pinyin: 'tài guì le' },
      { en: 'Can I pay by card?', zh: '可以刷卡吗？', pinyin: 'kěyǐ shuākǎ ma?' },
      { en: 'I\'ll scan your code', zh: '我扫你的码', pinyin: 'wǒ sǎo nǐ de mǎ' },
    ],
  },
  {
    id: 'transport', label: 'Getting Around', icon: '🚕',
    phrases: [
      { en: 'Where is the subway?', zh: '地铁站在哪里？', pinyin: 'dìtiě zhàn zài nǎlǐ?' },
      { en: 'Please take me to this address', zh: '请带我去这个地址', pinyin: 'qǐng dài wǒ qù zhège dìzhǐ' },
      { en: 'Stop here, please', zh: '请在这里停', pinyin: 'qǐng zài zhèlǐ tíng' },
      { en: 'Train station', zh: '火车站', pinyin: 'huǒchē zhàn' },
      { en: 'Airport', zh: '机场', pinyin: 'jīchǎng' },
      { en: 'How do I get to...?', zh: '怎么去...？', pinyin: 'zěnme qù...?' },
    ],
  },
  {
    id: 'food', label: 'Food & Dining', icon: '🍜',
    phrases: [
      { en: 'The menu, please', zh: '请给我菜单', pinyin: 'qǐng gěi wǒ càidān' },
      { en: 'I am vegetarian', zh: '我吃素', pinyin: 'wǒ chī sù' },
      { en: 'Not spicy, please', zh: '请不要辣', pinyin: 'qǐng búyào là' },
      { en: 'Water, please', zh: '请给我水', pinyin: 'qǐng gěi wǒ shuǐ' },
      { en: 'The bill, please', zh: '买单', pinyin: 'mǎidān' },
      { en: 'It\'s delicious', zh: '很好吃', pinyin: 'hěn hǎochī' },
    ],
  },
  {
    id: 'help', label: 'Help & Emergencies', icon: '🆘',
    phrases: [
      { en: 'Help!', zh: '救命！', pinyin: 'jiùmìng!' },
      { en: 'Where is the toilet?', zh: '洗手间在哪里？', pinyin: 'xǐshǒujiān zài nǎlǐ?' },
      { en: 'I need a doctor', zh: '我需要看医生', pinyin: 'wǒ xūyào kàn yīshēng' },
      { en: 'Call the police', zh: '请报警', pinyin: 'qǐng bàojǐng' },
      { en: 'I am lost', zh: '我迷路了', pinyin: 'wǒ mílù le' },
      { en: 'Please write it down', zh: '请写下来', pinyin: 'qǐng xiě xiàlái' },
    ],
  },
];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Herramienta</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Frases Esenciales en Chino</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- Controles -->
    <div class="mt-6 flex flex-wrap items-center gap-3 print:hidden">
      <button data-filter="all" class="phrase-filter btn-primary text-sm">Todo</button>
      {groups.map((g) => (
        <button data-filter={g.id} class="phrase-filter rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:border-brand-400">
          {g.icon} {g.label}
        </button>
      ))}
      <button id="print-btn" class="ml-auto rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:border-brand-400">
        🖨️ Imprimir / Guardar PDF
      </button>
    </div>

    <!-- Grupos de frases -->
    <div class="mt-6 space-y-8">
      {groups.map((g) => (
        <section class="phrase-group" data-group={g.id}>
          <h2 class="mb-3 text-xl font-bold text-gray-900">{g.icon} {g.label}</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            {g.phrases.map((p) => (
              <div class="card flex flex-col">
                <span class="text-sm text-gray-500">{p.en}</span>
                <span class="mt-1 text-2xl font-bold text-gray-900">{p.zh}</span>
                <span class="mt-0.5 text-sm italic text-brand-600">{p.pinyin}</span>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>

    <AffiliateCta
      title="Mantente en Línea para Traducir sobre la Marcha"
      description="Una eSIM de viaje para China mantiene las aplicaciones de traducción y los mapas funcionando desde el momento en que aterrizas."
      buttonText="Conéctate"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.phrase-filter');
  const sections = document.querySelectorAll<HTMLElement>('.phrase-group');
  const printBtn = document.getElementById('print-btn');

  const activeCls = ['btn-primary'];
  const idleCls = ['rounded-lg', 'border', 'border-gray-300', 'px-3', 'py-1.5', 'text-sm', 'font-medium', 'text-gray-700', 'hover:border-brand-400'];

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      sections.forEach((s) => {
        s.classList.toggle('hidden', filter !== 'all' && s.dataset.group !== filter);
      });
      buttons.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('btn-primary', on);
        idleCls.forEach((c) => b.classList.toggle(c, !on));
      });
    });
  });

  printBtn?.addEventListener('click', () => window.print());
</script>