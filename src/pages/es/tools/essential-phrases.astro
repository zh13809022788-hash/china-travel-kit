---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Frases esenciales en chino para viajeros';
const description =
  'Una lista práctica e imprimible de frases esenciales en chino mandarín para turistas en China, con pinyin y español. Incluye saludos, pagos, transporte, comida y emergencias.';

interface Frase {
  es: string;
  zh: string;
  pinyin: string;
}
interface Grupo {
  id: string;
  label: string;
  icon: string;
  phrases: Frase[];
}

const groups: Grupo[] = [
  {
    id: 'basics', label: 'Saludos y frases básicas', icon: '👋',
    phrases: [
      { es: 'Hola', zh: '你好', pinyin: 'nǐ hǎo' },
      { es: 'Gracias', zh: '谢谢', pinyin: 'xièxie' },
      { es: 'De nada', zh: '不客气', pinyin: 'bú kèqi' },
      { es: 'Perdón / Disculpe', zh: '对不起', pinyin: 'duìbuqǐ' },
      { es: 'Sí / Correcto', zh: '对', pinyin: 'duì' },
      { es: 'No', zh: '不是', pinyin: 'bú shì' },
      { es: 'No entiendo', zh: '我不明白', pinyin: 'wǒ bù míngbái' },
      { es: '¿Habla inglés?', zh: '你会说英语吗？', pinyin: 'nǐ huì shuō yīngyǔ ma?' },
    ],
  },
  {
    id: 'payment', label: 'Dinero y pagos', icon: '💳',
    phrases: [
      { es: '¿Cuánto cuesta?', zh: '多少钱？', pinyin: 'duōshao qián?' },
      { es: '¿Puedo usar Alipay?', zh: '可以用支付宝吗？', pinyin: 'kěyǐ yòng zhīfùbǎo ma?' },
      { es: '¿Puedo usar WeChat Pay?', zh: '可以用微信支付吗？', pinyin: 'kěyǐ yòng wēixìn zhīfù ma?' },
      { es: 'Es demasiado caro', zh: '太贵了', pinyin: 'tài guì le' },
      { es: '¿Puedo pagar con tarjeta?', zh: '可以刷卡吗？', pinyin: 'kěyǐ shuākǎ ma?' },
      { es: 'Voy a escanear tu código', zh: '我扫你的码', pinyin: 'wǒ sǎo nǐ de mǎ' },
    ],
  },
  {
    id: 'transport', label: 'Transporte y desplazamientos', icon: '🚕',
    phrases: [
      { es: '¿Dónde está el metro?', zh: '地铁站在哪里？', pinyin: 'dìtiě zhàn zài nǎlǐ?' },
      { es: 'Por favor, lléveme a esta dirección', zh: '请带我去这个地址', pinyin: 'qǐng dài wǒ qù zhège dìzhǐ' },
      { es: 'Pare aquí, por favor', zh: '请在这里停', pinyin: 'qǐng zài zhèlǐ tíng' },
      { es: 'Estación de tren', zh: '火车站', pinyin: 'huǒchē zhàn' },
      { es: 'Aeropuerto', zh: '机场', pinyin: 'jīchǎng' },
      { es: '¿Cómo llego a...?', zh: '怎么去...？', pinyin: 'zěnme qù...?' },
    ],
  },
  {
    id: 'food', label: 'Comida y restaurantes', icon: '🍜',
    phrases: [
      { es: 'El menú, por favor', zh: '请给我菜单', pinyin: 'qǐng gěi wǒ càidān' },
      { es: 'Soy vegetariano/a', zh: '我吃素', pinyin: 'wǒ chī sù' },
      { es: 'Sin picante, por favor', zh: '请不要辣', pinyin: 'qǐng búyào là' },
      { es: 'Agua, por favor', zh: '请给我水', pinyin: 'qǐng gěi wǒ shuǐ' },
      { es: 'La cuenta, por favor', zh: '买单', pinyin: 'mǎidān' },
      { es: 'Está delicioso', zh: '很好吃', pinyin: 'hěn hǎochī' },
    ],
  },
  {
    id: 'help', label: 'Ayuda y emergencias', icon: '🆘',
    phrases: [
      { es: '¡Ayuda!', zh: '救命！', pinyin: 'jiùmìng!' },
      { es: '¿Dónde está el baño?', zh: '洗手间在哪里？', pinyin: 'xǐshǒujiān zài nǎlǐ?' },
      { es: 'Necesito un médico', zh: '我需要看医生', pinyin: 'wǒ xūyào kàn yīshēng' },
      { es: 'Llame a la policía', zh: '请报警', pinyin: 'qǐng bàojǐng' },
      { es: 'Estoy perdido/a', zh: '我迷路了', pinyin: 'wǒ mílù le' },
      { es: 'Por favor, escríbalo', zh: '请写下来', pinyin: 'qǐng xiě xiàlái' },
    ],
  },
];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Herramienta</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Frases esenciales en chino para viajeros</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- Controles -->
    <div class="mt-6 flex flex-wrap items-center gap-3 print:hidden">
      <button data-filter="all" class="phrase-filter btn-primary text-sm">Todas</button>
      {groups.map((g) => (
        <button data-filter={g.id} class="phrase-filter rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:border-brand-400">
          {g.icon} {g.label}
        </button>
      ))}
      <button id="print-btn" class="ml-auto rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:border-brand-400">
        🖨️ Imprimir / Guardar como PDF
      </button>
    </div>

    <!-- Grupos de frases -->
    <div class="mt-6 space-y-8">
      {groups.map((g) => (
        <section class="phrase-group" data-group={g.id}>
          <h2 class="mb-3 text-xl font-bold text-gray-900">{g.icon} {g.label}</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            {g.phrases.map((p) => (
              <div class="card flex flex-col">
                <span class="text-sm text-gray-500">{p.es}</span>
                <span class="mt-1 text-2xl font-bold text-gray-900">{p.zh}</span>
                <span class="mt-0.5 text-sm italic text-brand-600">{p.pinyin}</span>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>

    <AffiliateCta
      title="Mantente conectado para traducir mientras te desplazas"
      description="Una eSIM de viaje para China mantiene funcionando las aplicaciones de traducción y los mapas desde el momento en que aterrizas."
      buttonText="Conéctate"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script>
  const botones = document.querySelectorAll<HTMLButtonElement>('.phrase-filter');
  const secciones = document.querySelectorAll<HTMLElement>('.phrase-group');
  const botonImprimir = document.getElementById('print-btn');

  const clasesInactivas = ['rounded-lg', 'border', 'border-gray-300', 'px-3', 'py-1.5', 'text-sm', 'font-medium', 'text-gray-700', 'hover:border-brand-400'];

  botones.forEach((boton) => {
    boton.addEventListener('click', () => {
      const filtro = boton.dataset.filter;
      secciones.forEach((seccion) => {
        seccion.classList.toggle('hidden', filtro !== 'all' && seccion.dataset.group !== filtro);
      });
      botones.forEach((b) => {
        const estaActivo = b === boton;
        b.classList.toggle('btn-primary', estaActivo);
        clasesInactivas.forEach((clase) => b.classList.toggle(clase, !estaActivo));
      });
    });
  });

  botonImprimir?.addEventListener('click', () => window.print());
</script>
