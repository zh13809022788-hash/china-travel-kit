---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import AffiliateCta from '../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../config';

const title = 'Verificador de Enchufes y Voltaje en China';
const description =
  'Descubre si necesitas un adaptador de enchufe o un convertidor de voltaje para China según tu país de origen. China utiliza 220V y los tipos de enchufe A, C e I.';

const countries = [
  'Estados Unidos', 'Reino Unido', 'Canadá', 'Australia', 'Alemania',
  'Francia', 'Italia', 'España', 'Países Bajos', 'Japón', 'Corea del Sur',
  'Singapur', 'India', 'Brasil', 'Nueva Zelanda', 'Suiza',
  'Sudáfrica', 'Emiratos Árabes Unidos', 'Otro',
];
---
<!-- Contenido generado con asistencia de IA, revisado por redactor nativo -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Herramienta</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Verificador de Enchufes y Voltaje</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-6">
      <label class="flex flex-col text-sm sm:max-w-sm">
        <span class="mb-1 font-medium text-gray-700">Viajas desde</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <button id="check-btn" class="btn-primary mt-4 w-full sm:w-auto">Comprobar lo que necesito</button>
    </div>

    <!-- Reference: China's own standard -->
    <div class="mt-6 grid gap-4 sm:grid-cols-3">
      <div class="card"><dt class="text-sm text-gray-500">Voltaje</dt><dd class="text-2xl font-bold text-gray-900">220 V</dd></div>
      <div class="card"><dt class="text-sm text-gray-500">Frecuencia</dt><dd class="text-2xl font-bold text-gray-900">50 Hz</dd></div>
      <div class="card"><dt class="text-sm text-gray-500">Tipos de enchufe</dt><dd class="text-2xl font-bold text-gray-900">A · C · I</dd></div>
    </div>

    <!-- Result -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>

      <AffiliateCta
        title="Consigue un adaptador universal para China"
        description="Un adaptador de viaje compacto todo en uno que encaja en los enchufes de China y carga varios dispositivos al mismo tiempo."
        buttonText="Ver adaptador recomendado"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  // Each country's domestic voltage and the plug types it uses.
  const data: Record<string, { volts: number; plugs: string[] }> = {
    'Estados Unidos': { volts: 120, plugs: ['A', 'B'] },
    'Canadá': { volts: 120, plugs: ['A', 'B'] },
    'Japón': { volts: 100, plugs: ['A', 'B'] },
    'Brasil': { volts: 127, plugs: ['C', 'N'] },
    'Reino Unido': { volts: 230, plugs: ['G'] },
    'Australia': { volts: 230, plugs: ['I'] },
    'Nueva Zelanda': { volts: 230, plugs: ['I'] },
    'Alemania': { volts: 230, plugs: ['C', 'F'] },
    'Francia': { volts: 230, plugs: ['C', 'E'] },
    'Italia': { volts: 230, plugs: ['C', 'F', 'L'] },
    'España': { volts: 230, plugs: ['C', 'F'] },
    'Países Bajos': { volts: 230, plugs: ['C', 'F'] },
    'Suiza': { volts: 230, plugs: ['C', 'J'] },
    'Corea del Sur': { volts: 220, plugs: ['C', 'F'] },
    'Singapur': { volts: 230, plugs: ['G'] },
    'India': { volts: 230, plugs: ['C', 'D', 'M'] },
    'Sudáfrica': { volts: 230, plugs: ['C', 'D', 'M', 'N'] },
    'Emiratos Árabes Unidos': { volts: 230, plugs: ['C', 'D', 'G'] },
    'Otro': { volts: 0, plugs: [] },
  };

  // China accepts plug types A, C, and I.
  const CHINA_PLUGS = ['A', 'C', 'I'];
  const CHINA_VOLTS = 220;

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const country = countryEl.value;
    const info = data[country];

    let heading: string, body: string, tone: 'good' | 'warn' | 'info';
    const points: string[] = [];

    if (!info || info.volts === 0) {
      tone = 'info';
      heading = 'Comprueba tu enchufe y voltaje específicos';
      body = 'No tenemos datos para tu selección. Mira la etiqueta de tu cargador: si dice "100–240V", solo necesitas un adaptador de enchufe para las tomas tipo A, C o I de China.';
      points.push('China utiliza 220V, 50Hz y los tipos de enchufe A, C e I.');
      points.push('La mayoría de los cargadores de teléfonos y portátiles son de doble voltaje (100–240V) y solo necesitan un adaptador de enchufe.');
    } else {
      const plugMatch = info.plugs.some((p) => CHINA_PLUGS.includes(p));
      const voltMatch = Math.abs(info.volts - CHINA_VOLTS) <= 20;

      if (plugMatch && voltMatch) {
        tone = 'good';
        heading = 'Probablemente no necesites un adaptador';
        body = `${country} utiliza tipos de enchufe compatibles (${info.plugs.join(', ')}) y un voltaje similar (${info.volts}V). Tus enchufes deberían encajar directamente en las tomas de China.`;
        points.push('Verifica cada enchufe: lleva un adaptador por si acaso alguna toma queda demasiado ajustada.');
      } else if (!plugMatch && voltMatch) {
        tone = 'warn';
        heading = 'Necesitas un adaptador de enchufe (pero no un convertidor de voltaje)';
        body = `${country} funciona con un voltaje similar (${info.volts}V), así que tus dispositivos están seguros. Pero tu tipo de enchufe (${info.plugs.join(', ')}) no encaja en las tomas de China, así que lleva un adaptador de enchufe.`;
        points.push('Un adaptador de enchufe sencillo y económico para tipo A/C/I es todo lo que necesitas.');
        points.push('No hace falta un voluminoso convertidor de voltaje.');
      } else if (plugMatch && !voltMatch) {
        tone = 'warn';
        heading = 'Vigila el voltaje en los dispositivos de voltaje único';
        body = `Tus enchufes (${info.plugs.join(', ')}) pueden encajar, pero el voltaje de ${country} (${info.volts}V) es diferente de los 220V de China.`;
        points.push('Los teléfonos, portátiles y cámaras con la etiqueta 100–240V funcionan bien en cualquier lugar.');
        points.push('Los artículos de voltaje único (algunos secadores de pelo y planchas) necesitan un convertidor de voltaje o es mejor dejarlos en casa.');
      } else {
        tone = 'warn';
        heading = 'Necesitas un adaptador de enchufe y comprobar el voltaje';
        body = `${country} utiliza enchufes diferentes (${info.plugs.join(', ')}) y un voltaje diferente (${info.volts}V) a los 220V de China. Lleva un adaptador de enchufe para tipo A/C/I.`;
        points.push('Los cargadores de doble voltaje (100–240V) solo necesitan el adaptador de enchufe.');
        points.push('Los dispositivos monovoltaje de alta potencia también necesitan un convertidor de voltaje, o comprar en su lugar un equivalente local.');
      }
    }

    const toneStyles = {
      good: 'border-green-200 bg-green-50',
      warn: 'border-amber-200 bg-amber-50',
      info: 'border-blue-200 bg-blue-50',
    } as const;
    const toneBadge = {
      good: 'bg-green-600 text-white',
      warn: 'bg-amber-500 text-white',
      info: 'bg-blue-600 text-white',
    } as const;
    const toneLabel = { good: 'No necesitas adaptador', warn: 'Necesitas adaptador', info: 'Revisa tu cargador' } as const;

    card.className = `card border ${toneStyles[tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[tone]}">${toneLabel[tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${heading}</h2>
      <p class="mt-2 text-gray-700">${body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>