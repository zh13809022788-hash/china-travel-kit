---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Best Time to Visit China — City & Month Planner';
const description =
  'See the weather, crowds, and what to pack for major Chinese cities by month. Plan the best time to visit Beijing, Shanghai, Xi\'an, Chengdu, Guangzhou, and Harbin.';

const cities = ['Beijing', 'Shanghai', "Xi'an", 'Chengdu', 'Guangzhou', 'Harbin'];
const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Herramienta</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Mejor época para visitar China</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Ciudad</span>
        <select id="city" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {cities.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Mes del viaje</span>
        <select id="month" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {months.map((m, i) => <option value={i}>{m}</option>)}
        </select>
      </label>
    </div>

    <div id="result" class="mt-6">
      <div class="card" id="result-card"></div>
    </div>

    <!-- Nota de advertencia sobre la temporada de viajes -->
    <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
      <strong>Evita las multitudes:</strong> Los días festivos chinos — especialmente el Año Nuevo chino
      (finales de enero/febrero), el Día del Trabajo (principios de mayo) y el Día Nacional / Semana Dorada (primera semana de octubre)
      — generan enormes desplazamientos internos. Los trenes y hoteles se agotan y los precios se disparan. Reserva con mucha antelación o
      planifica evitando estas fechas.
    </div>

    <AffiliateCta
      title="Reserva trenes y hoteles con antelación"
      description="Las rutas populares se agotan rápido en temporada alta. Asegura tu tren de alta velocidad y tus estancias con tiempo."
      buttonText="Ver opciones de reserva"
      placeholder={AFFILIATE_LINKS.transport}
    />
  </main>
  <Footer />
</BaseLayout>

