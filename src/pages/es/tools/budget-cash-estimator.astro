---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'China Trip Budget & Cash Estimator';
const description =
  'Estimate your daily budget and how much cash to bring to China based on trip length, travel style, and city tier. Get a clear RMB and USD breakdown.';
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Herramienta</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Estimador de presupuesto y efectivo</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- Controles de entrada -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Duración del viaje (noches)</span>
        <input id="nights" type="number" min="1" max="60" value="7"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Número de viajeros</span>
        <input id="travelers" type="number" min="1" max="10" value="1"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Estilo de viaje</span>
        <select id="style" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="budget">Económico (hostales, comida callejera, metro)</option>
          <option value="mid" selected>Gama media (hoteles de 3–4★, restaurantes)</option>
          <option value="comfort">Comodidad (hoteles de 4–5★, taxis, comidas fuera)</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Categoría de ciudad</span>
        <select id="tier" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="tier1">Categoría 1 (Beijing, Shanghai, Shenzhen)</option>
          <option value="tier2" selected>Categoría 2 (Chengdu, Xi'an, Hangzhou)</option>
          <option value="tier3">Ciudades y pueblos más pequeños</option>
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="calc-btn" class="btn-primary w-full sm:w-auto">Estimar mi presupuesto</button>
      </div>
    </div>

    <!-- Resultado -->
    <div id="result" class="mt-6 hidden">
      <div class="grid gap-5 md:grid-cols-2">
        <div class="card" id="budget-card"></div>
        <div class="card" id="cash-card"></div>
      </div>
      <div class="card mt-5" id="breakdown-card"></div>
      <p class="mt-3 text-xs text-gray-400">
        Las estimaciones son aproximadas y excluyen los vuelos internacionales. Los costos reales varían según la temporada,
        el tipo de cambio y las elecciones personales. Tipo de cambio asumido en ~7.2 RMB por USD.
      </p>

      <AffiliateCta
        title="Paga como un local, ahorra en comisiones"
        description="Configura un método de pago listo para viajar para que la mayor parte de tus gastos no requiera efectivo."
        buttonText="Ver opciones de Pagos"
        placeholder={AFFILIATE_LINKS.payment}
      />
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  type StyleKey = 'budget' | 'mid' | 'comfort';
  type TierKey = 'tier1' | 'tier2' | 'tier3';

  const USD_RATE = 7.2; // RMB por USD (aproximado)

  // Gasto diario por persona en RMB, sin incluir alojamiento.
  const dailySpend: Record<StyleKey, { food: number; transport: number; activities: number; misc: number }> = {
    budget: { food: 80, transport: 30, activities: 40, misc: 30 },
    mid: { food: 180, transport: 70, activities: 100, misc: 60 },
    comfort: { food: 400, transport: 200, activities: 220, misc: 130 },
  };

  // Alojamiento por noche en RMB (por habitación, se asume compartida por hasta 2).
  const lodging: Record<StyleKey, number> = {
    budget: 150,
    mid: 450,
    comfort: 1100,
  };

  // Multiplicador de costo por categoría de ciudad.
  const tierMult: Record<TierKey, number> = {
    tier1: 1.25,
    tier2: 1.0,
    tier3: 0.8,
  };

  const rmb = (n: number) => `¥${Math.round(n).toLocaleString()}`;
  const usd = (n: number) => `$${Math.round(n / USD_RATE).toLocaleString()}`;

  const btn = document.getElementById('calc-btn');
  const result = document.getElementById('result');
  const budgetCard = document.getElementById('budget-card');
  const cashCard = document.getElementById('cash-card');
  const breakdownCard = document.getElementById('breakdown-card');

  const nightsEl = document.getElementById('nights') as HTMLInputElement;
  const travelersEl = document.getElementById('travelers') as HTMLInputElement;
  const styleEl = document.getElementById('style') as HTMLSelectElement;
  const tierEl = document.getElementById('tier') as HTMLSelectElement;

  function calc() {
    if (!budgetCard || !cashCard || !breakdownCard || !result) return;

    const nights = Math.max(1, Math.min(60, Number(nightsEl.value) || 1));
    const travelers = Math.max(1, Math.min(10, Number(travelersEl.value) || 1));
    const style = styleEl.value as StyleKey;
    const tier = tierEl.value as TierKey;
    const mult = tierMult[tier];

    const spend = dailySpend[style];
    const perPersonDaily = (spend.food + spend.transport + spend.activities + spend.misc) * mult;

    // Alojamiento: 1 habitación por cada 2 viajeros, redondeado hacia arriba.
    const rooms = Math.ceil(travelers / 2);
    const lodgingTotal = lodging[style] * mult * rooms * nights;

    const spendTotal = perPersonDaily * travelers * nights;
    const grandTotal = spendTotal + lodgingTotal;

    // Efectivo recomendado: ~10% del gasto diario, limitado a una reserva razonable.
    const dailyCashFloat = Math.min(perPersonDaily * 0.15 * travelers, 200 * travelers);
    const cashRecommended = Math.min(dailyCashFloat * nights, 2000 + 100 * travelers);

    budgetCard.innerHTML = `
      <h3 class="text-lg font-bold text-gray-900">Presupuesto total estimado</h3>
      <p class="mt-2 text-3xl font-bold text-brand-600">${rmb(grandTotal)}</p>
      <p class="text-sm text-gray-500">≈ ${usd(grandTotal)} para ${travelers} viajero(s), ${nights} noche(s)</p>
      <dl class="mt-4 space-y-2 text-sm">
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Alojamiento</dt><dd class="font-medium text-gray-900">${rmb(lodgingTotal)}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Gasto diario</dt><dd class="font-medium text-gray-900">${rmb(spendTotal)}</dd></div>
        <div class="flex justify-between gap-4 border-t border-gray-100 pt-2"><dt class="text-gray-700 font-semibold">Por persona</dt><dd class="font-semibold text-gray-900">${rmb(grandTotal / travelers)}</dd></div>
      </dl>`;

    cashCard.innerHTML = `
      <h3 class="text-lg font-bold text-gray-900">Efectivo para llevar</h3>
      <p class="mt-2 text-3xl font-bold text-gray-900">${rmb(cashRecommended)}</p>
      <p class="text-sm text-gray-500">≈ ${usd(cashRecommended)} en RMB físico</p>
      <p class="mt-4 text-sm text-gray-600">
        China prioriza el pago móvil — pagarás casi todo con Alipay o WeChat Pay vinculado a una
        tarjeta extranjera. Este efectivo es una red de seguridad para taxis sin lectores QR, pequeños vendedores rurales y
        máquinas que solo aceptan billetes. Lleva denominaciones pequeñas (¥10, ¥20, ¥50).
      </p>`;

    breakdownCard.innerHTML = `
      <h3 class="text-lg font-bold text-gray-900">Desglose del gasto diario <span class="text-sm font-normal text-gray-500">(por persona)</span></h3>
      <dl class="mt-4 grid gap-3 sm:grid-cols-4 text-sm">
        <div><dt class="text-gray-500">Comida</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.food * mult)}</dd></div>
        <div><dt class="text-gray-500">Transporte local</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.transport * mult)}</dd></div>
        <div><dt class="text-gray-500">Actividades</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.activities * mult)}</dd></div>
        <div><dt class="text-gray-500">Varios</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.misc * mult)}</dd></div>
      </dl>`;

    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  btn?.addEventListener('click', calc);
</script>