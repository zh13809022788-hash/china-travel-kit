---

import BaseLayout from '../../../layouts/BaseLayout.astro';

import Header from '../../../components/Header.astro';

import Footer from '../../../components/Footer.astro';

import AdSlot from '../../../components/AdSlot.astro';

import AffiliateCta from '../../../components/AffiliateCta.astro';

import { AFFILIATE_LINKS } from '../../../config';

const title = 'Calculadora de presupuesto y efectivo para un viaje a China';

const description =
  'Calcula tu presupuesto diario y cuánto efectivo llevar a China según la duración del viaje, el tipo de viaje y la categoría de la ciudad. Obtén un desglose claro en RMB y USD.';

---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">

  <Header locale="es" />

  <main class="container-page py-10">

    <header class="max-w-2xl">

      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Herramienta</span>

      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Calculadora de presupuesto y efectivo</h1>

      <p class="mt-3 text-lg text-gray-600">{description}</p>

    </header>

    <AdSlot format="banner" />

    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">

      <label class="flex flex-col text-sm">

        <span class="mb-1 font-medium text-gray-700">Duración del viaje (noches)</span>

        <input
          id="nights"
          type="number"
          min="1"
          max="60"
          value="7"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm"
        />

      </label>

      <label class="flex flex-col text-sm">

        <span class="mb-1 font-medium text-gray-700">Número de viajeros</span>

        <input
          id="travelers"
          type="number"
          min="1"
          max="10"
          value="1"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm"
        />

      </label>

      <label class="flex flex-col text-sm">

        <span class="mb-1 font-medium text-gray-700">Tipo de viaje</span>

        <select id="style" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">

          <option value="economico">Económico (hostales, comida callejera y metro)</option>

          <option value="medio" selected>Estándar (hoteles de 3 a 4 estrellas y restaurantes)</option>

          <option value="comodo">Cómodo (hoteles de 4 a 5 estrellas, taxis y comidas fuera)</option>

        </select>

      </label>

      <label class="flex flex-col text-sm">

        <span class="mb-1 font-medium text-gray-700">Categoría de ciudad</span>

        <select id="tier" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">

          <option value="categoria1">Categoría 1 (Pekín, Shanghái y Shenzhen)</option>

          <option value="categoria2" selected>Categoría 2 (Chengdu, Xi'an y Hangzhou)</option>

          <option value="categoria3">Ciudades y pueblos pequeños</option>

        </select>

      </label>

      <div class="sm:col-span-2">

        <button id="calc-btn" class="btn-primary w-full sm:w-auto">Calcular presupuesto</button>

      </div>

    </div>

    <div id="result" class="mt-6 hidden">

      <div class="grid gap-5 md:grid-cols-2">

        <div class="card" id="budget-card"></div>

        <div class="card" id="cash-card"></div>

      </div>

      <div class="card mt-5" id="breakdown-card"></div>

      <p class="mt-3 text-xs text-gray-400">
        Las estimaciones son orientativas y no incluyen vuelos internacionales. Los costes reales varían según la temporada,
        el tipo de cambio y tus decisiones personales. Se asume un tipo de cambio aproximado de 7,2 RMB por USD.
      </p>

      <AffiliateCta
        title="Paga como un residente y ahorra en comisiones"
        description="Configura un método de pago pensado para viajar y así reducir al mínimo la necesidad de llevar efectivo."
        buttonText="Ver opciones de pago"
        placeholder={AFFILIATE_LINKS.payment}
      />

    </div>

  </main>

  <Footer />

</BaseLayout>

<script>

  type StyleKey = 'economico' | 'medio' | 'comodo';

  type TierKey = 'categoria1' | 'categoria2' | 'categoria3';

  const USD_RATE = 7.2; // RMB por USD (aproximado)

  // Gasto diario por persona en RMB, sin incluir alojamiento.
  const dailySpend: Record<StyleKey, { comida: number; transporte: number; actividades: number; varios: number }> = {
    economico: { comida: 80, transporte: 30, actividades: 40, varios: 30 },
    medio: { comida: 180, transporte: 70, actividades: 100, varios: 60 },
    comodo: { comida: 400, transporte: 200, actividades: 220, varios: 130 },
  };

  // Alojamiento por noche en RMB (por habitación; se asume compartida por un máximo de 2 personas).
  const lodging: Record<StyleKey, number> = {
    economico: 150,
    medio: 450,
    comodo: 1100,
  };

  // Multiplicador de coste según la categoría de ciudad.
  const tierMult: Record<TierKey, number> = {
    categoria1: 1.25,
    categoria2: 1.0,
    categoria3: 0.8,
  };

  const rmb = (n: number) => `¥${Math.round(n).toLocaleString()}`;
  const usd = (n: number) => `$${Math.round(n / USD_RATE).toLocaleString()}`;

  const btn = document.getElementById('calc-btn');
  const result = document.getElementById('result');
  const budgetCard = document.getElementById('budget-card');
  const cashCard = document.getElementById('cash-card');
  const breakdownCard = document.getElementById('breakdown-card');

  const nightsEl = document.getElementById('nights') as HTMLInputElement;
  const travelersEl = document.getElementById('travelers') as HTMLInputElement;
  const styleEl = document.getElementById('style') as HTMLSelectElement;
  const tierEl = document.getElementById('tier') as HTMLSelectElement;

  function calc() {
    if (!budgetCard || !cashCard || !breakdownCard || !result) return;

    const nights = Math.max(1, Math.min(60, Number(nightsEl.value) || 1));
    const travelers = Math.max(1, Math.min(10, Number(travelersEl.value) || 1));
    const style = styleEl.value as StyleKey;
    const tier = tierEl.value as TierKey;
    const mult = tierMult[tier];

    const spend = dailySpend[style];
    const perPersonDaily = (spend.comida + spend.transporte + spend.actividades + spend.varios) * mult;

    // Alojamiento: 1 habitación por cada 2 viajeros, redondeando hacia arriba.
    const rooms = Math.ceil(travelers / 2);
    const lodgingTotal = lodging[style] * mult * rooms * nights;

    const spendTotal = perPersonDaily * travelers * nights;
    const grandTotal = spendTotal + lodgingTotal;

    // Efectivo recomendado: alrededor del 10-15 % del gasto diario, con un límite de reserva razonable.
    const dailyCashFloat = Math.min(perPersonDaily * 0.15 * travelers, 200 * travelers);
    const cashRecommended = Math.min(dailyCashFloat * nights, 2000 + 100 * travelers);

    budgetCard.innerHTML = `
      <h3 class="text-lg font-bold text-gray-900">Presupuesto total estimado</h3>
      <p class="mt-2 text-3xl font-bold text-brand-600">${rmb(grandTotal)}</p>
      <p class="text-sm text-gray-500">≈ ${usd(grandTotal)} para ${travelers} viajero(s) y ${nights} noche(s)</p>
      <dl class="mt-4 space-y-2 text-sm">
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Alojamiento</dt><dd class="font-medium text-gray-900">${rmb(lodgingTotal)}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Gastos diarios</dt><dd class="font-medium text-gray-900">${rmb(spendTotal)}</dd></div>
        <div class="flex justify-between gap-4 border-t border-gray-100 pt-2"><dt class="font-semibold text-gray-700">Por persona</dt><dd class="font-semibold text-gray-900">${rmb(grandTotal / travelers)}</dd></div>
      </dl>`;

    cashCard.innerHTML = `
      <h3 class="text-lg font-bold text-gray-900">Efectivo recomendado para llevar</h3>
      <p class="mt-2 text-3xl font-bold text-gray-900">${rmb(cashRecommended)}</p>
      <p class="text-sm text-gray-500">≈ ${usd(cashRecommended)} en efectivo</p>
      <p class="mt-4 text-sm text-gray-600">
        En China predominan los pagos móviles: casi todo lo pagarás con Alipay o WeChat Pay vinculados a una
        tarjeta extranjera. Este efectivo sirve como respaldo para taxis sin lector QR, vendedores pequeños en zonas rurales y
        máquinas que solo aceptan billetes. Lleva billetes de denominaciones pequeñas (¥10, ¥20 y ¥50).
      </p>`;

    breakdownCard.innerHTML = `
      <h3 class="text-lg font-bold text-gray-900">Desglose del gasto diario <span class="text-sm font-normal text-gray-500">(por persona)</span></h3>
      <dl class="mt-4 grid gap-3 text-sm sm:grid-cols-4">
        <div><dt class="text-gray-500">Comida</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.comida * mult)}</dd></div>
        <div><dt class="text-gray-500">Transporte local</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.transporte * mult)}</dd></div>
        <div><dt class="text-gray-500">Actividades</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.actividades * mult)}</dd></div>
        <div><dt class="text-gray-500">Varios</dt><dd class="text-lg font-semibold text-gray-900">${rmb(spend.varios * mult)}</dd></div>
      </dl>`;

    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  btn?.addEventListener('click', calc);

</script>
