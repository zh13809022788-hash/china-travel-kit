---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';
import FaqSection from '../../../components/FaqSection.astro';

const title = 'Comprobador de compatibilidad de tarjetas de pago para China';
const description =
  'Comprueba si tu tarjeta de crédito funciona con Alipay y WeChat Pay en China. Consulta compatibilidad, límites, comisiones y configuración por nacionalidad y red de tarjeta.';

const nationalities = [
  'United States', 'United Kingdom', 'Canada', 'Australia',
  'Germany', 'France', 'Japan', 'Singapore', 'Other',
];
const cardNetworks = ['Visa', 'Mastercard', 'Amex', 'Discover'];

const nextSteps = [
  { href: '/es/posts/alipay-foreign-credit-card-step-by-step/', title: 'Configurar Alipay con una tarjeta extranjera' },
  { href: '/es/posts/link-a-foreign-visa-or-mastercard-to-wechat-pay-in-china/', title: 'Vincular Visa o Mastercard a WeChat Pay' },
  { href: '/es/posts/can-you-still-use-cash-in-china-as-a-foreigner-in-2026/', title: 'Saber cuándo el efectivo todavía ayuda' },
  { href: '/es/payment/', title: 'Ver todas las guías de pagos en China' },
];

const faqItems = [
  {
    question: '¿Funcionan todas las Visa o Mastercard extranjeras en China?',
    answer:
      'No. Visa y Mastercard son el punto de partida más seguro para Alipay y WeChat Pay, pero cada banco puede bloquear verificaciones, rechazar la vinculación o marcar transacciones en China. Lleva una segunda tarjeta y algo de efectivo.',
  },
  {
    question: '¿Conviene que los turistas configuren Alipay y WeChat Pay?',
    answer:
      'Sí, si es posible. Alipay suele ser más fácil para visitantes, mientras WeChat Pay puede ser útil para mini-programas, restaurantes y servicios locales. Tener ambas reduce el riesgo de quedarte bloqueado en un comercio.',
  },
  {
    question: '¿Cuánto efectivo debo llevar si funciona el pago móvil?',
    answer:
      'Lleva billetes pequeños suficientes para transporte desde el aeropuerto, comidas de respaldo y tiendas pequeñas, pero no dependas solo del efectivo. Muchos lugares prefieren pago QR y algunos empleados pueden no tener cambio.',
  },
];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Herramienta</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Comprobador de compatibilidad de pagos</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <section class="mt-6 grid gap-4 md:grid-cols-3" aria-label="Qué ayuda a resolver este comprobador de pagos">
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">Comprobar compatibilidad de billeteras</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Mira si la red de tu tarjeta encaja bien con Alipay y WeChat Pay.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">Planificar según límites</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Revisa límites y comisiones habituales antes de compras grandes.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">Crear un plan de respaldo</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Sabe cuándo llevar efectivo, cambiar de tarjeta o preparar ambas apps de pago.</p>
      </div>
    </section>

    <AdSlot format="banner" />

    <!-- Controles de entrada -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Tu nacionalidad</span>
        <select id="nationality" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {nationalities.map((n) => <option value={n}>{n}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Red de tarjeta</span>
        <select id="network" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {cardNetworks.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="check-btn" class="btn-primary w-full sm:w-auto">Comprobar compatibilidad</button>
      </div>
    </div>

    <!-- Resultados -->
    <div id="result" class="mt-6 hidden">
      <div class="grid gap-5 md:grid-cols-2">
        <div class="card" id="alipay-card"></div>
        <div class="card" id="wechat-card"></div>
      </div>

      <AffiliateCta
        title="Prepara una tarjeta lista para viajar"
        description="Consigue una tarjeta prepago de viaje que se vincule de forma fiable con Alipay y WeChat Pay para tu viaje a China."
        buttonText="Ver tarjeta recomendada"
        placeholder={AFFILIATE_LINKS.payment}
      />
    </div>

    <section class="mt-12 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">Cómo usar este comprobador</h2>
        <ol class="mt-4 space-y-3 text-sm leading-6 text-gray-600">
          <li><strong class="text-gray-900">1. Elige el país de tu pasaporte o residencia.</strong> Esto ayuda a contextualizar problemas comunes de banco y verificación.</li>
          <li><strong class="text-gray-900">2. Elige la red de tu tarjeta.</strong> Visa y Mastercard suelen ser las mejores primeras opciones para billeteras de viaje en China.</li>
          <li><strong class="text-gray-900">3. Prepara al menos un respaldo.</strong> Lleva una segunda tarjeta, instala ambas apps de pago y guarda efectivo pequeño para casos límite.</li>
        </ol>
        <p class="mt-4 text-sm leading-6 text-gray-600">
          Las normas de pago, verificación de billeteras y controles de riesgo del emisor pueden cambiar. Usa el resultado como orientación práctica y confirma límites de transacciones grandes en Alipay, WeChat Pay y con el emisor antes de salir.
        </p>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Siguientes pasos de pago</h2>
        <div class="mt-4 grid gap-3">
          {nextSteps.map((item) => (
            <a href={item.href} class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">
              {item.title}
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6" aria-labelledby="payment-checker-seo">
      <h2 id="payment-checker-seo" class="text-2xl font-bold text-gray-900">Qué puede y no puede decirte este comprobador</h2>
      <p class="mt-3 text-sm leading-6 text-gray-600">
        Esta herramienta está diseñada para planificar antes de salir. Te ayuda a pensar en la red de tarjeta,
        compatibilidad de billetera, posibles comisiones y métodos de respaldo antes de estar en una caja en China.
        No puede garantizar que tu banco apruebe cada pago.
      </p>
      <div class="mt-5 overflow-x-auto rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200 text-sm">
          <thead class="bg-gray-50 text-left text-gray-700">
            <tr>
              <th class="px-4 py-3 font-semibold">Riesgo</th>
              <th class="px-4 py-3 font-semibold">Por qué ocurre</th>
              <th class="px-4 py-3 font-semibold">Mejor respaldo</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 bg-white text-gray-600">
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">Falla la vinculación de tarjeta</td>
              <td class="px-4 py-3">El emisor bloquea la verificación de billetera o falla 3-D Secure.</td>
              <td class="px-4 py-3">Prueba otra Visa/Mastercard de otro banco.</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">Pago grande rechazado</td>
              <td class="px-4 py-3">Un límite de billetera, comercio o emisor activa una revisión.</td>
              <td class="px-4 py-3">Divide el pago, usa tarjeta física o pregunta al hotel/comercio por opciones.</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">Sin señal en caja</td>
              <td class="px-4 py-3">Datos móviles débiles, sin roaming o la app no carga.</td>
              <td class="px-4 py-3">Usa la otra billetera, el Wi-Fi del comercio o efectivo pequeño de respaldo.</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-sm leading-6 text-gray-600">
        Para la configuración más sólida, lee la guía completa de <a href="/es/posts/how-to-pay-in-china-tourist-guide/" class="font-semibold">pagos para turistas en China</a>,
        compara <a href="/es/posts/alipay-vs-wechat-pay-foreigners/" class="font-semibold">Alipay vs WeChat Pay</a>,
        y mantén un pequeño respaldo en RMB con nuestra <a href="/es/posts/how-much-cash-to-bring-to-china/" class="font-semibold">guía de efectivo</a>.
      </p>
    </section>

    <FaqSection items={faqItems} title="Preguntas frecuentes del comprobador de pagos" />
  </main>
  <Footer />
</BaseLayout>

<script>
  type NetworkKey = 'Visa' | 'Mastercard' | 'Amex' | 'Discover';

  // Matriz estática de compatibilidad (orientación representativa)
  const matrix: Record<NetworkKey, {
    alipay: { status: string; single: string; daily: string; fee: string; how: string };
    wechat: { status: string; single: string; daily: string; fee: string; how: string };
  }> = {
    Visa: {
      alipay: { status: 'Compatible', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% sobre 200 RMB', how: 'Añade la tarjeta en Alipay Wallet y verifica el pasaporte' },
      wechat: { status: 'Compatible', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% sobre 200 RMB', how: 'Añade la tarjeta en WeChat Wallet y verifica el pasaporte' },
    },
    Mastercard: {
      alipay: { status: 'Compatible', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% sobre 200 RMB', how: 'Añade la tarjeta en Alipay Wallet y verifica el pasaporte' },
      wechat: { status: 'Compatible', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% sobre 200 RMB', how: 'Añade la tarjeta en WeChat Wallet y verifica el pasaporte' },
    },
    Amex: {
      alipay: { status: 'Parcialmente compatible', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% sobre 200 RMB', how: 'Amex funciona en Alipay en la mayoría de casos; lleva respaldo Visa/MC' },
      wechat: { status: 'Limitado', single: 'Varía', daily: 'Varía', fee: '~3% sobre 200 RMB', how: 'La compatibilidad es irregular; prefiere Visa/Mastercard en WeChat' },
    },
    Discover: {
      alipay: { status: 'Limitado', single: 'Varía', daily: 'Varía', fee: 'Varía', how: 'La aceptación es limitada; se recomienda mucho Visa/Mastercard' },
      wechat: { status: 'No recomendado', single: '—', daily: '—', fee: '—', how: 'Usa una Visa o Mastercard en su lugar' },
    },
  };

  const statusColor = (status: string) => {
    if (/^compatible/i.test(status)) return 'text-green-700 bg-green-50 border-green-200';
    if (/parcial|limitado/i.test(status)) return 'text-amber-700 bg-amber-50 border-amber-200';
    return 'text-red-700 bg-red-50 border-red-200';
  };

  function cardHtml(wallet: string, d: { status: string; single: string; daily: string; fee: string; how: string }) {
    return `
      <h3 class="text-lg font-bold text-gray-900">${wallet}</h3>
      <span class="mt-2 inline-block rounded-full border px-3 py-0.5 text-xs font-semibold ${statusColor(d.status)}">${d.status}</span>
      <dl class="mt-4 space-y-2 text-sm">
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Transacción única</dt><dd class="font-medium text-gray-900">${d.single}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Límite diario</dt><dd class="font-medium text-gray-900">${d.daily}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Comisión de procesamiento</dt><dd class="font-medium text-gray-900">${d.fee}</dd></div>
        <div class="pt-2 text-gray-600"><dt class="text-gray-500">Cómo configurarlo</dt><dd class="mt-1">${d.how}</dd></div>
      </dl>`;
  }

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const networkEl = document.getElementById('network') as HTMLSelectElement;
  const alipayCard = document.getElementById('alipay-card');
  const wechatCard = document.getElementById('wechat-card');

  btn?.addEventListener('click', () => {
    const net = networkEl.value as NetworkKey;
    const data = matrix[net];
    if (!data || !alipayCard || !wechatCard || !result) return;
    alipayCard.innerHTML = cardHtml('Alipay', data.alipay);
    wechatCard.innerHTML = cardHtml('WeChat Pay', data.wechat);
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>