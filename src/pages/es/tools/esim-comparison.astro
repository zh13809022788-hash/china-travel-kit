---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const titulo = 'Comparador de planes eSIM para viajar a China';
const descripcion =
  'Compara los mejores planes eSIM para viajar a China según los datos incluidos, la validez, el precio y la red. Filtra y ordena para encontrar la opción ideal para tu viaje.';

// 8 planes eSIM representativos para viajar a China (datos de ejemplo)
const planes = [
  { id: 1, nombre: 'China Explorer 5 GB', datos: 5, etiquetaDatos: '5 GB', dias: 7, precio: 9.5, red: 'China Unicom', nota: 'Evita las restricciones de las apps locales' },
  { id: 2, nombre: 'China Explorer 10 GB', datos: 10, etiquetaDatos: '10 GB', dias: 15, precio: 16, red: 'China Unicom', nota: 'Evita las restricciones de las apps locales' },
  { id: 3, nombre: 'China continental 3 GB', datos: 3, etiquetaDatos: '3 GB', dias: 7, precio: 6.5, red: 'China Mobile', nota: 'Red local, sin enrutamiento por VPN' },
  { id: 4, nombre: 'Gran China 8 GB', datos: 8, etiquetaDatos: '8 GB', dias: 30, precio: 18.9, red: 'China Unicom', nota: 'Cubre China continental, Hong Kong, Macao y Taiwán' },
  { id: 5, nombre: 'Datos ilimitados diarios', datos: 9999, etiquetaDatos: 'Ilimitados*', dias: 10, precio: 29, red: 'China Unicom', nota: 'Sujeto a política de uso razonable tras 2 GB al día' },
  { id: 6, nombre: 'Negocios 20 GB', datos: 20, etiquetaDatos: '20 GB', dias: 30, precio: 32, red: 'China Unicom', nota: 'Evita las restricciones de las apps locales' },
  { id: 7, nombre: 'Escapada corta 1 GB', datos: 1, etiquetaDatos: '1 GB', dias: 3, precio: 3.2, red: 'China Mobile', nota: 'Ideal para escalas breves' },
  { id: 8, nombre: 'Familia 30 GB', datos: 30, etiquetaDatos: '30 GB', dias: 30, precio: 45, red: 'China Unicom', nota: 'Se puede compartir con zona Wi-Fi' },
];
---
<BaseLayout title={`${titulo} | ChinaTripBox`} description={descripcion} locale="es">
  <Header locale="es" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Herramienta</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Comparador de planes eSIM</h1>
      <p class="mt-3 text-lg text-gray-600">{descripcion}</p>
    </header>

    <AdSlot format="banner" />

    <!-- Controles -->
    <div class="mt-6 flex flex-wrap items-end gap-4 rounded-xl border border-gray-200 bg-gray-50 p-4">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Ordenar por</span>
        <select id="ordenar-por" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="precio-asc">Precio: de menor a mayor</option>
          <option value="precio-desc">Precio: de mayor a menor</option>
          <option value="datos-desc">Datos: de mayor a menor</option>
          <option value="dias-desc">Validez: de mayor a menor</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Red</span>
        <select id="filtrar-red" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="todas">Todas las redes</option>
          <option value="China Unicom">China Unicom</option>
          <option value="China Mobile">China Mobile</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Datos mínimos (GB)</span>
        <select id="filtrar-datos" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="0">Cualquiera</option>
          <option value="5">5 GB o más</option>
          <option value="10">10 GB o más</option>
          <option value="20">20 GB o más</option>
        </select>
      </label>
    </div>

    <!-- Tabla comparativa -->
    <div class="mt-6 overflow-x-auto">
      <table class="w-full min-w-[720px] border-collapse text-sm">
        <thead>
          <tr class="border-b-2 border-gray-200 text-left text-gray-500">
            <th class="py-3 pr-4 font-semibold">Plan</th>
            <th class="py-3 pr-4 font-semibold">Datos</th>
            <th class="py-3 pr-4 font-semibold">Validez</th>
            <th class="py-3 pr-4 font-semibold">Precio (USD)</th>
            <th class="py-3 pr-4 font-semibold">Red</th>
            <th class="py-3 pr-4 font-semibold">Notas</th>
          </tr>
        </thead>
        <tbody id="filas-planes"></tbody>
      </table>
      <p id="sin-resultados" class="hidden py-8 text-center text-gray-500">Ningún plan coincide con los filtros seleccionados.</p>
    </div>

    <AffiliateCta
      title="¿Listo para conectarte?"
      description="Activa una eSIM recomendada para China y tendrás internet desde el momento en que aterrices."
      buttonText="Consigue tu eSIM"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ planes }}>
  const filasEl = document.getElementById('filas-planes');
  const sinResultados = document.getElementById('sin-resultados');
  const ordenarPor = document.getElementById('ordenar-por');
  const filtrarRed = document.getElementById('filtrar-red');
  const filtrarDatos = document.getElementById('filtrar-datos');

  function renderizar() {
    let lista = [...planes];
    const red = filtrarRed.value;
    const datosMinimos = Number(filtrarDatos.value);

    if (red !== 'todas') lista = lista.filter((plan) => plan.red === red);
    if (datosMinimos > 0) lista = lista.filter((plan) => plan.datos >= datosMinimos);

    switch (ordenarPor.value) {
      case 'precio-asc': lista.sort((a, b) => a.precio - b.precio); break;
      case 'precio-desc': lista.sort((a, b) => b.precio - a.precio); break;
      case 'datos-desc': lista.sort((a, b) => b.datos - a.datos); break;
      case 'dias-desc': lista.sort((a, b) => b.dias - a.dias); break;
    }

    filasEl.innerHTML = lista
      .map(
        (plan) => `
      <tr class="border-b border-gray-100">
        <td class="py-3 pr-4 font-semibold text-gray-900">${plan.nombre}</td>
        <td class="py-3 pr-4">${plan.etiquetaDatos}</td>
        <td class="py-3 pr-4">${plan.dias} días</td>
        <td class="py-3 pr-4 font-semibold">$${plan.precio.toFixed(2)}</td>
        <td class="py-3 pr-4">${plan.red}</td>
        <td class="py-3 pr-4 text-gray-500">${plan.nota}</td>
      </tr>`
      )
      .join('');

    sinResultados.classList.toggle('hidden', lista.length > 0);
  }

  [ordenarPor, filtrarRed, filtrarDatos].forEach((elemento) => elemento.addEventListener('change', renderizar));
  renderizar();
</script>