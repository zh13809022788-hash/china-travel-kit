---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Comparador de planes eSIM para viajar a China';
const description =
  'Compara los mejores planes eSIM para viajar a China por datos, duraci\u00F3n, precio y red. Filtra y ordena para encontrar el mejor plan para tu viaje.';

// 8 productos eSIM representativos para viajar a China (datos de muestra representativos)
const plans = [
  { id: 1, name: 'Explorador de China 5 GB', data: 5, dataLabel: '5 GB', days: 7, price: 9.5, network: 'China Unicom', note: 'Evita las restricciones de apps locales' },
  { id: 2, name: 'Explorador de China 10 GB', data: 10, dataLabel: '10 GB', days: 15, price: 16, network: 'China Unicom', note: 'Evita las restricciones de apps locales' },
  { id: 3, name: 'China continental ligera 3 GB', data: 3, dataLabel: '3 GB', days: 7, price: 6.5, network: 'China Mobile', note: 'Red local, sin enrutamiento VPN' },
  { id: 4, name: 'Gran China 8 GB', data: 8, dataLabel: '8 GB', days: 30, price: 18.9, network: 'China Unicom', note: 'Cubre China continental, Hong Kong, Macao y Taiw\u00E1n' },
  { id: 5, name: 'Ilimitado diario', data: 9999, dataLabel: 'Ilimitado*', days: 10, price: 29, network: 'China Unicom', note: 'Limite de uso justo despues de 2 GB/dia' },
  { id: 6, name: 'Negocios 20 GB', data: 20, dataLabel: '20 GB', days: 30, price: 32, network: 'China Unicom', note: 'Evita las restricciones de apps locales' },
  { id: 7, name: 'Viaje corto 1 GB', data: 1, dataLabel: '1 GB', days: 3, price: 3.2, network: 'China Mobile', note: 'Ideal para escalas cortas' },
  { id: 8, name: 'Familia 30 GB', data: 30, dataLabel: '30 GB', days: 30, price: 45, network: 'China Unicom', note: 'Se puede compartir mediante zona Wi-Fi' },
];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Herramienta</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Comparador de planes eSIM</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- Controles -->
    <div class="mt-6 flex flex-wrap items-end gap-4 rounded-xl border border-gray-200 bg-gray-50 p-4">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Ordenar por</span>
        <select id="sort-by" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="price-asc">Precio: de menor a mayor</option>
          <option value="price-desc">Precio: de mayor a menor</option>
          <option value="data-desc">Datos: de mayor a menor</option>
          <option value="days-desc">Duraci&oacute;n: de mayor a menor</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Red</span>
        <select id="filter-network" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="all">Todas las redes</option>
          <option value="China Unicom">China Unicom</option>
          <option value="China Mobile">China Mobile</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Datos m&iacute;nimos (GB)</span>
        <select id="filter-data" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="0">Cualquiera</option>
          <option value="5">5+ GB</option>
          <option value="10">10+ GB</option>
          <option value="20">20+ GB</option>
        </select>
      </label>
    </div>

    <!-- Tabla de comparaci&oacute;n -->
    <div class="mt-6 overflow-x-auto">
      <table class="w-full min-w-[720px] border-collapse text-sm">
        <thead>
          <tr class="border-b-2 border-gray-200 text-left text-gray-500">
            <th class="py-3 pr-4 font-semibold">Plan</th>
            <th class="py-3 pr-4 font-semibold">Datos</th>
            <th class="py-3 pr-4 font-semibold">Duraci&oacute;n</th>
            <th class="py-3 pr-4 font-semibold">Precio (USD)</th>
            <th class="py-3 pr-4 font-semibold">Red</th>
            <th class="py-3 pr-4 font-semibold">Notas</th>
          </tr>
        </thead>
        <tbody id="plan-rows"></tbody>
      </table>
      <p id="no-results" class="hidden py-8 text-center text-gray-500">Ning&uacute;n plan coincide con tus filtros.</p>
    </div>

    <AffiliateCta
      title="&iquest;Listo para conectarte?"
      description="Activa una eSIM recomendada para China y estar&aacute;s en l&iacute;nea en cuanto aterrices."
      buttonText="Obt&eacute;n tu eSIM"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ plans }}>
  const rowsEl = document.getElementById('plan-rows');
  const noResults = document.getElementById('no-results');
  const sortBy = document.getElementById('sort-by');
  const filterNetwork = document.getElementById('filter-network');
  const filterData = document.getElementById('filter-data');

  function render() {
    let list = [...plans];
    const net = filterNetwork.value;
    const minData = Number(filterData.value);

    if (net !== 'all') list = list.filter((p) => p.network === net);
    if (minData > 0) list = list.filter((p) => p.data >= minData);

    switch (sortBy.value) {
      case 'price-asc': list.sort((a, b) => a.price - b.price); break;
      case 'price-desc': list.sort((a, b) => b.price - a.price); break;
      case 'data-desc': list.sort((a, b) => b.data - a.data); break;
      case 'days-desc': list.sort((a, b) => b.days - a.days); break;
    }

    rowsEl.innerHTML = list
      .map(
        (p) => `
      <tr class="border-b border-gray-100">
        <td class="py-3 pr-4 font-semibold text-gray-900">${p.name}</td>
        <td class="py-3 pr-4">${p.dataLabel}</td>
        <td class="py-3 pr-4">${p.days} d&iacute;as</td>
        <td class="py-3 pr-4 font-semibold">$${p.price.toFixed(2)}</td>
        <td class="py-3 pr-4">${p.network}</td>
        <td class="py-3 pr-4 text-gray-500">${p.note}</td>
      </tr>`
      )
      .join('');

    noResults.classList.toggle('hidden', list.length > 0);
  }

  [sortBy, filterNetwork, filterData].forEach((el) => el.addEventListener('change', render));
  render();
</script>
