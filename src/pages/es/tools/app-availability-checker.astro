---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Will My Apps Work in China? App Availability Checker';
const description =
  'Check whether Google, WhatsApp, Instagram, and other apps work in China without a VPN — and see the local alternative for each blocked service.';

interface AppInfo {
  name: string;
  category: string;
  status: 'works' | 'blocked' | 'partial';
  note: string;
  alt?: string;
}

const apps: AppInfo[] = [
  { name: 'Google Search', category: 'Google', status: 'blocked', note: 'Blocked without a VPN.', alt: 'Bing (works) or Baidu' },
  { name: 'Google Maps', category: 'Google', status: 'partial', note: 'Loads but data is inaccurate/offset in mainland China.', alt: 'Apple Maps, Amap, or Baidu Maps' },
  { name: 'Gmail', category: 'Google', status: 'blocked', note: 'Blocked without a VPN.', alt: 'Outlook / a non-Google email' },
  { name: 'YouTube', category: 'Google', status: 'blocked', note: 'Blocked without a VPN.', alt: 'Bilibili (local)' },
  { name: 'WhatsApp', category: 'Messaging', status: 'blocked', note: 'Blocked without a VPN.', alt: 'WeChat' },
  { name: 'Facebook', category: 'Social', status: 'blocked', note: 'Blocked without a VPN.', alt: 'WeChat Moments / RED' },
  { name: 'Instagram', category: 'Social', status: 'blocked', note: 'Blocked without a VPN.', alt: 'RED (Xiaohongshu)' },
  { name: 'X (Twitter)', category: 'Social', status: 'blocked', note: 'Blocked without a VPN.', alt: 'Weibo' },
  { name: 'Telegram', category: 'Messaging', status: 'blocked', note: 'Blocked without a VPN.', alt: 'WeChat' },
  { name: 'WeChat', category: 'Messaging', status: 'works', note: 'Works fully — the default in China.' },
  { name: 'Apple services (iMessage, App Store)', category: 'Apple', status: 'works', note: 'Works normally.' },
  { name: 'Microsoft / Bing / Outlook', category: 'Microsoft', status: 'works', note: 'Works normally.' },
  { name: 'Booking.com', category: 'Travel', status: 'works', note: 'Works normally.' },
  { name: 'Airbnb', category: 'Travel', status: 'works', note: 'Works normally.' },
  { name: 'Trip.com', category: 'Travel', status: 'works', note: 'Works fully — great for trains and hotels.' },
  { name: 'Alipay', category: 'Pagos', status: 'works', note: 'Works fully — supports foreign cards.' },
  { name: 'Uber', category: 'Transporte', status: 'blocked', note: 'Not operational in mainland China.', alt: 'DiDi' },
  { name: 'Netflix', category: 'Media', status: 'blocked', note: 'Not available in mainland China.', alt: 'Local streaming or download beforehand' },
  { name: 'Spotify', category: 'Media', status: 'blocked', note: 'Not available in mainland China.', alt: 'QQ Music / download offline first' },
];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Herramienta</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">¿Funcionarán Mis Apps en China?</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-4">
      <label class="flex flex-col text-sm sm:max-w-sm">
        <span class="mb-1 font-medium text-gray-700">Buscar o filtrar apps</span>
        <input id="search" type="text" placeholder="p. ej. WhatsApp, Google, Netflix"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <div class="mt-3 flex flex-wrap gap-2 text-sm">
        <button data-status="all" class="status-filter btn-primary px-3 py-1">Todas</button>
        <button data-status="works" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">✅ Funcionan</button>
        <button data-status="partial" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">⚠️ Parcial</button>
        <button data-status="blocked" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">🚫 Bloqueadas</button>
      </div>
    </div>

    <div id="app-list" class="mt-6 grid gap-3 sm:grid-cols-2"></div>
    <p id="no-results" class="hidden py-8 text-center text-gray-500">Ninguna app coincide con tu búsqueda.</p>

    <AffiliateCta
      title="Mantén Tus Apps Funcionando con una eSIM de Viaje"
      description="Una eSIM de viaje para China que evita las restricciones locales mantiene tus apps habituales en línea — sin necesidad de configurar una VPN aparte."
      buttonText="Ver Opciones de eSIM"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ apps }}>
  const listEl = document.getElementById('app-list');
  const noResults = document.getElementById('no-results');
  const searchEl = document.getElementById('search');
  const filters = document.querySelectorAll('.status-filter');
  let activeStatus = 'all';

  const badge = {
    works: { cls: 'bg-green-100 text-green-800', label: '✅ Funcionan' },
    partial: { cls: 'bg-amber-100 text-amber-800', label: '⚠️ Parcial' },
    blocked: { cls: 'bg-red-100 text-red-800', label: '🚫 Bloqueadas' },
  };

  function render() {
    const q = searchEl.value.trim().toLowerCase();
    const list = apps.filter((a) => {
      const matchStatus = activeStatus === 'all' || a.status === activeStatus;
      const matchQuery = !q || a.name.toLowerCase().includes(q) || a.category.toLowerCase().includes(q);
      return matchStatus && matchQuery;
    });

    listEl.innerHTML = list
      .map((a) => `
        <div class="card">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="font-bold text-gray-900">${a.name}</h3>
              <span class="text-xs text-gray-400">${a.category}</span>
            </div>
            <span class="whitespace-nowrap rounded-full px-2.5 py-0.5 text-xs font-semibold ${badge[a.status].cls}">${badge[a.status].label}</span>
          </div>
          <p class="mt-2 text-sm text-gray-600">${a.note}</p>
          ${a.alt ? `<p class="mt-1.5 text-sm"><span class="text-gray-500">Usar en su lugar:</span> <span class="font-medium text-brand-600">${a.alt}</span></p>` : ''}
        </div>`)
      .join('');

    noResults.classList.toggle('hidden', list.length > 0);
  }

  searchEl.addEventListener('input', render);
  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeStatus = btn.dataset.status;
      filters.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('btn-primary', on);
        ['rounded-lg', 'border', 'border-gray-300', 'font-medium', 'text-gray-700'].forEach((c) => b.classList.toggle(c, !on));
      });
      render();
    });
  });

  render();
</script>