---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'China Visa-Free & Transit Checker';
const description =
  'Check whether you can enter China visa-free, use 240-hour transit without a visa, or need to apply based on your nationality and trip type.';

const lastReviewed = 'July 13, 2026';

// Representative policy data for 2026. This is guidance, not legal advice;
// travelers must confirm with an embassy before booking.
const countries = [
  'United States', 'United Kingdom', 'Canada', 'Australia', 'Germany',
  'France', 'Italy', 'Spain', 'Netherlands', 'Japan', 'South Korea',
  'Singapore', 'Malaysia', 'Thailand', 'Brazil', 'New Zealand',
  'Switzerland', 'Ireland', 'Norway', 'Other',
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Tool</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Visa-Free & Transit Checker</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <p class="mt-3 text-sm text-gray-500">
        Last reviewed: {lastReviewed}. This checker is a planning aid, not an official eligibility decision.
      </p>
    </header>

    <AdSlot format="banner" />

    <!-- Input controls -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Your passport nationality</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Trip type</span>
        <select id="trip" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="tourism">Tourism / visiting</option>
          <option value="business">Business</option>
          <option value="transit">Just transiting to another country</option>
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="check-btn" class="btn-primary w-full sm:w-auto">Check My Eligibility</button>
      </div>
    </div>

    <!-- Result -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>
      <p class="mt-3 text-xs text-gray-400">
        Policies change frequently and depend on your specific circumstances. Always confirm with a
        Chinese embassy or consulate before booking travel. This tool provides general guidance only.
      </p>

      <AffiliateCta
        title="Plan the Rest of Your Trip"
        description="Sort your connectivity, payments, and transport before you land in China."
        buttonText="See Travel Essentials"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6" aria-labelledby="official-sources">
      <h2 id="official-sources" class="text-xl font-bold text-gray-950">Official sources to verify before booking</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        Visa-free country lists, entry ports, permitted travel areas, and airline boarding checks can change.
        Treat official government and airline rules as final.
      </p>
      <ul class="mt-4 grid gap-2 text-sm leading-6 text-gray-700">
        <li><a href="https://en.nia.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">National Immigration Administration</a> for border inspection and transit exemption updates.</li>
        <li><a href="https://english.www.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">State Council information portal</a> for English-language policy announcements.</li>
        <li><a href="https://www.mfa.gov.cn/eng/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">Ministry of Foreign Affairs</a> and Chinese embassy or consulate websites for passport-specific rules.</li>
      </ul>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">How to avoid visa-free mistakes</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          The most common error is mixing up ordinary visa-free entry with visa-free transit. A
          normal round trip and a stopover to a third country are not the same itinerary. Airlines
          check documents before boarding, so a misunderstanding can stop the trip before you reach
          China.
        </p>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-gray-600">
          <li><strong class="text-gray-900">Check passport nationality first.</strong> Residence country and card billing country do not decide visa-free eligibility.</li>
          <li><strong class="text-gray-900">Separate entry from transit.</strong> Transit usually requires confirmed onward travel to a third country or region.</li>
          <li><strong class="text-gray-900">Confirm entry ports.</strong> Transit policies depend on designated ports and permitted travel areas.</li>
          <li><strong class="text-gray-900">Keep proof ready.</strong> Airlines and border officers may ask for onward ticket, hotel, itinerary, or invitation details.</li>
        </ul>
      </div>
      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Plan the rest of arrival</h2>
        <div class="mt-4 grid gap-3">
          <a href="/es/posts/china-visa-free-entry-transit-guide-2026/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Read the full visa-free guide</a>
          <a href="/es/posts/first-24-hours-in-china-arrival-checklist/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Use the arrival checklist</a>
          <a href="/es/posts/airport-to-city-transport-beijing-shanghai-guangzhou/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Plan airport transport</a>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  type TripKey = 'tourism' | 'business' | 'transit';

  // Nationalities eligible for the 30-day unilateral visa-free entry (2026 program).
  const visaFree30 = new Set([
    'Germany', 'France', 'Italy', 'Spain', 'Netherlands', 'Switzerland',
    'Ireland', 'Norway', 'Japan', 'South Korea', 'Brazil', 'New Zealand',
    'Malaysia', 'Thailand', 'Australia',
  ]);

  // Nationalities eligible for 240-hour (10-day) visa-free transit through
  // designated ports when travelling onward to a third country/region.
  const transit240 = new Set([
    'United States', 'United Kingdom', 'Canada', 'Australia', 'Germany',
    'France', 'Italy', 'Spain', 'Netherlands', 'Japan', 'South Korea',
    'Singapore', 'Switzerland', 'Ireland', 'Norway', 'Brazil', 'New Zealand',
  ]);

  interface Verdict {
    tone: 'good' | 'warn' | 'info';
    heading: string;
    body: string;
    points: string[];
  }

  function evaluate(country: string, trip: TripKey): Verdict {
    const has30 = visaFree30.has(country);
    const hasTransit = transit240.has(country);

    if (trip === 'transit') {
      if (hasTransit) {
        return {
          tone: 'good',
          heading: 'You likely qualify for 240-hour visa-free transit',
          body: `As a ${country} passport holder transiting China to a third country, you can generally stay up to 240 hours (10 days) without a visa when entering through an eligible port.`,
          points: [
            'You must hold a confirmed onward ticket to a third country or region within 240 hours.',
            'Entry and exit must be through designated transit ports (most major international airports qualify).',
            'You are usually limited to the province/region of entry - check the specific port rules.',
          ],
        };
      }
      return {
        tone: 'warn',
        heading: 'Transit visa exemption may not apply to your nationality',
        body: `${country} is not on the standard 240-hour transit list in our data. You may still qualify for visa-free entry if eligible, or you may need a transit (G) visa.`,
        points: [
          'Check whether your nationality qualifies for full visa-free entry instead.',
          'If not, apply for the appropriate visa before travel.',
        ],
      };
    }

    // tourism or business
    if (has30) {
      return {
        tone: 'good',
        heading: 'You likely qualify for 30-day visa-free entry',
        body: `As a ${country} passport holder, you can generally enter China visa-free for up to 30 days for tourism, business, family visits, or transit under the current unilateral policy.`,
        points: [
          'Your passport should be valid for at least 6 months with blank pages.',
          'Have proof of onward/return travel and accommodation ready for immigration.',
          'The 30 days is per entry - confirm the latest count before you book.',
        ],
      };
    }
    if (hasTransit) {
      return {
        tone: 'info',
        heading: 'A visa is likely required - but transit exemption may help',
        body: `${country} is not on our 30-day visa-free list for tourism/business, so a visa is generally required. However, if you are passing through to a third country, you may use the 240-hour visa-free transit instead.`,
        points: [
          'For a dedicated visit, apply for an L (tourist) or M (business) visa in advance.',
          'For a stopover en route elsewhere, you may qualify for 240-hour transit - switch "Trip type" to Transit to check.',
        ],
      };
    }
    return {
      tone: 'warn',
      heading: 'A visa is likely required',
      body: `Based on our data, ${country} passport holders generally need a visa to enter China for this trip type. Apply through a Chinese embassy, consulate, or authorized visa center before travelling.`,
      points: [
        'Apply for an L (tourist) or M (business) visa well ahead of your trip.',
        'Requirements typically include an invitation or itinerary, hotel bookings, and return tickets.',
      ],
    };
  }

  const toneStyles: Record<Verdict['tone'], string> = {
    good: 'border-green-200 bg-green-50',
    warn: 'border-amber-200 bg-amber-50',
    info: 'border-blue-200 bg-blue-50',
  };
  const toneBadge: Record<Verdict['tone'], string> = {
    good: 'bg-green-600 text-white',
    warn: 'bg-amber-500 text-white',
    info: 'bg-blue-600 text-white',
  };
  const toneLabel: Record<Verdict['tone'], string> = {
    good: 'Likely eligible',
    warn: 'Visa likely needed',
    info: 'Depends on your plan',
  };

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;
  const tripEl = document.getElementById('trip') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const v = evaluate(countryEl.value, tripEl.value as TripKey);
    card.className = `card border ${toneStyles[v.tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[v.tone]}">${toneLabel[v.tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${v.heading}</h2>
      <p class="mt-2 text-gray-700">${v.body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${v.points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>

