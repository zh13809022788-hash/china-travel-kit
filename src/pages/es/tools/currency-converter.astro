---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import AffiliateCta from '../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../config';

const title = 'Convertidor de divisas RMB para viajeros a China';
const description =
  'Convierte tu moneda local a yuan chino (RMB) y viceversa, y mira cuánto cuestan las cosas cotidianas en China para poder comparar precios en el momento.';
---
<!-- Contenido generado con asistencia de IA, revisado por redactor nativo -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Herramienta</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Convertidor de divisas RMB</h1>
<p class="mt-4 max-w-3xl text-lg leading-8 text-gray-600">
  Usa este convertidor para consultar los tipos de cambio actuales entre tu moneda local y el yuan chino (RMB/CNY). Los precios de referencia que aparecen abajo te dan una idea de los costos habituales: un plato de fideos cuesta alrededor de 15-25 RMB, un viaje en metro 3-7 RMB y un hotel de gama media 200-500 RMB por noche. China es, en gran medida, una sociedad sin efectivo: Alipay y WeChat Pay se aceptan en todas partes, desde vendedores ambulantes hasta hoteles de lujo. Para obtener los mejores tipos de cambio, usa la tarjeta de débito internacional de tu banco en cajeros automáticos de bancos chinos, o cambia divisa en bancos locales en lugar de hacerlo en aeropuertos u hoteles.
</p>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- Converter -->
    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-6">
      <div class="grid gap-4 sm:grid-cols-[1fr_auto_1fr] sm:items-end">
        <label class="flex flex-col text-sm">
          <span class="mb-1 font-medium text-gray-700">Tu moneda</span>
          <div class="flex gap-2">
            <select id="currency" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
              <option value="USD">USD ($)</option>
              <option value="EUR">EUR (€)</option>
              <option value="GBP">GBP (£)</option>
              <option value="AUD">AUD (A$)</option>
              <option value="CAD">CAD (C$)</option>
              <option value="JPY">JPY (¥)</option>
              <option value="SGD">SGD (S$)</option>
            </select>
            <input id="foreign-amount" type="number" min="0" value="100"
              class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
          </div>
        </label>
        <div class="hidden pb-2 text-center text-gray-400 sm:block">⇄</div>
        <label class="flex flex-col text-sm">
          <span class="mb-1 font-medium text-gray-700">Yuan chino (RMB)</span>
          <input id="rmb-amount" type="number" min="0"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
        </label>
      </div>
      <p id="rate-line" class="mt-3 text-sm text-gray-500"></p>
      <p class="mt-1 text-xs text-gray-400">
        Los tipos de cambio son referencias aproximadas para planificar, no tipos de mercado en tiempo real. Consulta con tu banco o un
        convertidor en vivo para conocer el tipo exacto en el momento de tu transacción.
      </p>
    </div>

    <!-- What things cost -->
    <section class="mt-8">
      <h2 class="text-xl font-bold text-gray-900">Cuánto cuestan las cosas en China</h2>
      <p class="mt-1 text-sm text-gray-500">Precios típicos en RMB, con tu moneda mostrada como referencia.</p>
      <div id="cost-grid" class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3"></div>
    </section>

    <AffiliateCta
      title="Evita la ventanilla de cambio"
      description="Vincula una tarjeta sin comisiones por cambio de divisa a Alipay o WeChat Pay y paga al tipo de cambio real, sin recargo por cambio en efectivo."
      buttonText="Ver configuración de pago"
      placeholder={AFFILIATE_LINKS.payment}
    />
  </main>
  <Footer />
</BaseLayout>

<script>
  // Approximate reference rates: 1 unit of currency = X RMB.
  const ratesToRmb: Record<string, number> = {
    USD: 7.2,
    EUR: 7.8,
    GBP: 9.1,
    AUD: 4.7,
    CAD: 5.2,
    JPY: 0.048,
    SGD: 5.3,
  };
  const symbols: Record<string, string> = {
    USD: '$', EUR: '€', GBP: '£', AUD: 'A$', CAD: 'C$', JPY: '¥', SGD: 'S$',
  };

  const commonCosts: { label: string; rmb: number }[] = [
    { label: 'Botella de agua', rmb: 2 },
    { label: 'Viaje en metro', rmb: 4 },
    { label: 'Tentempié de comida callejera', rmb: 10 },
    { label: 'Café (cafetería)', rmb: 30 },
    { label: 'Comida en restaurante informal', rmb: 45 },
    { label: 'Trayecto corto en DiDi / taxi', rmb: 25 },
    { label: 'Tren de alta velocidad (1–2 h)', rmb: 250 },
    { label: 'Entrada a museo / atracción', rmb: 60 },
    { label: 'Hotel de gama media / noche', rmb: 450 },
  ];

  const currencyEl = document.getElementById('currency') as HTMLSelectElement;
  const foreignEl = document.getElementById('foreign-amount') as HTMLInputElement;
  const rmbEl = document.getElementById('rmb-amount') as HTMLInputElement;
  const rateLine = document.getElementById('rate-line');
  const costGrid = document.getElementById('cost-grid');

  function rate() {
    return ratesToRmb[currencyEl.value];
  }
  function sym() {
    return symbols[currencyEl.value];
  }

  function fromForeign() {
    const v = Number(foreignEl.value) || 0;
    rmbEl.value = (v * rate()).toFixed(2);
    updateMeta();
  }
  function fromRmb() {
    const v = Number(rmbEl.value) || 0;
    foreignEl.value = (v / rate()).toFixed(2);
    updateMeta();
  }

  function updateMeta() {
    if (rateLine) {
      rateLine.textContent = `Tipo de cambio de referencia: 1 ${currencyEl.value} ≈ ¥${rate().toFixed(2)} RMB`;
    }
    if (costGrid) {
      costGrid.innerHTML = commonCosts
        .map((c) => `
          <div class="card">
            <span class="text-sm text-gray-500">${c.label}</span>
            <div class="mt-1 flex items-baseline gap-2">
              <span class="text-xl font-bold text-gray-900">¥${c.rmb}</span>
              <span class="text-sm text-brand-600">≈ ${sym()}${(c.rmb / rate()).toFixed(2)}</span>
            </div>
          </div>`)
        .join('');
    }
  }

  foreignEl.addEventListener('input', fromForeign);
  rmbEl.addEventListener('input', fromRmb);
  currencyEl.addEventListener('change', fromForeign);

  fromForeign();
</script>