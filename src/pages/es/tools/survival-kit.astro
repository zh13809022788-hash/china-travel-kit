---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ShowToLocal from '../../../components/ShowToLocal.astro';
import SurvivalChecklist from '../../../components/SurvivalChecklist.astro';
import ContextAiBubble from '../../../components/ContextAiBubble.astro';
import survivalKits from '../../../data/survival-kits.json';

const title = 'Kit de supervivencia para China: tarjetas de traduccion y listas de viaje';
const description =
  'Kits interactivos de supervivencia para China para visitantes extranjeros: tarjetas de traduccion a pantalla completa, listas de configuracion al llegar, tarjetas de alergias alimentarias y herramientas de comunicacion local.';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Kit de supervivencia</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-950 md:text-4xl">Kit de supervivencia para China</h1>
      <p class="mt-3 text-lg leading-8 text-gray-600">
        Usa tarjetas de traduccion a pantalla completa y listas guardadas para esos momentos en que leer una guia larga es demasiado lento:
        llegada al aeropuerto, check-in en el hotel, taxis, restaurantes, alergias y configuracion del primer dia.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="#arrival" class="btn-primary">Empezar por la llegada</a>
        <a href="#food" class="btn-outline">Abrir tarjetas de comida</a>
      </div>
    </header>

    <section class="mt-8 grid gap-4 md:grid-cols-3">
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Tarjetas a pantalla completa</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Toca una tarjeta y muestra texto chino grande a un conductor, recepcion de hotel o personal de restaurante.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Listas guardadas</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">El progreso de la lista se guarda en tu navegador para que puedas cerrar y volver mas tarde.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Acceso a IA contextual</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Usa el asistente flotante para abrir ayuda de viaje de ChinaTripBox con un prompt adaptado al tema.</p>
      </div>
    </section>

    <div class="mt-10 grid gap-8">
      {survivalKits.map((kit) => (
        <section id={kit.slug} class="grid gap-5 rounded-xl border border-gray-200 bg-gray-50 p-5">
          <div class="max-w-3xl">
            <p class="section-kicker">{kit.slug} kit</p>
            <h2 class="mt-1 text-2xl font-bold text-gray-950">{kit.title}</h2>
            <p class="mt-2 text-sm leading-6 text-gray-600">{kit.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {kit.related_paths.map((path) => (
                <a href={path} class="rounded-full border border-gray-200 bg-white px-3 py-1.5 text-xs font-semibold text-brand-700 hover:border-brand-300 hover:no-underline">
                  Guia relacionada
                </a>
              ))}
            </div>
          </div>
          <div class="grid gap-5 lg:grid-cols-[1fr_0.85fr]">
            <ShowToLocal themeId={kit.theme_id} tools={kit.tools} />
            <SurvivalChecklist themeId={kit.theme_id} steps={kit.checklist_steps} />
          </div>
        </section>
      ))}
    </div>
  </main>
  <ContextAiBubble defaultPrompt="Ayudame a usar el kit de supervivencia para China para llegada, restaurantes, tarjetas de traduccion y preparacion de listas." />
  <Footer />
</BaseLayout>
