---

import { getCollection } from 'astro:content';

import BaseLayout from '../../../layouts/BaseLayout.astro';

import Header from '../../../components/Header.astro';

import Footer from '../../../components/Footer.astro';

import AdSlot from '../../../components/AdSlot.astro';

import CoverImage from '../../../components/CoverImage.astro';



const posts = (await getCollection('posts-es'))

  .filter((p) => p.data.category === 'food' || p.data.tags.includes('tipping') || p.data.tags.includes('restaurants'))

  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());



const title = 'Guías de comida, restaurantes y etiqueta en China';

const description =

  'Guías prácticas de comida en China para visitantes extranjeros: pedir a domicilio, seguridad de la comida callejera, niveles de picante, propinas, etiqueta en restaurantes y cultura gastronómica.';



const pathways = [

  {

    title: 'Pedir sin saber chino',

    desc: 'Configura apps de entrega, guarda la dirección del hotel y evita confusiones con los repartidores.',

    href: '/es/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',

  },

  {

    title: 'Comer comida callejera con seguridad',

    desc: 'Usa la rotación, el calor visible, los hábitos de agua y las frases sobre picante para elegir mejores puestos.',

    href: '/es/posts/chengdu-street-food-safety-spice-levels-what-to-order/',

  },

  {

    title: 'Gestionar la etiqueta en la mesa',

    desc: 'Sabe cuándo no dar propina, cuándo importan los cargos por servicio y cómo funcionan las normas locales de los restaurantes.',

    href: '/es/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/',

  },

];



const cultureLinks = [

  {

    href: 'https://baijiu365.com/baijiu-101/',

    title: 'Baijiu 101',

    desc: 'Contexto útil si un banquete o cena con anfitrión incluye el aguardiente nacional de China.',

  },

  {

    href: 'https://baijiu365.com/how-to-drink-baijiu/',

    title: 'Cómo beber baijiu con educación',

    desc: 'Una guía complementaria más detallada sobre brindis, pequeñas dosis y ritmo en comidas formales.',

  },

];

---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">

  <Header locale="es" />

  <main class="container-page py-10">

    <header class="max-w-3xl">

      <p class="section-kicker">Comida y restaurantes</p>

      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>

      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>

    </header>



    <CoverImage name="topic-chengdu-food" alt="Platos picantes de comida callejera de Sichuan en un mercado nocturno en China" loading="lazy" />



    <AdSlot format="banner" />



    <section class="mt-8 grid gap-5 md:grid-cols-3" aria-labelledby="food-pathways">

      <h2 id="food-pathways" class="sr-only">Rutas de planificación gastronómica</h2>

      {pathways.map((item) => (

        <a href={item.href} class="card block hover:no-underline">

          <h3 class="text-lg font-bold text-gray-950">{item.title}</h3>

          <p class="mt-2 text-sm leading-6 text-gray-600">{item.desc}</p>

          <span class="mt-4 inline-flex text-sm font-semibold text-brand-700">Leer guía</span>

        </a>

      ))}

    </section>



    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">

      <div>

        <div class="section-heading">

          <div>

            <p class="section-kicker">Guías</p>

            <h2>Artículos sobre comida y etiqueta</h2>

          </div>

        </div>

        <div class="mt-6 grid gap-5 md:grid-cols-2">

          {posts.map((post) => (

            <a href={`/es/posts/${post.slug}/`} class="card block hover:no-underline">

              <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{post.data.category}</span>

              <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>

              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>

            </a>

          ))}

        </div>

      </div>



      <aside class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">

        <p class="section-kicker">Acompañante cultural</p>

        <h2 class="mt-1 text-xl font-bold text-gray-950">Cuando aparece el baijiu</h2>

        <p class="mt-3 text-sm leading-6 text-gray-600">

          La mayoría de las comidas turísticas no requieren conocimientos sobre alcohol, pero los banquetes con anfitrión, las cenas de negocios,

          y las comidas familiares rurales a veces incluyen brindis con baijiu. Estos recursos complementarios profundizan más

          mientras ChinaTripBox se mantiene centrado en la logística de viaje.

        </p>

        <div class="mt-5 grid gap-3">

          {cultureLinks.map((link) => (

            <a href={link.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">

              <h3 class="text-sm font-semibold text-gray-950">{link.title}</h3>

              <p class="mt-1 text-sm leading-6 text-gray-600">{link.desc}</p>

            </a>

          ))}

        </div>

      </aside>

    </section>

  </main>

  <Footer />

</BaseLayout>