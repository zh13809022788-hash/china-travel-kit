---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Pagina no encontrada';
const description = 'No se pudo encontrar la pagina de ChinaTripBox que solicitaste.';
---
<!-- Contenido generado con asistencia de IA, revisado por redactor nativo -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description} noindex>
  <Header />
  <main class="container-page py-16">
    <section class="mx-auto max-w-2xl">
      <p class="section-kicker">404</p>
      <h1 class="mt-2 text-4xl font-bold text-gray-950">Pagina no encontrada</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">
        Es posible que la pagina se haya movido o que la direccion sea incorrecta. Empieza desde el centro de guias o usa una herramienta de planificacion abajo.
      </p>
      <div class="mt-8 flex flex-wrap gap-3">
        <a href="/" class="btn-primary">Ir al inicio</a>
        <a href="/resources/" class="btn-outline">Comenzar aqui</a>
        <a href="/tools/" class="btn-outline">Abrir herramientas</a>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>