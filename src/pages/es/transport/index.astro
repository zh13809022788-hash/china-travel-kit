---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const CATEGORY = 'transport';
const posts = (await getCollection('posts-es'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Transporte en China: trenes, DiDi y movilidad urbana';
const description =
  'Aprende a reservar trenes de alta velocidad, usar DiDi y moverte por China en metro, taxi y transporte público.';

const transportPaths = [
  { href: '/es/posts/china-high-speed-rail-guide-foreigners/', title: 'Trenes de larga distancia', desc: 'Úsalo para planificar trayectos entre ciudades, clases de asiento, acceso con pasaporte y tiempos de estación.' },
  { href: '/es/posts/airport-to-city-transport-beijing-shanghai-guangzhou/', title: 'Llegada desde el aeropuerto', desc: 'Compara metro, taxi, DiDi y tren aeroportuario para el primer traslado a la ciudad.' },
  { href: '/es/posts/didi-china-foreign-tourists-guide/', title: 'Transporte con app', desc: 'Configura DiDi, usa puntos de recogida traducidos y evita llamadas complicadas con el conductor.' },
  { href: '/es/posts/shanghai-metro-for-foreigners-tickets-qr-codes-transfers/', title: 'Redes de metro', desc: 'Aprende a usar billetes QR, transbordos y hábitos de hora punta con el ejemplo de Shanghái.' },
];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Transporte</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Guías de transporte en China</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="hub-transport" alt="Tren de alta velocidad en China" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-transport">
      <h2 id="featured-transport" class="sr-only">Guías destacadas de transporte</h2>
      <a href="/es/posts/china-high-speed-rail-guide-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Guía de trenes de alta velocidad</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Reserva billetes, elige clases y muévete por estaciones grandes</p>
      </a>
      <a href="/es/posts/book-china-train-tickets-12306-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Reserva de trenes en 12306</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Paso a paso para comprar con pasaporte extranjero</p>
      </a>
      <a href="/es/posts/didi-china-foreign-tourists-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Cómo usar DiDi</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">La forma más sencilla de pedir coche en muchas ciudades</p>
      </a>
      <a href="/es/posts/airport-to-city-transport-beijing-shanghai-guangzhou/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Traslados desde el aeropuerto</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Guías de Pekín, Shanghái y Cantón</p>
      </a>
    </section>

    <section class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4" aria-labelledby="transport-paths">
      <h2 id="transport-paths" class="sr-only">Rutas de planificación de transporte</h2>
      {transportPaths.map((path) => (
        <a href={path.href} class="card block hover:no-underline">
          <h3 class="text-lg font-bold text-gray-950">{path.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{path.desc}</p>
        </a>
      ))}
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/es/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{post.data.category}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">Guías próximamente.</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>
