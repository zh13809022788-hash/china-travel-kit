---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const CATEGORY = 'payment';
const posts = (await getCollection('posts-es'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Pagos en China: Alipay, WeChat Pay y tarjetas extranjeras';
const description =
  'Guías paso a paso para pagar en China: configurar Alipay y WeChat Pay, vincular tarjetas internacionales y evitar errores comunes.';

const prioritySteps = [
  'Install Alipay and WeChat before departure, then verify identity while you still have access to your home bank and phone number.',
  'Link at least one Visa or Mastercard, then keep a second card from another issuer as a backup.',
  'Carry a small amount of RMB cash for taxis, small shops, and moments when wallet verification or card authorization fails.',
];

const paymentTools = [
  { href: '/es/tools/payment-checker/', title: 'Pagos compatibility checker', desc: 'Check card support, typical limits, and fees for Alipay and WeChat Pay.' },
  { href: '/es/tools/budget-cash-estimator/', title: 'Budget and cash estimator', desc: 'Estimate trip spending and how much backup cash to carry.' },
  { href: '/es/tools/currency-converter/', title: 'RMB currency converter', desc: 'Convert prices to yuan and understand everyday costs.' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Pagos</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Guías de pago en China</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-how-to-pay" alt="Mobile payment setup with smartphone showing payment methods for China travel" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-payment">
      <h2 id="featured-payment" class="sr-only">Guías destacadas de pagos</h2>
      <a href="/es/posts/alipay-foreign-credit-card-step-by-step/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Alipay Setup</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Step-by-step guide to installing Alipay and linking a foreign credit card</p>
      </a>
      <a href="/es/posts/wechat-pay-foreign-visitors-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">WeChat Pay</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Complete setup and usage guide for foreign visitors</p>
      </a>
      <a href="/es/posts/alipay-vs-wechat-pay-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Alipay vs WeChat Pay</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Which payment app should you use in 2026?</p>
      </a>
      <a href="/es/posts/how-to-pay-in-china-tourist-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Complete Pagos Guide</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Everything you need to know about paying in China as a tourist</p>
      </a>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[1fr_340px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">Start with a reliable payment setup</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          China is mostly QR-payment first. A tourist-friendly setup usually means one primary wallet, one backup wallet, two card options, and a small amount of cash for exceptions.
        </p>
        <ol class="mt-5 space-y-3 text-sm leading-6 text-gray-600">
          {prioritySteps.map((step, index) => (
            <li class="flex gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand-50 text-xs font-bold text-brand-700">{index + 1}</span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Pagos tools</h2>
        <div class="mt-4 grid gap-3">
          {paymentTools.map((tool) => (
            <a href={tool.href} class="rounded-lg border border-brand-100 bg-white p-4 hover:border-brand-200 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-900 hover:text-brand-700">{tool.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{tool.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/es/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{post.data.category}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('es-ES', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">Guías próximamente.</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>
