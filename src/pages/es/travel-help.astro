---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'Ayuda de viaje para China';
const description =
  'Haz preguntas individuales sobre pagos, eSIM, transporte, apps y preparación del primer día en China, con clasificación asistida por AI y ayuda humana opcional.';

const quickPrompts = [
  'Mi tarjeta no se vincula a Alipay o WeChat Pay.',
  'Necesito un plan de eSIM y acceso a apps para mi viaje.',
  'Necesito ayuda para ir del aeropuerto al hotel.',
  'No sé cuánto efectivo llevar.',
];

const supportAreas = [
  'Configuración de pagos: Alipay, WeChat Pay, tarjetas, comisiones y efectivo de respaldo',
  'Conectividad: eSIM, roaming, apps sensibles a VPN y datos al llegar al aeropuerto',
  'Transporte: rutas desde aeropuerto, metro, DiDi, taxis y bases del tren de alta velocidad',
  'Uso de apps: traducción, comida a domicilio, mapas, transporte y capturas',
  'Preparación del viaje: lista del primer día, preparación por ciudad y próximos pasos prácticos',
  'Escalado humano: casos complejos que necesitan contexto de ida y vuelta',
];

const safetyRules = [
  'No envíes fotos de pasaporte, números completos de tarjeta, contraseñas, PIN ni códigos de un solo uso.',
  'No pidas a nadie que inicie sesión en tus cuentas ni complete verificaciones de identidad por ti.',
  'No uses esto para asesoramiento legal, migratorio, médico, bancario o de emergencia.',
  'Confirma normas importantes con fuentes oficiales, aerolíneas, bancos, telecomunicaciones u operadores de apps.',
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main>
    <section class="border-b border-gray-200 bg-white">
      <div class="container-page grid gap-8 py-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <div>
          <p class="section-kicker">Ayuda de viaje individual</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Pregunta sobre tu viaje a China antes de que te bloquee
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Empieza con ayuda gratuita de AI para problemas prácticos de viaje en China. Si tu pregunta necesita
            criterio humano, capturas o contexto de ida y vuelta, conviértela en solicitud de revisión.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#travel-help-chat" class="btn-primary">Iniciar solicitud</a>
            <a href="/es/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-outline">Usar lista previa al viaje</a>
            <a href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Travel%20Help%20Request" class="btn-outline">
              Enviar email directamente
            </a>
          </div>
        </div>

        <aside class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Estado piloto</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">AI primero, revisión humana después</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Las respuestas gratuitas las genera AI. La ayuda revisada por humanos aún se gestiona por email
            mientras probamos el flujo.
          </p>
          <dl class="mt-5 grid gap-3 text-sm">
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">Ideal para</dt>
              <dd class="font-semibold text-gray-900">Preparación práctica del viaje</dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">Vía de respuesta</dt>
              <dd class="font-semibold text-gray-900">AI + seguimiento por email</dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">Pagos</dt>
              <dd class="font-semibold text-gray-900">No activo</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <section id="travel-help-chat" class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
          <div class="border-b border-gray-200 bg-gray-50 px-5 py-4">
          <p class="section-kicker">Ayuda gratuita de viaje con AI</p>
            <h2 class="mt-1 text-2xl font-bold text-gray-950">Mesa de ayuda de viaje</h2>
          </div>

          <div class="grid gap-0 md:grid-cols-[minmax(0,1fr)_280px]">
            <div class="flex min-h-[560px] flex-col">
              <div id="chat-log" class="flex-1 space-y-4 overflow-y-auto p-5" aria-live="polite">
                <div class="max-w-[88%] rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-700">
                  <strong class="block text-gray-950">Ayuda de ChinaTripBox</strong>
                  Cuéntanos qué intentas hacer, en qué fase del viaje estás y qué ha ocurrido ya.
                  La ayuda de AI sugerirá próximos pasos y marcará cuándo conviene revisión humana.
                </div>
              </div>

              <div class="border-t border-gray-200 p-4">
                <div class="mb-3 flex flex-wrap gap-2">
                  {quickPrompts.map((prompt) => (
                    <button
                      type="button"
                      class="quick-prompt rounded-full border border-gray-200 bg-white px-3 py-1.5 text-left text-xs font-medium text-gray-700 hover:border-brand-300 hover:bg-brand-50"
                      data-prompt={prompt}
                    >
                      {prompt}
                    </button>
                  ))}
                </div>
                <form id="travel-help-form" class="grid gap-3">
                  <label class="sr-only" for="help-message">Tu pregunta de viaje</label>
                  <textarea
                    id="help-message"
                    name="message"
                    rows="5"
                    class="w-full resize-y rounded-lg border border-gray-300 px-4 py-3 text-sm leading-6 text-gray-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
                    placeholder="Ejemplo: llego mañana a Shanghai. Mi Mastercard no se vincula a WeChat Pay, pero Alipay funciona. ¿Aún puedo usar metro, DiDi y comida a domicilio?"
                    required
                  ></textarea>
                  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <p id="form-status" class="text-sm text-gray-500">Evita datos personales sensibles.</p>
                    <button id="help-submit" type="submit" class="btn-primary">Preguntar a AI</button>
                  </div>
                </form>
              </div>
            </div>

            <aside class="border-t border-gray-200 bg-gray-50 p-5 md:border-l md:border-t-0">
              <h3 class="text-lg font-bold text-gray-950">Detalles de la solicitud</h3>
              <div class="mt-4 grid gap-4">
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  Fase del viaje
                  <select id="trip-stage" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                    <option>Antes de salir</option>
                    <option>En el aeropuerto</option>
                    <option>Ya en China</option>
                    <option>Planificación de estancia larga</option>
                  </select>
                </label>
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  Tema principal
                  <select id="help-topic" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                    <option>Pagos apps</option>
                    <option>Internet y eSIM</option>
                    <option>Ruta de transporte</option>
                    <option>Comida, entrega o apps locales</option>
                    <option>Preparación general del viaje</option>
                  </select>
                </label>
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  Ciudad o ruta
                  <input
                    id="help-location"
                    class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700"
                    placeholder="Shanghai, Beijing, aeropuerto al hotel..."
                  />
                </label>
              </div>

              <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-4">
                <p class="text-sm font-bold text-gray-950">Mejora humana</p>
                <p class="mt-2 text-sm leading-6 text-gray-700">
                  Úsalo cuando una guía simple no sea suficiente. El email preparado incluye tu tema,
                  fase, ubicación y pregunta para que una persona responda con contexto.
                </p>
              </div>

              <a
                id="email-request-link"
                href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Travel%20Help%20Request"
                class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:border-brand-600 hover:text-brand-600 hover:no-underline"
              >
                Preparar solicitud por email
              </a>
            </aside>
          </div>
        </div>

        <aside class="space-y-6">
          <section class="rounded-lg border border-gray-200 bg-white p-5">
            <p class="section-kicker">Alcance</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">En qué puede ayudar</h2>
            <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
              {supportAreas.map((area) => (
                <li class="border-b border-gray-100 pb-3 last:border-b-0 last:pb-0">{area}</li>
              ))}
            </ul>
          </section>

          <section class="rounded-lg border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Normas de seguridad</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">No incluyas datos sensibles</h2>
            <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
              {safetyRules.map((rule) => (
                <li>{rule}</li>
              ))}
            </ul>
          </section>
        </aside>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <div class="card">
          <p class="section-kicker">Paso 1</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Describe el problema</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Comparte la ciudad, app, ruta, plazo y lo que ya has probado.
          </p>
        </div>
        <div class="card">
          <p class="section-kicker">Paso 2</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Obtén el siguiente paso</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            La página da una primera respuesta práctica y te dirige a guías relevantes.
          </p>
        </div>
        <div class="card">
          <p class="section-kicker">Paso 3</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Escalar por email</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Para ayuda individual, envía el email preparado y continúa la conversación en privado.
          </p>
        </div>
      </section>

      <section class="mt-10 rounded-lg border border-gray-200 bg-white p-5 md:p-6">
        <p class="section-kicker">Primero autoservicio</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950">Guías que responden preguntas comunes del primer viaje</h2>
        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <a href="/es/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Planificador para el primer viaje a China</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Úsalo cuando aún estás organizando pagos, datos, transporte y tu primer día de llegada.</p>
          </a>
          <a href="/es/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Lista de configuración antes de salir</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Revisa Alipay, WeChat Pay, eSIM, DiDi, billetes de tren, traducción, direcciones y efectivo antes de volar.</p>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('travel-help-form') as HTMLFormElement | null;
  const message = document.getElementById('help-message') as HTMLTextAreaElement | null;
  const chatLog = document.getElementById('chat-log');
  const status = document.getElementById('form-status');
  const stage = document.getElementById('trip-stage') as HTMLSelectElement | null;
  const topic = document.getElementById('help-topic') as HTMLSelectElement | null;
  const locationInput = document.getElementById('help-location') as HTMLInputElement | null;
  const emailLink = document.getElementById('email-request-link') as HTMLAnchorElement | null;
  const submitButton = document.getElementById('help-submit') as HTMLButtonElement | null;

  const guideLinks: Record<string, { label: string; href: string }> = {
    'Pagos apps': { label: 'guía de configuración de pagos', href: '/es/payment/' },
    'Internet y eSIM': { label: 'guía de eSIM', href: '/es/esim/' },
    'Ruta de transporte': { label: 'guía de transporte', href: '/es/transport/' },
    'Comida, entrega o apps locales': {
      label: 'guía de comida a domicilio',
      href: '/es/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    },
    'Preparación general del viaje': { label: 'página de herramientas', href: '/es/tools/' },
  };

  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char] ?? char);

  const updateEmailLink = () => {
    if (!emailLink) return;
    const selectedStage = stage?.value ?? 'Antes de salir';
    const selectedTopic = topic?.value ?? 'Preparación general del viaje';
    const place = locationInput?.value.trim() || 'No especificado';
    const question = message?.value.trim() || '';
    const body = [
      'Solicitud de ayuda de viaje ChinaTripBox',
      '',
      `Fase del viaje: ${selectedStage}`,
      `Tema principal: ${selectedTopic}`,
      `Ciudad o ruta: ${place}`,
      '',
      'Pregunta:',
      question,
      '',
      'Entiendo que no debo incluir fotos de pasaporte, números completos de tarjeta bancaria, contraseñas, PIN ni códigos de un solo uso.',
    ].join('\n');

    emailLink.href = `mailto:zh13809022788@gmail.com?subject=${encodeURIComponent(
      `Ayuda de viaje: ${selectedTopic}`,
    )}&body=${encodeURIComponent(body)}`;
  };

  const addBubble = (content: string, fromUser = false) => {
    if (!chatLog) return null;
    const wrapper = document.createElement('div');
    wrapper.className = fromUser
      ? 'ml-auto max-w-[88%] rounded-lg bg-brand-600 p-4 text-sm leading-6 text-white'
      : 'max-w-[88%] rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-700';
    wrapper.innerHTML = content;
    chatLog.appendChild(wrapper);
    chatLog.scrollTop = chatLog.scrollHeight;
    return wrapper;
  };

  const formatAIAnswer = (value: string) =>
    escapeHtml(value)
      .replace(/\n{3,}/g, '\n\n')
      .replace(/\n/g, '<br>');

  const buildReply = (question: string) => {
    const selectedTopic = topic?.value ?? 'Preparación general del viaje';
    const selectedStage = stage?.value ?? 'Antes de salir';
    const place = locationInput?.value.trim();
    const guide = guideLinks[selectedTopic] ?? guideLinks['Preparación general del viaje'];
    const needsHuman =
      /screenshot|photo|declin|failed|stuck|urgent|tomorrow|today|passport|verification|identity|hotel|route/i.test(
        question,
      );

    const placeLine = place
      ? `Como esto implica <strong>${escapeHtml(place)}</strong>, incluye el aeropuerto, estación, zona del hotel, nombre de la app y fecha exactos cuando envíes el email.`
      : 'Añade ciudad, aeropuerto, estación, zona del hotel o nombre de app antes de enviar esto para ayuda individual.';

    const escalation = needsHuman
      ? 'Parece buen candidato para seguimiento humano porque puede necesitar contexto o comprobaciones de ida y vuelta.'
      : 'Quizá pueda responderse primero con la guía; usa seguimiento humano si la guía no encaja con tu situación exacta.';

    return `
      <strong class="block text-gray-950">Siguiente paso sugerido</strong>
      <span class="block mt-1">Tema: ${escapeHtml(selectedTopic)}. Fase: ${escapeHtml(selectedStage)}.</span>
      <span class="block mt-2">${placeLine}</span>
      <span class="block mt-2">Empieza con la <a href="${guide.href}" class="font-semibold text-brand-700">${guide.label}</a>, y luego usa el botón de email preparado si todavía necesitas ayuda individual.</span>
      <span class="block mt-2">${escalation}</span>
    `;
  };

  document.querySelectorAll<HTMLButtonElement>('.quick-prompt').forEach((button) => {
    button.addEventListener('click', () => {
      if (!message) return;
      message.value = button.dataset.prompt ?? '';
      message.focus();
      updateEmailLink();
    });
  });

  [message, stage, topic, locationInput].forEach((element) => {
    element?.addEventListener('input', updateEmailLink);
    element?.addEventListener('change', updateEmailLink);
  });

  const requestAIAnswer = async (question: string) => {
    const response = await fetch('/api/travel-help', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({
        message: question,
        stage: stage?.value ?? 'Antes de salir',
        topic: topic?.value ?? 'Preparación general del viaje',
        location: locationInput?.value.trim() ?? '',
      }),
    });

    const data = await response.json() as { answer?: string; error?: string };
    if (!response.ok || !data.answer) {
      throw new Error(data.error || 'Ayuda de AI no disponible.');
    }
    return data.answer;
  };

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const question = message?.value.trim() ?? '';
    if (!question) {
      if (status) status.textContent = 'Añade primero tu pregunta.';
      return;
    }
    addBubble(escapeHtml(question), true);
    const thinking = addBubble('La AI está revisando tu pregunta de viaje...');
    if (status) status.textContent = 'Preguntando a la ayuda de viaje con AI...';
    if (submitButton) submitButton.disabled = true;

    try {
      const answer = await requestAIAnswer(question);
      if (thinking) {
        thinking.innerHTML = `
          <strong class="block text-gray-950">Ayuda de viaje con AI</strong>
          <span class="mt-2 block">${formatAIAnswer(answer)}</span>
          <span class="mt-3 block text-xs text-gray-500">Para problemas complejos de cuenta, pago, visa, legales, médicos o de emergencia, verifica con el proveedor oficial o solicita revisión humana.</span>
        `;
      }
      if (status) status.textContent = 'Respuesta de AI lista. Usa el email si quieres revisión humana.';
    } catch {
      if (thinking) thinking.innerHTML = buildReply(question);
      if (status) status.textContent = 'La AI no está disponible, así que se preparó una respuesta local de respaldo.';
    } finally {
      if (submitButton) submitButton.disabled = false;
    }
    updateEmailLink();
  });

  updateEmailLink();
</script>
