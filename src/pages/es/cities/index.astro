---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CoverImage from '../../../components/CoverImage.astro';
import ChinaMap from '../../../components/ChinaMap.astro';
import AdSlot from '../../../components/AdSlot.astro';

const allPosts = await getCollection('posts-es');
const cityNames = ['beijing', 'shanghai', 'chengdu', 'hangzhou', 'sanya', 'guangzhou', 'xian', 'chongqing', 'kunming', 'nanjing'];
const cityPosts = allPosts
  .filter((post) => cityNames.some((city) => post.slug.includes(city) || post.data.tags.includes(city)))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const title = 'Guías de ciudades de China para viajeros internacionales';
const description =
  'Organiza tu ruta por China con guías prácticas de Pekín, Shanghái, Cantón, Chengdu, Xi\'an, Hangzhou, Chongqing y Sanya, además de consejos sobre aeropuertos, metro, comida y transporte local.';

const mapCities = [
  { name: 'Pekín', x: 470, y: 80, href: '#beijing' },
  { name: 'Xi\'an', x: 340, y: 155, href: '#xian' },
  { name: 'Nanjing', x: 490, y: 180, href: '' },
  { name: 'Shanghái', x: 540, y: 200, href: '#shanghai' },
  { name: 'Chengdu', x: 250, y: 220, href: '#chengdu' },
  { name: 'Hangzhou', x: 520, y: 205, href: '#hangzhou' },
  { name: 'Chongqing', x: 310, y: 260, href: '#chongqing' },
  { name: 'Guilin', x: 370, y: 300, href: '' },
  { name: 'Kunming', x: 210, y: 335, href: '' },
  { name: 'Cantón', x: 400, y: 370, href: '#guangzhou' },
  { name: 'Shenzhen', x: 430, y: 390, href: '' },
  { name: 'Sanya', x: 360, y: 440, href: '#sanya' },
];

const cities = [
  {
    name: 'Pekín',
    href: '/es/posts/beijing-city-guide-for-foreigners/',
    desc: 'Perfecta para descubrir historia imperial, hutongs, la Gran Muralla y los grandes imprescindibles del primer viaje.',
    days: '4-5 días',
    bestSeason: 'Septiembre-octubre',
    difficulty: 'Media',
    whyGo: 'Palacios imperiales, museos, hutongs y el acceso más sencillo a la Gran Muralla.',
    next: '/es/posts/beijing-daxing-airport-to-city-center-a-first-timer-s-guide/',
    nextLabel: 'Cómo ir del aeropuerto de Daxing al centro',
  },
  {
    name: 'Shanghái',
    href: '/es/posts/shanghai-city-guide-for-foreigners/',
    desc: 'Muy recomendable para una llegada cómoda, perfil urbano moderno, gastronomía internacional y excelente red de metro.',
    days: '3-4 días',
    bestSeason: 'Marzo-mayo, octubre-noviembre',
    difficulty: 'Fácil',
    whyGo: 'Es la puerta de entrada más sencilla para moverse en metro, gestionar pagos, dormir bien y orientarse rápido.',
    next: '/es/posts/shanghai-metro-for-foreigners-tickets-qr-codes-transfers/',
    nextLabel: 'Guía del metro de Shanghái',
  },
  {
    name: 'Chengdu',
    href: '/es/posts/chengdu-city-guide-for-foreigners/',
    desc: 'Ideal para probar la cocina de Sichuan, ver pandas, disfrutar de casas de té y llevar un ritmo más pausado.',
    days: '3-5 días',
    bestSeason: 'Marzo-junio, septiembre-noviembre',
    difficulty: 'Media',
    whyGo: 'Pandas, comida memorable, ambiente relajado, costes más bajos y buenas conexiones hacia el oeste del país.',
    next: '/es/posts/chengdu-street-food-safety-spice-levels-what-to-order/',
    nextLabel: 'Qué comer en Chengdu sin complicarte',
  },
  {
    name: 'Xi\'an',
    href: '/es/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/',
    desc: 'Muy buena opción para sumergirte en la historia antigua, los Guerreros de Terracota y la herencia cultural china.',
    days: '3-4 días',
    bestSeason: 'Marzo-mayo, septiembre-noviembre',
    difficulty: 'Media',
    whyGo: 'Guerreros de Terracota, muralla histórica, barrio musulmán y una de las ciudades con más peso histórico del país.',
    next: '/es/posts/china-high-speed-rail-guide-foreigners/',
    nextLabel: 'Guía del tren de alta velocidad hacia Xi\'an',
  },
  {
    name: 'Cantón',
    href: '/es/posts/airport-to-city-transport-beijing-shanghai-guangzhou/',
    desc: 'Gran elección para cocina cantonesa, ambiente comercial, clima más templado y conexión fácil con Hong Kong.',
    days: '3-4 días',
    bestSeason: 'Octubre-diciembre, marzo-abril',
    difficulty: 'Media',
    whyGo: 'Dim sum, arquitectura histórica, energía comercial y una alternativa sureña a Pekín y Shanghái.',
    next: '/es/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    nextLabel: 'Guía para moverte por la cocina cantonesa',
  },
  {
    name: 'Chongqing',
    href: '/es/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    desc: 'Muy atractiva para amantes de la olla caliente, paisajes urbanos futuristas y una ciudad vertical con mucha personalidad.',
    days: '3-4 días',
    bestSeason: 'Marzo-mayo, septiembre-noviembre',
    difficulty: 'Difícil',
    whyGo: 'Olla caliente intensa, vistas nocturnas espectaculares, teleférico sobre el Yangtsé y una geografía urbana única.',
    next: '/es/food/',
    nextLabel: 'Ideas para comer bien en Chongqing',
  },
  {
    name: 'Hangzhou',
    href: '/es/posts/hangzhou-city-guide-for-foreigners/',
    desc: 'Encaja muy bien para ver el Lago del Oeste, disfrutar de paisajes verdes y añadir una escapada tranquila al viaje.',
    days: '2-3 días',
    bestSeason: 'Marzo-mayo, septiembre-noviembre',
    difficulty: 'Fácil-media',
    whyGo: 'Lago del Oeste, pueblos del té, templos y una escapada cómoda en tren desde Shanghái.',
    next: '/es/transport/',
    nextLabel: 'Planificar trenes y transporte urbano',
  },
  {
    name: 'Sanya',
    href: '/es/posts/sanya-city-guide-for-foreigners/',
    desc: 'La mejor base para playa, complejos turísticos, descanso invernal y estancias cálidas en Hainan.',
    days: '3-7 días',
    bestSeason: 'Noviembre-abril',
    difficulty: 'Media',
    whyGo: 'Playa, sol en invierno, marisco, complejos turísticos y buen ambiente para quedarse más tiempo.',
    next: '/es/posts/what-to-pack-for-china-a-season-by-season-checklist/',
    nextLabel: 'Qué llevar según la temporada',
  },
];

const routes = [
  {
    name: 'Primer viaje a China, 8-10 días',
    plan: 'Shanghái 3 días, Hangzhou 2 días, Pekín 4 días',
    fit: 'La combinación más equilibrada entre llegada cómoda, paisajes clásicos e historia monumental.',
  },
  {
    name: 'Gastronomía y ritmo tranquilo, 7-9 días',
    plan: 'Chengdu 4 días, Pekín o Shanghái 3-4 días',
    fit: 'Muy buena opción si buscas pandas, casas de té, olla caliente y una gran ciudad como punto de entrada.',
  },
  {
    name: 'Escapada de invierno, 6-10 días',
    plan: 'Sanya 4-6 días, Shanghái 2-3 días',
    fit: 'Funciona especialmente bien cuando el norte está frío y quieres mezclar ciudad con playa sin demasiada logística.',
  },
];

const faqItems = [
  {
    question: '¿Qué ciudad de China es la más sencilla para un primer viaje?',
    answer:
      'Shanghái suele ser la opción más fácil para empezar porque aeropuertos, metro, hoteles, restaurantes y servicios internacionales están mejor adaptados al visitante extranjero. Pekín también es muy manejable, pero exige algo más de planificación diaria y reservas anticipadas.',
  },
  {
    question: '¿Cuántas ciudades conviene visitar en un solo viaje?',
    answer:
      'Para un primer viaje de 8-10 días, lo más razonable es elegir dos o tres ciudades. China es enorme y los traslados entre aeropuertos, estaciones, controles y hoteles consumen más tiempo del que parece.',
  },
  {
    question: '¿Qué ciudad encaja mejor para una estancia larga?',
    answer:
      'Shanghái destaca por servicios y facilidad general, Chengdu por coste y ritmo relajado, y Hangzhou por su equilibrio entre naturaleza, comodidad y entorno tecnológico. Sanya funciona mejor como base estacional que como ciudad para vivir todo el año.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
import { getCategoryLabel } from '../../../i18n/categories';
const locale = 'es';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Planificación por ciudades</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="city-shanghai" alt="Perfil urbano de Shanghái y el Bund al atardecer como símbolo de un viaje urbano por China" loading="eager" />

    <ChinaMap cities={mapCities} />

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3" aria-labelledby="city-shortcuts">
      <h2 id="city-shortcuts" class="sr-only">Accesos rápidos a ciudades</h2>
      {cities.map((city) => (
        <article class="card" id={city.name.toLowerCase().replace(/[^a-z]/g, '')}>
          <h3 class="text-xl font-bold text-gray-950">{city.name}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{city.desc}</p>
          <dl class="mt-4 grid gap-2 text-sm text-gray-700">
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Duración recomendada</dt>
              <dd class="text-right">{city.days}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Mejor época</dt>
              <dd class="text-right">{city.bestSeason}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Facilidad para el viajero</dt>
              <dd class="text-right">{city.difficulty}</dd>
            </div>
          </dl>
          <div class="mt-5 grid gap-2 text-sm font-semibold">
            <a href={city.href} class="text-brand-700 hover:text-brand-800">Ver guía de la ciudad</a>
            <a href={city.next} class="text-gray-700 hover:text-brand-700">{city.nextLabel}</a>
          </div>
        </article>
      ))}
    </section>

    <section class="mt-12" aria-labelledby="compare-cities">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Comparativa de ciudades</p>
          <h2 id="compare-cities">Qué ciudad elegir según tu tipo de viaje</h2>
        </div>
      </div>
      <div class="mt-6 overflow-hidden rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
          <thead class="bg-gray-50 text-xs font-semibold uppercase tracking-wide text-gray-600">
            <tr>
              <th class="px-4 py-3">Ciudad</th>
              <th class="px-4 py-3">Motivo principal</th>
              <th class="px-4 py-3">Duración recomendada</th>
              <th class="px-4 py-3">Mejor época</th>
              <th class="px-4 py-3">Facilidad</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {cities.map((city) => (
              <tr>
                <th class="px-4 py-4 font-bold text-gray-950">
                  <a href={city.href} class="text-brand-700 hover:text-brand-800">{city.name}</a>
                </th>
                <td class="px-4 py-4 leading-6 text-gray-700">{city.whyGo}</td>
                <td class="px-4 py-4 text-gray-700">{city.days}</td>
                <td class="px-4 py-4 text-gray-700">{city.bestSeason}</td>
                <td class="px-4 py-4 text-gray-700">{city.difficulty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-12 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]" aria-labelledby="route-ideas">
      <div>
        <p class="section-kicker">Ideas de ruta</p>
        <h2 id="route-ideas" class="mt-2 text-3xl font-bold text-gray-950">Combinaciones de ciudades que sí funcionan</h2>
        <p class="mt-3 leading-7 text-gray-600">
          Un itinerario por China suele salir mejor cuando cada ciudad cumple una función distinta. Usa Shanghái como entrada cómoda,
          Pekín para historia, Hangzhou para paisaje, Chengdu para gastronomía y acceso al oeste, y Sanya para terminar con clima cálido.
          En viajes cortos, evita acumular demasiados vuelos o traslados largos entre estaciones.
        </p>
      </div>
      <div class="grid gap-4">
        {routes.map((route) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-lg font-bold text-gray-950">{route.name}</h3>
            <p class="mt-2 font-semibold text-brand-700">{route.plan}</p>
            <p class="mt-2 text-sm leading-6 text-gray-600">{route.fit}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Guías relacionadas</p>
            <h2>Artículos sobre ciudades y transporte urbano</h2>
          </div>
        </div>
        <div class="mt-6 grid gap-5 md:grid-cols-2">
          {cityPosts.map((post) => (
            <a href={`/es/posts/${post.slug}/`} class="card block hover:no-underline">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
              <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <p class="section-kicker">Antes de decidir</p>
        <h2 class="mt-1 text-xl font-bold text-gray-950">Revisa toda la logística</h2>
        <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
          <li><a href="/es/payment/" class="font-semibold text-brand-700">Pagos:</a> deja configurados Alipay, WeChat Pay y algo de efectivo antes de salir de las grandes ciudades.</li>
          <li><a href="/es/esim/" class="font-semibold text-brand-700">Internet:</a> elige eSIM, roaming o SIM local antes de depender de mapas y traducción.</li>
          <li><a href="/es/transport/" class="font-semibold text-brand-700">Transporte:</a> compara trenes, traslados aeroportuarios, DiDi y códigos QR del metro.</li>
          <li><a href="/es/tools/best-time-to-visit/" class="font-semibold text-brand-700">Fechas:</a> revisa clima, festivos y nivel de afluencia según el mes.</li>
        </ul>
      </aside>
    </section>

    <section class="mt-12" aria-labelledby="city-faq">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Preguntas frecuentes</p>
          <h2 id="city-faq">Dudas habituales al elegir ciudades en China</h2>
        </div>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {faqItems.map((item) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-base font-bold text-gray-950">{item.question}</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">{item.answer}</p>
          </article>
        ))}
      </div>
    </section>

    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  </main>
  <Footer />
</BaseLayout>