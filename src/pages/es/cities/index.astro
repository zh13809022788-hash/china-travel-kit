---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CoverImage from '../../../components/CoverImage.astro';
import ChinaMap from '../../../components/ChinaMap.astro';
import AdSlot from '../../../components/AdSlot.astro';

const allPosts = await getCollection('posts-es');
const cityNames = ['beijing', 'shanghai', 'chengdu', 'hangzhou', 'sanya', 'guangzhou', 'xian', 'chongqing', 'kunming', 'nanjing'];
const cityPosts = allPosts
  .filter((post) => cityNames.some((city) => post.slug.includes(city) || post.data.tags.includes(city)))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const title = 'Guías de ciudades chinas para visitantes extranjeros';
const description =
  'Planifica paradas prácticas en ciudades de China con guías para Beijing, Shanghai, Guangzhou, Chengdu, Xi\'an, Hangzhou, Chongqing y Sanya, además de aeropuerto, metro, comida y transporte para los próximos pasos.';

const mapCities = [
  { name: 'Beijing', x: 470, y: 80, href: '#beijing' },
  { name: 'Xi\'an', x: 340, y: 155, href: '#xian' },
  { name: 'Nanjing', x: 490, y: 180, href: '' },
  { name: 'Shanghai', x: 540, y: 200, href: '#shanghai' },
  { name: 'Chengdu', x: 250, y: 220, href: '#chengdu' },
  { name: 'Hangzhou', x: 520, y: 205, href: '#hangzhou' },
  { name: 'Chongqing', x: 310, y: 260, href: '#chongqing' },
  { name: 'Guilin', x: 370, y: 300, href: '' },
  { name: 'Kunming', x: 210, y: 335, href: '' },
  { name: 'Guangzhou', x: 400, y: 370, href: '#guangzhou' },
  { name: 'Shenzhen', x: 430, y: 390, href: '' },
  { name: 'Sanya', x: 360, y: 440, href: '#sanya' },
];

const cities = [
  {
    name: 'Beijing',
    href: '/es/posts/beijing-city-guide-for-foreigners/',
    desc: 'Ideal para historia, hutongs, la Gran Muralla y visitas turísticas clásicas para primerizos.',
    days: '4-5 días',
    bestSeason: 'Septiembre-octubre',
    difficulty: 'Media',
    whyGo: 'Historia imperial, museos y el acceso más fácil a la Gran Muralla.',
    next: '/es/posts/beijing-daxing-airport-to-city-center-a-first-timer-s-guide/',
    nextLabel: 'Guía de traslado desde el aeropuerto de Daxing',
  },
  {
    name: 'Shanghai',
    href: '/es/posts/shanghai-city-guide-for-foreigners/',
    desc: 'Ideal para una llegada sencilla, comida internacional, paseos por el skyline y amplia cobertura de metro.',
    days: '3-4 días',
    bestSeason: 'Marzo-mayo, octubre-noviembre',
    difficulty: 'Fácil',
    whyGo: 'La primera parada más fluida para metro, aeropuertos, comida y servicios en inglés.',
    next: '/es/posts/shanghai-metro-for-foreigners-tickets-qr-codes-transfers/',
    nextLabel: 'Guía del metro de Shanghai',
  },
  {
    name: 'Chengdu',
    href: '/es/posts/chengdu-city-guide-for-foreigners/',
    desc: 'Ideal para comida de Sichuan, ritmo de casas de té, pandas y un ritmo urbano más relajado.',
    days: '3-5 días',
    bestSeason: 'Marzo-junio, septiembre-noviembre',
    difficulty: 'Media',
    whyGo: 'Pandas, comida de Sichuan, casas de té, costes más bajos y excursiones al oeste de China.',
    next: '/es/posts/chengdu-street-food-safety-spice-levels-what-to-order/',
    nextLabel: 'Guía de comida callejera de Chengdu',
  },
  {
    name: 'Xi\'an',
    href: '/es/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/',
    desc: 'Ideal para historia antigua, los Guerreros de Terracota, murallas antiguas y herencia china en primera mano.',
    days: '3-4 días',
    bestSeason: 'Marzo-mayo, septiembre-noviembre',
    difficulty: 'Media',
    whyGo: 'Guerreros de Terracota, muralla antigua, calle de comida del Barrio Musulmán y un profundo sentido de la historia china.',
    next: '/es/posts/china-high-speed-rail-guide-foreigners/',
    nextLabel: 'Tren de alta velocidad a Xi\'an',
  },
  {
    name: 'Guangzhou',
    href: '/es/posts/airport-to-city-transport-beijing-shanghai-guangzhou/',
    desc: 'Ideal para comida cantonesa, energía de ciudad comercial, puerta del sur y acceso fácil a Hong Kong.',
    days: '3-4 días',
    bestSeason: 'Octubre-diciembre, marzo-abril',
    difficulty: 'Media',
    whyGo: 'Dim sum cantonés, Academia del Clan Chen, Torre de Cantón y una alternativa sureña más cálida a Beijing y Shanghai.',
    next: '/es/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    nextLabel: 'Guía de comida cantonesa',
  },
  {
    name: 'Chongqing',
    href: '/es/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    desc: 'Ideal para hot pot de Sichuan, skyline futurista, terreno de ciudad montañosa y cruceros por el río Yangtsé.',
    days: '3-4 días',
    bestSeason: 'Marzo-mayo, septiembre-noviembre',
    difficulty: 'Difícil',
    whyGo: 'Hot pot de Chongqing, Cueva de Hongya, skyline nocturno, teleférico del Yangtsé y un diseño urbano verticalmente único.',
    next: '/es/food/',
    nextLabel: 'Guía de comida de Chongqing',
  },
  {
    name: 'Hangzhou',
    href: '/es/posts/hangzhou-city-guide-for-foreigners/',
    desc: 'Ideal para el Lago del Oeste, paisajes verdes, ritmo de fin de semana y una escapada urbana pulida.',
    days: '2-3 días',
    bestSeason: 'Marzo-mayo, septiembre-noviembre',
    difficulty: 'Fácil-media',
    whyGo: 'Lago del Oeste, pueblos del té, templos y una extensión tranquila en tren de alta velocidad desde Shanghai.',
    next: '/es/transport/',
    nextLabel: 'Planificar trenes y transporte local',
  },
  {
    name: 'Sanya',
    href: '/es/posts/sanya-city-guide-for-foreigners/',
    desc: 'Ideal para clima cálido en invierno, estancias en resorts, tiempo de playa y excursiones por Hainan.',
    days: '3-7 días',
    bestSeason: 'Noviembre-abril',
    difficulty: 'Media',
    whyGo: 'Tiempo de playa en China, sol de invierno, marisco, resorts y estancias estacionales más largas.',
    next: '/es/posts/what-to-pack-for-china-a-season-by-season-checklist/',
    nextLabel: 'Guía de equipaje por temporadas',
  },
];

const routes = [
  {
    name: 'Primer viaje a China, 8-10 días',
    plan: 'Shanghai 3 días, Hangzhou 2 días, Beijing 4 días',
    fit: 'Mejor equilibrio entre llegada sencilla, paisajes clásicos e historia destacada.',
  },
  {
    name: 'Comida y ritmo relajado, 7-9 días',
    plan: 'Chengdu 4 días, Beijing o Shanghai 3-4 días',
    fit: 'Bueno para viajeros que quieren pandas, casas de té, hot pot y una ciudad de entrada principal.',
  },
  {
    name: 'Escapada de invierno, 6-10 días',
    plan: 'Sanya 4-6 días, Shanghai 2-3 días',
    fit: 'Ideal cuando el norte de China está frío y quieres una combinación sencilla de playa y ciudad.',
  },
];

const faqItems = [
  {
    question: '¿Qué ciudad de China es la más fácil para visitantes extranjeros primerizos?',
    answer:
      'Shanghai suele ser la primera ciudad más fácil porque los aeropuertos, las señales del metro, los hoteles, los restaurantes y los servicios internacionales son los más amigables para extranjeros. Beijing también es muy manejable, pero requiere más reservas anticipadas y una planificación diaria más cuidadosa.',
  },
  {
    question: '¿Cuántas ciudades chinas debería visitar en un solo viaje?',
    answer:
      'Para un primer viaje de 8-10 días, dos o tres ciudades son suficientes. China es grande, y los traslados al aeropuerto, las estaciones de tren, los controles de seguridad y los cambios de hotel pueden consumir más tiempo del esperado. Elige una ciudad de entrada, una parada cultural o paisajística y una extensión opcional.',
  },
  {
    question: '¿Qué ciudad es mejor para una estancia más larga en China?',
    answer:
      'Shanghai es la base más fácil para estancias largas por sus servicios y cobertura en inglés, Chengdu es más fuerte para costes más bajos y una vida relajada, y Hangzhou ofrece un punto intermedio con paisajes y una fuerte economía tecnológica. Sanya funciona bien para estancias de invierno más que para la vida urbana durante todo el año.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Planificación de ciudades</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="city-shanghai" alt="Horizonte de Shanghai y el Bund al atardecer representando viajes urbanos por China" loading="eager" />

    <ChinaMap cities={mapCities} />

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3" aria-labelledby="city-shortcuts">
      <h2 id="city-shortcuts" class="sr-only">Atajos de ciudades</h2>
      {cities.map((city) => (
        <article class="card" id={city.name.toLowerCase().replace(/[^a-z]/g, '')}>
          <h3 class="text-xl font-bold text-gray-950">{city.name}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{city.desc}</p>
          <dl class="mt-4 grid gap-2 text-sm text-gray-700">
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Estancia sugerida</dt>
              <dd class="text-right">{city.days}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Mejor temporada</dt>
              <dd class="text-right">{city.bestSeason}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Facilidad para visitantes</dt>
              <dd class="text-right">{city.difficulty}</dd>
            </div>
          </dl>
          <div class="mt-5 grid gap-2 text-sm font-semibold">
            <a href={city.href} class="text-brand-700 hover:text-brand-800">Abrir guía de la ciudad</a>
            <a href={city.next} class="text-gray-700 hover:text-brand-700">{city.nextLabel}</a>
          </div>
        </article>
      ))}
    </section>

    <section class="mt-12" aria-labelledby="compare-cities">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Comparación de ciudades</p>
          <h2 id="compare-cities">¿Qué ciudad de China deberías elegir?</h2>
        </div>
      </div>
      <div class="mt-6 overflow-hidden rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
          <thead class="bg-gray-50 text-xs font-semibold uppercase tracking-wide text-gray-600">
            <tr>
              <th class="px-4 py-3">Ciudad</th>
              <th class="px-4 py-3">Por qué ir</th>
              <th class="px-4 py-3">Estancia sugerida</th>
              <th class="px-4 py-3">Mejor temporada</th>
              <th class="px-4 py-3">Facilidad</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {cities.map((city) => (
              <tr>
                <th class="px-4 py-4 font-bold text-gray-950">
                  <a href={city.href} class="text-brand-700 hover:text-brand-800">{city.name}</a>
                </th>
                <td class="px-4 py-4 leading-6 text-gray-700">{city.whyGo}</td>
                <td class="px-4 py-4 text-gray-700">{city.days}</td>
                <td class="px-4 py-4 text-gray-700">{city.bestSeason}</td>
                <td class="px-4 py-4 text-gray-700">{city.difficulty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-12 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]" aria-labelledby="route-ideas">
      <div>
        <p class="section-kicker">Planificación de rutas</p>
        <h2 id="route-ideas" class="mt-2 text-3xl font-bold text-gray-950">Combinaciones prácticas de ciudades</h2>
        <p class="mt-3 leading-7 text-gray-600">
          Un buen itinerario por China suele funcionar mejor cuando las ciudades cumplen funciones diferentes. Usa Shanghai como un punto de
          llegada sencillo, Beijing para historia, Hangzhou para paisajes, Chengdu para comida y acceso al oeste de China, y
          Sanya para un descanso con clima cálido. Evita añadir demasiados vuelos o traslados en estaciones de tren a un viaje corto.
        </p>
      </div>
      <div class="grid gap-4">
        {routes.map((route) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-lg font-bold text-gray-950">{route.name}</h3>
            <p class="mt-2 font-semibold text-brand-700">{route.plan}</p>
            <p class="mt-2 text-sm leading-6 text-gray-600">{route.fit}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Todas las guías relacionadas con ciudades</p>
            <h2>Artículos de ciudades y transporte local</h2>
          </div>
        </div>
        <div class="mt-6 grid gap-5 md:grid-cols-2">
          {cityPosts.map((post) => (
            <a href={`/es/posts/${post.slug}/`} class="card block hover:no-underline">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{post.data.category}</span>
              <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <p class="section-kicker">Antes de elegir una ciudad</p>
        <h2 class="mt-1 text-xl font-bold text-gray-950">Comprueba el conjunto logístico</h2>
        <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
          <li><a href="/es/payment/" class="font-semibold text-brand-700">Pagos:</a> configura Alipay, WeChat Pay y una reserva de efectivo antes de viajar a ciudades más pequeñas.</li>
          <li><a href="/es/esim/" class="font-semibold text-brand-700">Internet:</a> elige eSIM, roaming o SIM local antes de depender de mapas y traducción.</li>
          <li><a href="/es/transport/" class="font-semibold text-brand-700">Transporte:</a> compara trenes, traslados al aeropuerto, DiDi y códigos QR del metro.</li>
          <li><a href="/es/tools/best-time-to-visit/" class="font-semibold text-brand-700">Fechas:</a> consulta el clima, los festivos y la presión de multitudes por mes.</li>
        </ul>
      </aside>
    </section>

    <section class="mt-12" aria-labelledby="city-faq">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Preguntas frecuentes sobre ciudades</p>
          <h2 id="city-faq">Preguntas comunes sobre la planificación de ciudades en China</h2>
        </div>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {faqItems.map((item) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-base font-bold text-gray-950">{item.question}</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">{item.answer}</p>
          </article>
        ))}
      </div>
    </section>

    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  </main>
  <Footer />
</BaseLayout>