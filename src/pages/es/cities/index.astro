---
import { getCollection } from 'astro:content';
import { getCategoryLabel } from "../../../i18n/categories";
import { CITY_GUIDES, type CityGuideEntry } from "../../../data/cityGuideData";
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import CoverImage from "../../../components/CoverImage.astro";
import ChinaMap from "../../../components/ChinaMap.astro";
import AdSlot from "../../../components/AdSlot.astro";

const allPosts = await getCollection('posts');

// Encontrar qué guías de ciudad tienen publicaciones publicadas
const postMap = new Map<string, typeof allPosts[0]>();
for (const post of allPosts) {
  for (const guide of CITY_GUIDES) {
    if (post.slug === guide.slug || post.slug.includes(guide.slug)) {
      postMap.set(guide.slug, post);
    }
  }
}

// Mostrar solo las ciudades que tienen una publicación de guía publicada
const activeGuides = CITY_GUIDES.filter((g) => postMap.has(g.slug));
const activeSlugs = new Set(activeGuides.map((g) => g.slug));

// Coordenadas del mapa con enlaces href correctos
const mapCities = CITY_GUIDES.map((g) => ({
  name: g.name,
  x: g.mapX,
  y: g.mapY,
  href: postMap.has(g.slug) ? `#${g.name.toLowerCase().replace(/[^a-z]/g, '')}` : '',
}));

// Tarjetas de ciudades ordenadas por nombre
const cities = [...activeGuides].sort((a, b) => a.name.localeCompare(b.name));

// Todas las publicaciones relacionadas con ciudades (ordenadas por título)
const cityPosts = allPosts
  .filter((post) => activeSlugs.has(post.slug) || post.data.tags?.some((t: string) =>
    [...activeSlugs].some((s) => s.includes(t) || t.includes(s))
  ))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const title = 'Guías de ciudades de China para visitantes extranjeros';
const description = `Planifica paradas prácticas en ciudades de China con guías de ${activeGuides.map((g) => g.name).join(', ')}.`;

const routes = [
  {
    name: 'Primer viaje a China, 8-10 días',
    plan: 'Shanghai 3 días, Hangzhou 2 días, Beijing 4 días',
    fit: 'El mejor equilibrio entre una llegada fácil, paisajes clásicos e historia emblemática.',
  },
  {
    name: 'Comida y ritmo relajado, 7-9 días',
    plan: 'Chengdu 4 días, Beijing o Shanghai 3-4 días',
    fit: 'Bueno para viajeros que quieren pandas, casas de té, hotpot y una gran ciudad de entrada.',
  },
  {
    name: 'Escapada de invierno, 6-10 días',
    plan: 'Sanya 4-6 días, Shanghai 2-3 días',
    fit: 'Ideal cuando el norte de China está frío y quieres una combinación sencilla de playa y ciudad.',
  },
  {
    name: 'Descubrimiento del sur, 10-12 días',
    plan: 'Guangzhou 3 días, Guilin 3 días, Shanghai 4 días',
    fit: 'Excelente para amantes de la comida, paisajes escénicos y un ritmo relajado por el sur de China.',
  },
  {
    name: 'Capitales antiguas, 10-12 días',
    plan: 'Beijing 4 días, Xi\'an 3 días, Nanjing 2 días, Shanghai 3 días',
    fit: 'Ruta centrada en la historia por las capitales imperiales de China con conexiones en tren de alta velocidad.',
  },
];

const faqItems = [
  {
    question: '¿Qué ciudad de China es la más fácil para visitantes extranjeros que viajan por primera vez?',
    answer:
      'Shanghai suele ser la primera ciudad más fácil porque los aeropuertos, las señales del metro, los hoteles, los restaurantes y los servicios internacionales son los más amigables para extranjeros. Beijing sigue siendo muy manejable, pero requiere más reservas anticipadas y una planificación diaria más cuidadosa.',
  },
  {
    question: '¿Cuántas ciudades chinas debería visitar en un solo viaje?',
    answer:
      'Para un primer viaje de 8-10 días, dos o tres ciudades son suficientes. China es grande, y los traslados al aeropuerto, las estaciones de tren, los controles de seguridad y los cambios de hotel pueden consumir más tiempo del esperado. Elige una ciudad de entrada, una parada cultural o escénica y una extensión opcional.',
  },
  {
    question: '¿Qué ciudad es mejor para una estancia más larga en China?',
    answer:
      'Shanghai es la base más fácil para estancias largas por sus servicios y cobertura en inglés, Chengdu destaca más por sus costos más bajos y su estilo de vida relajado, y Hangzhou ofrece un punto intermedio con paisajes y una sólida economía tecnológica. Sanya funciona bien para estancias de invierno más que para la vida urbana durante todo el año.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
const locale = 'en';
---
<!-- Contenido generado con asistencia de IA, revisado por redactor nativo -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header>
      <p class="section-kicker">Planificación de ciudades</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="city-shanghai" alt="Horizonte de Shanghai y el Bund al anochecer representando los viajes urbanos en China" loading="eager" />

    <ChinaMap cities={mapCities} />

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3" aria-labelledby="city-shortcuts">
      <h2 id="city-shortcuts" class="sr-only">Accesos directos a ciudades</h2>
      {cities.map((city) => (
        <a href={city.slug ? `/posts/${city.slug}/` : '#'} class="card block hover:no-underline scroll-mt-20" id={city.name.toLowerCase().replace(/[^a-z]/g, '')}>
          <h3 class="text-xl font-bold text-gray-950">{city.name}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{city.desc}</p>
          <dl class="mt-4 grid gap-2 text-sm text-gray-700">
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Estancia sugerida</dt>
              <dd class="text-right">{city.days}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Mejor temporada</dt>
              <dd class="text-right">{city.bestSeason}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Facilidad para visitantes</dt>
              <dd class="text-right">{city.difficulty}</dd>
            </div>
          </dl>
          <span class="mt-3 inline-block text-sm font-semibold text-brand-700">Abrir guía de la ciudad →</span>
        </a>
      ))}
    </section>

    <section class="mt-12" aria-labelledby="compare-cities">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Comparación de ciudades</p>
          <h2 id="compare-cities">¿Qué ciudad de China deberías elegir?</h2>
        </div>
      </div>
      <div class="mt-6 overflow-hidden rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
          <thead class="bg-gray-50 text-xs font-semibold uppercase tracking-wide text-gray-600">
            <tr>
              <th class="px-4 py-3">Ciudad</th>
              <th class="px-4 py-3">Por qué ir</th>
              <th class="px-4 py-3">Estancia sugerida</th>
              <th class="px-4 py-3">Mejor temporada</th>
              <th class="px-4 py-3">Facilidad</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {cities.map((city) => (
              <tr>
                <th class="px-4 py-4 font-bold text-gray-950">
                  <a href={`/posts/${city.slug}/`} class="text-brand-700 hover:text-brand-800">{city.name}</a>
                </th>
                <td class="px-4 py-4 leading-6 text-gray-700">{city.whyGo}</td>
                <td class="px-4 py-4 text-gray-700">{city.days}</td>
                <td class="px-4 py-4 text-gray-700">{city.bestSeason}</td>
                <td class="px-4 py-4 text-gray-700">{city.difficulty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-12 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]" aria-labelledby="route-ideas">
      <div>
        <p class="section-kicker">Planificación de rutas</p>
        <h2 id="route-ideas" class="mt-2 text-3xl font-bold text-gray-950">Combinaciones prácticas de ciudades</h2>
        <p class="mt-3 leading-7 text-gray-600">
          Un buen itinerario por China suele funcionar mejor cuando las ciudades cumplen funciones diferentes. Usa Shanghai como un punto de llegada fácil,
          Beijing para la historia, Hangzhou para los paisajes, Chengdu para la comida y el acceso al oeste de China, y
          Sanya para una pausa de clima cálido. Evita añadir demasiados vuelos o traslados entre estaciones de tren en un viaje corto.
        </p>
      </div>
      <div class="grid gap-4">
        {routes.map((route) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-lg font-bold text-gray-950">{route.name}</h3>
            <p class="mt-2 font-semibold text-brand-700">{route.plan}</p>
            <p class="mt-2 text-sm leading-6 text-gray-600">{route.fit}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Todas las guías relacionadas con ciudades</p>
            <h2>Artículos de ciudades y transporte local</h2>
          </div>
        </div>
        <div class="mt-6 grid gap-5 md:grid-cols-2">
          {cityPosts.map((post) => (
            <a href={`/posts/${post.slug}/`} class="card block hover:no-underline">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
              <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <p class="section-kicker">Antes de elegir una ciudad</p>
        <h2 class="mt-1 text-xl font-bold text-gray-950">Revisa la logística completa</h2>
        <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
          <li><a href="/payment/" class="font-semibold text-brand-700">Pagos:</a> configura Alipay, WeChat Pay y un respaldo en efectivo antes de viajar a ciudades más pequeñas.</li>
          <li><a href="/esim/" class="font-semibold text-brand-700">Internet:</a> elige eSIM, roaming o SIM local antes de depender de mapas y traducción.</li>
          <li><a href="/transport/" class="font-semibold text-brand-700">Transporte:</a> compara trenes, traslados al aeropuerto, DiDi y códigos QR del metro.</li>
          <li><a href="/tools/best-time-to-visit/" class="font-semibold text-brand-700">Fechas:</a> revisa el clima, los festivos y la presión de multitudes por mes.</li>
        </ul>
      </aside>
    </section>

    <section class="mt-12" aria-labelledby="city-faq">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Preguntas frecuentes sobre ciudades</p>
          <h2 id="city-faq">Preguntas comunes sobre la planificación de ciudades en China</h2>
        </div>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {faqItems.map((item) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-base font-bold text-gray-950">{item.question}</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">{item.answer}</p>
          </article>
        ))}
      </div>
    </section>

    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  </main>
  <Footer />
</BaseLayout>