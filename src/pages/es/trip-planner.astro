---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';

const title = 'Planificador gratuito de viaje a China';
const description =
  'Crea un plan inicial y práctico para tu viaje a China con recomendaciones sobre pagos, eSIM, transporte, apps, efectivo y prioridades del primer día.';

const needOptions = [
  { value: 'payment', label: 'Preparar pagos' },
  { value: 'esim', label: 'eSIM e internet' },
  { value: 'transport', label: 'Aeropuerto y trenes' },
  { value: 'hotel', label: 'Elegir zona de hotel' },
  { value: 'apps', label: 'Apps y traducción' },
  { value: 'cash', label: 'Efectivo de respaldo' },
  { value: 'visa', label: 'Entrada sin visa' },
  { value: 'food', label: 'Comida y reparto' },
];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main>
    <section class="border-b border-gray-200 bg-white">
      <div class="container-page grid gap-8 py-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <div>
          <p class="section-kicker">Herramienta gratuita de planificación</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Diseña un plan de llegada a China antes de subir al avión
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Genera un primer esquema para pagos, datos eSIM, transporte desde el aeropuerto, apps básicas,
            efectivo de respaldo y ritmo del viaje. Todo funciona en tu navegador y no guardamos tus respuestas.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#planner" class="btn-primary">Empezar</a>
            <a href="/es/travel-help/" class="btn-outline">Pedir ayuda de viaje</a>
            <a href="/es/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">Leer guía para primera visita</a>
          </div>
        </div>

        <aside class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="section-kicker">Pensado para</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Preparar un primer viaje con cabeza</h2>
          <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
            <li>Dejar listos los pagos antes de aterrizar</li>
            <li>Elegir entre eSIM, roaming y acceso a apps</li>
            <li>Trazar la primera ruta del aeropuerto al hotel</li>
            <li>Tener un marco simple por ciudad</li>
          </ul>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <AdSlot format="banner" />

      <section id="planner" class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <form id="trip-planner-form" class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm md:p-6">
          <div class="border-b border-gray-200 pb-5">
            <p class="section-kicker">Detalles del viaje</p>
            <h2 class="mt-2 text-2xl font-bold text-gray-950">Cuéntanos lo que ya sabes</h2>
          </div>

          <div class="mt-6 grid gap-5 md:grid-cols-2">
            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              País o región de salida
              <input id="home-country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="Estados Unidos, Reino Unido, Singapur..." />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Ciudad de llegada
              <select id="arrival-city" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Shanghái</option>
                <option>Pekín</option>
                <option>Cantón</option>
                <option>Shenzhen</option>
                <option>Chengdu</option>
                <option>Hangzhou</option>
                <option>Otra ciudad</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800 md:col-span-2">
              Ciudades del itinerario
              <input id="destination-cities" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="Shanghái, Hangzhou, Pekín" />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Duración del viaje
              <select id="trip-length" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option value="3">3 días</option>
                <option value="5">5 días</option>
                <option value="7" selected>7 días</option>
                <option value="10">10 días</option>
                <option value="14">14 días</option>
                <option value="21">21 días o más</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Motivo del viaje
              <select id="trip-purpose" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Turismo</option>
                <option>Negocios</option>
                <option>Estancia larga</option>
                <option>Nómada digital</option>
                <option>Visita familiar</option>
                <option>Tránsito</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Presupuesto
              <select id="budget-range" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Económico</option>
                <option selected>Cómodo</option>
                <option>Premium</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Estilo de viaje
              <select id="travel-style" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Eficiente</option>
                <option>Económico</option>
                <option selected>Cómodo</option>
                <option>Familiar</option>
                <option>Negocios</option>
                <option>Centrado en la comida</option>
              </select>
            </label>
          </div>

          <fieldset class="mt-6">
            <legend class="text-sm font-semibold text-gray-800">¿Con qué necesitas ayuda?</legend>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              {needOptions.map((option) => (
                <label class="flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-700">
                  <input class="h-4 w-4 rounded border-gray-300 text-brand-600" type="checkbox" name="needs" value={option.value} checked={['payment', 'esim', 'transport', 'apps'].includes(option.value)} />
                  {option.label}
                </label>
              ))}
            </div>
          </fieldset>

          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p id="planner-status" class="text-sm text-gray-500">No hace falta crear cuenta ni compartir datos sensibles.</p>
            <button class="btn-primary" type="submit">Generar plan</button>
          </div>
        </form>

        <aside class="space-y-6">
          <section class="rounded-lg border border-gray-200 bg-white p-5">
            <p class="section-kicker">Siguiente nivel</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">¿Quieres una revisión humana?</h2>
            <p class="mt-3 text-sm leading-6 text-gray-600">
              Si tu ruta, los tiempos, los pagos o el primer día te generan dudas, puedes enviar el plan
              por email y pedir una revisión manual con observaciones concretas.
            </p>
            <a id="planner-email-link" class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:border-brand-600 hover:text-brand-600 hover:no-underline" href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Trip%20Review%20Request">
              Preparar email de revisión
            </a>
          </section>

          <section class="rounded-lg border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Límites</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Úsalo como ayuda de planificación</h2>
            <p class="mt-3 text-sm leading-6 text-gray-700">
              Esta herramienta no sustituye asesoramiento legal, migratorio, médico, bancario ni de emergencia. Verifica
              siempre las normas importantes de entrada, aerolínea, hotel, tarjeta, telecomunicaciones y apps con fuentes oficiales.
            </p>
          </section>
        </aside>
      </section>

      <section id="plan-output" class="mt-10 hidden rounded-lg border border-brand-100 bg-brand-50 p-5 md:p-6" aria-live="polite">
        <div class="border-b border-brand-100 pb-4">
          <p class="section-kicker">Plan generado</p>
          <h2 class="mt-2 text-2xl font-bold text-gray-950">Borrador de preparación para tu viaje a China</h2>
        </div>
        <div id="plan-content" class="mt-5 grid gap-5"></div>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <a href="/es/payment/" class="card block hover:no-underline">
          <p class="section-kicker">Pagos</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Deja listos Alipay y WeChat Pay</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Llega con al menos una cartera configurada y un método de respaldo preparado.</p>
        </a>
        <a href="/es/esim/" class="card block hover:no-underline">
          <p class="section-kicker">Internet</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Decide entre eSIM y roaming</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Asegúrate de tener datos para mapas, traducción, mensajes y transporte desde el minuto uno.</p>
        </a>
        <a href="/es/transport/" class="card block hover:no-underline">
          <p class="section-kicker">Transporte</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Traza tu primera ruta</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Ten claro cómo ir del aeropuerto al hotel y cuándo usar metro, taxi, DiDi o tren.</p>
        </a>
      </section>

      <section class="mt-10 rounded-lg border border-gray-200 bg-white p-5 md:p-6">
        <p class="section-kicker">Antes de empezar</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950">Lee las guías básicas si es tu primera vez en China</h2>
        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <a href="/es/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Planificador de viaje a China para primerizos</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Sigue el mismo orden que esta herramienta: internet, pagos, traslado desde el aeropuerto, apps, orden de ciudades y lista del primer día.</p>
          </a>
          <a href="/es/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Qué dejar configurado antes de viajar a China</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Checklist de salida para Alipay, WeChat Pay, eSIM, DiDi, billetes de tren, mapas y efectivo.</p>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('trip-planner-form') as HTMLFormElement | null;
  const output = document.getElementById('plan-output');
  const content = document.getElementById('plan-content');
  const status = document.getElementById('planner-status');
  const emailLink = document.getElementById('planner-email-link') as HTMLAnchorElement | null;

  const getValue = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null)?.value.trim() || '';
  const selectedNeeds = () =>
    Array.from(document.querySelectorAll<HTMLInputElement>('input[name="needs"]:checked')).map((input) => input.value);
  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char] ?? char);

  const splitCities = (value: string, arrival: string) => {
    const typed = value
      .split(',')
      .map((city) => city.trim())
      .filter(Boolean);
    const cities = typed.length ? typed : [arrival];
    return Array.from(new Set(cities));
  };

  const list = (items: string[]) => `<ul class="mt-3 grid gap-2 text-sm leading-6 text-gray-700">${items.map((item) => `<li>${item}</li>`).join('')}</ul>`;
  const panel = (title: string, items: string[]) => `
    <section class="rounded-lg border border-gray-200 bg-white p-5">
      <h3 class="text-lg font-bold text-gray-950">${title}</h3>
      ${list(items)}
    </section>
  `;

  const buildPlan = () => {
    const home = getValue('home-country') || 'tu país de origen';
    const arrival = getValue('arrival-city') || 'Shanghái';
    const cities = splitCities(getValue('destination-cities'), arrival);
    const days = Number(getValue('trip-length') || '7');
    const purpose = getValue('trip-purpose') || 'Turismo';
    const budget = getValue('budget-range') || 'Cómodo';
    const style = getValue('travel-style') || 'Cómodo';
    const needs = selectedNeeds();
    const perCity = Math.max(1, Math.floor(days / Math.max(1, cities.length)));

    const preDeparture = [
      `Instala Alipay, WeChat, DiDi, una app de traducción y un mapa offline antes de salir de ${escapeHtml(home)}.`,
      needs.includes('payment')
        ? 'Vincula una Visa o Mastercard extranjera a Alipay y prueba una verificación pequeña antes de viajar.'
        : 'Simplifica pagos: una cartera móvil, una tarjeta física y algo de RMB en efectivo.',
      needs.includes('esim')
        ? 'Compra y activa una eSIM o un plan de roaming antes del vuelo, y guarda el QR también offline.'
        : 'Confirma que tendrás datos nada más aterrizar antes de depender de mapas o transporte.',
      'Guarda la dirección del hotel en inglés y en chino, junto con la estación de metro más cercana.',
    ];

    const payment = [
      'Configuración principal: Alipay con tarjeta extranjera, porque suele ser la opción más sencilla para visitantes.',
      'Respaldo: WeChat Pay si tu tarjeta enlaza bien, además de una Visa o Mastercard física.',
      budget === 'Económico'
        ? 'Lleva una pequeña cantidad de RMB por si necesitas pagar en puestos, dejar depósitos o resolver fallos de la app.'
        : 'Mantén suficiente RMB para taxi, tentempiés y una comida simple por si falla el pago móvil.',
      'No dependas de Apple Pay o Google Pay como sistema principal en China continental.',
    ];

    const internet = [
      'Para viajes cortos, una eSIM suele ser la forma más simple de aterrizar con datos.',
      'Si vas a quedarte más tiempo o consumir mucho, compara roaming, eSIM, pocket WiFi y SIM local antes de llegar.',
      'Prueba los datos móviles antes de salir del aeropuerto: pagos, transporte, traducción y mapas dependen de esa conexión.',
      'Guarda offline la información crítica del hotel y del transporte por si la primera conexión falla.',
    ];

    const transport = [
      `Primer trayecto: deja pensada la ruta desde el aeropuerto o estación de ${escapeHtml(arrival)} hasta el hotel antes de aterrizar.`,
      'Usa metro para recorridos urbanos predecibles, DiDi para puerta a puerta y tren de alta velocidad entre ciudades.',
      needs.includes('transport')
        ? 'Si vas a coger tren, reserva con margen cuando puedas y mantén exactamente los mismos datos de pasaporte en la plataforma.'
        : 'Evita enlazar el mismo día un vuelo internacional con un tren largo si el margen es ajustado.',
      'Lleva a mano una tarjeta con la dirección en chino para taxis o recepción del hotel.',
    ];

    const dayPlan = cities.map((city, index) => {
      const start = index * perCity + 1;
      const end = index === cities.length - 1 ? days : Math.min(days, start + perCity - 1);
      return `Días ${start}-${end}: ${escapeHtml(city)} - deja la primera media jornada ligera, confirma pagos y datos, y agrupa visitas por zona.`;
    });

    const mistakes = [
      'No esperes a llegar para configurar todas las apps, tarjetas y datos.',
      'No pongas un día intensísimo de visitas justo después de un vuelo largo.',
      'No dependas de un único método de pago.',
      purpose === 'Negocios'
        ? 'Si viajas por negocios, reserva margen para tráfico, controles de seguridad, facturas y acceso a edificios.'
        : 'Si viajas por ocio, deja un bloque flexible cada dos o tres días por clima, cansancio o colas.',
      style === 'Centrado en la comida'
        ? 'Si el viaje gira en torno a la gastronomía, guarda nombres de restaurantes en chino y revisa horarios antes de cruzar la ciudad.'
        : 'Ten pensado al menos un plan de comidas cerca del hotel.',
    ];

    const html = [
      panel('Checklist antes de salir', preDeparture),
      panel('Pagos y efectivo', payment),
      panel('Internet y apps', internet),
      panel('Transporte y primer día', transport),
      panel('Esquema diario sencillo', dayPlan),
      panel('Errores que conviene evitar', mistakes),
    ].join('');

    const emailBody = [
      'Solicitud de revisión de viaje ChinaTripBox',
      '',
      `País o región de salida: ${home}`,
      `Ciudad de llegada: ${arrival}`,
      `Ciudades del itinerario: ${cities.join(', ')}`,
      `Duración del viaje: ${days} días`,
      `Motivo: ${purpose}`,
      `Presupuesto: ${budget}`,
      `Estilo: ${style}`,
      `Necesidades: ${needs.join(', ') || 'no especificado'}`,
      '',
      'Por favor revisa mi preparación de viaje a China para pagos, eSIM, transporte, tiempos y posibles errores del primer día.',
    ].join('\n');

    if (emailLink) {
      emailLink.href = `mailto:zh13809022788@gmail.com?subject=${encodeURIComponent(
        'Solicitud de revisión de viaje ChinaTripBox',
      )}&body=${encodeURIComponent(emailBody)}`;
    }

    return html;
  };

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!content || !output) return;
    content.innerHTML = buildPlan();
    output.classList.remove('hidden');
    output.scrollIntoView({ behavior: 'smooth', block: 'start' });
    if (status) status.textContent = 'Plan generado. Puedes ajustar las respuestas y volver a generarlo cuando quieras.';
  });
</script>
