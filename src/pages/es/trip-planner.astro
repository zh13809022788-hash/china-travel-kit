---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';

const title = 'Planificador gratuito de viaje a China';
const description =
  'Crea un primer plan práctico para viajar a China con recomendaciones de pagos, eSIM, transporte, apps, efectivo y lista del primer día.';

const needOptions = [
  { value: 'payment', label: 'Configuración de pagos' },
  { value: 'esim', label: 'eSIM e internet' },
  { value: 'transport', label: 'Aeropuerto y trenes' },
  { value: 'hotel', label: 'Elección de zona de hotel' },
  { value: 'apps', label: 'Apps y traducción' },
  { value: 'cash', label: 'Efectivo de respaldo' },
  { value: 'visa', label: 'Entrada sin visa' },
  { value: 'food', label: 'Comida y entrega' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main>
    <section class="border-b border-gray-200 bg-white">
      <div class="container-page grid gap-8 py-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <div>
          <p class="section-kicker">Herramienta gratuita de planificación</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Crea un plan práctico de llegada a China antes de volar
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Obtén un primer plan para pagos, datos eSIM, transporte desde el aeropuerto, configuración de apps,
            efectivo de respaldo y ritmo diario. Funciona en tu navegador y no guarda tus respuestas.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#planner" class="btn-primary">Empezar planificación</a>
            <a href="/es/travel-help/" class="btn-outline">Pedir ayuda de viaje</a>
            <a href="/es/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">Leer guía para primera visita</a>
          </div>
        </div>

        <aside class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="section-kicker">Ideal para</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Preparación para primera visita</h2>
          <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
            <li>Pagos listos antes de llegar</li>
            <li>Decisiones de eSIM, roaming y acceso a apps</li>
            <li>Primer paso del aeropuerto a la ciudad</li>
            <li>Marco simple por ciudad</li>
          </ul>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <AdSlot format="banner" />

      <section id="planner" class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <form id="trip-planner-form" class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm md:p-6">
          <div class="border-b border-gray-200 pb-5">
            <p class="section-kicker">Detalles del viaje</p>
            <h2 class="mt-2 text-2xl font-bold text-gray-950">Cuéntanos lo que sabes</h2>
          </div>

          <div class="mt-6 grid gap-5 md:grid-cols-2">
            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              País o región de origen
              <input id="home-country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="United States, UK, Singapore..." />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Ciudad de llegada
              <select id="arrival-city" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Shanghai</option>
                <option>Beijing</option>
                <option>Guangzhou</option>
                <option>Shenzhen</option>
                <option>Chengdu</option>
                <option>Hangzhou</option>
                <option>Otra ciudad</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800 md:col-span-2">
              Ciudades de destino
              <input id="destination-cities" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="Shanghai, Hangzhou, Beijing" />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Duración del viaje
              <select id="trip-length" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option value="3">3 días</option>
                <option value="5">5 días</option>
                <option value="7" selected>7 días</option>
                <option value="10">10 días</option>
                <option value="14">14 días</option>
                <option value="21">21 días o más</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Motivo del viaje
              <select id="trip-purpose" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Turismo</option>
                <option>Negocios</option>
                <option>Estancia larga</option>
                <option>Nómada digital</option>
                <option>Visita familiar</option>
                <option>Tránsito</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Rango de presupuesto
              <select id="budget-range" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Económico</option>
                <option selected>Cómodo</option>
                <option>Premium</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Estilo de viaje
              <select id="travel-style" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Eficiente</option>
                <option>Económico</option>
                <option selected>Cómodo</option>
                <option>Familia</option>
                <option>Negocios</option>
                <option>Centrado en comida</option>
              </select>
            </label>
          </div>

          <fieldset class="mt-6">
            <legend class="text-sm font-semibold text-gray-800">¿Con qué necesitas ayuda?</legend>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              {needOptions.map((option) => (
                <label class="flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-700">
                  <input class="h-4 w-4 rounded border-gray-300 text-brand-600" type="checkbox" name="needs" value={option.value} checked={['payment', 'esim', 'transport', 'apps'].includes(option.value)} />
                  {option.label}
                </label>
              ))}
            </div>
          </fieldset>

          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p id="planner-status" class="text-sm text-gray-500">No necesitas cuenta ni datos sensibles.</p>
            <button class="btn-primary" type="submit">Generar plan</button>
          </div>
        </form>

        <aside class="space-y-6">
          <section class="rounded-lg border border-gray-200 bg-white p-5">
            <p class="section-kicker">Vía de mejora</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">¿Necesitas revisión humana?</h2>
            <p class="mt-3 text-sm leading-6 text-gray-600">
              Si tu ruta, tiempos, pagos o primer día parecen arriesgados, envía el plan generado
              por email y pide una lista de correcciones revisada por una persona.
            </p>
            <a id="planner-email-link" class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:border-brand-600 hover:text-brand-600 hover:no-underline" href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Trip%20Review%20Request">
              Preparar email de revisión
            </a>
          </section>

          <section class="rounded-lg border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Límites</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Úsalo como ayuda de planificación</h2>
            <p class="mt-3 text-sm leading-6 text-gray-700">
              Esta herramienta no es asesoramiento legal, migratorio, médico, bancario ni de emergencia. Verifica
              normas importantes de entrada, aerolínea, hotel, tarjeta, telecomunicaciones y apps con fuentes oficiales.
            </p>
          </section>
        </aside>
      </section>

      <section id="plan-output" class="mt-10 hidden rounded-lg border border-brand-100 bg-brand-50 p-5 md:p-6" aria-live="polite">
        <div class="border-b border-brand-100 pb-4">
          <p class="section-kicker">Plan generado</p>
          <h2 class="mt-2 text-2xl font-bold text-gray-950">Borrador de preparación para tu viaje a China</h2>
        </div>
        <div id="plan-content" class="mt-5 grid gap-5"></div>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <a href="/es/payment/" class="card block hover:no-underline">
          <p class="section-kicker">Pagos</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Prepara Alipay y WeChat Pay</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Configura al menos una billetera y un método de pago de respaldo antes de llegar.</p>
        </a>
        <a href="/es/esim/" class="card block hover:no-underline">
          <p class="section-kicker">Internet</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Elige eSIM o roaming</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Asegúrate de poder cargar mapas, traducir, enviar mensajes y pedir transporte el primer día.</p>
        </a>
        <a href="/es/transport/" class="card block hover:no-underline">
          <p class="section-kicker">Transporte</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Planifica tu primera ruta</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Conoce tu ruta del aeropuerto al hotel y cuándo usar metro, taxi, DiDi o tren.</p>
        </a>
      </section>

      <section class="mt-10 rounded-lg border border-gray-200 bg-white p-5 md:p-6">
        <p class="section-kicker">Antes de usar el planificador</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950">Lee las guías de preparación si es tu primer viaje a China</h2>
        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <a href="/es/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Planificador de viaje a China para primera visita</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Usa el mismo orden que esta herramienta: internet, pagos, ruta desde el aeropuerto, apps, orden de ciudades y lista del primer día.</p>
          </a>
          <a href="/es/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Qué configurar antes de viajar a China</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Lista práctica previa a la salida para Alipay, WeChat Pay, eSIM, DiDi, billetes de tren, mapas y efectivo.</p>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('trip-planner-form') as HTMLFormElement | null;
  const output = document.getElementById('plan-output');
  const content = document.getElementById('plan-content');
  const status = document.getElementById('planner-status');
  const emailLink = document.getElementById('planner-email-link') as HTMLAnchorElement | null;

  const getValue = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null)?.value.trim() || '';
  const selectedNeeds = () =>
    Array.from(document.querySelectorAll<HTMLInputElement>('input[name="needs"]:checked')).map((input) => input.value);
  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char] ?? char);

  const splitCities = (value: string, arrival: string) => {
    const typed = value
      .split(',')
      .map((city) => city.trim())
      .filter(Boolean);
    const cities = typed.length ? typed : [arrival];
    return Array.from(new Set(cities));
  };

  const list = (items: string[]) => `<ul class="mt-3 grid gap-2 text-sm leading-6 text-gray-700">${items.map((item) => `<li>${item}</li>`).join('')}</ul>`;
  const panel = (title: string, items: string[]) => `
    <section class="rounded-lg border border-gray-200 bg-white p-5">
      <h3 class="text-lg font-bold text-gray-950">${title}</h3>
      ${list(items)}
    </section>
  `;

  const buildPlan = () => {
    const home = getValue('home-country') || 'tu país de origen';
    const arrival = getValue('arrival-city') || 'Shanghai';
    const cities = splitCities(getValue('destination-cities'), arrival);
    const days = Number(getValue('trip-length') || '7');
    const purpose = getValue('trip-purpose') || 'Turismo';
    const budget = getValue('budget-range') || 'Cómodo';
    const style = getValue('travel-style') || 'Cómodo';
    const needs = selectedNeeds();
    const perCity = Math.max(1, Math.floor(days / Math.max(1, cities.length)));

    const preDeparture = [
      `Install Alipay, WeChat, DiDi, a translation app, and an offline map before leaving ${escapeHtml(home)}.`,
      needs.includes('payment')
        ? 'Vincula una Visa o Mastercard extranjera a Alipay y prueba una verificación pequeña antes de salir.'
        : 'Mantén los pagos simples: una billetera móvil, una tarjeta física y algo de efectivo en RMB.',
      needs.includes('esim')
        ? 'Compra y activa una eSIM o plan de roaming antes del vuelo, y guarda el código QR offline.'
        : 'Confirma que tu teléfono tendrá datos al llegar antes de depender de mapas o transporte.',
      'Guarda la dirección de tu hotel en inglés y chino, además de la estación de metro más cercana.',
    ];

    const payment = [
      'Configuración principal: Alipay con tarjeta extranjera, porque suele ser la primera billetera más práctica para visitantes.',
      'Respaldo: WeChat Pay si tu tarjeta se vincula correctamente, más una Visa o Mastercard física.',
      budget === 'Económico'
        ? 'Efectivo de respaldo: carry a small amount of RMB for stalls, deposits, or card/wallet issues.'
        : 'Efectivo de respaldo: keep enough RMB for taxi, snacks, and one simple meal in case mobile payment fails.',
      'No dependas de Apple Pay o Google Pay como método principal en China continental.',
    ];

    const internet = [
      'Para viajes cortos, una eSIM de viaje suele ser lo más fácil si tu teléfono la admite.',
      'Para estancias largas o mucho uso de datos, compara roaming, eSIM, pocket WiFi y SIM local antes de llegar.',
      'Prueba los datos móviles antes de salir del aeropuerto, porque pagos, transporte, traducción y mapas dependen de ellos.',
      'Guarda información de hotel y transporte offline por si la primera conexión es inestable.',
    ];

    const transport = [
      `First route: plan ${escapeHtml(arrival)} airport or station to hotel before landing.`,
      'Usa metro para rutas urbanas predecibles, DiDi para puerta a puerta y tren de alta velocidad entre ciudades.',
      needs.includes('transport')
        ? 'Para días de tren, reserva con antelación cuando sea posible y mantén los datos del pasaporte iguales en la plataforma.'
        : 'Evita conexiones ajustadas el mismo día entre vuelos internacionales y trenes de larga distancia.',
      'Ten preparada una tarjeta de dirección en chino para taxis o recepciones de hotel.',
    ];

    const dayPlan = cities.map((city, index) => {
      const start = index * perCity + 1;
      const end = index === cities.length - 1 ? days : Math.min(days, start + perCity - 1);
      return `Days ${start}-${end}: ${escapeHtml(city)} - mantén ligera la primera media jornada, confirma pagos/datos y agrupa visitas por distrito.`;
    });

    const mistakes = [
      'No esperes a llegar para configurar todas las apps, tarjetas y datos.',
      'No programes un día de visitas intenso justo después de un vuelo largo.',
      'No dependas de un solo método de pago.',
      purpose === 'Negocios'
        ? 'Para viajes de negocios, deja tiempo extra para tráfico, controles de seguridad, facturas y acceso a edificios.'
        : 'Para ocio, deja un bloque flexible cada dos o tres días por clima, multitudes o cansancio.',
      style === 'Centrado en comida'
        ? 'Para viajes centrados en comida, guarda nombres de restaurantes en chino y confirma horarios antes de cruzar la ciudad.'
        : 'Ten un plan simple de comidas cerca del hotel.',
    ];

    const html = [
      panel('Lista previa a la salida', preDeparture),
      panel('Configuración de pagos y efectivo', payment),
      panel('Configuración de internet y apps', internet),
      panel('Transporte y primer día', transport),
      panel('Marco simple día a día', dayPlan),
      panel('Avisos de errores comunes', mistakes),
    ].join('');

    const emailBody = [
      'Solicitud de revisión de viaje ChinaTripBox',
      '',
      `País o región de origen: ${home}`,
      `Ciudad de llegada: ${arrival}`,
      `Ciudades de destino: ${cities.join(', ')}`,
      `Duración del viaje: ${days} days`,
      `Motivo: ${purpose}`,
      `Económico: ${budget}`,
      `Estilo: ${style}`,
      `Necesidades: ${needs.join(', ') || 'no especificado'}`,
      '',
      'Por favor revisa mi preparación de viaje a China para pagos, eSIM, transporte, tiempos y errores del primer día.',
    ].join('\n');

    if (emailLink) {
      emailLink.href = `mailto:zh13809022788@gmail.com?subject=${encodeURIComponent(
        'Solicitud de revisión de viaje ChinaTripBox',
      )}&body=${encodeURIComponent(emailBody)}`;
    }

    return html;
  };

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!content || !output) return;
    content.innerHTML = buildPlan();
    output.classList.remove('hidden');
    output.scrollIntoView({ behavior: 'smooth', block: 'start' });
    if (status) status.textContent = 'Plan generado. Ajusta tus respuestas y vuelve a generarlo cuando quieras.';
  });
</script>
