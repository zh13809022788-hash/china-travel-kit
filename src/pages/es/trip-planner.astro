---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';

const title = 'Planificador de Viaje Gratis a China';
const description =
  'Crea un plan practico para tu primer viaje a China con recomendaciones sobre pagos, eSIM, transporte, configuracion de apps, efectivo y lista de verificacion del primer dia.';

const needOptions = [
  { value: 'payment', label: 'Configuracion de pagos' },
  { value: 'esim', label: 'eSIM e internet' },
  { value: 'transport', label: 'Aeropuerto y trenes' },
  { value: 'hotel', label: 'Logica de la zona del hotel' },
  { value: 'apps', label: 'Apps y traduccion' },
  { value: 'cash', label: 'Respaldo en efectivo' },
  { value: 'visa', label: 'Entrada sin visa' },
  { value: 'food', label: 'Comida y delivery' },
];
---
<!-- Contenido generado con asistencia de IA, revisado por redactor nativo -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main>
    <section class="border-b border-gray-200 bg-white">
      <div class="container-page grid gap-8 py-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <div>
          <p class="section-kicker">Herramienta de planificacion gratuita</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Crea un plan practico de llegada a China antes de volar
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Obtiene un plan inicial para pagos, datos eSIM, transporte desde el aeropuerto, configuracion de apps,
            respaldo en efectivo y ritmo diario. Funciona en tu navegador y no guarda tus respuestas.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#planner" class="btn-primary">Empezar a planificar</a>
            <a href="/travel-help/" class="btn-outline">Pedir ayuda de viaje</a>
            <a href="/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">Leer la guia para principiantes</a>
          </div>
        </div>

        <aside class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="section-kicker">Ideal para</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Configuracion para quienes visitan por primera vez</h2>
          <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
            <li>Preparacion de pagos antes de llegar</li>
            <li>Decisiones sobre eSIM, roaming y acceso a apps</li>
            <li>Planificacion del primer trayecto del aeropuerto a la ciudad</li>
            <li>Marco simple de viaje ciudad por ciudad</li>
          </ul>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <AdSlot format="banner" />

      <section id="planner" class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <form id="trip-planner-form" class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm md:p-6">
          <div class="border-b border-gray-200 pb-5">
            <p class="section-kicker">Detalles del viaje</p>
            <h2 class="mt-2 text-2xl font-bold text-gray-950">Dinos lo que sabes</h2>
          </div>

          <div class="mt-6 grid gap-5 md:grid-cols-2">
            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Pais o region de origen
              <input id="home-country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="Estados Unidos, Reino Unido, Singapur..." />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Ciudad de llegada
              <select id="arrival-city" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Shanghai</option>
                <option>Beijing</option>
                <option>Guangzhou</option>
                <option>Shenzhen</option>
                <option>Chengdu</option>
                <option>Hangzhou</option>
                <option>Otra ciudad</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800 md:col-span-2">
              Ciudades de destino
              <input id="destination-cities" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="Shanghai, Hangzhou, Beijing" />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Duracion del viaje
              <select id="trip-length" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option value="3">3 dias</option>
                <option value="5">5 dias</option>
                <option value="7" selected>7 dias</option>
                <option value="10">10 dias</option>
                <option value="14">14 dias</option>
                <option value="21">21 dias o mas</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Motivo del viaje
              <select id="trip-purpose" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Turismo</option>
                <option>Negocios</option>
                <option>Estancia larga</option>
                <option>Nomada digital</option>
                <option>Visita familiar</option>
                <option>Transito</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Rango de presupuesto
              <select id="budget-range" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Economico</option>
                <option selected>Comodo</option>
                <option>Premium</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Estilo de viaje
              <select id="travel-style" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Eficiente</option>
                <option>Economico</option>
                <option selected>Comodo</option>
                <option>Familiar</option>
                <option>Negocios</option>
                <option>Centrado en la comida</option>
              </select>
            </label>
          </div>

          <fieldset class="mt-6">
            <legend class="text-sm font-semibold text-gray-800">¿Con que necesitas ayuda?</legend>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              {needOptions.map((option) => (
                <label class="flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-700">
                  <input class="h-4 w-4 rounded border-gray-300 text-brand-600" type="checkbox" name="needs" value={option.value} checked={['payment', 'esim', 'transport', 'apps'].includes(option.value)} />
                  {option.label}
                </label>
              ))}
            </div>
          </fieldset>

          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p id="planner-status" class="text-sm text-gray-500">No se necesita cuenta ni datos sensibles.</p>
            <button class="btn-primary" type="submit">Generar plan</button>
          </div>
        </form>

        <aside class="space-y-6">
          <section class="rounded-lg border border-gray-200 bg-white p-5">
            <p class="section-kicker">Ruta de mejora</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">¿Necesitas una revision humana?</h2>
            <p class="mt-3 text-sm leading-6 text-gray-600">
              Si tu ruta, tiempos, configuracion de pago o primer dia te parecen arriesgados, envia el plan generado
              por correo electronico y pide una lista de correcciones revisada por una persona.
            </p>
            <a id="planner-email-link" class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:border-brand-600 hover:text-brand-600 hover:no-underline" href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Trip%20Review%20Request">
              Preparar correo para revision
            </a>
          </section>

          <section class="rounded-lg border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Limites</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Usa esto como ayuda de planificacion</h2>
            <p class="mt-3 text-sm leading-6 text-gray-700">
              Esta herramienta no constituye asesoramiento legal, migratorio, medico, bancario ni de emergencia. Verifica
              las reglas importantes de entrada, aerolinea, hotel, tarjeta, telecomunicaciones y apps con fuentes oficiales.
            </p>
          </section>
        </aside>
      </section>

      <section id="plan-output" class="mt-10 hidden rounded-lg border border-brand-100 bg-brand-50 p-5 md:p-6" aria-live="polite">
        <div class="border-b border-brand-100 pb-4">
          <p class="section-kicker">Plan generado</p>
          <h2 class="mt-2 text-2xl font-bold text-gray-950">Borrador de configuracion de tu viaje a China</h2>
        </div>
        <div id="plan-content" class="mt-5 grid gap-5"></div>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <a href="/payment/" class="card block hover:no-underline">
          <p class="section-kicker">Pagos</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Prepara Alipay y WeChat Pay</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Configura al menos una billetera y un metodo de pago de respaldo antes de llegar.</p>
        </a>
        <a href="/esim/" class="card block hover:no-underline">
          <p class="section-kicker">Internet</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Elige una configuracion de eSIM o roaming</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Asegurate de poder cargar mapas, traducir, enviar mensajes y pedir un viaje el primer dia.</p>
        </a>
        <a href="/transport/" class="card block hover:no-underline">
          <p class="section-kicker">Transporte</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Planifica tu primera ruta</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Conoce tu ruta del aeropuerto al hotel y cuando usar metro, taxi, DiDi o tren.</p>
        </a>
      </section>

      <section class="mt-10 rounded-lg border border-gray-200 bg-white p-5 md:p-6">
        <p class="section-kicker">Antes de usar el planificador</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950">Lee las guias de configuracion si este es tu primer viaje a China</h2>
        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <a href="/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Planificador de viaje a China para quienes viajan por primera vez</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Usa el mismo orden de planificacion que esta herramienta: internet, pagos, ruta desde el aeropuerto, apps, orden de ciudades y lista de verificacion del primer dia.</p>
          </a>
          <a href="/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Que configurar antes de viajar a China</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Una lista practica de verificacion previa a la salida para Alipay, WeChat Pay, eSIM, DiDi, boletos de tren, mapas y respaldo en efectivo.</p>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('trip-planner-form') as HTMLFormElement | null;
  const output = document.getElementById('plan-output');
  const content = document.getElementById('plan-content');
  const status = document.getElementById('planner-status');
  const emailLink = document.getElementById('planner-email-link') as HTMLAnchorElement | null;

  const getValue = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null)?.value.trim() || '';
  const selectedNeeds = () =>
    Array.from(document.querySelectorAll<HTMLInputElement>('input[name="needs"]:checked')).map((input) => input.value);
  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char] ?? char);

  const splitCities = (value: string, arrival: string) => {
    const typed = value
      .split(',')
      .map((city) => city.trim())
      .filter(Boolean);
    const cities = typed.length ? typed : [arrival];
    return Array.from(new Set(cities));
  };

  const list = (items: string[]) => `<ul class="mt-3 grid gap-2 text-sm leading-6 text-gray-700">${items.map((item) => `<li>${item}</li>`).join('')}</ul>`;
  const panel = (title: string, items: string[]) => `
    <section class="rounded-lg border border-gray-200 bg-white p-5">
      <h3 class="text-lg font-bold text-gray-950">${title}</h3>
      ${list(items)}
    </section>
  `;

  const buildPlan = () => {
    const home = getValue('home-country') || 'tu pais de origen';
    const arrival = getValue('arrival-city') || 'Shanghai';
    const cities = splitCities(getValue('destination-cities'), arrival);
    const days = Number(getValue('trip-length') || '7');
    const purpose = getValue('trip-purpose') || 'Turismo';
    const budget = getValue('budget-range') || 'Comodo';
    const style = getValue('travel-style') || 'Comodo';
    const needs = selectedNeeds();
    const perCity = Math.max(1, Math.floor(days / Math.max(1, cities.length)));

    const preDeparture = [
      `Instala Alipay, WeChat, DiDi, una app de traduccion y un mapa sin conexion antes de salir de ${escapeHtml(home)}.`,
      needs.includes('payment')
        ? 'Vincula una tarjeta extranjera Visa o Mastercard a Alipay y prueba una pequena verificacion antes de la salida.'
        : 'Mantén la configuracion de pagos simple: una billetera movil, una tarjeta fisica y algo de efectivo en RMB.',
      needs.includes('esim')
        ? 'Compra y activa una eSIM o plan de roaming antes del vuelo, y luego mantén el codigo QR disponible sin conexion.'
        : 'Confirma que tu telefono tendra datos al llegar antes de depender de mapas o apps para pedir transporte.',
      'Guarda la direccion de tu hotel en ingles y en chino, ademas de la estacion de metro mas cercana.',
    ];

    const payment = [
      'Configuracion principal: Alipay con una tarjeta extranjera, porque suele ser la billetera inicial mas practica para los visitantes.',
      'Configuracion de respaldo: WeChat Pay si tu tarjeta se vincula correctamente, ademas de una tarjeta fisica Visa o Mastercard.',
      budget === 'Budget'
        ? 'Respaldo en efectivo: lleva una pequena cantidad de RMB para puestos, depositos o problemas con la tarjeta o la billetera.'
        : 'Respaldo en efectivo: guarda suficiente RMB para taxi, snacks y una comida sencilla en caso de que falle el pago movil.',
      'No dependas de Apple Pay o Google Pay como tu metodo de pago principal en China continental.',
    ];

    const internet = [
      'Para viajes cortos, una eSIM de viaje suele ser la configuracion mas facil si tu telefono admite eSIM.',
      'Para estancias mas largas o uso intensivo de datos, compara roaming, eSIM, pocket WiFi y opciones de SIM local antes de llegar.',
      'Prueba los datos moviles antes de salir del aeropuerto, porque las apps de pago, las de transporte, la traduccion y los mapas dependen de ellos.',
      'Guarda la informacion del hotel y del transporte sin conexion por si tu primera conexion es inestable.',
    ];

    const transport = [
      `Primera ruta: planifica el trayecto desde el aeropuerto o la estacion de ${escapeHtml(arrival)} hasta el hotel antes de aterrizar.`,
      'Usa el metro para rutas urbanas predecibles, DiDi para trayectos puerta a puerta y el tren de alta velocidad para viajar entre ciudades.',
      needs.includes('transport')
        ? 'Para los dias de tren, reserva con antelacion cuando sea posible y mantén los datos del pasaporte consistentes con la plataforma de boletos.'
        : 'Evita conexiones ajustadas el mismo dia entre vuelos internacionales y trenes de larga distancia.',
      'Ten lista una tarjeta con la direccion en chino para taxis o recepciones de hotel.',
    ];

    const dayPlan = cities.map((city, index) => {
      const start = index * perCity + 1;
      const end = index === cities.length - 1 ? days : Math.min(days, start + perCity - 1);
      return `Dias ${start}-${end}: ${escapeHtml(city)} - mantén la primera mitad del dia mas ligera, confirma pago/datos y luego agrupa los lugares por distrito.`;
    });

    const mistakes = [
      'No esperes hasta llegar para configurar todas las apps, tarjetas y planes de datos.',
      'No programes un dia de turismo cargado inmediatamente despues de un vuelo de larga distancia.',
      'No dependas de un solo metodo de pago.',
      purpose === 'Business'
        ? 'Para viajes de negocios, deja tiempo extra para trafico, controles de seguridad, facturas y acceso a edificios.'
        : 'Para viajes de ocio, deja un bloque flexible cada dos o tres dias por clima, multitudes o cansancio.',
      style === 'Food-focused'
        ? 'Para viajes centrados en la comida, guarda los nombres de los restaurantes en chino y confirma los horarios antes de cruzar la ciudad.'
        : 'Mantén un plan de respaldo simple para comidas cerca de tu hotel.',
    ];

    const html = [
      panel('Lista de verificacion previa a la salida', preDeparture),
      panel('Configuracion de pagos y efectivo', payment),
      panel('Configuracion de internet y apps', internet),
      panel('Transporte y primer dia', transport),
      panel('Marco simple dia por dia', dayPlan),
      panel('Advertencias sobre errores comunes', mistakes),
    ].join('');

    const emailBody = [
      'ChinaTripBox Trip Review Request',
      '',
      `Home country or region: ${home}`,
      `Arrival city: ${arrival}`,
      `Destination cities: ${cities.join(', ')}`,
      `Trip length: ${days} days`,
      `Purpose: ${purpose}`,
      `Budget: ${budget}`,
      `Style: ${style}`,
      `Needs: ${needs.join(', ') || 'not specified'}`,
      '',
      'Please review my China trip setup for payment, eSIM, transport, timing, and first-day mistakes.',
    ].join('\n');

    if (emailLink) {
      emailLink.href = `mailto:zh13809022788@gmail.com?subject=${encodeURIComponent(
        'ChinaTripBox Trip Review Request',
      )}&body=${encodeURIComponent(emailBody)}`;
    }

    return html;
  };

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!content || !output) return;
    content.innerHTML = buildPlan();
    output.classList.remove('hidden');
    output.scrollIntoView({ behavior: 'smooth', block: 'start' });
    if (status) status.textContent = 'Plan generado. Ajusta tus respuestas y vuelve a generarlo cuando quieras.';
  });
</script>