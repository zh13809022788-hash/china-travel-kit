---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CoverImage from '../../components/CoverImage.astro';
import AdSlot from '../../components/AdSlot.astro';

const title = 'Apps esenciales de China para viajeros extranjeros: enlaces de descarga y alternativas web';
const description = 'Un directorio completo de las apps que necesitas en China: WeChat, Alipay, DiDi, Baidu Maps, Meituan, 12306, VPN y más. Cada app incluye enlaces de descarga de App Store / Google Play y versiones web H5 que funcionan sin instalar nada.';

const appGroups = [
  {
    category: 'Pagos y billetera',
    apps: [
      {
        name: 'Alipay',
        desc: 'La billetera móvil con mayor aceptación en China. Vincula una Visa o Mastercard extranjera y paga con código QR en tiendas, restaurantes, taxis y puestos callejeros.',
        android: 'https://play.google.com/store/apps/details?id=com.eg.android.AlipayGphone',
        ios: 'https://apps.apple.com/app/alipay/id333206289',
        h5: null,
        note: 'La configuración toma entre 10 y 15 min. Necesitas pasaporte para la verificación.',
        guide: '/posts/alipay-foreign-credit-card-step-by-step/',
      },
      {
        name: 'WeChat',
        desc: 'La super app de China. Úsala para mensajería, llamadas, Moments (feed social) y WeChat Pay. La mayoría de los chinos la usa a diario para todo.',
        android: 'https://play.google.com/store/apps/details?id=com.tencent.mm',
        ios: 'https://apps.apple.com/app/wechat/id414478124',
        h5: 'https://web.wechat.com/',
        note: 'WeChat Pay necesita una tarjeta vinculada. WeChat en sí funciona para mensajería sin configuración.',
        guide: '/posts/link-a-foreign-visa-or-mastercard-to-wechat-pay-in-china/',
      },
    ],
  },
  {
    category: 'Transporte y viajes compartidos',
    apps: [
      {
        name: 'DiDi',
        desc: 'El Uber de China. Reserva taxis y autos privados. Compatible con interfaz en inglés. Puedes pagar con Alipay o WeChat Pay.',
        android: 'https://play.google.com/store/apps/details?id=com.didi.sdk',
        ios: 'https://apps.apple.com/app/didi/id1164272094',
        h5: 'https://www.didiglobal.com/',
        note: 'La versión H5 funciona en el navegador o en el mini-programa de WeChat. No necesitas app para viajes ocasionales.',
        guide: '/posts/didi-china-foreign-tourists-guide/',
      },
      {
        name: 'Mini-Programa de Transporte de Alipay',
        desc: 'Dentro de Alipay, usa el mini-programa de transporte para escanear códigos QR del metro y de autobuses urbanos en la mayoría de las grandes ciudades.',
        android: null,
        ios: null,
        h5: null,
        note: 'Abre Alipay → icono "Transport". No necesitas instalar nada por separado.',
        guide: '/transport/',
      },
      {
        name: '12306',
        desc: 'App oficial de China Railway para reservar billetes de tren. Interfaz solo en chino y requiere verificación. Alternativa: usa Trip.com.',
        android: 'https://play.google.com/store/apps/details?id=com.cars.blaili',
        ios: 'https://apps.apple.com/app/12306/id564757494',
        h5: 'https://www.12306.cn/',
        note: 'Complicada para extranjeros. Usa Trip.com (en inglés, sin las molestias de la verificación).',
        guide: '/posts/book-china-train-tickets-12306-foreigners/',
      },
      {
        name: 'Trip.com (Ctrip)',
        desc: 'App en inglés para reservar trenes, vuelos y hoteles. Acepta tarjetas extranjeras directamente.',
        android: 'https://play.google.com/store/apps/details?id=com.ctrip',
        ios: 'https://apps.apple.com/app/trip-com/id1612956441',
        h5: 'https://www.trip.com/',
        note: 'La mejor alternativa a 12306 para billetes de tren. Tiene una comisión de servicio más alta, pero es mucho más fácil.',
        guide: null,
      },
    ],
  },
  {
    category: 'Navegación y mapas',
    apps: [
      {
        name: 'Baidu Maps',
        desc: 'El mapa más detallado de China. Navegación giro a giro, rutas en transporte público y búsqueda de restaurantes. Solo en chino, pero utilizable con gestos.',
        android: 'https://play.google.com/store/apps/details?id=com.baidu.BaiduMap',
        ios: 'https://apps.apple.com/app/baidu-maps/id452186370',
        h5: 'https://map.baidu.com/',
        note: 'Google Maps está bloqueado en China. Necesitas Baidu o Amap para navegar.',
        guide: null,
      },
      {
        name: 'Amap (Gaode)',
        desc: 'Alternativa a Baidu Maps. Muchos locales prefieren Amap. Es mejor para navegación en taxi, tráfico en vivo y reseñas de restaurantes.',
        android: 'https://play.google.com/store/apps/details?id=com.autonavi.minimap',
        ios: 'https://apps.apple.com/app/amap/id461703208',
        h5: 'https://ditu.amap.com/',
        note: 'Tanto Baidu como Amap funcionan. Elige uno. Amap suele ser más preciso para pedir taxi.',
        guide: null,
      },
      {
        name: 'Google Maps',
        desc: 'Funciona de forma parcial en China para explorar, pero la navegación y el tráfico en tiempo real no son fiables. Es bueno para planificar antes del viaje.',
        android: null,
        ios: null,
        h5: 'https://maps.google.com/',
        note: 'No funcionará para navegación giro a giro en China sin VPN.',
        guide: '/posts/do-you-need-a-vpn-in-china-2026/',
      },
    ],
  },
  {
    category: 'Comida y restaurantes',
    apps: [
      {
        name: 'Meituan',
        desc: 'Entrega de comida, reservas en restaurantes, entradas de cine y reservas de hotel. Solo en chino. Úsala dentro del mini-programa de Alipay para obtener ayuda en inglés.',
        android: 'https://play.google.com/store/apps/details?id=com.sankuai.meituan',
        ios: 'https://apps.apple.com/app/meituan/id423924287',
        h5: 'https://waimai.meituan.com/',
        note: 'La entrega de comida por H5 funciona en el navegador. Paga con Alipay al recibir.',
        guide: '/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
      },
      {
        name: 'Ele.me',
        desc: 'App de entrega de comida (propiedad de Alibaba). Similar a Meituan. Puedes pedir comida con Alipay.',
        android: 'https://play.google.com/store/apps/details?id=me.ele',
        ios: 'https://apps.apple.com/app/ele-me/id532785356',
        h5: 'https://www.ele.me/',
        note: 'Tanto Meituan como Ele.me funcionan. Prueba ambas para tener mejor cobertura de restaurantes.',
        guide: '/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
      },
      {
        name: 'Dianping',
        desc: 'El Yelp de China. Reseñas de restaurantes, valoraciones y fotos. Ayuda a encontrar buenos sitios locales para comer. Solo en chino.',
        android: 'https://play.google.com/store/apps/details?id=com.dianping.v1',
        ios: 'https://apps.apple.com/app/dianping/id416896465',
        h5: 'https://www.dianping.com/',
        note: 'Usa la función de búsqueda por fotos: mira cómo son los platos antes de pedir.',
        guide: '/food/',
      },
    ],
  },
  {
    category: 'Comunicación y VPN',
    apps: [
      {
        name: 'VPN (elige una antes de viajar)',
        desc: 'Instala una VPN ANTES de salir. ExpressVPN, NordVPN y Astrill funcionan en China. Las VPN gratis están bloqueadas en su mayoría.',
        android: null,
        ios: null,
        h5: null,
        note: 'ESENCIAL: instálala y pruébala antes de llegar. Actívala cuando aterrices.',
        guide: '/posts/do-you-need-a-vpn-in-china-2026/',
      },
      {
        name: 'Google Translate',
        desc: 'Traducción con cámara para menús, carteles y documentos. Descarga el paquete sin conexión de chino (simplificado).',
        android: 'https://play.google.com/store/apps/details?id=com.google.android.apps.translate',
        ios: 'https://apps.apple.com/app/google-translate/id414706506',
        h5: 'https://translate.google.com/',
        note: 'La mejor herramienta de traducción. Descarga el paquete sin conexión antes del viaje.',
        guide: '/tools/survival-kit/',
      },
    ],
  },
  {
    category: 'Reservas de viaje',
    apps: [
      {
        name: 'Trip.com (Hoteles)',
        desc: 'La mejor opción para reservar hoteles con tarjetas extranjeras. Amplia cobertura. Interfaz en inglés.',
        android: null,
        ios: null,
        h5: 'https://www.trip.com/hotels/',
        note: 'También sirve para vuelos y trenes. Una solución integral.',
        guide: null,
      },
      {
        name: 'Fliggy (Alitrip)',
        desc: 'La plataforma de reservas de viajes de Alibaba. Dentro de la app de Alipay. Buena para vuelos nacionales.',
        android: null,
        ios: null,
        h5: 'https://www.fliggy.com/',
        note: 'Puedes pagar con Alipay. No necesitas descargar nada por separado.',
        guide: null,
      },
    ],
  },
];
---
<!-- Contenido generado con asistencia de IA, revisado por redactor nativo -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Apps móviles</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">Apps esenciales de China</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-internet-apps" alt="Smartphone con iconos de apps esenciales para viajar por China" loading="eager" />

    <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-5 text-sm leading-6 text-amber-900">
      <strong>Antes de irte:</strong> Instala estas apps con WiFi antes de salir. Algunas tiendas de apps son lentas o están bloqueadas dentro de China. Descarga en casa los paquetes de traducción sin conexión y las apps de VPN.
    </div>

    <AdSlot format="banner" />

    {appGroups.map((group) => (
      <section class="mt-12" aria-labelledby={group.category.replace(/\s+/g, '-').toLowerCase()}>
        <h2 id={group.category.replace(/\s+/g, '-').toLowerCase()} class="text-2xl font-bold text-gray-950">{group.category}</h2>
        <div class="mt-5 grid gap-5 md:grid-cols-2">
          {group.apps.map((app) => (
            <article class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
              <h3 class="text-lg font-bold text-gray-950">{app.name}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{app.desc}</p>

              <div class="mt-4 flex flex-wrap gap-2">
                {app.ios && (
                  <a href={app.ios} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md bg-gray-900 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-gray-700">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
                    App Store
                  </a>
                )}
                {app.android && (
                  <a href={app.android} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md bg-green-700 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-green-600">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M18.33 8.7c-.55-.96-1.1-1.91-1.66-2.86l.32-.32c.18-.18.36-.36.54-.54.77-.77.77-1.53 0-2.3-.74-.74-1.52-.74-2.26 0-.36.36-.72.72-1.08 1.08l-.1.1A7.83 7.83 0 0 0 12 3.5c-1.1 0-2.15.2-3.12.61l-.1-.1c-.36-.36-.72-.72-1.08-1.08-.74-.74-1.52-.74-2.26 0-.77.77-.77 1.53 0 2.3.18.18.36.36.54.54l.32.32C5.2 6.8 4.64 7.75 4.08 8.7c-.55.95-1.09 1.9-1.64 2.86h15.53c-.55-.96-1.1-1.91-1.64-2.86M7.75 5.75c-.4 0-.72-.33-.72-.72s.32-.72.72-.72c.4 0 .72.33.72.72s-.32.72-.72.72m8.2 0c-.4 0-.72-.33-.72-.72s.32-.72.72-.72c.4 0 .72.33.72.72s-.32.72-.72.72M6.3 13.36v4.58c0 .66.53 1.2 1.2 1.2h.7c.66 0 1.2-.54 1.2-1.2v-4.58c0-.66-.54-1.2-1.2-1.2h-.7c-.67 0-1.2.54-1.2 1.2m8.72 0v4.58c0 .66.53 1.2 1.2 1.2h.7c.66 0 1.2-.54 1.2-1.2v-4.58c0-.66-.54-1.2-1.2-1.2h-.7c-.67 0-1.2.54-1.2 1.2"/></svg>
                    Google Play
                  </a>
                )}
                {app.h5 && (
                  <a href={app.h5} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-gray-700 transition-colors hover:bg-gray-50">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                    Abrir versión web
                  </a>
                )}
              </div>

              {app.note && (
                <p class="mt-3 text-xs leading-5 text-gray-500"><span class="font-semibold">Consejo:</span> {app.note}</p>
              )}
              {app.guide && (
                <a href={app.guide} class="mt-2 inline-block text-xs font-semibold text-brand-700 hover:text-brand-800">Leer guía de configuración &rarr;</a>
              )}
            </article>
          ))}
        </div>
      </section>
    ))}

    <section class="mt-12 rounded-lg border border-gray-200 p-6">
      <h2 class="text-xl font-bold text-gray-950">Apps web H5: no hace falta descargar nada</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        Muchos servicios de China tienen <strong>versiones web (H5)</strong> que funcionan directamente en el navegador de tu teléfono o dentro de los mini-programas de WeChat/Alipay. Son una gran opción para viajeros de corta estancia que no quieren llenar su teléfono con más de 10 apps. Las principales son:
      </p>
      <div class="mt-4 grid gap-3 text-sm sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">DiDi</strong> — <span class="text-gray-600">www.didiglobal.com (inglés disponible)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Baidu Maps</strong> — <span class="text-gray-600">map.baidu.com (solo en chino)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">WeChat Web</strong> — <span class="text-gray-600">web.wechat.com (solo mensajería)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Meituan</strong> — <span class="text-gray-600">waimai.meituan.com (entrega de comida)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Dianping</strong> — <span class="text-gray-600">dianping.com (búsqueda de restaurantes)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Mini-Programas de Alipay</strong> — <span class="text-gray-600">Todo dentro de Alipay (sin instalación adicional)</span></div>
      </div>
      <p class="mt-4 text-xs text-gray-500">
        <strong>Las versiones web funcionan sin VPN</strong> en la mayoría de los casos. Para descargar apps, instálalas antes de llegar usando el WiFi de casa.
      </p>
    </section>

    <section class="mt-10 text-center">
      <p class="text-sm text-gray-500">Los enlaces de las tiendas de apps abren páginas oficiales. Los precios y la disponibilidad están sujetos a restricciones regionales.</p>
    </section>
  </main>
  <Footer />
</BaseLayout>