---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CoverImage from '../../../components/CoverImage.astro';
import AdSlot from '../../../components/AdSlot.astro';

const title = 'Apps imprescindibles para China: enlaces y alternativas web';
const description = 'Directorio práctico de las apps que realmente necesitas en China: WeChat, Alipay, DiDi, Baidu Maps, Meituan, 12306, VPN y más. Cada una incluye enlaces oficiales de App Store / Google Play y, cuando existe, su versión web H5.';

const appGroups = [
  {
    category: 'Pagos y cartera digital',
    apps: [
      {
        name: 'Alipay',
        desc: 'La cartera móvil más extendida en China. Puedes vincular una Visa o Mastercard extranjera y pagar con QR en tiendas, restaurantes, taxis y puestos callejeros.',
        android: 'https://play.google.com/store/apps/details?id=com.eg.android.AlipayGphone',
        ios: 'https://apps.apple.com/app/alipay/id333206289',
        h5: null,
        note: 'La configuración suele llevar entre 10 y 15 minutos. Necesitarás el pasaporte para verificar la cuenta.',
        guide: '/es/posts/alipay-foreign-credit-card-step-by-step/',
      },
      {
        name: 'WeChat',
        desc: 'La superapp de China. Sirve para mensajería, llamadas, Moments y WeChat Pay. En la práctica, casi todo el mundo la usa a diario.',
        android: 'https://play.google.com/store/apps/details?id=com.tencent.mm',
        ios: 'https://apps.apple.com/app/wechat/id414478124',
        h5: 'https://web.wechat.com/',
        note: 'WeChat Pay requiere una tarjeta vinculada. Para chatear, la app funciona sin configuración adicional.',
        guide: '/es/posts/link-a-foreign-visa-or-mastercard-to-wechat-pay-in-china/',
      },
    ],
  },
  {
    category: 'Transporte y VTC',
    apps: [
      {
        name: 'DiDi',
        desc: 'El equivalente chino de Uber. Permite pedir taxis y coches privados, tiene interfaz en inglés y se paga con Alipay o WeChat Pay.',
        android: 'https://play.google.com/store/apps/details?id=com.didi.sdk',
        ios: 'https://apps.apple.com/app/didi/id1164272094',
        h5: 'https://m.didiglobal.com/',
        note: 'La versión H5 funciona en el navegador o como mini-programa de WeChat. Para trayectos puntuales no necesitas instalar la app.',
        guide: '/es/posts/didi-china-foreign-tourists-guide/',
      },
      {
        name: 'Mini-programa de transporte de Alipay',
        desc: 'Dentro de Alipay puedes activar el mini-programa de transporte para escanear QR en el metro y en autobuses urbanos de la mayoría de grandes ciudades.',
        android: null,
        ios: null,
        h5: null,
        note: 'Abre Alipay y entra en el icono "Transporte". No hace falta instalar nada más.',
        guide: '/es/transport/',
      },
      {
        name: '12306',
        desc: 'La app oficial de China Railway para comprar billetes de tren. La interfaz está en chino y la verificación puede resultar pesada; como alternativa, usa Trip.com.',
        android: 'https://play.google.com/store/apps/details?id=com.cars.blaili',
        ios: 'https://apps.apple.com/app/12306/id564757494',
        h5: 'https://www.12306.cn/',
        note: 'No suele ser la opción más cómoda para extranjeros. Trip.com es más simple aunque cobra más comisión.',
        guide: '/es/posts/book-china-train-tickets-12306-foreigners/',
      },
      {
        name: 'Trip.com (Ctrip)',
        desc: 'App en inglés muy fácil de usar para reservar trenes, vuelos y hoteles. Acepta tarjetas extranjeras directamente.',
        android: 'https://play.google.com/store/apps/details?id=com.ctrip',
        ios: 'https://apps.apple.com/app/trip-com/id1612956441',
        h5: 'https://www.trip.com/',
        note: 'Es la mejor alternativa a 12306 si priorizas comodidad frente a coste.',
        guide: null,
      },
    ],
  },
  {
    category: 'Mapas y navegación',
    apps: [
      {
        name: 'Baidu Maps',
        desc: 'El mapa más detallado para China. Ofrece navegación, transporte público y búsqueda de restaurantes. Está en chino, pero se puede usar con algo de práctica.',
        android: 'https://play.google.com/store/apps/details?id=com.baidu.BaiduMap',
        ios: 'https://apps.apple.com/app/baidu-maps/id452186370',
        h5: 'https://map.baidu.com/',
        note: 'Google Maps no es fiable dentro de China. Necesitas Baidu Maps o Amap para orientarte bien.',
        guide: null,
      },
      {
        name: 'Amap (Gaode)',
        desc: 'La gran alternativa a Baidu Maps. Muchos locales la prefieren para tráfico en tiempo real, taxis y búsquedas de sitios cercanos.',
        android: 'https://play.google.com/store/apps/details?id=com.autonavi.minimap',
        ios: 'https://apps.apple.com/app/amap/id461703208',
        h5: 'https://ditu.amap.com/',
        note: 'Ambas funcionan bien. Amap suele ir especialmente fina para pedir coche o calcular tráfico.',
        guide: null,
      },
      {
        name: 'Google Maps',
        desc: 'Puede servir para consultar ubicaciones o preparar el viaje desde fuera, pero dentro de China la navegación y el tráfico en tiempo real no son fiables.',
        android: null,
        ios: null,
        h5: 'https://maps.google.com/',
        note: 'No cuentes con Google Maps para navegar paso a paso en China sin VPN.',
        guide: '/es/posts/do-you-need-a-vpn-in-china-2026/',
      },
    ],
  },
  {
    category: 'Comida y restaurantes',
    apps: [
      {
        name: 'Meituan',
        desc: 'Sirve para pedir comida, reservar restaurantes, comprar entradas y reservar hotel. Está en chino, pero puede usarse desde mini-programas y con ayuda de traducción.',
        android: 'https://play.google.com/store/apps/details?id=com.sankuai.meituan',
        ios: 'https://apps.apple.com/app/meituan/id423924287',
        h5: 'https://waimai.meituan.com/',
        note: 'La entrega de comida vía H5 funciona desde el navegador y se paga con Alipay.',
        guide: '/es/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
      },
      {
        name: 'Ele.me',
        desc: 'Otra app importante de reparto de comida, propiedad de Alibaba. Funciona de forma parecida a Meituan y se integra bien con Alipay.',
        android: 'https://play.google.com/store/apps/details?id=me.ele',
        ios: 'https://apps.apple.com/app/ele-me/id532785356',
        h5: 'https://www.ele.me/',
        note: 'Conviene probar ambas para ver cuál cubre mejor tu zona o tu restaurante preferido.',
        guide: '/es/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
      },
      {
        name: 'Dianping',
        desc: 'La referencia local para reseñas, valoraciones y fotos de restaurantes. Muy útil para elegir dónde comer, aunque esté en chino.',
        android: 'https://play.google.com/store/apps/details?id=com.dianping.v1',
        ios: 'https://apps.apple.com/app/dianping/id416896465',
        h5: 'https://www.dianping.com/',
        note: 'La búsqueda por fotos ayuda mucho cuando no sabes leer el menú.',
        guide: '/es/food/',
      },
    ],
  },
  {
    category: 'Comunicación y VPN',
    apps: [
      {
        name: 'VPN (elige una antes de viajar)',
        desc: 'Instala tu VPN antes de despegar. ExpressVPN, NordVPN y Astrill son opciones conocidas; las VPN gratuitas suelen fallar o estar bloqueadas.',
        android: null,
        ios: null,
        h5: null,
        note: 'Es clave instalarla, probarla y dejarla lista antes de llegar a China.',
        guide: '/es/posts/do-you-need-a-vpn-in-china-2026/',
      },
      {
        name: 'Google Translate',
        desc: 'Muy útil para traducir menús, carteles y documentos con la cámara. Descarga antes el paquete sin conexión de chino simplificado.',
        android: 'https://play.google.com/store/apps/details?id=com.google.android.apps.translate',
        ios: 'https://apps.apple.com/app/google-translate/id414706506',
        h5: 'https://translate.google.com/',
        note: 'Sigue siendo una de las mejores herramientas para resolver barreras lingüísticas sobre la marcha.',
        guide: '/es/tools/survival-kit/',
      },
    ],
  },
  {
    category: 'Reservas de viaje',
    apps: [
      {
        name: 'Trip.com (Hoteles)',
        desc: 'Muy práctica para reservar hoteles con tarjetas extranjeras. Tiene buena cobertura, filtros claros y atención en inglés.',
        android: null,
        ios: null,
        h5: 'https://www.trip.com/hotels/',
        note: 'También sirve para vuelos y trenes, así que puede centralizar casi toda la logística del viaje.',
        guide: null,
      },
      {
        name: 'Fliggy (Alitrip)',
        desc: 'La plataforma de viajes de Alibaba. Se usa mucho para vuelos nacionales y puede integrarse con el ecosistema de Alipay.',
        android: null,
        ios: null,
        h5: 'https://www.fliggy.com/',
        note: 'Si ya usas Alipay, es una opción cómoda para no añadir otra app a tu móvil.',
        guide: null,
      },
    ],
  },
];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Apps móviles</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">Apps esenciales para viajar por China</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-internet-apps" alt="Teléfono móvil con iconos de apps clave para moverse y pagar en China" loading="eager" />

    <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-5 text-sm leading-6 text-amber-900">
      <strong>Antes de salir:</strong> instala estas apps con buen WiFi antes del viaje. Algunas tiendas funcionan peor dentro de China y conviene llevar descargados los paquetes offline y la VPN.
    </div>

    <AdSlot format="banner" />

    {appGroups.map((group) => (
      <section class="mt-12" aria-labelledby={group.category.replace(/\s+/g, '-').toLowerCase()}>
        <h2 id={group.category.replace(/\s+/g, '-').toLowerCase()} class="text-2xl font-bold text-gray-950">{group.category}</h2>
        <div class="mt-5 grid gap-5 md:grid-cols-2">
          {group.apps.map((app) => (
            <article class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
              <h3 class="text-lg font-bold text-gray-950">{app.name}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{app.desc}</p>

              <div class="mt-4 flex flex-wrap gap-2">
                {app.ios && (
                  <a href={app.ios} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md bg-gray-900 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-gray-700">
                    App Store
                  </a>
                )}
                {app.android && (
                  <a href={app.android} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md bg-green-700 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-green-600">
                    Google Play
                  </a>
                )}
                {app.h5 && (
                  <a href={app.h5} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-gray-700 transition-colors hover:bg-gray-50">
                    Abrir versión web
                  </a>
                )}
              </div>

              {app.note && (
                <p class="mt-3 text-xs leading-5 text-gray-500"><span class="font-semibold">Consejo:</span> {app.note}</p>
              )}
              {app.guide && (
                <a href={app.guide} class="mt-2 inline-block text-xs font-semibold text-brand-700 hover:text-brand-800">Leer guía de configuración &rarr;</a>
              )}
            </article>
          ))}
        </div>
      </section>
    ))}

    <section class="mt-12 rounded-lg border border-gray-200 p-6">
      <h2 class="text-xl font-bold text-gray-950">Apps web H5: útiles si no quieres instalarlo todo</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        Muchos servicios chinos tienen <strong>versiones web (H5)</strong> que funcionan directamente en el navegador o dentro de mini-programas de WeChat y Alipay. Son una solución muy cómoda para viajes cortos.
      </p>
      <div class="mt-4 grid gap-3 text-sm sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">DiDi</strong> - <span class="text-gray-600">m.didiglobal.com (con opción en inglés)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Baidu Maps</strong> - <span class="text-gray-600">map.baidu.com (en chino)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">WeChat Web</strong> - <span class="text-gray-600">web.wechat.com (solo mensajería)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Meituan</strong> - <span class="text-gray-600">waimai.meituan.com (reparto de comida)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Dianping</strong> - <span class="text-gray-600">dianping.com (búsqueda de restaurantes)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Mini-programas de Alipay</strong> - <span class="text-gray-600">Todo dentro de Alipay, sin instalación adicional</span></div>
      </div>
      <p class="mt-4 text-xs text-gray-500">
        <strong>La mayoría de estas versiones web funcionan sin VPN.</strong> Aun así, si piensas descargar apps o depender de herramientas internacionales, mejor dejarlo listo antes de aterrizar.
      </p>
    </section>

    <section class="mt-10 text-center">
      <p class="text-sm text-gray-500">Los enlaces abren páginas oficiales. La disponibilidad de algunas apps puede variar según tu región.</p>
    </section>
  </main>
  <Footer />
</BaseLayout>
