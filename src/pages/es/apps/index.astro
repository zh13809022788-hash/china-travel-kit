---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CoverImage from '../../../components/CoverImage.astro';
import AdSlot from '../../../components/AdSlot.astro';

const title = 'Apps esenciales para China: enlaces y alternativas web';
const description = 'Un directorio completo de las apps que necesitas en China: WeChat, Alipay, DiDi, Baidu Maps, Meituan, 12306, VPN y mas. Cada app incluye enlaces de descarga de App Store / Google Play y versiones web H5 que funcionan sin instalar nada.';

const appGroups = [
  {
    category: 'Pagos y billetera',
    apps: [
      {
        name: 'Alipay',
        desc: 'La billetera movil mas aceptada en China. Vincula una Visa o Mastercard extranjera y paga con codigo QR en tiendas, restaurantes, taxis y puestos callejeros.',
        android: 'https://play.google.com/store/apps/details?id=com.eg.android.AlipayGphone',
        ios: 'https://apps.apple.com/app/alipay/id333206289',
        h5: null,
        note: 'La configuracion tarda 10-15 min. Necesitas pasaporte para la verificacion.',
        guide: '/es/posts/alipay-foreign-credit-card-step-by-step/',
      },
      {
        name: 'WeChat',
        desc: 'La superapp de China. Usala para mensajes, llamadas, Moments (feed social) y WeChat Pay. La mayoria de la gente en China la usa a diario para todo.',
        android: 'https://play.google.com/store/apps/details?id=com.tencent.mm',
        ios: 'https://apps.apple.com/app/wechat/id414478124',
        h5: 'https://web.wechat.com/',
        note: 'WeChat Pay necesita una tarjeta vinculada. WeChat funciona para mensajeria sin configuracion adicional.',
        guide: '/es/posts/link-a-foreign-visa-or-mastercard-to-wechat-pay-in-china/',
      },
    ],
  },
  {
    category: 'Transporte y VTC',
    apps: [
      {
        name: 'DiDi',
        desc: 'El Uber de China. Reserva taxis y coches privados. Tiene interfaz en ingles. Puedes pagar con Alipay o WeChat Pay.',
        android: 'https://play.google.com/store/apps/details?id=com.didi.sdk',
        ios: 'https://apps.apple.com/app/didi/id1164272094',
        h5: 'https://m.didiglobal.com/',
        note: 'La version H5 funciona en el navegador o como mini-programa de WeChat. No necesitas app para trayectos ocasionales.',
        guide: '/es/posts/didi-china-foreign-tourists-guide/',
      },
      {
        name: 'Mini-programa de transporte de Alipay',
        desc: 'Dentro de Alipay, usa el mini-programa de transporte para escanear codigos QR en el metro y los autobuses urbanos de la mayoria de las grandes ciudades.',
        android: null,
        ios: null,
        h5: null,
        note: 'Abre Alipay -> icono "Transporte". No necesitas instalar nada aparte.',
        guide: '/es/transport/',
      },
      {
        name: '12306',
        desc: 'App oficial de China Railway para reservar billetes de tren. Interfaz solo en chino y requiere verificacion. Alternativa: usa Trip.com.',
        android: 'https://play.google.com/store/apps/details?id=com.cars.blaili',
        ios: 'https://apps.apple.com/app/12306/id564757494',
        h5: 'https://www.12306.cn/',
        note: 'Complicada para extranjeros. Usa Trip.com (en ingles, sin complicaciones de verificacion).',
        guide: '/es/posts/book-china-train-tickets-12306-foreigners/',
      },
      {
        name: 'Trip.com (Ctrip)',
        desc: 'App facil de usar en ingles para reservar trenes, vuelos y hoteles. Acepta tarjetas extranjeras directamente.',
        android: 'https://play.google.com/store/apps/details?id=com.ctrip',
        ios: 'https://apps.apple.com/app/trip-com/id1612956441',
        h5: 'https://www.trip.com/',
        note: 'La mejor alternativa a 12306 para billetes de tren. Cobra una comision de servicio mas alta, pero es mucho mas facil.',
        guide: null,
      },
    ],
  },
  {
    category: 'Navegacion y mapas',
    apps: [
      {
        name: 'Baidu Maps',
        desc: 'El mapa mas detallado de China. Navegacion paso a paso, rutas en transporte publico y busqueda de restaurantes. Solo en chino, pero usable con gestos.',
        android: 'https://play.google.com/store/apps/details?id=com.baidu.BaiduMap',
        ios: 'https://apps.apple.com/app/baidu-maps/id452186370',
        h5: 'https://map.baidu.com/',
        note: 'Google Maps esta bloqueado en China. Necesitas Baidu o Amap para navegar.',
        guide: null,
      },
      {
        name: 'Amap (Gaode)',
        desc: 'Alternativa a Baidu Maps. Muchos locales prefieren Amap. Mejor para navegacion en taxi, trafico en tiempo real y resenas de restaurantes.',
        android: 'https://play.google.com/store/apps/details?id=com.autonavi.minimap',
        ios: 'https://apps.apple.com/app/amap/id461703208',
        h5: 'https://ditu.amap.com/',
        note: 'Tanto Baidu como Amap funcionan. Elige una. Amap suele ser mas preciso para pedir taxi.',
        guide: null,
      },
      {
        name: 'Google Maps',
        desc: 'Funciona parcialmente en China para consultar mapas, pero la navegacion y el trafico en tiempo real no son fiables. Bueno para planificar antes del viaje.',
        android: null,
        ios: null,
        h5: 'https://maps.google.com/',
        note: 'No funcionara para navegacion paso a paso en China sin VPN.',
        guide: '/es/posts/do-you-need-a-vpn-in-china-2026/',
      },
    ],
  },
  {
    category: 'Comida y restaurantes',
    apps: [
      {
        name: 'Meituan',
        desc: 'Entrega de comida, reservas de restaurantes, entradas de cine y reservas de hotel. Solo en chino. Usalo dentro del mini-programa de Alipay para obtener ayuda en ingles.',
        android: 'https://play.google.com/store/apps/details?id=com.sankuai.meituan',
        ios: 'https://apps.apple.com/app/meituan/id423924287',
        h5: 'https://waimai.meituan.com/',
        note: 'La entrega de comida H5 funciona en el navegador. Paga con Alipay al hacer el pedido.',
        guide: '/es/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
      },
      {
        name: 'Ele.me',
        desc: 'App de entrega de comida (propiedad de Alibaba). Similar a Meituan. Puedes pedir comida con Alipay.',
        android: 'https://play.google.com/store/apps/details?id=me.ele',
        ios: 'https://apps.apple.com/app/ele-me/id532785356',
        h5: 'https://www.ele.me/',
        note: 'Tanto Meituan como Ele.me funcionan. Prueba ambas para tener la mejor cobertura de restaurantes.',
        guide: '/es/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
      },
      {
        name: 'Dianping',
        desc: 'El Yelp de China. Resenas, valoraciones y fotos de restaurantes. Ayuda a encontrar buenos locales. Solo en chino.',
        android: 'https://play.google.com/store/apps/details?id=com.dianping.v1',
        ios: 'https://apps.apple.com/app/dianping/id416896465',
        h5: 'https://www.dianping.com/',
        note: 'Usa la funcion de busqueda por fotos: mira como son los platos antes de pedir.',
        guide: '/es/food/',
      },
    ],
  },
  {
    category: 'Comunicacion y VPN',
    apps: [
      {
        name: 'VPN (elige una antes de viajar)',
        desc: 'Instala una VPN ANTES de salir. ExpressVPN, NordVPN y Astrill funcionan en China. Las VPN gratuitas suelen estar bloqueadas.',
        android: null,
        ios: null,
        h5: null,
        note: 'ESENCIAL: instalala y pruebala antes de llegar. Activala al aterrizar.',
        guide: '/es/posts/do-you-need-a-vpn-in-china-2026/',
      },
      {
        name: 'Google Translate',
        desc: 'Traduccion con camara para menus, senales y documentos. Descarga el paquete sin conexion de chino simplificado.',
        android: 'https://play.google.com/store/apps/details?id=com.google.android.apps.translate',
        ios: 'https://apps.apple.com/app/google-translate/id414706506',
        h5: 'https://translate.google.com/',
        note: 'La mejor herramienta de traduccion. Descarga el paquete sin conexion antes del viaje.',
        guide: '/es/tools/survival-kit/',
      },
    ],
  },
  {
    category: 'Reservas de viaje',
    apps: [
      {
        name: 'Trip.com (Hoteles)',
        desc: 'Ideal para reservar hoteles con tarjetas extranjeras. Amplia cobertura. Interfaz en ingles.',
        android: null,
        ios: null,
        h5: 'https://www.trip.com/hotels/',
        note: 'Tambien sirve para vuelos y trenes. Todo en un solo lugar.',
        guide: null,
      },
      {
        name: 'Fliggy (Alitrip)',
        desc: 'La plataforma de reservas de viaje de Alibaba. Dentro de la app Alipay. Buena para vuelos nacionales.',
        android: null,
        ios: null,
        h5: 'https://www.fliggy.com/',
        note: 'Puedes pagar con Alipay. No necesitas descargar otra app.',
        guide: null,
      },
    ],
  },
];
---
<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="es">
  <Header locale="es" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Apps móviles</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">Apps esenciales para China</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-internet-apps" alt="Smartphone con iconos de apps esenciales para viajar por China" loading="eager" />

    <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-5 text-sm leading-6 text-amber-900">
      <strong>Antes de salir:</strong> Instala estas apps por WiFi antes de partir. Algunas tiendas de apps son lentas o están bloqueadas dentro de China. Descarga en casa los paquetes de traducción sin conexión y las apps de VPN.
    </div>

    <AdSlot format="banner" />

    {appGroups.map((group) => (
      <section class="mt-12" aria-labelledby={group.category.replace(/\s+/g, '-').toLowerCase()}>
        <h2 id={group.category.replace(/\s+/g, '-').toLowerCase()} class="text-2xl font-bold text-gray-950">{group.category}</h2>
        <div class="mt-5 grid gap-5 md:grid-cols-2">
          {group.apps.map((app) => (
            <article class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
              <h3 class="text-lg font-bold text-gray-950">{app.name}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{app.desc}</p>

              <div class="mt-4 flex flex-wrap gap-2">
                {app.ios && (
                  <a href={app.ios} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md bg-gray-900 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-gray-700">
                    App Store
                  </a>
                )}
                {app.android && (
                  <a href={app.android} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md bg-green-700 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-green-600">
                    Google Play
                  </a>
                )}
                {app.h5 && (
                  <a href={app.h5} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-gray-700 transition-colors hover:bg-gray-50">
                    Abrir versión web
                  </a>
                )}
              </div>

              {app.note && (
                <p class="mt-3 text-xs leading-5 text-gray-500"><span class="font-semibold">Consejo:</span> {app.note}</p>
              )}
              {app.guide && (
                <a href={app.guide} class="mt-2 inline-block text-xs font-semibold text-brand-700 hover:text-brand-800">Leer guía de configuración &rarr;</a>
              )}
            </article>
          ))}
        </div>
      </section>
    ))}

    <section class="mt-12 rounded-lg border border-gray-200 p-6">
      <h2 class="text-xl font-bold text-gray-950">Apps web H5: no hace falta descargar</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        Muchos servicios de China tienen <strong>versiones web (H5)</strong> que funcionan directamente en el navegador del teléfono o dentro de mini-programas de WeChat/Alipay. Son ideales para viajeros de corta estancia que no quieren llenar el teléfono con más de 10 apps. Principales opciones:
      </p>
      <div class="mt-4 grid gap-3 text-sm sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">DiDi</strong> — <span class="text-gray-600">m.didiglobal.com (inglés disponible)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Baidu Maps</strong> — <span class="text-gray-600">map.baidu.com (solo chino)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">WeChat Web</strong> — <span class="text-gray-600">web.wechat.com (solo mensajería)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Meituan</strong> — <span class="text-gray-600">waimai.meituan.com (entrega de comida)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Dianping</strong> — <span class="text-gray-600">dianping.com (búsqueda de restaurantes)</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Mini-programas de Alipay</strong> — <span class="text-gray-600">Todo dentro de Alipay (sin instalación adicional)</span></div>
      </div>
      <p class="mt-4 text-xs text-gray-500">
        <strong>Las versiones web funcionan sin VPN</strong> en la mayoría de los casos. Para descargar apps, instálalas antes de llegar usando tu WiFi de casa.
      </p>
    </section>

    <section class="mt-10 text-center">
      <p class="text-sm text-gray-500">Los enlaces de tiendas de apps abren páginas oficiales. Los precios y la disponibilidad están sujetos a restricciones regionales.</p>
    </section>
  </main>
  <Footer />
</BaseLayout>