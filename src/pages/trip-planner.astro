---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';

const title = 'Free China Trip Planner';
const description =
  'Build a practical first China trip plan with payment, eSIM, transport, app setup, cash, and first-day checklist recommendations.';

const needOptions = [
  { value: 'payment', label: 'Payment setup' },
  { value: 'esim', label: 'eSIM and internet' },
  { value: 'transport', label: 'Airport and trains' },
  { value: 'hotel', label: 'Hotel area logic' },
  { value: 'apps', label: 'Apps and translation' },
  { value: 'cash', label: 'Cash backup' },
  { value: 'visa', label: 'Visa-free entry' },
  { value: 'food', label: 'Food and delivery' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main>
    <section class="border-b border-gray-200 bg-white">
      <div class="container-page grid gap-8 py-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <div>
          <p class="section-kicker">Free planning tool</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Build a practical China arrival plan before you fly
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Get a first-pass plan for payments, eSIM data, airport transport, app setup,
            cash backup, and daily pacing. It runs in your browser and does not save your answers.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#planner" class="btn-primary">Start planning</a>
            <a href="/travel-help/" class="btn-outline">Ask travel help</a>
          </div>
        </div>

        <aside class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="section-kicker">Best for</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">First-time visitor setup</h2>
          <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
            <li>Payment readiness before arrival</li>
            <li>eSIM, roaming, and app access decisions</li>
            <li>Airport-to-city first step planning</li>
            <li>Simple city-by-city trip framework</li>
          </ul>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <AdSlot format="banner" />

      <section id="planner" class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <form id="trip-planner-form" class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm md:p-6">
          <div class="border-b border-gray-200 pb-5">
            <p class="section-kicker">Trip details</p>
            <h2 class="mt-2 text-2xl font-bold text-gray-950">Tell us what you know</h2>
          </div>

          <div class="mt-6 grid gap-5 md:grid-cols-2">
            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Home country or region
              <input id="home-country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="United States, UK, Singapore..." />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Arrival city
              <select id="arrival-city" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Shanghai</option>
                <option>Beijing</option>
                <option>Guangzhou</option>
                <option>Shenzhen</option>
                <option>Chengdu</option>
                <option>Hangzhou</option>
                <option>Other city</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800 md:col-span-2">
              Destination cities
              <input id="destination-cities" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="Shanghai, Hangzhou, Beijing" />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Trip length
              <select id="trip-length" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option value="3">3 days</option>
                <option value="5">5 days</option>
                <option value="7" selected>7 days</option>
                <option value="10">10 days</option>
                <option value="14">14 days</option>
                <option value="21">21 days or more</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Travel purpose
              <select id="trip-purpose" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Tourism</option>
                <option>Business</option>
                <option>Long stay</option>
                <option>Digital nomad</option>
                <option>Family visit</option>
                <option>Transit</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Budget range
              <select id="budget-range" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Budget</option>
                <option selected>Comfort</option>
                <option>Premium</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Travel style
              <select id="travel-style" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Efficient</option>
                <option>Budget</option>
                <option selected>Comfort</option>
                <option>Family</option>
                <option>Business</option>
                <option>Food-focused</option>
              </select>
            </label>
          </div>

          <fieldset class="mt-6">
            <legend class="text-sm font-semibold text-gray-800">What do you need help with?</legend>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              {needOptions.map((option) => (
                <label class="flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-700">
                  <input class="h-4 w-4 rounded border-gray-300 text-brand-600" type="checkbox" name="needs" value={option.value} checked={['payment', 'esim', 'transport', 'apps'].includes(option.value)} />
                  {option.label}
                </label>
              ))}
            </div>
          </fieldset>

          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p id="planner-status" class="text-sm text-gray-500">No account or sensitive data needed.</p>
            <button class="btn-primary" type="submit">Generate plan</button>
          </div>
        </form>

        <aside class="space-y-6">
          <section class="rounded-lg border border-gray-200 bg-white p-5">
            <p class="section-kicker">Upgrade path</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Need human review?</h2>
            <p class="mt-3 text-sm leading-6 text-gray-600">
              If your route, timing, payment setup, or first day feels risky, send the generated
              plan by email and ask for a human-reviewed correction list.
            </p>
            <a id="planner-email-link" class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:border-brand-600 hover:text-brand-600 hover:no-underline" href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Trip%20Review%20Request">
              Prepare review email
            </a>
          </section>

          <section class="rounded-lg border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Limits</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Use this as planning help</h2>
            <p class="mt-3 text-sm leading-6 text-gray-700">
              This tool is not legal, immigration, medical, banking, or emergency advice. Verify
              important entry, airline, hotel, card, telecom, and app rules with official sources.
            </p>
          </section>
        </aside>
      </section>

      <section id="plan-output" class="mt-10 hidden rounded-lg border border-brand-100 bg-brand-50 p-5 md:p-6" aria-live="polite">
        <div class="border-b border-brand-100 pb-4">
          <p class="section-kicker">Generated plan</p>
          <h2 class="mt-2 text-2xl font-bold text-gray-950">Your China trip setup draft</h2>
        </div>
        <div id="plan-content" class="mt-5 grid gap-5"></div>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <a href="/payment/" class="card block hover:no-underline">
          <p class="section-kicker">Payment</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Prepare Alipay and WeChat Pay</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Set up at least one wallet and one backup payment method before arrival.</p>
        </a>
        <a href="/esim/" class="card block hover:no-underline">
          <p class="section-kicker">Internet</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Choose an eSIM or roaming setup</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Make sure you can load maps, translate, message, and call a ride on day one.</p>
        </a>
        <a href="/transport/" class="card block hover:no-underline">
          <p class="section-kicker">Transport</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Plan your first route</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Know your airport-to-hotel route and when to use metro, taxi, DiDi, or train.</p>
        </a>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('trip-planner-form') as HTMLFormElement | null;
  const output = document.getElementById('plan-output');
  const content = document.getElementById('plan-content');
  const status = document.getElementById('planner-status');
  const emailLink = document.getElementById('planner-email-link') as HTMLAnchorElement | null;

  const getValue = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null)?.value.trim() || '';
  const selectedNeeds = () =>
    Array.from(document.querySelectorAll<HTMLInputElement>('input[name="needs"]:checked')).map((input) => input.value);
  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char] ?? char);

  const splitCities = (value: string, arrival: string) => {
    const typed = value
      .split(',')
      .map((city) => city.trim())
      .filter(Boolean);
    const cities = typed.length ? typed : [arrival];
    return Array.from(new Set(cities));
  };

  const list = (items: string[]) => `<ul class="mt-3 grid gap-2 text-sm leading-6 text-gray-700">${items.map((item) => `<li>${item}</li>`).join('')}</ul>`;
  const panel = (title: string, items: string[]) => `
    <section class="rounded-lg border border-gray-200 bg-white p-5">
      <h3 class="text-lg font-bold text-gray-950">${title}</h3>
      ${list(items)}
    </section>
  `;

  const buildPlan = () => {
    const home = getValue('home-country') || 'your home country';
    const arrival = getValue('arrival-city') || 'Shanghai';
    const cities = splitCities(getValue('destination-cities'), arrival);
    const days = Number(getValue('trip-length') || '7');
    const purpose = getValue('trip-purpose') || 'Tourism';
    const budget = getValue('budget-range') || 'Comfort';
    const style = getValue('travel-style') || 'Comfort';
    const needs = selectedNeeds();
    const perCity = Math.max(1, Math.floor(days / Math.max(1, cities.length)));

    const preDeparture = [
      `Install Alipay, WeChat, DiDi, a translation app, and an offline map before leaving ${escapeHtml(home)}.`,
      needs.includes('payment')
        ? 'Link one foreign Visa or Mastercard to Alipay and try a small verification before departure.'
        : 'Keep payment setup simple: one mobile wallet, one physical card, and some RMB cash.',
      needs.includes('esim')
        ? 'Buy and activate an eSIM or roaming plan before the flight, then keep the QR code available offline.'
        : 'Confirm your phone will have data on arrival before depending on maps or ride-hailing.',
      'Save your hotel address in English and Chinese, plus the nearest metro station.',
    ];

    const payment = [
      'Primary setup: Alipay with a foreign card, because it is usually the most practical first wallet for visitors.',
      'Backup setup: WeChat Pay if your card links successfully, plus one physical Visa or Mastercard.',
      budget === 'Budget'
        ? 'Cash backup: carry a small amount of RMB for stalls, deposits, or card/wallet issues.'
        : 'Cash backup: keep enough RMB for taxi, snacks, and one simple meal in case mobile payment fails.',
      'Do not rely on Apple Pay or Google Pay as your main payment method in mainland China.',
    ];

    const internet = [
      'For short trips, a travel eSIM is usually the easiest setup if your phone supports eSIM.',
      'For longer stays or heavy data use, compare roaming, eSIM, pocket WiFi, and local SIM options before arrival.',
      'Test mobile data before leaving the airport, because payment apps, ride-hailing, translation, and maps all depend on it.',
      'Save hotel and transport information offline in case your first connection is unstable.',
    ];

    const transport = [
      `First route: plan ${escapeHtml(arrival)} airport or station to hotel before landing.`,
      'Use metro for predictable city routes, DiDi for door-to-door trips, and high-speed rail for city-to-city travel.',
      needs.includes('transport')
        ? 'For train days, book earlier when possible and keep passport details consistent with the ticket platform.'
        : 'Avoid tight same-day transfers between international flights and long-distance trains.',
      'Keep a Chinese address card ready for taxis or hotel front desks.',
    ];

    const dayPlan = cities.map((city, index) => {
      const start = index * perCity + 1;
      const end = index === cities.length - 1 ? days : Math.min(days, start + perCity - 1);
      return `Days ${start}-${end}: ${escapeHtml(city)} - keep the first half-day lighter, confirm payment/data, then group sights by district.`;
    });

    const mistakes = [
      'Do not wait until arrival to set up every app, card, and data plan.',
      'Do not schedule a packed sightseeing day immediately after a long-haul flight.',
      'Do not depend on one payment method only.',
      purpose === 'Business'
        ? 'For business travel, keep extra time for traffic, security checks, invoices, and building access.'
        : 'For leisure travel, leave one flexible block every two or three days for weather, crowds, or fatigue.',
      style === 'Food-focused'
        ? 'For food-focused trips, save restaurant names in Chinese and confirm opening hours before crossing town.'
        : 'Keep a simple backup plan for meals near your hotel.',
    ];

    const html = [
      panel('Pre-departure checklist', preDeparture),
      panel('Payment and cash setup', payment),
      panel('Internet and app setup', internet),
      panel('Transport and first day', transport),
      panel('Simple day-by-day framework', dayPlan),
      panel('Common mistake warnings', mistakes),
    ].join('');

    const emailBody = [
      'ChinaTripBox Trip Review Request',
      '',
      `Home country or region: ${home}`,
      `Arrival city: ${arrival}`,
      `Destination cities: ${cities.join(', ')}`,
      `Trip length: ${days} days`,
      `Purpose: ${purpose}`,
      `Budget: ${budget}`,
      `Style: ${style}`,
      `Needs: ${needs.join(', ') || 'not specified'}`,
      '',
      'Please review my China trip setup for payment, eSIM, transport, timing, and first-day mistakes.',
    ].join('\n');

    if (emailLink) {
      emailLink.href = `mailto:zh13809022788@gmail.com?subject=${encodeURIComponent(
        'ChinaTripBox Trip Review Request',
      )}&body=${encodeURIComponent(emailBody)}`;
    }

    return html;
  };

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!content || !output) return;
    content.innerHTML = buildPlan();
    output.classList.remove('hidden');
    output.scrollIntoView({ behavior: 'smooth', block: 'start' });
    if (status) status.textContent = 'Plan generated. Adjust your answers and regenerate any time.';
  });
</script>
