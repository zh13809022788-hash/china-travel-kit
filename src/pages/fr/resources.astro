---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'Ressources pour voyager en Chine';
const description =
  'Un centre de ressources pratique pour les visiteurs étrangers en Chine : paiements, eSIM, trains, visas, guides de villes, outils et liens de planification du premier voyage.';

const resourceGroups = [
  {
    title: 'Si vous n’avez que 30 minutes',
    description: 'Un parcours de lecture court pour les voyageurs qui ont besoin d’une configuration chinoise utilisable rapidement.',
    links: [
      { href: '/fr/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: 'Liste de vérification avant départ' },
      { href: '/fr/tools/survival-kit/', title: 'Cartes et listes de vérification de survie en Chine' },
      { href: '/fr/tools/payment-checker/', title: 'Vérifiez votre plan de paiement de secours' },
      { href: '/fr/tools/visa-free-checker/', title: 'Vérifiez l’entrée sans visa ou le transit' },
      { href: '/fr/posts/china-high-speed-rail-guide-foreigners/', title: 'Comprendre la réservation de train et l’entrée en gare' },
    ],
  },
  {
    title: 'Commencez ici : configuration du premier voyage',
    description: 'Le chemin le plus court de « je vais en Chine » à un plan d’arrivée utilisable.',
    links: [
      { href: '/fr/trip-planner/', title: 'Planificateur de voyage en Chine gratuit' },
      { href: '/fr/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/', title: 'Planificateur de voyage en Chine pour premiers voyageurs' },
      { href: '/fr/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: 'Ce qu’il faut configurer avant de voyager en Chine' },
      { href: '/fr/posts/china-visa-free-entry-transit-guide-2026/', title: 'Guide d’entrée sans visa et de transit en Chine' },
      { href: '/fr/tools/best-time-to-visit/', title: 'Meilleure période pour visiter la Chine' },
      { href: '/fr/posts/what-to-pack-for-china-a-season-by-season-checklist/', title: 'Quoi emporter pour la Chine' },
    ],
  },
  {
    title: 'Paiements et argent',
    description: 'Paiements mobiles, réserve de liquide, cartes et problèmes quotidiens de paiement.',
    links: [
      { href: '/fr/posts/how-to-pay-in-china-tourist-guide/', title: 'Comment payer en Chine en tant que touriste' },
      { href: '/fr/posts/alipay-foreign-credit-card-step-by-step/', title: 'Configurer Alipay avec une carte étrangère' },
      { href: '/fr/posts/wechat-pay-foreign-visitors-guide/', title: 'Guide WeChat Pay pour les visiteurs étrangers' },
      { href: '/fr/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: 'Liste de vérification paiement et applications avant départ' },
      { href: '/fr/tools/payment-checker/', title: 'Vérificateur de compatibilité de paiement' },
    ],
  },
  {
    title: 'Internet et applications',
    description: 'Restez en ligne, choisissez une eSIM et sachez quelles applications fonctionnent avant l’arrivée.',
    links: [
      { href: '/fr/posts/best-esim-for-china-travel-2026/', title: 'Meilleure eSIM pour voyager en Chine' },
      { href: '/fr/posts/china-esim-vs-roaming-2026-the-real-10-day-cost/', title: 'Coût eSIM Chine vs itinérance' },
      { href: '/fr/posts/internet-access-china-apps-that-work-2026/', title: 'Accès Internet et applications en Chine' },
      { href: '/fr/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/', title: 'Planification du premier voyage avec eSIM et applications' },
      { href: '/fr/tools/app-availability-checker/', title: 'Mes applications fonctionneront-elles en Chine ?' },
    ],
  },
  {
    title: 'Transport et guides de villes',
    description: 'Trains, métro, aéroports, VTC et planification urbaine pratique.',
    links: [
      { href: '/fr/cities/', title: 'Hub des guides de villes chinoises' },
      { href: '/fr/posts/china-high-speed-rail-guide-foreigners/', title: 'Guide du train à grande vitesse en Chine pour étrangers' },
      { href: '/fr/posts/book-china-train-tickets-12306-foreigners/', title: 'Réserver des billets de train chinois sur 12306' },
      { href: '/fr/posts/didi-china-foreign-tourists-guide/', title: 'Utiliser DiDi en tant que touriste étranger' },
      { href: '/fr/posts/airport-to-city-transport-beijing-shanghai-guangzhou/', title: 'Guide de transport de l’aéroport à la ville' },
    ],
  },
  {
    title: 'Nourriture, étiquette et vie quotidienne',
    description: 'Restauration, pourboires, applications de livraison, street food et habitudes pratiques qui réduisent les frictions sur le terrain.',
    links: [
      { href: '/fr/food/', title: 'Hub de la nourriture et de la restauration en Chine' },
      { href: '/fr/posts/ordering-food-in-china-without-chinese-meituan-ele-me/', title: 'Commander à manger sans chinois' },
      { href: '/fr/posts/chengdu-street-food-safety-spice-levels-what-to-order/', title: 'Sécurité et guide des épices de la street-food de Chengdu' },
      { href: '/fr/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/', title: 'Pourboires en Chine : quand c’est attendu' },
    ],
  },
  {
    title: 'Séjours plus longs et travail à distance',
    description: 'Pour les voyages mesurés en semaines ou en mois, commencez par la légalité, le logement, le paiement et la fiabilité des outils de travail.',
    links: [
      { href: '/fr/long-stay/', title: 'Guide du séjour de longue durée en Chine' },
      { href: '/fr/digital-nomads/', title: 'Guide des nomades numériques en Chine' },
      { href: '/fr/digital-nomads/visa/', title: 'Guide des visas chinois pour nomades numériques' },
      { href: '/fr/digital-nomads/payment/', title: 'Configuration des paiements pour longs séjours' },
    ],
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-10">
    <section class="max-w-3xl">
      <p class="section-kicker">Centre de ressources</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </section>

    <section class="mt-10 grid gap-5 md:grid-cols-2">
      {resourceGroups.map((group) => (
        <article class="card">
          <h2 class="text-xl font-bold text-gray-950">{group.title}</h2>
          <p class="mt-2 text-sm leading-6 text-gray-600">{group.description}</p>
          <ul class="mt-5 grid gap-3">
            {group.links.map((link) => (
              <li>
                <a href={link.href} class="font-semibold text-brand-700 hover:text-brand-800">
                  {link.title}
                </a>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>
