---

import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const CATEGORY = 'esim';
const posts = (await getCollection('posts-fr'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'eSIM et données en Chine : rester connecté à l’arrivée';
const description = 'Comparez et configurez les meilleurs forfaits de données eSIM pour voyager en Chine. Connectez-vous dès votre arrivée, sans changer de carte SIM physique.';

const connectionChoices = [
  {
    title: 'eSIM',
    desc: "Idéal pour la plupart des courts séjours lorsque votre téléphone prend en charge l'eSIM et que vous voulez des données prêtes avant l'atterrissage.",
  },
  {
    title: 'Itinérance',
    desc: "Utile comme solution de secours pour les SMS bancaires et la connexion de la première heure, mais souvent plus cher pour une utilisation intensive de données.",
  },
  {
    title: 'Pocket Wi-Fi ou carte SIM locale',
    desc: "À envisager pour les groupes, les séjours prolongés ou les téléphones ne pouvant pas installer d'eSIM de voyage.",
  },
];

const internetTools = [
  { href: '/fr/tools/esim-comparison/', title: 'eSIM plan comparator', desc: 'Compare travel data plans, validity, and expected use cases.' },
  { href: '/fr/tools/app-availability-checker/', title: 'App availability checker', desc: 'Check whether common apps work in China and what alternatives to prepare.' },
  { href: '/fr/posts/internet-access-china-apps-that-work-2026/', title: 'Internet access guide', desc: 'Understand app access, VPN expectations, and practical setup before arrival.' },
];
---


<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">eSIM</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Guides eSIM et données</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="hub-esim" alt="Mobile network and data connectivity options for China travel" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-esim">
      <h2 id="featured-esim" class="sr-only">Guides internet à lire</h2>
      <a href="/fr/posts/best-esim-for-china-travel-2026/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Best eSIM 2026</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Compare Airalo, Holafly, Nomad for China travel</p>
      </a>
      <a href="/fr/posts/china-esim-vs-roaming-2026-the-real-10-day-cost/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">eSIM vs Roaming</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Real 10-day cost comparison for tourists</p>
      </a>
      <a href="/fr/posts/do-you-need-a-vpn-in-china-2026/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">VPN Guide 2026</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Do tourists still need a VPN in China?</p>
      </a>
      <a href="/fr/posts/pocket-wifi-vs-esim-vs-sim-china/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Pocket WiFi vs eSIM</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Compare all connectivity options</p>
      </a>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[1fr_340px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">Choisissez votre solution internet pour la Chine</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          La solution la plus sûre pour les visiteurs consiste généralement à prévoir une option de données principale, plus une solution de secours pour la banque, les cartes, la traduction et les applications de VTC pendant le premier jour.
        </p>
        <div class="mt-5 grid gap-3">
          {connectionChoices.map((choice) => (
            <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
              <h3 class="text-sm font-bold text-gray-900">{choice.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{choice.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Internet tools</h2>
        <div class="mt-4 grid gap-3">
          {internetTools.map((tool) => (
            <a href={tool.href} class="rounded-lg border border-brand-100 bg-white p-4 hover:border-brand-200 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-900 hover:text-brand-700">{tool.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{tool.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/fr/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{post.data.category}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('fr-FR', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">Guides bientôt disponibles.</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>