---
import { getCollection } from 'astro:content';
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import AdSlot from "../../../components/AdSlot.astro";
import CoverImage from "../../../components/CoverImage.astro";

const CATEGORY = 'esim';
const posts = (await getCollection('posts'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Guides eSIM et données pour la Chine — Restez connecté dès votre arrivée';
const description =
  'Comparez et configurez les meilleurs forfaits de données eSIM pour voyager en Chine. Connectez-vous dès l’instant où vous atterrissez, sans avoir à remplacer votre carte SIM physique.';

const connectionChoices = [
  {
    title: 'eSIM',
    desc: 'La meilleure option pour la plupart des courts séjours si votre téléphone prend en charge l’eSIM et que vous voulez avoir vos données prêtes avant l’atterrissage.',
  },
  {
    title: 'Roaming',
    desc: 'Utile comme solution de secours pour les SMS bancaires et la connectivité de la première heure, mais souvent plus coûteux en cas d’usage intensif des données.',
  },
  {
    title: 'Pocket Wi-Fi or local SIM',
    desc: 'À envisager pour les groupes, les séjours plus longs ou les téléphones qui ne peuvent pas installer d’eSIM de voyage.',
  },
];

const internetTools = [
  { href: '/tools/esim-comparison/', title: 'Comparateur de forfaits eSIM', desc: 'Comparez les forfaits de données de voyage, leur durée de validité et les cas d’usage attendus.' },
  { href: '/tools/app-availability-checker/', title: 'Vérificateur de disponibilité des applications', desc: 'Vérifiez si les applications courantes fonctionnent en Chine et quelles alternatives préparer.' },
  { href: '/posts/internet-access-china-apps-that-work-2026/', title: 'Guide d’accès à Internet', desc: 'Comprenez l’accès aux applications, les attentes concernant les VPN et la configuration pratique avant l’arrivée.' },
];
import { getCategoryLabel } from "../../../i18n/categories";
const locale = 'en';
---
<!-- Contenu genere avec assistance IA, revise par un redacteur natif -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">eSIM</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Guides eSIM et données</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="hub-esim" alt="Options de réseau mobile et de connectivité des données pour un voyage en Chine" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-esim">
      <h2 id="featured-esim" class="sr-only">Guides Internet mis en avant</h2>
      <a href="/posts/best-esim-for-china-travel-2026/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Meilleure eSIM 2026</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Comparez Airalo, Holafly, Nomad pour voyager en Chine</p>
      </a>
      <a href="/posts/china-esim-vs-roaming-2026-the-real-10-day-cost/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">eSIM vs roaming</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Comparaison réelle des coûts sur 10 jours pour les touristes</p>
      </a>
      <a href="/posts/do-you-need-a-vpn-in-china-2026/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Guide VPN 2026</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Les touristes ont-ils encore besoin d’un VPN en Chine ?</p>
      </a>
      <a href="/posts/pocket-wifi-vs-esim-vs-sim-china/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Pocket WiFi vs eSIM</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Comparez toutes les options de connectivité</p>
      </a>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[1fr_340px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">Choisissez votre configuration Internet pour la Chine</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          La configuration la plus sûre pour les visiteurs consiste généralement en une option de données principale plus une solution de secours pour la banque, les cartes, la traduction et les applications de VTC pendant le premier jour.
        </p>
        <div class="mt-5 grid gap-3">
          {connectionChoices.map((choice) => (
            <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
              <h3 class="text-sm font-bold text-gray-900">{choice.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{choice.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Outils Internet</h2>
        <div class="mt-4 grid gap-3">
          {internetTools.map((tool) => (
            <a href={tool.href} class="rounded-lg border border-brand-100 bg-white p-4 hover:border-brand-200 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-900 hover:text-brand-700">{tool.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{tool.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{getCategoryLabel(post.data.category, locale)}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">Guides à venir prochainement.</p>}
    </section>
  
    <section class="mt-12 rounded-lg border border-gray-200 bg-gray-50 p-6">
      <h2 class="text-xl font-bold text-gray-950">Guides Internet associés</h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <a href="/posts/best-esim-for-china-travel-2026/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Meilleurs forfaits eSIM 2026</p>
          <p class="mt-1 text-sm text-gray-600">Comparez les principaux fournisseurs d’eSIM pour voyager en Chine</p>
        </a>
        <a href="/posts/china-esim-vs-roaming-2026-the-real-10-day-cost/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Coût eSIM vs roaming</p>
          <p class="mt-1 text-sm text-gray-600">Comparaison réelle des coûts sur 10 jours pour les voyageurs en Chine</p>
        </a>
        <a href="/posts/do-you-need-a-vpn-in-china-2026/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Guide VPN pour la Chine</p>
          <p class="mt-1 text-sm text-gray-600">Avez-vous besoin d’un VPN ? Lesquels fonctionnent en 2026 ?</p>
        </a>
        <a href="/posts/internet-access-china-apps-that-work-2026/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Guide d’accès à Internet</p>
          <p class="mt-1 text-sm text-gray-600">Quelles applications fonctionnent sans VPN en Chine</p>
        </a>
      </div>
    </section>
</main>
  <Footer />
</BaseLayout>