---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Phrases chinoises essentielles pour les voyageurs';
const description =
  'Une liste pratique et imprimable de phrases de mandarin utiles en voyage, avec pinyin et traduction française. Paiement, transport, repas, salutations et urgences.';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Outil</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Phrases chinoises essentielles</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>
    <AdSlot format="banner" />
    <div class="mt-6 rounded-lg border border-gray-200 bg-white p-5">
      <p class="text-sm leading-6 text-gray-600">
        Cette page sert surtout d’aide visuelle rapide. Les caractères chinois et le pinyin restent
        inchangés, mais les intitulés sont adaptés pour un public francophone.
      </p>
    </div>
    <AffiliateCta
      title="Restez connecté pour traduire sur place"
      description="Une eSIM adaptée facilite l’usage des applications de traduction, des cartes et des messages dès l’arrivée."
      buttonText="Voir les eSIM"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>
