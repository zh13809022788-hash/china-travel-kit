---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Mes applications fonctionneront-elles en Chine ? V\u00e9rificateur de disponibilit\u00e9 des applis';
const description =
  'V\u00e9rifiez si Google, WhatsApp, Instagram et d\u2019autres applis fonctionnent en Chine sans VPN, et d\u00e9couvrez l\u2019alternative locale pour chaque service bloqu\u00e9.';

interface AppInfo {
  name: string;
  category: string;
  status: 'works' | 'blocked' | 'partial';
  note: string;
  alt?: string;
}

const apps: AppInfo[] = [
  { name: 'Google Search', category: 'Google', status: 'blocked', note: 'Bloqu\u00e9 sans VPN.', alt: 'Bing (fonctionne) ou Baidu' },
  { name: 'Google Maps', category: 'Google', status: 'partial', note: 'Se charge, mais les donn\u00e9es sont inexactes ou d\u00e9cal\u00e9es en Chine continentale.', alt: 'Apple Maps, Amap ou Baidu Maps' },
  { name: 'Gmail', category: 'Google', status: 'blocked', note: 'Bloqu\u00e9 sans VPN.', alt: 'Outlook ou une messagerie non Google' },
  { name: 'YouTube', category: 'Google', status: 'blocked', note: 'Bloqu\u00e9 sans VPN.', alt: 'Bilibili (local)' },
  { name: 'WhatsApp', category: 'Messagerie', status: 'blocked', note: 'Bloqu\u00e9 sans VPN.', alt: 'WeChat' },
  { name: 'Facebook', category: 'R\u00e9seaux sociaux', status: 'blocked', note: 'Bloqu\u00e9 sans VPN.', alt: 'Moments sur WeChat / RED' },
  { name: 'Instagram', category: 'R\u00e9seaux sociaux', status: 'blocked', note: 'Bloqu\u00e9 sans VPN.', alt: 'RED (Xiaohongshu)' },
  { name: 'X (Twitter)', category: 'R\u00e9seaux sociaux', status: 'blocked', note: 'Bloqu\u00e9 sans VPN.', alt: 'Weibo' },
  { name: 'Telegram', category: 'Messagerie', status: 'blocked', note: 'Bloqu\u00e9 sans VPN.', alt: 'WeChat' },
  { name: 'WeChat', category: 'Messagerie', status: 'works', note: 'Fonctionne pleinement, c\u2019est l\u2019application par d\u00e9faut en Chine.' },
  { name: 'Apple services (iMessage, App Store)', category: 'Apple', status: 'works', note: 'Fonctionnent normalement.' },
  { name: 'Microsoft / Bing / Outlook', category: 'Microsoft', status: 'works', note: 'Fonctionnent normalement.' },
  { name: 'Booking.com', category: 'Voyage', status: 'works', note: 'Fonctionne normalement.' },
  { name: 'Airbnb', category: 'Voyage', status: 'works', note: 'Fonctionne normalement.' },
  { name: 'Trip.com', category: 'Voyage', status: 'works', note: 'Fonctionne pleinement, excellent pour les trains et les h\u00f4tels.' },
  { name: 'Alipay', category: 'Paiement', status: 'works', note: 'Fonctionne pleinement et prend en charge les cartes \u00e9trang\u00e8res.' },
  { name: 'Uber', category: 'Transport', status: 'blocked', note: 'N\u2019est pas op\u00e9rationnel en Chine continentale.', alt: 'DiDi' },
  { name: 'Netflix', category: 'M\u00e9dias', status: 'blocked', note: 'Non disponible en Chine continentale.', alt: 'Streaming local ou t\u00e9l\u00e9chargement avant le d\u00e9part' },
  { name: 'Spotify', category: 'M\u00e9dias', status: 'blocked', note: 'Non disponible en Chine continentale.', alt: 'QQ Music / t\u00e9l\u00e9chargement hors ligne au pr\u00e9alable' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Outil</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Mes applications fonctionneront-elles en Chine&nbsp;?</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-4">
      <label class="flex flex-col text-sm sm:max-w-sm">
        <span class="mb-1 font-medium text-gray-700">Rechercher ou filtrer des applis</span>
        <input
          id="search"
          type="text"
          placeholder="Ex.&nbsp;: WhatsApp, Google, Netflix"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm"
        />
      </label>
      <div class="mt-3 flex flex-wrap gap-2 text-sm">
        <button data-status="all" class="status-filter btn-primary px-3 py-1">Toutes</button>
        <button data-status="works" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">Fonctionne</button>
        <button data-status="partial" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">Partiel</button>
        <button data-status="blocked" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">Bloqu&eacute;</button>
      </div>
    </div>

    <div id="app-list" class="mt-6 grid gap-3 sm:grid-cols-2"></div>
    <p id="no-results" class="hidden py-8 text-center text-gray-500">Aucune appli ne correspond &agrave; votre recherche.</p>

    <AffiliateCta
      title="Gardez vos applis actives avec une eSIM de voyage"
      description="Une eSIM de voyage pour la Chine qui contourne les restrictions locales permet &agrave; vos applis habituelles de rester en ligne, sans configuration VPN s&eacute;par&eacute;e."
      buttonText="Voir les options eSIM"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ apps }}>
  const listEl = document.getElementById('app-list');
  const noResults = document.getElementById('no-results');
  const searchEl = document.getElementById('search');
  const filters = document.querySelectorAll('.status-filter');
  let activeStatus = 'all';

  const badge = {
    works: { cls: 'bg-green-100 text-green-800', label: 'Fonctionne' },
    partial: { cls: 'bg-amber-100 text-amber-800', label: 'Partiel' },
    blocked: { cls: 'bg-red-100 text-red-800', label: 'Bloqu\u00e9' },
  };

  function render() {
    const q = searchEl.value.trim().toLowerCase();
    const list = apps.filter((a) => {
      const matchStatus = activeStatus === 'all' || a.status === activeStatus;
      const matchQuery = !q || a.name.toLowerCase().includes(q) || a.category.toLowerCase().includes(q);
      return matchStatus && matchQuery;
    });

    listEl.innerHTML = list
      .map((a) => `
        <div class="card">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="font-bold text-gray-900">${a.name}</h3>
              <span class="text-xs text-gray-400">${a.category}</span>
            </div>
            <span class="whitespace-nowrap rounded-full px-2.5 py-0.5 text-xs font-semibold ${badge[a.status].cls}">${badge[a.status].label}</span>
          </div>
          <p class="mt-2 text-sm text-gray-600">${a.note}</p>
          ${a.alt ? `<p class="mt-1.5 text-sm"><span class="text-gray-500">Utilisez plut\u00f4t :</span> <span class="font-medium text-brand-600">${a.alt}</span></p>` : ''}
        </div>`)
      .join('');

    noResults.classList.toggle('hidden', list.length > 0);
  }

  searchEl.addEventListener('input', render);
  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeStatus = btn.dataset.status;
      filters.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('btn-primary', on);
        ['rounded-lg', 'border', 'border-gray-300', 'font-medium', 'text-gray-700'].forEach((c) => b.classList.toggle(c, !on));
      });
      render();
    });
  });

  render();
</script>
