---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import AdSlot from "../../../components/AdSlot.astro";
import AffiliateCta from "../../../components/AffiliateCta.astro";
import { AFFILIATE_LINKS } from "../../../config";

const title = 'Mes apps fonctionneront-elles en Chine ? Vérificateur de disponibilité des apps';
const description =
  'Vérifiez si Google, WhatsApp, Instagram et d’autres apps fonctionnent en Chine sans VPN — et découvrez l’alternative locale pour chaque service bloqué.';

interface AppInfo {
  name: string;
  category: string;
  status: 'works' | 'blocked' | 'partial';
  note: string;
  alt?: string;
}

const apps: AppInfo[] = [
  { name: 'Google Search', category: 'Google', status: 'blocked', note: 'Bloqué sans VPN.', alt: 'Bing (fonctionne) ou Baidu' },
  { name: 'Google Maps', category: 'Google', status: 'partial', note: 'Se charge, mais les données sont inexactes/décalées en Chine continentale.', alt: 'Apple Maps, Amap ou Baidu Maps' },
  { name: 'Gmail', category: 'Google', status: 'blocked', note: 'Bloqué sans VPN.', alt: 'Outlook / un e-mail non-Google' },
  { name: 'YouTube', category: 'Google', status: 'blocked', note: 'Bloqué sans VPN.', alt: 'Bilibili (local)' },
  { name: 'WhatsApp', category: 'Messaging', status: 'blocked', note: 'Bloqué sans VPN.', alt: 'WeChat' },
  { name: 'Facebook', category: 'Social', status: 'blocked', note: 'Bloqué sans VPN.', alt: 'WeChat Moments / RED' },
  { name: 'Instagram', category: 'Social', status: 'blocked', note: 'Bloqué sans VPN.', alt: 'RED (Xiaohongshu)' },
  { name: 'X (Twitter)', category: 'Social', status: 'blocked', note: 'Bloqué sans VPN.', alt: 'Weibo' },
  { name: 'Telegram', category: 'Messaging', status: 'blocked', note: 'Bloqué sans VPN.', alt: 'WeChat' },
  { name: 'WeChat', category: 'Messaging', status: 'works', note: 'Fonctionne entièrement — c’est l’app par défaut en Chine.' },
  { name: 'Apple services (iMessage, App Store)', category: 'Apple', status: 'works', note: 'Fonctionne normalement.' },
  { name: 'Microsoft / Bing / Outlook', category: 'Microsoft', status: 'works', note: 'Fonctionne normalement.' },
  { name: 'Booking.com', category: 'Travel', status: 'works', note: 'Fonctionne normalement.' },
  { name: 'Airbnb', category: 'Travel', status: 'works', note: 'Fonctionne normalement.' },
  { name: 'Trip.com', category: 'Travel', status: 'works', note: 'Fonctionne entièrement — excellent pour les trains et les hôtels.' },
  { name: 'Alipay', category: 'Payment', status: 'works', note: 'Fonctionne entièrement — prend en charge les cartes étrangères.' },
  { name: 'Uber', category: 'Transport', status: 'blocked', note: 'N’est pas opérationnel en Chine continentale.', alt: 'DiDi' },
  { name: 'Netflix', category: 'Media', status: 'blocked', note: 'Non disponible en Chine continentale.', alt: 'Streaming local ou téléchargement à l’avance' },
  { name: 'Spotify', category: 'Media', status: 'blocked', note: 'Non disponible en Chine continentale.', alt: 'QQ Music / télécharger hors ligne d’abord' },
];
---
<!-- Contenu genere avec assistance IA, revise par un redacteur natif -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Outil</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Mes apps fonctionneront-elles en Chine ?</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-4">
      <label class="flex flex-col text-sm sm:max-w-sm">
        <span class="mb-1 font-medium text-gray-700">Rechercher ou filtrer des apps</span>
        <input id="search" type="text" placeholder="ex. WhatsApp, Google, Netflix"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <div class="mt-3 flex flex-wrap gap-2 text-sm">
        <button data-status="all" class="status-filter btn-primary px-3 py-1">Toutes</button>
        <button data-status="works" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">✅ Fonctionne</button>
        <button data-status="partial" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">⚠️ Partiel</button>
        <button data-status="blocked" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">🚫 Bloqué</button>
      </div>
    </div>

    <div id="app-list" class="mt-6 grid gap-3 sm:grid-cols-2"></div>
    <p id="no-results" class="hidden py-8 text-center text-gray-500">Aucune app ne correspond à votre recherche.</p>

    <AffiliateCta
      title="Gardez vos apps actives avec une eSIM de voyage"
      description="Une eSIM de voyage pour la Chine qui contourne les restrictions locales permet à vos apps habituelles de rester en ligne — sans configuration VPN séparée."
      buttonText="Voir les options eSIM"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ apps }}>
  const listEl = document.getElementById('app-list');
  const noResults = document.getElementById('no-results');
  const searchEl = document.getElementById('search');
  const filters = document.querySelectorAll('.status-filter');
  let activeStatus = 'all';

  const badge = {
    works: { cls: 'bg-green-100 text-green-800', label: '✅ Fonctionne' },
    partial: { cls: 'bg-amber-100 text-amber-800', label: '⚠️ Partiel' },
    blocked: { cls: 'bg-red-100 text-red-800', label: '🚫 Bloqué' },
  };

  function render() {
    const q = searchEl.value.trim().toLowerCase();
    const list = apps.filter((a) => {
      const matchStatus = activeStatus === 'all' || a.status === activeStatus;
      const matchQuery = !q || a.name.toLowerCase().includes(q) || a.category.toLowerCase().includes(q);
      return matchStatus && matchQuery;
    });

    listEl.innerHTML = list
      .map((a) => `
        <div class="card">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="font-bold text-gray-900">${a.name}</h3>
              <span class="text-xs text-gray-400">${a.category}</span>
            </div>
            <span class="whitespace-nowrap rounded-full px-2.5 py-0.5 text-xs font-semibold ${badge[a.status].cls}">${badge[a.status].label}</span>
          </div>
          <p class="mt-2 text-sm text-gray-600">${a.note}</p>
          ${a.alt ? `<p class="mt-1.5 text-sm"><span class="text-gray-500">À utiliser à la place :</span> <span class="font-medium text-brand-600">${a.alt}</span></p>` : ''}
        </div>`)
      .join('');

    noResults.classList.toggle('hidden', list.length > 0);
  }

  searchEl.addEventListener('input', render);
  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeStatus = btn.dataset.status;
      filters.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('btn-primary', on);
        ['rounded-lg', 'border', 'border-gray-300', 'font-medium', 'text-gray-700'].forEach((c) => b.classList.toggle(c, !on));
      });
      render();
    });
  });

  render();
</script>