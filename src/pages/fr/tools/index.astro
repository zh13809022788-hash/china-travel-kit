---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import { TOOLS as tools } from '../../config';

const title = 'Outils gratuits pour voyager en Chine : visa, paiement, eSIM, budget, cartes pour chauffeurs et phrases';
const description =
  'Outils interactifs gratuits pour planifier un voyage en Chine : vérifiez l’entrée sans visa, la compatibilité des cartes de paiement, les options eSIM, le budget du voyage, une réserve d’argent liquide, les prises électriques, les phrases en chinois et les cartes d’adresse pour chauffeur de taxi.';

const toolUseCases = [
  {
    title: 'Avant de réserver vos vols',
    text: 'Utilisez le vérificateur d’entrée sans visa, l’outil pour choisir la meilleure période et l’estimateur de budget avant de fixer vos dates et vos villes.',
    links: [
      { href: '/tools/visa-free-checker/', label: 'Vérificateur d’entrée sans visa' },
      { href: '/tools/best-time-to-visit/', label: 'Meilleure période pour partir' },
      { href: '/tools/budget-cash-estimator/', label: 'Estimateur de budget' },
    ],
  },
  {
    title: 'Avant le départ',
    text: 'Utilisez les outils de paiement, eSIM, applications, prises et phrases pendant que vous avez encore le temps de résoudre les problèmes de configuration depuis chez vous.',
    links: [
      { href: '/tools/payment-checker/', label: 'Vérificateur de paiement' },
      { href: '/tools/esim-comparison/', label: 'Comparateur eSIM' },
      { href: '/tools/app-availability-checker/', label: 'Vérificateur d’applications' },
    ],
  },
  {
    title: 'Une fois sur place en Chine',
    text: 'Utilisez les cartes pour chauffeurs, la conversion de devises et les phrases essentielles lorsque les applications, les taxis, les menus ou les comptoirs d’accueil deviennent déroutants.',
    links: [
      { href: '/tools/survival-kit/', label: 'Kit de survie' },
      { href: '/tools/show-to-driver/', label: 'Montrer au chauffeur' },
      { href: '/tools/currency-converter/', label: 'Convertisseur RMB' },
      { href: '/tools/essential-phrases/', label: 'Phrases essentielles' },
    ],
  },
];

const toolsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  hasPart: tools.map((tool) => ({
    '@type': 'WebApplication',
    name: tool.title,
    description: tool.desc,
    applicationCategory: 'TravelApplication',
    url: new URL(tool.href, 'https://www.chinatripbox.com').toString(),
  })),
};
---
<!-- Contenu genere avec assistance IA, revise par un redacteur natif -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(toolsJsonLd)} />
  <Header />
  <main class="container-page py-12">
    <header class="max-w-2xl">
      <p class="section-kicker">Centre d’outils</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Outils gratuits pour voyager en Chine</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-primary">Utiliser la checklist avant le départ</a>
        <a href="/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">Lire le guide du premier voyage</a>
      </div>
    </header>

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 lg:grid-cols-3" aria-labelledby="tool-use-cases-heading">
      <div class="lg:col-span-3">
        <h2 id="tool-use-cases-heading" class="text-2xl font-bold text-gray-950">Quel outil utiliser en premier ?</h2>
      </div>
      {toolUseCases.map((useCase) => (
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <h3 class="text-lg font-bold text-gray-950">{useCase.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{useCase.text}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {useCase.links.map((link) => (
              <a href={link.href} class="block rounded-lg border border-brand-200 bg-brand-50 px-4 py-2 text-sm font-semibold text-brand-700 hover:border-brand-300 hover:bg-brand-100 hover:no-underline">{link.label}</a>
            ))}
          </div>
        </div>
      ))}
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {tools.map((tool) => (
        <a href={tool.href} class="card block hover:no-underline">
          <div class="text-3xl">{tool.icon}</div>
          <h2 class="mt-3 text-lg font-bold text-gray-900">{tool.title}</h2>
          <p class="mt-1.5 text-sm text-gray-600">{tool.desc}</p>
          <span class="mt-3 inline-block text-sm font-semibold text-brand-600">Ouvrir l’outil →</span>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>