---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Convertisseur RMB pour les voyageurs en Chine';
const description =
  'Convertissez votre devise en yuan chinois (RMB) et inversement, puis consultez le coût des dépenses courantes en Chine pour vérifier les prix sur place.';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Outil</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Convertisseur RMB</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- Convertisseur -->
    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-6">
      <div class="grid gap-4 sm:grid-cols-[1fr_auto_1fr] sm:items-end">
        <label class="flex flex-col text-sm">
          <span class="mb-1 font-medium text-gray-700">Votre devise</span>
          <div class="flex gap-2">
            <select id="currency" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
              <option value="USD">USD ($)</option>
              <option value="EUR">EUR (€)</option>
              <option value="GBP">GBP (£)</option>
              <option value="AUD">AUD (A$)</option>
              <option value="CAD">CAD (C$)</option>
              <option value="JPY">JPY (¥)</option>
              <option value="SGD">SGD (S$)</option>
            </select>
            <input id="foreign-amount" type="number" min="0" value="100"
              class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
          </div>
        </label>
        <div class="hidden pb-2 text-center text-gray-400 sm:block">⇄</div>
        <label class="flex flex-col text-sm">
          <span class="mb-1 font-medium text-gray-700">Yuan chinois (RMB)</span>
          <input id="rmb-amount" type="number" min="0"
            class="w-full rounded-lg border border-gray-300 px-3 py-2 text-sm" />
        </label>
      </div>
      <p id="rate-line" class="mt-3 text-sm text-gray-500"></p>
      <p class="mt-1 text-xs text-gray-400">
        Les taux sont des références approximatives pour préparer votre voyage, pas des taux de marché en direct.
        Consultez votre banque ou un convertisseur en temps réel pour connaître le taux exact au moment de la transaction.
      </p>
    </div>

    <!-- Coût des dépenses courantes -->
    <section class="mt-8">
      <h2 class="text-xl font-bold text-gray-900">Combien coûtent les choses en Chine</h2>
      <p class="mt-1 text-sm text-gray-500">Prix typiques en RMB, avec votre devise affichée à titre indicatif.</p>
      <div id="cost-grid" class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3"></div>
    </section>

    <AffiliateCta
      title="Éviter le bureau de change"
      description="Associez une carte sans frais de change à Alipay ou WeChat Pay et payez au taux réel, sans majoration de change en espèces."
      buttonText="Voir la configuration du paiement"
      placeholder={AFFILIATE_LINKS.payment}
    />
  </main>
  <Footer />
</BaseLayout>

<script>
  // Taux de référence approximatifs : 1 unité de devise = X RMB.
  const ratesToRmb: Record<string, number> = {
    USD: 7.2,
    EUR: 7.8,
    GBP: 9.1,
    AUD: 4.7,
    CAD: 5.2,
    JPY: 0.048,
    SGD: 5.3,
  };
  const symbols: Record<string, string> = {
    USD: '$', EUR: '€', GBP: '£', AUD: 'A$', CAD: 'C$', JPY: '¥', SGD: 'S$',
  };

  const commonCosts: { label: string; rmb: number }[] = [
    { label: 'Bouteille d’eau', rmb: 2 },
    { label: 'Trajet en métro', rmb: 4 },
    { label: 'En-cas de cuisine de rue', rmb: 10 },
    { label: 'Café', rmb: 30 },
    { label: 'Repas dans un restaurant simple', rmb: 45 },
    { label: 'Court trajet DiDi / taxi', rmb: 25 },
    { label: 'Train à grande vitesse (1 à 2 h)', rmb: 250 },
    { label: 'Billet de musée / attraction', rmb: 60 },
    { label: 'Hôtel milieu de gamme / nuit', rmb: 450 },
  ];

  const currencyEl = document.getElementById('currency') as HTMLSelectElement;
  const foreignEl = document.getElementById('foreign-amount') as HTMLInputElement;
  const rmbEl = document.getElementById('rmb-amount') as HTMLInputElement;
  const rateLine = document.getElementById('rate-line');
  const costGrid = document.getElementById('cost-grid');

  function rate() {
    return ratesToRmb[currencyEl.value];
  }
  function sym() {
    return symbols[currencyEl.value];
  }

  function fromForeign() {
    const v = Number(foreignEl.value) || 0;
    rmbEl.value = (v * rate()).toFixed(2);
    updateMeta();
  }
  function fromRmb() {
    const v = Number(rmbEl.value) || 0;
    foreignEl.value = (v / rate()).toFixed(2);
    updateMeta();
  }

  function updateMeta() {
    if (rateLine) {
      rateLine.textContent = `Taux de référence : 1 ${currencyEl.value} ≈ ¥${rate().toFixed(2)} RMB`;
    }
    if (costGrid) {
      costGrid.innerHTML = commonCosts
        .map((c) => `
          <div class="card">
            <span class="text-sm text-gray-500">${c.label}</span>
            <div class="mt-1 flex items-baseline gap-2">
              <span class="text-xl font-bold text-gray-900">¥${c.rmb}</span>
              <span class="text-sm text-brand-600">≈ ${sym()}${(c.rmb / rate()).toFixed(2)}</span>
            </div>
          </div>`)
        .join('');
    }
  }

  foreignEl.addEventListener('input', fromForeign);
  rmbEl.addEventListener('input', fromRmb);
  currencyEl.addEventListener('change', fromForeign);

  fromForeign();
</script>
