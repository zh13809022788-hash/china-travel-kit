---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ShowToLocal from '../../../components/ShowToLocal.astro';
import SurvivalChecklist from '../../../components/SurvivalChecklist.astro';
import ContextAiBubble from '../../../components/ContextAiBubble.astro';
import survivalKits from '../../../data/survival-kits.json';

const title = 'Kit de survie Chine : cartes de traduction et checklists de voyage';
const description =
  'Kits de survie interactifs pour les visiteurs étrangers en Chine : cartes de traduction plein écran, checklists d’arrivée, cartes d’allergies alimentaires et outils de communication locale.';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Kit de survie</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-950 md:text-4xl">Kit de survie Chine</h1>
      <p class="mt-3 text-lg leading-8 text-gray-600">
        Utilisez des cartes de traduction plein écran et des checklists enregistrées lorsque lire un
        long guide prend trop de temps : arrivée à l’aéroport, enregistrement à l’hôtel, taxis,
        restaurants, allergies et configuration du premier jour.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="#arrival" class="btn-primary">Commencer par l’arrivée</a>
        <a href="#food" class="btn-outline">Ouvrir les cartes repas</a>
      </div>
    </header>

    <section class="mt-8 grid gap-4 md:grid-cols-3">
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Cartes plein écran</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Touchez une carte et montrez un grand texte chinois à un chauffeur, à la réception d’un hôtel ou au personnel d’un restaurant.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Checklists enregistrées</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Votre progression est enregistrée dans le navigateur afin que vous puissiez fermer la page et revenir plus tard.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Accès à l’aide IA contextuelle</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Utilisez l’assistant flottant pour ouvrir l’aide voyage ChinaTripBox avec une question adaptée au sujet.</p>
      </div>
    </section>

    <div class="mt-10 grid gap-8">
      {survivalKits.map((kit) => (
        <section id={kit.slug} class="grid gap-5 rounded-xl border border-gray-200 bg-gray-50 p-5">
          <div class="max-w-3xl">
            <p class="section-kicker">Kit {kit.slug}</p>
            <h2 class="mt-1 text-2xl font-bold text-gray-950">{kit.title}</h2>
            <p class="mt-2 text-sm leading-6 text-gray-600">{kit.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {kit.related_paths.map((path) => (
                <a href={path} class="rounded-full border border-gray-200 bg-white px-3 py-1.5 text-xs font-semibold text-brand-700 hover:border-brand-300 hover:no-underline">
                  Guide associé
                </a>
              ))}
            </div>
          </div>
          <div class="grid gap-5 lg:grid-cols-[1fr_0.85fr]">
            <ShowToLocal themeId={kit.theme_id} tools={kit.tools} />
            <SurvivalChecklist themeId={kit.theme_id} steps={kit.checklist_steps} />
          </div>
        </section>
      ))}
    </div>
  </main>
  <ContextAiBubble defaultPrompt="Aidez-moi à utiliser le kit de survie Chine pour l’arrivée, les restaurants, les cartes de traduction et la préparation des checklists." />
  <Footer />
</BaseLayout>
