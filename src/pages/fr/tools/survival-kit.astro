---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import ShowToLocal from "../../../components/ShowToLocal.astro";
import SurvivalChecklist from "../../../components/SurvivalChecklist.astro";
import survivalKits from "../../../data/survival-kits.json";

const title = 'Kit de survie pour la Chine : cartes de traduction et check-lists de voyage';
const description =
  'Kits de survie interactifs pour la Chine destinés aux visiteurs étrangers : cartes de traduction en plein écran, check-lists de préparation à l’arrivée, cartes pour allergies alimentaires et outils de communication locale.';
---
<!-- Contenu genere avec assistance IA, revise par un redacteur natif -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Kit de survie</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-950 md:text-4xl">Kit de survie pour la Chine</h1>
<p class="mt-4 max-w-3xl text-lg leading-8 text-gray-600">
  Notre kit de survie pour la Chine vous aide a preparer votre voyage en toute confiance. Il comprend des check-lists interactives couvrant chaque etape de la preparation avant le depart : demande de visa, assurance voyage, configuration des paiements (Alipay/WeChat Pay), achat d’une eSIM ou d’une carte SIM, reservation d’hebergement et essentiels a emporter. La section des cartes de phrases vous permet de montrer du texte chinois aux habitants dans des situations courantes comme commander a manger, demander son chemin et negocier le prix d’un taxi. Vous pouvez egalement ajouter des cartes personnalisees avec vos propres phrases. Tout est enregistre dans votre navigateur, afin que vous puissiez y revenir a tout moment pendant votre voyage sans creer de compte.
</p>
      <p class="mt-3 text-lg leading-8 text-gray-600">
        Utilisez des cartes de traduction en plein ecran et des check-lists enregistrees dans les moments ou lire un long guide est trop lent :
        arrivee a l’aeroport, enregistrement a l’hotel, taxis, restaurants, allergies et installation du premier jour.
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="#arrival" class="btn-primary">Commencer par l’arrivee</a>
        <a href="#food" class="btn-outline">Ouvrir les cartes alimentaires</a>
      </div>
    </header>

    <section class="mt-8 grid gap-4 md:grid-cols-3">
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Cartes en plein ecran</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Touchez une carte et montrez un grand texte chinois a un chauffeur, au comptoir de l’hotel ou au personnel d’un restaurant.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Check-lists enregistrees</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">La progression de la check-list est stockee dans votre navigateur, vous pouvez donc fermer la page et y revenir plus tard.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Entree IA contextuelle</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Utilisez l’assistant flottant pour ouvrir l’aide au voyage de ChinaTripBox avec une invite adaptee au sujet.</p>
      </div>
    </section>

    <div class="mt-10 grid gap-8">
      {survivalKits.map((kit) => (
        <section id={kit.slug} class="grid gap-5 rounded-xl border border-gray-200 bg-gray-50 p-5">
          <div class="max-w-3xl">
            <p class="section-kicker">{kit.slug} kit</p>
            <h2 class="mt-1 text-2xl font-bold text-gray-950">{kit.title}</h2>
            <p class="mt-2 text-sm leading-6 text-gray-600">{kit.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {kit.related_paths.map((path) => (
                <a href={path} class="rounded-full border border-gray-200 bg-white px-3 py-1.5 text-xs font-semibold text-brand-700 hover:border-brand-300 hover:no-underline">
                  Guide associe
                </a>
              ))}
            </div>
          </div>
          <div class="grid gap-5 lg:grid-cols-[1fr_0.85fr]">
            <ShowToLocal themeId={kit.theme_id} tools={kit.tools} />
            <SurvivalChecklist themeId={kit.theme_id} steps={kit.checklist_steps} />
          </div>
        </section>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>