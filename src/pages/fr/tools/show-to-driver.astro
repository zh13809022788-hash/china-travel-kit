---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';

const title = 'Afficher au pilote: Carte d\'adresse Chinae';
const description =
  'Créez une grande carte de message Chinae sur votre téléphone pour les chauffeurs de taxi, le personnel de l\'hôtel et demandez des instructions en China. Pas de connexion, pas d\'installation d\'application, pas de données personnelles enregistrées.';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-8 md:py-10">
    <header class="max-w-3xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Outil</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Afficher au pilote</h1>
      <p class="mt-3 text-lg text-gray-600">
        Générer une grande carte Chinae pour les taxis, les pick-up, les réceptions de l'hôtel, et demander
pour les directions. Tout fonctionne dans votre navigateur.
      </p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-6 lg:grid-cols-[minmax(0,0.9fr)_minmax(0,1.1fr)]">
      <div class="rounded-xl border border-gray-200 bg-gray-50 p-5">
        <div class="grid gap-4">
          <label class="flex flex-col text-sm">
            <span class="mb-1 font-medium text-gray-700">Adresse ou nom du lieu China</span>
            <textarea
              id="destination"
              rows="4"
              class="rounded-lg border border-gray-300 px-3 py-2 text-base"
              placeholder="Collez l'adresse Chinae de Amap, Trip.com, votre réservation d'hôtel ou un ami."
            ></textarea>
            <span class="mt-1 text-xs text-gray-500">
              Meilleur résultat : coller le nom/adresse China. Les noms de lieux en anglais seulement peuvent être difficiles pour un
chauffeur local à identifier.
            </span>
          </label>

          <label class="flex flex-col text-sm">
            <span class="mb-1 font-medium text-gray-700">Note facultative</span>
            <select id="note" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
              <option value="route">Veuillez suivre la navigation et me conduire à cette adresse.</option>
              <option value="pickup">J'attends ici. Appelez-moi ou envoyez-moi un message dans l'application.</option>
              <option value="hotel">Aidez-moi à rejoindre cet hôtel ou à contacter la réception.</option>
              <option value="stop">S'il vous plaît arrêtez ici si c'est sûr et légal.</option>
              <option value="receipt">Donnez-moi un reçu si possible.</option>
            </select>
          </label>

          <label class="flex flex-col text-sm">
            <span class="mb-1 font-medium text-gray-700">Détails supplémentaires pour le conducteur</span>
            <input
              id="extra"
              class="rounded-lg border border-gray-300 px-3 py-2 text-base"
              placeholder="Numéro de porte, hall d'hôtel, point de réception, bagages, etc."
            />
          </label>

          <div class="grid gap-3 sm:grid-cols-2">
            <button id="generate-btn" class="btn-primary">Générer la carte</button>
            <button
              id="clear-btn"
              class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:border-brand-400"
            >
              Effacer
            </button>
          </div>
        </div>

        <div class="mt-5 rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-900">
          Cet outil ne réserve pas les tours ou les pilotes de contact. Pour les urgences, contactez le service local d'urgence
services ou votre hôtel d'abord.
        </div>
      </div>

      <section class="min-w-0">
        <div id="driver-card" class="rounded-xl border border-gray-900 bg-white p-5 shadow-sm">
          <div class="flex items-center justify-between gap-3 border-b border-gray-200 pb-3">
            <div>
              <p class="text-xs font-semibold uppercase tracking-wide text-gray-500">Afficher cet écran</p>
              <h2 class="text-lg font-bold text-gray-900">给司机看的中文小条</h2>
            </div>
            <span class="rounded-full bg-green-50 px-3 py-1 text-xs font-semibold text-green-700">
              Hors ligne
            </span>
          </div>

          <div class="py-5">
            <p id="main-line" class="text-center text-2xl font-black leading-tight text-gray-950 sm:text-4xl">
              请帮我去这个地址
            </p>
            <p
              id="address-line"
              class="mt-5 whitespace-pre-wrap break-words text-center text-4xl font-black leading-tight text-gray-950 sm:text-6xl"
            >
              在左侧输入地址
            </p>
            <p id="note-line" class="mt-5 text-center text-2xl font-bold leading-snug text-gray-900 sm:text-3xl">
              请按照导航路线行驶，谢谢。
            </p>
            <p id="extra-line" class="mt-4 hidden whitespace-pre-wrap break-words text-center text-xl font-semibold text-gray-800 sm:text-2xl"></p>
          </div>

          <div class="grid gap-3 border-t border-gray-200 pt-4 sm:grid-cols-3">
            <button id="copy-btn" class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:border-brand-400">
              Copier le texte
            </button>
            <button id="fullscreen-btn" class="rounded-lg border border-gray-300 px-4 py-2 text-sm font-semibold text-gray-700 hover:border-brand-400">
              Plein écran
            </button>
            <a href="/fr/travel-help/" class="rounded-lg border border-brand-200 px-4 py-2 text-center text-sm font-semibold text-brand-700 hover:border-brand-400">
              Demander l’aide AI
            </a>
          </div>
        </div>

        <div class="mt-5 grid gap-3 sm:grid-cols-2">
          <button data-quick="请问这个地址怎么走？谢谢。" class="quick rounded-lg border border-gray-300 px-4 py-3 text-left text-sm font-medium text-gray-700 hover:border-brand-400">
            Demander des directions
          </button>
          <button data-quick="我不会说中文，请用翻译软件和我沟通，谢谢。" class="quick rounded-lg border border-gray-300 px-4 py-3 text-left text-sm font-medium text-gray-700 hover:border-brand-400">
            Je ne parle pas China
          </button>
          <button data-quick="请在安全合法的地方停车，谢谢。" class="quick rounded-lg border border-gray-300 px-4 py-3 text-left text-sm font-medium text-gray-700 hover:border-brand-400">
            Arrêter en toute sécurité
          </button>
          <button data-quick="如果找不到我，请在打车软件里发消息。" class="quick rounded-lg border border-gray-300 px-4 py-3 text-left text-sm font-medium text-gray-700 hover:border-brand-400">
            Messagez-moi dans l'application
          </button>
        </div>
      </section>
    </section>
  </main>
  <Footer />
</BaseLayout>

<style>
  #driver-card:fullscreen {
    display: flex;
    min-height: 100vh;
    width: 100vw;
    flex-direction: column;
    justify-content: center;
    border-radius: 0;
    border: 0;
    padding: 6vw;
  }
</style>

<script>
  const noteMap: Record<string, string> = {
    route: '请按照导航路线行驶，谢谢。',
    pickup: '我在这里等您，请在打车软件里联系我。',
    hotel: '请帮我到这家酒店，必要时请联系酒店前台。',
    stop: '请在安全合法的地方停车，谢谢。',
    receipt: '如果可以的话，请给我发票或收据，谢谢。',
  };

  const destination = document.getElementById('destination') as HTMLTextAreaElement | null;
  const note = document.getElementById('note') as HTMLSelectElement | null;
  const extra = document.getElementById('extra') as HTMLInputElement | null;
  const mainLine = document.getElementById('main-line');
  const addressLine = document.getElementById('address-line');
  const noteLine = document.getElementById('note-line');
  const extraLine = document.getElementById('extra-line');
  const card = document.getElementById('driver-card');
  const copyBtn = document.getElementById('copy-btn');
  const fullscreenBtn = document.getElementById('fullscreen-btn');
  const generateBtn = document.getElementById('generate-btn');
  const clearBtn = document.getElementById('clear-btn');
  const quickButtons = document.querySelectorAll<HTMLButtonElement>('.quick');

  function cardText() {
    const address = destination?.value.trim() || '在左侧输入地址';
    const noteText = noteMap[note?.value || 'route'];
    const extraText = extra?.value.trim();
    return [
      '请帮我去这个地址：',
      address,
      noteText,
      extraText ? `补充说明：${extraText}` : '',
    ].filter(Boolean).join('\n');
  }

  function render() {
    const address = destination?.value.trim();
    const extraText = extra?.value.trim();
    if (mainLine) mainLine.textContent = '请帮我去这个地址：';
    if (addressLine) addressLine.textContent = address || '在左侧输入地址';
    if (noteLine) noteLine.textContent = noteMap[note?.value || 'route'];
    if (extraLine) {
      extraLine.textContent = extraText ? `补充说明：${extraText}` : '';
      extraLine.classList.toggle('hidden', !extraText);
    }
  }

  generateBtn?.addEventListener('click', () => {
    render();
    card?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });

  [destination, note, extra].forEach((el) => el?.addEventListener('input', render));

  clearBtn?.addEventListener('click', () => {
    if (destination) destination.value = '';
    if (extra) extra.value = '';
    if (note) note.value = 'route';
    render();
  });

  copyBtn?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(cardText());
      copyBtn.textContent = 'Copié';
      window.setTimeout(() => {
        copyBtn.textContent = 'Copier le texte';
      }, 1400);
    } catch {
      copyBtn.textContent = 'Échec de la copie';
    }
  });

  fullscreenBtn?.addEventListener('click', async () => {
    if (!card) return;
    if (!document.fullscreenElement) {
      await card.requestFullscreen?.();
      fullscreenBtn.textContent = 'Exit Plein écran';
    } else {
      await document.exitFullscreen?.();
      fullscreenBtn.textContent = 'Plein écran';
    }
  });

  document.addEventListener('fullscreenchange', () => {
    if (!fullscreenBtn) return;
    fullscreenBtn.textContent = document.fullscreenElement ? 'Exit Plein écran' : 'Plein écran';
  });

  quickButtons.forEach((button) => {
    button.addEventListener('click', () => {
      if (!extra) return;
      extra.value = button.dataset.quick || '';
      render();
      card?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
  });

  render();
</script>
