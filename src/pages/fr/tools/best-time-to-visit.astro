---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import AffiliateCta from '../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../config';

const title = 'Meilleure période pour visiter la Chine — planificateur par ville et par mois';
const description =
  'Consultez la météo, l’affluence et ce qu’il faut emporter pour les grandes villes chinoises mois par mois. Planifiez la meilleure période pour visiter Beijing, Shanghai, Xi\'an, Chengdu, Guangzhou et Harbin.';

const cities = ['Beijing', 'Shanghai', "Xi'an", 'Chengdu', 'Guangzhou', 'Harbin'];
const months = ['Jan', 'Fév', 'Mar', 'Avr', 'Mai', 'Jun', 'Jul', 'Aoû', 'Sep', 'Oct', 'Nov', 'Déc'];
---
<!-- Contenu genere avec assistance IA, revise par un redacteur natif -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Outil</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Meilleure période pour visiter la Chine</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Ville</span>
        <select id="city" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {cities.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Mois du voyage</span>
        <select id="month" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {months.map((m, i) => <option value={i}>{m}</option>)}
        </select>
      </label>
    </div>

    <div id="result" class="mt-6">
      <div class="card" id="result-card"></div>
    </div>

    <!-- Note d’avertissement sur les saisons touristiques -->
    <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
      <strong>Évitez la foule :</strong> les jours fériés chinois — en particulier le Nouvel An chinois
      (fin janv./fév.), la fête du Travail (début mai) et la fête nationale / la Golden Week (première semaine d’octobre)
      — entraînent un énorme trafic touristique intérieur. Les trains et les hôtels affichent complet et les prix flambent. Réservez très à l’avance ou
      planifiez votre voyage en dehors de ces dates.
    </div>

    <AffiliateCta
      title="Réservez trains et hôtels à l’avance"
      description="Les itinéraires populaires affichent rapidement complet en haute saison. Réservez à l’avance votre train à grande vitesse et vos hébergements."
      buttonText="Voir les options de réservation"
      placeholder={AFFILIATE_LINKS.transport}
    />
  </main>
  <Footer />
</BaseLayout>

