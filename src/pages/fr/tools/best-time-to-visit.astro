  const monthEl = document.getElementById('month') as HTMLSelectElement;
  const card = document.getElementById('result-card');

  function render() {
    if (!card) return;
    const city = cityEl.value;
    const m = Number(monthEl.value);
    const info = data[city][m];
    const style = ratingStyle[info.rating];

    card.className = `card border ${style.cls}`;
    card.innerHTML = `
