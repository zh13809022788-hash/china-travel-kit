---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'China Visa-libre et vérificateur de transit';
const description =
  'Vérifiez si vous pouvez entrer China sans visa, utiliser 240 heures de transit sans visa, ou besoin de demander en fonction de votre nationalité et le type de voyage.';

const lastReviewed = '13 juillet 2026';

// Representative policy data for 2026. This is guidance, not legal advice;
// travelers must confirm with an embassy before booking.
const countries = [
  'United States', 'United Kingdom', 'Canada', 'Australia', 'Germany',
  'France', 'Italy', 'Spain', 'Netherlands', 'Japan', 'South Korea',
  'Singapore', 'Malaysia', 'Thailand', 'Brazil', 'New Zealand',
  'Switzerland', 'Ireland', 'Norway', 'Other',
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Outil</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Vérificateur Visa gratuit et en transit</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <p class="mt-3 text-sm text-gray-500">
        Dernière révision : {lastReviewed}. Ce vérificateur est une aide à la planification, pas une décision officielle d’éligibilité.
      </p>
    </header>

    <AdSlot format="banner" />

    <!-- Input controls -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Votre nationalité de passeport</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Type de voyage</span>
        <select id="trip" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="tourism">Tourisme / visite</option>
          <option value="business">Entreprises</option>
          <option value="transit">Juste en transit vers un autre pays</option>
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="check-btn" class="btn-primary w-full sm:w-auto">Vérifier mon éligibilité</button>
      </div>
    </div>

    <!-- Result -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>
      <p class="mt-3 text-xs text-gray-400">
        Les politiques changent fréquemment et dépendent de votre situation particulière. Toujours confirmer avec un
ambassade ou consulat China avant de réserver un voyage. Cet outil fournit des conseils généraux seulement.
      </p>

      <AffiliateCta
        title="Planifiez le reste de votre voyage"
        description="Triez votre connectivité, vos paiements et votre transport avant d'atterrir en China."
        buttonText="Voir l'essentiel des voyages"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6" aria-labelledby="official-sources">
      <h2 id="official-sources" class="text-xl font-bold text-gray-950">Sources officielles à vérifier avant la réservation</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        Les listes de pays sans Visa, les ports d'entrée, les zones de voyage autorisées et les contrôles d'embarquement des compagnies aériennes peuvent changer.
Traiter les règles officielles du gouvernement et des compagnies aériennes comme définitives.
      </p>
      <ul class="mt-4 grid gap-2 text-sm leading-6 text-gray-700">
        <li><a href="https://en.nia.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">Administration nationale de l ' immigration</a> pour les mises à jour de l'inspection aux frontières et de l'exemption de transit.</li>
        <li><a href="https://english.www.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">Portail d ' information du Conseil d ' État</a> pour les annonces de politiques de langue anglaise.</li>
        <li><a href="https://www.mfa.gov.cn/eng/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">Ministère des affaires étrangères</a> et des sites Internet de l'ambassade ou du consulat China pour les règles spécifiques aux passeports.</li>
      </ul>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">Comment éviter les erreurs sans visa</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          L'erreur la plus courante est de mélanger l'entrée sans visa ordinaire avec le transit sans visa. A
aller-retour normal et une escale vers un pays tiers ne sont pas le même itinéraire. Compagnies aériennes
vérifier les documents avant l'embarquement, afin qu'un malentendu puisse arrêter le voyage avant que vous atteigniez
China.
        </p>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-gray-600">
          <li><strong class="text-gray-900">Vérifiez d'abord la nationalité du passeport.</strong> Le pays de résidence et le pays de carte ne décident pas de l'admissibilité sans visa.</li>
          <li><strong class="text-gray-900">Entrée séparée du transit.</strong> Le transit nécessite généralement un voyage confirmé vers un pays ou une région tiers.</li>
          <li><strong class="text-gray-900">Confirmez les ports d'entrée.</strong> Les politiques de transit dépendent des ports désignés et des zones de déplacement autorisées.</li>
          <li><strong class="text-gray-900">Gardez la preuve prête.</strong> Les compagnies aériennes et les agents frontaliers peuvent demander des détails sur le billet, l'hôtel, l'itinéraire ou l'invitation.</li>
        </ul>
      </div>
      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Planifiez le reste de l'arrivée</h2>
        <div class="mt-4 grid gap-3">
          <a href="/fr/posts/china-visa-free-entry-transit-guide-2026/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Lire le guide complet sans visa</a>
          <a href="/fr/posts/first-24-hours-in-china-arrival-checklist/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Utiliser la liste de contrôle d'arrivée</a>
          <a href="/fr/posts/airport-to-city-transport-beijing-shanghai-guangzhou/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Planification des transports aéroportuaires</a>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  type TripKey = 'tourism' | 'business' | 'transit';

  // Nationalities eligible for the 30-day unilateral visa-free entry (2026 program).
  const visaFree30 = new Set([
    'Germany', 'France', 'Italy', 'Spain', 'Netherlands', 'Switzerland',
    'Ireland', 'Norway', 'Japan', 'South Korea', 'Brazil', 'New Zealand',
    'Malaysia', 'Thailand', 'Australia',
  ]);

  // Nationalities eligible for 240-hour (10-day) visa-free transit through
  // designated ports when travelling onward to a third country/region.
  const transit240 = new Set([
    'United States', 'United Kingdom', 'Canada', 'Australia', 'Germany',
    'France', 'Italy', 'Spain', 'Netherlands', 'Japan', 'South Korea',
    'Singapore', 'Switzerland', 'Ireland', 'Norway', 'Brazil', 'New Zealand',
  ]);

  interface Verdict {
    tone: 'good' | 'warn' | 'info';
    heading: string;
    body: string;
    points: string[];
  }

  function evaluate(country: string, trip: TripKey): Verdict {
    const has30 = visaFree30.has(country);
    const hasTransit = transit240.has(country);

    if (trip === 'transit') {
      if (hasTransit) {
        return {
          tone: 'good',
          heading: 'Vous êtes probablement éligible au transit sans visa de 240 heures',
          body: `En tant que titulaire d’un passeport ${country} en transit vers un pays tiers, vous pouvez généralement séjourner jusqu’à 240 heures (10 jours) sans visa en entrant par un port éligible.`,
          points: [
            'Vous devez détenir un billet aller confirmé vers un pays ou une région tiers dans les 240 heures.',
            'L’entrée et la sortie doivent se faire par des ports de transit désignés (la plupart des grands aéroports internationaux sont éligibles).',
            'Vous êtes généralement limité à la province/région d’entrée — vérifiez les règles spécifiques au port.',
          ],
        };
      }
      return {
        tone: 'warn',
        heading: 'L’exemption de visa de transit peut ne pas s’appliquer à votre nationalité',
        body: `${country} ne figure pas sur la liste standard de transit de 240 heures dans nos données. Vous pouvez tout de même être éligible à l’entrée sans visa si vous y avez droit, ou vous pouvez avoir besoin d’un visa de transit (G).`,
        points: [
          'Vérifiez si votre nationalité permet l’entrée sans visa complète à la place.',
          'Si non, demandez le visa approprié avant le voyage.',
        ],
      };
    }

    // tourism or business
    if (has30) {
      return {
        tone: 'good',
        heading: 'Vous êtes probablement éligible à l’entrée sans visa de 30 jours',
        body: `En tant que titulaire d’un passeport ${country}, vous pouvez généralement entrer en Chine sans visa pour jusqu’à 30 jours pour le tourisme, les affaires, les visites familiales ou le transit selon la politique unilatérale actuelle.`,
        points: [
          'Votre passeport doit être valide au moins 6 mois avec des pages vierges.',
          'Ayez une preuve de voyage aller/retour et d’hébergement prête pour l’immigration.',
          'Les 30 jours sont par entrée — confirmez le nombre exact avant de réserver.',
        ],
      };
    }
    if (hasTransit) {
      return {
        tone: 'info',
        heading: 'Un visa est probablement requis — mais l’exemption de transit peut aider',
        body: `${country} ne figure pas sur notre liste d’entrée sans visa de 30 jours pour le tourisme/les affaires, donc un visa est généralement requis. Cependant, si vous passez par la Chine vers un pays tiers, vous pouvez utiliser le transit sans visa de 240 heures à la place.`,
        points: [
          'Pour une visite dédiée, demandez un visa L (touristique) ou M (affaires) à l’avance.',
          'Pour une escale vers ailleurs, vous pouvez être éligible au transit de 240 heures — changez « Type de voyage » sur Transit pour vérifier.',
        ],
      };
    }
    return {
      tone: 'warn',
      heading: 'Un visa est probablement requis',
      body: `D’après nos données, les titulaires d’un passeport ${country} ont généralement besoin d’un visa pour entrer en Chine pour ce type de voyage. Demandez-le auprès d’une ambassade, d’un consulat ou d’un centre de visa agréé avant de voyager.`,
      points: [
        'Demandez un visa L (touristique) ou M (affaires) bien avant votre voyage.',
        'Les justificatifs incluent généralement une invitation ou un itinéraire, des réservations d’hôtel et des billets de retour.',
      ],
    };
  }

  const toneStyles: Record<Verdict['tone'], string> = {
    good: 'border-green-200 bg-green-50',
    warn: 'border-amber-200 bg-amber-50',
    info: 'border-blue-200 bg-blue-50',
  };
  const toneBadge: Record<Verdict['tone'], string> = {
    good: 'bg-green-600 text-white',
    warn: 'bg-amber-500 text-white',
    info: 'bg-blue-600 text-white',
  };
  const toneLabel: Record<Verdict['tone'], string> = {
    good: 'Probablement éligible',
    warn: 'Visa probablement requis',
    info: 'Dépend de votre itinéraire',
  };

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;
  const tripEl = document.getElementById('trip') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const v = evaluate(countryEl.value, tripEl.value as TripKey);
    card.className = `card border ${toneStyles[v.tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[v.tone]}">${toneLabel[v.tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${v.heading}</h2>
      <p class="mt-2 text-gray-700">${v.body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${v.points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>

