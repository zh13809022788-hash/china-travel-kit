---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Vérificateur d\'entrée sans visa et de transit';
const description =
  'Vérifiez si vous pouvez entrer en Chine sans visa, utiliser le transit de 240 heures sans visa, ou si vous devez faire une demande selon votre nationalité et votre type de voyage.';

const lastReviewed = '13 juillet 2026';

// Representative policy data for 2026. This is guidance, not legal advice;
// travelers must confirm with an embassy before booking.
const countries = [
  'United States', 'United Kingdom', 'Canada', 'Australia', 'Germany',
  'France', 'Italy', 'Spain', 'Netherlands', 'Japan', 'South Korea',
  'Singapore', 'Malaysia', 'Thailand', 'Brazil', 'New Zealand',
  'Switzerland', 'Ireland', 'Norway', 'Other',
];
---
<!-- Contenu genere avec assistance IA, revise par un redacteur natif -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Outil</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Vérificateur d'entrée sans visa et de transit</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <p class="mt-3 text-sm text-gray-500">
        Dernière révision : {lastReviewed}. Ce vérificateur est une aide à la planification, pas une décision officielle d'éligibilité.
      </p>
    </header>

    <AdSlot format="banner" />

    <!-- Input controls -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Nationalité de votre passeport</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Type de voyage</span>
        <select id="trip" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="tourism">Tourisme / visite</option>
          <option value="business">Affaires</option>
          <option value="transit">Simple transit vers un autre pays</option>
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="check-btn" class="btn-primary w-full sm:w-auto">Vérifier mon éligibilité</button>
      </div>
    </div>

    <!-- Result -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>
      <p class="mt-3 text-xs text-gray-400">
        Les politiques changent fréquemment et dépendent de votre situation particulière. Confirmez toujours auprès d'une
        ambassade ou d'un consulat chinois avant de réserver votre voyage. Cet outil fournit uniquement des indications générales.
      </p>

      <AffiliateCta
        title="Préparez le reste de votre voyage"
        description="Réglez votre connectivité, vos paiements et vos transports avant d'atterrir en Chine."
        buttonText="Voir les essentiels de voyage"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6" aria-labelledby="official-sources">
      <h2 id="official-sources" class="text-xl font-bold text-gray-950">Sources officielles à vérifier avant de réserver</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        Les listes de pays exemptés de visa, les points d'entrée, les zones de voyage autorisées et les contrôles d'embarquement des compagnies aériennes peuvent changer.
        Considérez les règles officielles du gouvernement et des compagnies aériennes comme définitives.
      </p>
      <ul class="mt-4 grid gap-2 text-sm leading-6 text-gray-700">
        <li><a href="https://en.nia.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">National Immigration Administration</a> pour les mises à jour sur les contrôles aux frontières et les exemptions de transit.</li>
        <li><a href="https://english.www.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">Portail d'information du Conseil des affaires d'État</a> pour les annonces de politique en anglais.</li>
        <li><a href="https://www.mfa.gov.cn/eng/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">Ministère des Affaires étrangères</a> et les sites des ambassades ou consulats chinois pour les règles propres à chaque passeport.</li>
      </ul>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">Comment éviter les erreurs liées à l'entrée sans visa</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          L'erreur la plus fréquente consiste à confondre l'entrée ordinaire sans visa avec le transit sans visa. Un
          aller-retour classique et une escale vers un pays tiers ne correspondent pas au même itinéraire. Les compagnies aériennes
          vérifient les documents avant l'embarquement, donc un malentendu peut bloquer le voyage avant même d'arriver en
          Chine.
        </p>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-gray-600">
          <li><strong class="text-gray-900">Vérifiez d'abord la nationalité du passeport.</strong> Le pays de résidence et le pays de facturation de la carte ne déterminent pas l'éligibilité à l'entrée sans visa.</li>
          <li><strong class="text-gray-900">Distinguez l'entrée du transit.</strong> Le transit exige généralement un voyage confirmé vers un pays ou une région tiers.</li>
          <li><strong class="text-gray-900">Confirmez les points d'entrée.</strong> Les politiques de transit dépendent des ports désignés et des zones de voyage autorisées.</li>
          <li><strong class="text-gray-900">Gardez vos justificatifs à portée de main.</strong> Les compagnies aériennes et les agents aux frontières peuvent demander un billet de continuation, une réservation d'hôtel, un itinéraire ou les détails d'une invitation.</li>
        </ul>
      </div>
      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Préparez le reste de votre arrivée</h2>
        <div class="mt-4 grid gap-3">
          <a href="/posts/china-visa-free-entry-transit-guide-2026/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Lire le guide complet sur l'entrée sans visa</a>
          <a href="/posts/first-24-hours-in-china-arrival-checklist/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Utiliser la checklist d'arrivée</a>
          <a href="/posts/airport-to-city-transport-beijing-shanghai-guangzhou/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Prévoir le transport depuis l'aéroport</a>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  type TripKey = 'tourism' | 'business' | 'transit';

  // Nationalities eligible for the 30-day unilateral visa-free entry (2026 program).
  const visaFree30 = new Set([
    'Germany', 'France', 'Italy', 'Spain', 'Netherlands', 'Switzerland',
    'Ireland', 'Norway', 'Japan', 'South Korea', 'Brazil', 'New Zealand',
    'Malaysia', 'Thailand', 'Australia',
  ]);

  // Nationalities eligible for 240-hour (10-day) visa-free transit through
  // designated ports when travelling onward to a third country/region.
  const transit240 = new Set([
    'United States', 'United Kingdom', 'Canada', 'Australia', 'Germany',
    'France', 'Italy', 'Spain', 'Netherlands', 'Japan', 'South Korea',
    'Singapore', 'Switzerland', 'Ireland', 'Norway', 'Brazil', 'New Zealand',
  ]);

  interface Verdict {
    tone: 'good' | 'warn' | 'info';
    heading: string;
    body: string;
    points: string[];
  }

  function evaluate(country: string, trip: TripKey): Verdict {
    const has30 = visaFree30.has(country);
    const hasTransit = transit240.has(country);

    if (trip === 'transit') {
      if (hasTransit) {
        return {
          tone: 'good',
          heading: 'Vous remplissez probablement les conditions pour le transit sans visa de 240 heures',
          body: `En tant que titulaire d'un passeport ${country} en transit par la Chine vers un pays tiers, vous pouvez généralement séjourner jusqu'à 240 heures (10 jours) sans visa en entrant par un point d'entrée éligible.`,
          points: [
            'Vous devez disposer d\'un billet confirmé vers un pays ou une région tiers dans les 240 heures.',
            'L\'entrée et la sortie doivent se faire par des ports de transit désignés (la plupart des grands aéroports internationaux sont éligibles).',
            'Vous êtes généralement limité à la province ou région d\'entrée ; vérifiez les règles propres au point d\'entrée concerné.',
          ],
        };
      }
      return {
        tone: 'warn',
        heading: 'L\'exemption de visa pour transit peut ne pas s\'appliquer à votre nationalité',
        body: `${country} ne figure pas sur la liste standard du transit de 240 heures dans nos données. Vous pouvez tout de même être éligible à une entrée sans visa si cela s'applique à votre cas, ou vous pouvez avoir besoin d'un visa de transit (G).`,
        points: [
          'Vérifiez d\'abord si votre nationalité donne droit à une entrée complète sans visa.',
          'Sinon, demandez le visa approprié avant le voyage.',
        ],
      };
    }

    // tourism or business
    if (has30) {
      return {
        tone: 'good',
        heading: 'Vous remplissez probablement les conditions pour une entrée sans visa de 30 jours',
        body: `En tant que titulaire d'un passeport ${country}, vous pouvez généralement entrer en Chine sans visa pendant une durée maximale de 30 jours pour le tourisme, les affaires, les visites familiales ou le transit dans le cadre de la politique unilatérale actuelle.`,
        points: [
          'Votre passeport doit être valide pendant au moins 6 mois et comporter des pages vierges.',
          'Ayez à disposition une preuve de voyage retour/de continuation et d\'hébergement pour l\'immigration.',
          'Les 30 jours s\'appliquent par entrée ; confirmez le décompte le plus récent avant de réserver.',
        ],
      };
    }
    if (hasTransit) {
      return {
        tone: 'info',
        heading: 'Un visa est probablement requis, mais l\'exemption de transit peut aider',
        body: `${country} ne figure pas sur notre liste d'entrée sans visa de 30 jours pour le tourisme ou les affaires, donc un visa est généralement requis. Toutefois, si vous êtes simplement de passage vers un pays tiers, vous pouvez utiliser à la place le transit sans visa de 240 heures.`,
        points: [
          'Pour un séjour dédié, demandez à l\'avance un visa L (tourisme) ou M (affaires).',
          'Pour une escale en route vers une autre destination, vous pouvez être éligible au transit de 240 heures ; passez "Type de voyage" sur Transit pour vérifier.',
        ],
      };
    }
    return {
      tone: 'warn',
      heading: 'Un visa est probablement requis',
      body: `D'après nos données, les titulaires d'un passeport ${country} ont généralement besoin d'un visa pour entrer en Chine pour ce type de voyage. Faites votre demande auprès d'une ambassade, d'un consulat ou d'un centre de visa agréé chinois avant le départ.`,
      points: [
        'Demandez un visa L (tourisme) ou M (affaires) bien avant votre voyage.',
        'Les exigences comprennent généralement une invitation ou un itinéraire, des réservations d\'hôtel et des billets retour.',
      ],
    };
  }

  const toneStyles: Record<Verdict['tone'], string> = {
    good: 'border-green-200 bg-green-50',
    warn: 'border-amber-200 bg-amber-50',
    info: 'border-blue-200 bg-blue-50',
  };
  const toneBadge: Record<Verdict['tone'], string> = {
    good: 'bg-green-600 text-white',
    warn: 'bg-amber-500 text-white',
    info: 'bg-blue-600 text-white',
  };
  const toneLabel: Record<Verdict['tone'], string> = {
    good: 'Probablement éligible',
    warn: 'Visa probablement nécessaire',
    info: 'Cela dépend de votre projet',
  };

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;
  const tripEl = document.getElementById('trip') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const v = evaluate(countryEl.value, tripEl.value as TripKey);
    card.className = `card border ${toneStyles[v.tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[v.tone]}">${toneLabel[v.tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${v.heading}</h2>
      <p class="mt-2 text-gray-700">${v.body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${v.points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>