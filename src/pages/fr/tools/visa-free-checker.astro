---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Vérificateur d’entrée sans visa et de transit pour la Chine';
const description =
  'Vérifiez si vous pouvez entrer en Chine sans visa, profiter du transit sans visa de 240 heures ou si un visa reste nécessaire selon votre nationalité et votre type de voyage.';

const lastReviewed = '13 juillet 2026';

// Données représentatives de la politique pour 2026. Il s'agit d'un repère,
// pas d'un avis juridique ; les voyageurs doivent confirmer auprès d'une ambassade avant de réserver.
const countries = [
  'États-Unis', 'Royaume-Uni', 'Canada', 'Australie', 'Allemagne',
  'France', 'Italie', 'Espagne', 'Pays-Bas', 'Japon', 'Corée du Sud',
  'Singapour', 'Malaisie', 'Thaïlande', 'Brésil', 'Nouvelle-Zélande',
  'Suisse', 'Irlande', 'Norvège', 'Autre',
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Outil</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Vérificateur d’entrée sans visa et de transit</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <p class="mt-3 text-sm text-gray-500">
        Dernière révision : {lastReviewed}. Ce vérificateur est une aide à la planification, pas une décision officielle d’éligibilité.
      </p>
    </header>

    <AdSlot format="banner" />

    <!-- Contrôles de saisie -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Votre nationalité de passeport</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Type de voyage</span>
        <select id="trip" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="tourisme">Tourisme / visite</option>
          <option value="affaires">Affaires</option>
          <option value="transit">Simple transit vers un autre pays</option>
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="check-btn" class="btn-primary w-full sm:w-auto">Vérifier mon éligibilité</button>
      </div>
    </div>

    <!-- Résultat -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>
      <p class="mt-3 text-xs text-gray-400">
        Les politiques changent fréquemment et dépendent de votre situation particulière. Confirmez toujours auprès d’une
ambassade ou d’un consulat de Chine avant de réserver. Cet outil fournit uniquement des repères généraux.
      </p>

      <AffiliateCta
        title="Planifiez le reste de votre voyage"
        description="Préparez votre connexion, vos paiements et vos transports avant d’atterrir en Chine."
        buttonText="Voir l’essentiel des voyages"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6" aria-labelledby="official-sources">
      <h2 id="official-sources" class="text-xl font-bold text-gray-950">Sources officielles à vérifier avant la réservation</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        Les listes de pays sans Visa, les ports d'entrée, les zones de voyage autorisées et les contrôles d'embarquement des compagnies aériennes peuvent changer.
Traiter les règles officielles du gouvernement et des compagnies aériennes comme définitives.
      </p>
      <ul class="mt-4 grid gap-2 text-sm leading-6 text-gray-700">
        <li><a href="https://en.nia.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">Administration nationale de l’immigration</a> pour les mises à jour sur le contrôle aux frontières et l’exemption de transit.</li>
        <li><a href="https://english.www.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">Portail d’information du Conseil des affaires d’État</a> pour les annonces officielles en anglais.</li>
        <li><a href="https://www.mfa.gov.cn/eng/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">Ministère des Affaires étrangères</a> et sites d’ambassades ou de consulats de Chine pour les règles propres à chaque passeport.</li>
      </ul>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">Comment éviter les erreurs sans visa</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          L’erreur la plus courante consiste à confondre l’entrée sans visa classique avec le transit sans visa. Un aller-retour normal et une escale vers un pays tiers ne relèvent pas du même régime. Les compagnies aériennes vérifient les documents avant l’embarquement, donc un malentendu peut bloquer le voyage avant même votre arrivée en Chine.
        </p>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-gray-600">
          <li><strong class="text-gray-900">Vérifiez d’abord la nationalité du passeport.</strong> Le pays de résidence et le pays de facturation de la carte ne déterminent pas l’éligibilité sans visa.</li>
          <li><strong class="text-gray-900">Séparez l’entrée du transit.</strong> Le transit exige généralement un voyage confirmé vers un pays ou une région tiers.</li>
          <li><strong class="text-gray-900">Confirmez les ports d’entrée.</strong> Les politiques de transit dépendent des ports désignés et des zones de déplacement autorisées.</li>
          <li><strong class="text-gray-900">Préparez vos justificatifs.</strong> Les compagnies aériennes et les agents frontaliers peuvent demander le billet, l’hôtel, l’itinéraire ou l’invitation.</li>
        </ul>
      </div>
      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Préparez le reste de l’arrivée</h2>
        <div class="mt-4 grid gap-3">
          <a href="/fr/posts/china-visa-free-entry-transit-guide-2026/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Lire le guide complet sur le sans visa</a>
          <a href="/fr/posts/first-24-hours-in-china-arrival-checklist/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Utiliser la liste de contrôle d'arrivée</a>
          <a href="/fr/posts/airport-to-city-transport-beijing-shanghai-guangzhou/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">Planification des transports aéroportuaires</a>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  type TripKey = 'tourisme' | 'affaires' | 'transit';

  // Nationalités éligibles à l’entrée sans visa unilatérale de 30 jours (programme 2026).
  const visaFree30 = new Set([
    'Allemagne', 'France', 'Italie', 'Espagne', 'Pays-Bas', 'Suisse',
    'Irlande', 'Norvège', 'Japon', 'Corée du Sud', 'Brésil', 'Nouvelle-Zélande',
    'Malaisie', 'Thaïlande', 'Australie',
  ]);

  // Nationalités éligibles au transit sans visa de 240 heures (10 jours) via
  // des ports désignés lors d’un trajet vers un pays ou une région tiers.
  const transit240 = new Set([
    'États-Unis', 'Royaume-Uni', 'Canada', 'Australie', 'Allemagne',
    'France', 'Italie', 'Espagne', 'Pays-Bas', 'Japon', 'Corée du Sud',
    'Singapour', 'Suisse', 'Irlande', 'Norvège', 'Brésil', 'Nouvelle-Zélande',
  ]);

  interface Verdict {
    tone: 'good' | 'warn' | 'info';
    heading: string;
    body: string;
    points: string[];
  }

  function evaluate(country: string, trip: TripKey): Verdict {
    const has30 = visaFree30.has(country);
    const hasTransit = transit240.has(country);

    if (trip === 'transit') {
      if (hasTransit) {
        return {
          tone: 'good',
          heading: 'Vous êtes probablement éligible au transit sans visa de 240 heures',
          body: `En tant que titulaire d’un passeport ${country} en transit vers un pays tiers, vous pouvez généralement rester jusqu’à 240 heures (10 jours) sans visa en entrant par un port éligible.`,
          points: [
            'Vous devez détenir un billet de continuation confirmé vers un pays ou une région tiers dans les 240 heures.',
            'L’entrée et la sortie doivent se faire par des ports de transit désignés (la plupart des grands aéroports internationaux sont éligibles).',
            'Vous êtes généralement limité à la province ou à la région d’entrée : vérifiez les règles propres au port.',
          ],
        };
      }
      return {
        tone: 'warn',
        heading: 'L’exemption de visa de transit peut ne pas s’appliquer à votre nationalité',
        body: `${country} ne figure pas sur notre liste standard de transit de 240 heures. Vous pouvez tout de même être éligible à l’entrée sans visa si vous y avez droit, ou vous pouvez avoir besoin d’un visa de transit (G).`,
        points: [
          'Vérifiez d’abord si votre nationalité permet plutôt une entrée complète sans visa.',
          'Sinon, demandez le visa approprié avant le voyage.',
        ],
      };
    }

    // Tourisme ou affaires
    if (has30) {
      return {
        tone: 'good',
        heading: 'Vous êtes probablement éligible à l’entrée sans visa de 30 jours',
        body: `En tant que titulaire d’un passeport ${country}, vous pouvez généralement entrer en Chine sans visa pour une durée maximale de 30 jours pour le tourisme, les affaires, les visites familiales ou le transit selon la politique unilatérale actuelle.`,
        points: [
          'Votre passeport doit être valide au moins 6 mois avec des pages vierges.',
          'Ayez une preuve de voyage aller-retour et d’hébergement prête pour l’immigration.',
          'Les 30 jours sont par entrée — confirmez le nombre exact avant de réserver.',
        ],
      };
    }
    if (hasTransit) {
      return {
        tone: 'info',
        heading: 'Un visa est probablement requis, mais l’exemption de transit peut aider',
        body: `${country} ne figure pas sur notre liste d’entrée sans visa de 30 jours pour le tourisme ou les affaires, donc un visa est généralement requis. Cependant, si vous traversez la Chine vers un pays tiers, vous pouvez utiliser à la place le transit sans visa de 240 heures.`,
        points: [
          'Pour un séjour dédié, demandez à l’avance un visa L (tourisme) ou M (affaires).',
          'Pour une escale vers ailleurs, vous pouvez être éligible au transit de 240 heures : sélectionnez « Transit » dans le type de voyage pour vérifier.',
        ],
      };
    }
    return {
      tone: 'warn',
      heading: 'Un visa est probablement requis',
      body: `D’après nos données, les titulaires d’un passeport ${country} ont généralement besoin d’un visa pour entrer en Chine pour ce type de voyage. Demandez-le auprès d’une ambassade, d’un consulat ou d’un centre de visas agréé avant de voyager.`,
      points: [
        'Demandez un visa L (tourisme) ou M (affaires) bien avant votre voyage.',
        'Les justificatifs incluent généralement une invitation ou un itinéraire, des réservations d’hôtel et des billets de retour.',
      ],
    };
  }

  const toneStyles: Record<Verdict['tone'], string> = {
    good: 'border-green-200 bg-green-50',
    warn: 'border-amber-200 bg-amber-50',
    info: 'border-blue-200 bg-blue-50',
  };
  const toneBadge: Record<Verdict['tone'], string> = {
    good: 'bg-green-600 text-white',
    warn: 'bg-amber-500 text-white',
    info: 'bg-blue-600 text-white',
  };
  const toneLabel: Record<Verdict['tone'], string> = {
    good: 'Probablement éligible',
    warn: 'Visa probablement requis',
    info: 'Cela dépend de votre itinéraire',
  };

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;
  const tripEl = document.getElementById('trip') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const v = evaluate(countryEl.value, tripEl.value as TripKey);
    card.className = `card border ${toneStyles[v.tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[v.tone]}">${toneLabel[v.tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${v.heading}</h2>
      <p class="mt-2 text-gray-700">${v.body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${v.points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>

