---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const titre = 'Comparateur de forfaits eSIM pour voyager en Chine';
const description =
  'Comparez les meilleurs forfaits eSIM pour la Chine selon le volume de donnees, la duree de validite, le prix et le reseau. Filtrez et triez les offres pour trouver celle qui convient le mieux a votre voyage.';

// 8 forfaits eSIM predefinis pour voyager en Chine (donnees d'exemple representatives)
const forfaits = [
  { id: 1, name: 'Explorateur Chine 5 Go', data: 5, dataLabel: '5 Go', days: 7, price: 9.5, network: 'China Unicom', note: 'Permet d acceder aux applications habituellement restreintes' },
  { id: 2, name: 'Explorateur Chine 10 Go', data: 10, dataLabel: '10 Go', days: 15, price: 16, network: 'China Unicom', note: 'Permet d acceder aux applications habituellement restreintes' },
  { id: 3, name: 'Chine continentale Essentiel 3 Go', data: 3, dataLabel: '3 Go', days: 7, price: 6.5, network: 'China Mobile', note: 'Reseau local, sans routage via VPN' },
  { id: 4, name: 'Grande Chine 8 Go', data: 8, dataLabel: '8 Go', days: 30, price: 18.9, network: 'China Unicom', note: 'Couvre la Chine, Hong Kong, Macao et Taiwan' },
  { id: 5, name: 'Illimite quotidien', data: 9999, dataLabel: 'Illimite*', days: 10, price: 29, network: 'China Unicom', note: 'Usage raisonnable applique apres 2 Go par jour' },
  { id: 6, name: 'Pro 20 Go', data: 20, dataLabel: '20 Go', days: 30, price: 32, network: 'China Unicom', note: 'Permet d acceder aux applications habituellement restreintes' },
  { id: 7, name: 'Court sejour 1 Go', data: 1, dataLabel: '1 Go', days: 3, price: 3.2, network: 'China Mobile', note: 'Ideal pour les escales rapides' },
  { id: 8, name: 'Famille 30 Go', data: 30, dataLabel: '30 Go', days: 30, price: 45, network: 'China Unicom', note: 'Partage de connexion autorise' },
];
---

<BaseLayout title={`${titre} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Outil</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Comparateur de forfaits eSIM</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- Controles -->
    <div class="mt-6 flex flex-wrap items-end gap-4 rounded-xl border border-gray-200 bg-gray-50 p-4">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Trier par</span>
        <select id="tri" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="prix-croissant">Prix : du moins cher au plus cher</option>
          <option value="prix-decroissant">Prix : du plus cher au moins cher</option>
          <option value="donnees-decroissant">Donnees : du volume le plus eleve au plus faible</option>
          <option value="validite-decroissant">Validite : de la plus longue a la plus courte</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Reseau</span>
        <select id="filtre-reseau" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="tous">Tous les reseaux</option>
          <option value="China Unicom">China Unicom</option>
          <option value="China Mobile">China Mobile</option>
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Donnees min. (Go)</span>
        <select id="filtre-donnees" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="0">Sans preference</option>
          <option value="5">5 Go et plus</option>
          <option value="10">10 Go et plus</option>
          <option value="20">20 Go et plus</option>
        </select>
      </label>
    </div>

    <!-- Tableau comparatif -->
    <div class="mt-6 overflow-x-auto">
      <table class="w-full min-w-[720px] border-collapse text-sm">
        <thead>
          <tr class="border-b-2 border-gray-200 text-left text-gray-500">
            <th class="py-3 pr-4 font-semibold">Forfait</th>
            <th class="py-3 pr-4 font-semibold">Donnees</th>
            <th class="py-3 pr-4 font-semibold">Validite</th>
            <th class="py-3 pr-4 font-semibold">Prix (USD)</th>
            <th class="py-3 pr-4 font-semibold">Reseau</th>
            <th class="py-3 pr-4 font-semibold">Remarques</th>
          </tr>
        </thead>
        <tbody id="lignes-forfaits"></tbody>
      </table>
      <p id="aucun-resultat" class="hidden py-8 text-center text-gray-500">Aucun forfait ne correspond a vos filtres.</p>
    </div>

    <AffiliateCta
      title="Pret a rester connecte ?"
      description="Activez une eSIM recommandee pour la Chine et profitez d une connexion des votre arrivee."
      buttonText="Obtenir votre eSIM"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ forfaits }}>
  const lignesEl = document.getElementById('lignes-forfaits');
  const aucunResultat = document.getElementById('aucun-resultat');
  const tri = document.getElementById('tri');
  const filtreReseau = document.getElementById('filtre-reseau');
  const filtreDonnees = document.getElementById('filtre-donnees');

  function afficher() {
    let liste = [...forfaits];
    const reseau = filtreReseau.value;
    const donneesMin = Number(filtreDonnees.value);

    if (reseau !== 'tous') liste = liste.filter((p) => p.network === reseau);
    if (donneesMin > 0) liste = liste.filter((p) => p.data >= donneesMin);

    switch (tri.value) {
      case 'prix-croissant': liste.sort((a, b) => a.price - b.price); break;
      case 'prix-decroissant': liste.sort((a, b) => b.price - a.price); break;
      case 'donnees-decroissant': liste.sort((a, b) => b.data - a.data); break;
      case 'validite-decroissant': liste.sort((a, b) => b.days - a.days); break;
    }

    lignesEl.innerHTML = liste
      .map(
        (p) => `
      <tr class="border-b border-gray-100">
        <td class="py-3 pr-4 font-semibold text-gray-900">${p.name}</td>
        <td class="py-3 pr-4">${p.dataLabel}</td>
        <td class="py-3 pr-4">${p.days} jours</td>
        <td class="py-3 pr-4 font-semibold">$${p.price.toFixed(2)}</td>
        <td class="py-3 pr-4">${p.network}</td>
        <td class="py-3 pr-4 text-gray-500">${p.note}</td>
      </tr>`
      )
      .join('');

    aucunResultat.classList.toggle('hidden', liste.length > 0);
  }

  [tri, filtreReseau, filtreDonnees].forEach((el) => el.addEventListener('change', afficher));
  afficher();
</script>
