---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import AffiliateCta from '../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../config';
import FaqSection from '../../components/FaqSection.astro';

const title = 'Vérificateur de compatibilité des cartes de paiement pour la Chine';
const description =
  'Vérifiez si votre carte de crédit fonctionne avec Alipay et WeChat Pay en Chine. Consultez le statut de compatibilité, les limites, les frais et la configuration selon la nationalité et le réseau de carte.';

const nationalities = [
  'États-Unis', 'Royaume-Uni', 'Canada', 'Australie',
  'Allemagne', 'France', 'Japon', 'Singapour', 'Autre',
];
const cardNetworks = ['Visa', 'Mastercard', 'Amex', 'Discover'];

const nextSteps = [
  { href: '/posts/alipay-foreign-credit-card-step-by-step/', title: 'Configurer Alipay avec une carte étrangère' },
  { href: '/posts/link-a-foreign-visa-or-mastercard-to-wechat-pay-in-china/', title: 'Lier Visa ou Mastercard à WeChat Pay' },
  { href: '/posts/can-you-still-use-cash-in-china-as-a-foreigner-in-2026/', title: 'Savoir quand l’argent liquide reste utile' },
  { href: '/payment/', title: 'Voir tous les guides de paiement pour la Chine' },
];

const faqItems = [
  {
    question: 'Toutes les cartes Visa ou Mastercard étrangères fonctionneront-elles en Chine ?',
    answer:
      'Non. Visa et Mastercard sont les options les plus sûres pour commencer avec Alipay et WeChat Pay, mais certaines banques peuvent toujours bloquer la vérification, refuser l’association à un portefeuille numérique ou signaler les transactions en Chine. Gardez une deuxième carte et un peu d’argent liquide en secours.',
  },
  {
    question: 'Les touristes devraient-ils configurer à la fois Alipay et WeChat Pay ?',
    answer:
      'Oui, si possible. Alipay est souvent plus facile à configurer pour les visiteurs, tandis que WeChat Pay peut être utile pour les mini-programmes, les restaurants et les services locaux. Avoir les deux réduit le risque d’être bloqué chez un commerçant.',
  },
  {
    question: 'Combien d’argent liquide devrais-je emporter si le paiement mobile fonctionne ?',
    answer:
      'Emportez suffisamment de petites coupures pour le transport depuis l’aéroport, les repas de secours et les petites boutiques, mais ne comptez pas uniquement sur l’argent liquide. Beaucoup d’endroits préfèrent le paiement par QR code, et certains employés peuvent ne pas avoir de monnaie prête.',
  },
];
---
<!-- Contenu genere avec assistance IA, revise par un redacteur natif -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Outil</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Vérificateur de compatibilité des paiements</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <section class="mt-6 grid gap-4 md:grid-cols-3" aria-label="Ce que ce vérificateur de paiement vous aide à faire">
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">Vérifier la compatibilité des portefeuilles</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Voyez si votre réseau de carte convient bien à Alipay et WeChat Pay.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">Anticiper les limites</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Consultez les limites de transaction et les frais habituels avant d’effectuer des achats plus importants.</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-4">
        <h2 class="text-base font-bold text-gray-900">Prévoir une solution de secours</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">Sachez quand emporter de l’argent liquide, changer de carte ou préparer les deux applications de paiement.</p>
      </div>
    </section>

    <AdSlot format="banner" />

    <!-- Input controls -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Votre nationalité</span>
        <select id="nationality" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {nationalities.map((n) => <option value={n}>{n}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">Réseau de carte</span>
        <select id="network" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {cardNetworks.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="check-btn" class="btn-primary w-full sm:w-auto">Vérifier la compatibilité</button>
      </div>
    </div>

    <!-- Results -->
    <div id="result" class="mt-6 hidden">
      <div class="grid gap-5 md:grid-cols-2">
        <div class="card" id="alipay-card"></div>
        <div class="card" id="wechat-card"></div>
      </div>

      <AffiliateCta
        title="Configurer une carte prête pour le voyage"
        description="Obtenez une carte de voyage prépayée qui se lie de manière fiable à Alipay et WeChat Pay pour votre voyage en Chine."
        buttonText="Voir la carte recommandée"
        placeholder={AFFILIATE_LINKS.payment}
      />
    </div>

    <section class="mt-12 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">Comment utiliser ce vérificateur</h2>
        <ol class="mt-4 space-y-3 text-sm leading-6 text-gray-600">
          <li><strong class="text-gray-900">1. Choisissez votre pays de passeport ou de résidence.</strong> Cela aide à situer les problèmes courants liés aux banques et à la vérification.</li>
          <li><strong class="text-gray-900">2. Choisissez votre réseau de carte.</strong> Visa et Mastercard sont généralement les meilleurs premiers choix pour les portefeuilles de voyage en Chine.</li>
          <li><strong class="text-gray-900">3. Préparez au moins une solution de secours.</strong> Emportez une deuxième carte, installez les deux applications de paiement et gardez un peu de liquide pour les cas particuliers.</li>
        </ol>
        <p class="mt-4 text-sm leading-6 text-gray-600">
          Les règles de paiement, la vérification des portefeuilles et les contrôles de risque des émetteurs peuvent changer. Considérez le résultat comme un guide pratique pour préparer votre voyage, puis confirmez toute limite importante de transaction dans Alipay, WeChat Pay et auprès de l’émetteur de votre carte avant le départ.
        </p>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Prochaines étapes de paiement</h2>
        <div class="mt-4 grid gap-3">
          {nextSteps.map((item) => (
            <a href={item.href} class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">
              {item.title}
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6" aria-labelledby="payment-checker-seo">
      <h2 id="payment-checker-seo" class="text-2xl font-bold text-gray-900">Ce que ce vérificateur peut et ne peut pas vous dire</h2>
      <p class="mt-3 text-sm leading-6 text-gray-600">
        Cet outil est conçu pour la préparation avant le départ. Il vous aide à réfléchir au réseau
        de carte, à la compatibilité des portefeuilles, aux frais probables et aux méthodes de secours avant
        de vous retrouver à une caisse en Chine. Il ne peut pas garantir que votre banque
        approuvera chacun de vos paiements.
      </p>
      <div class="mt-5 overflow-x-auto rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200 text-sm">
          <thead class="bg-gray-50 text-left text-gray-700">
            <tr>
              <th class="px-4 py-3 font-semibold">Risque</th>
              <th class="px-4 py-3 font-semibold">Pourquoi cela arrive</th>
              <th class="px-4 py-3 font-semibold">Meilleure solution de secours</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-200 bg-white text-gray-600">
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">Échec de liaison de la carte</td>
              <td class="px-4 py-3">L’émetteur bloque la vérification du portefeuille ou 3-D Secure échoue.</td>
              <td class="px-4 py-3">Essayez une autre Visa/Mastercard d’une banque différente.</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">Paiement important refusé</td>
              <td class="px-4 py-3">Une limite du portefeuille, du commerçant ou de l’émetteur déclenche une vérification.</td>
              <td class="px-4 py-3">Scindez le paiement, utilisez la carte physique ou demandez les options à l’hôtel/au commerçant.</td>
            </tr>
            <tr>
              <td class="px-4 py-3 font-medium text-gray-900">Pas de signal en caisse</td>
              <td class="px-4 py-3">Données mobiles faibles, pas d’itinérance ou impossibilité de charger l’application.</td>
              <td class="px-4 py-3">Utilisez l’autre portefeuille, le Wi‑Fi du commerçant ou un petit secours en liquide.</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p class="mt-4 text-sm leading-6 text-gray-600">
        Pour la configuration la plus solide, lisez le <a href="/posts/how-to-pay-in-china-tourist-guide/" class="font-semibold">guide complet de paiement pour les touristes en Chine</a>,
        comparez <a href="/posts/alipay-vs-wechat-pay-foreigners/" class="font-semibold">Alipay vs WeChat Pay</a>,
        et gardez un petit secours en RMB grâce à notre <a href="/posts/how-much-cash-to-bring-to-china/" class="font-semibold">guide sur l’argent liquide</a>.
      </p>
    </section>

    <FaqSection items={faqItems} title="FAQ du vérificateur de paiement" />
  </main>
  <Footer />
</BaseLayout>

<script>
  type NetworkKey = 'Visa' | 'Mastercard' | 'Amex' | 'Discover';

  // Static compatibility matrix (representative guidance)
  const matrix: Record<NetworkKey, {
    alipay: { status: string; single: string; daily: string; fee: string; how: string };
    wechat: { status: string; single: string; daily: string; fee: string; how: string };
  }> = {
    Visa: {
      alipay: { status: 'Compatible', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% au-delà de 200 RMB', how: 'Ajoutez la carte dans Alipay Wallet, vérifiez le passeport' },
      wechat: { status: 'Compatible', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% au-delà de 200 RMB', how: 'Ajoutez la carte dans WeChat Wallet, vérifiez le passeport' },
    },
    Mastercard: {
      alipay: { status: 'Compatible', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% au-delà de 200 RMB', how: 'Ajoutez la carte dans Alipay Wallet, vérifiez le passeport' },
      wechat: { status: 'Compatible', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% au-delà de 200 RMB', how: 'Ajoutez la carte dans WeChat Wallet, vérifiez le passeport' },
    },
    Amex: {
      alipay: { status: 'Partiellement compatible', single: '~6,000 RMB', daily: '~50,000 RMB', fee: '~3% au-delà de 200 RMB', how: 'Amex fonctionne avec Alipay dans la plupart des cas ; gardez une Visa/MC en secours' },
      wechat: { status: 'Limité', single: 'Variable', daily: 'Variable', fee: '~3% au-delà de 200 RMB', how: 'La compatibilité n’est pas constante ; privilégiez Visa/Mastercard sur WeChat' },
    },
    Discover: {
      alipay: { status: 'Limité', single: 'Variable', daily: 'Variable', fee: 'Variable', how: 'L’acceptation est limitée ; une Visa/Mastercard est fortement recommandée' },
      wechat: { status: 'Non recommandé', single: '—', daily: '—', fee: '—', how: 'Utilisez plutôt une Visa ou Mastercard' },
    },
  };

  const statusColor = (status: string) => {
    if (/^supported/i.test(status)) return 'text-green-700 bg-green-50 border-green-200';
    if (/partial|limited/i.test(status)) return 'text-amber-700 bg-amber-50 border-amber-200';
    return 'text-red-700 bg-red-50 border-red-200';
  };

  function cardHtml(wallet: string, d: { status: string; single: string; daily: string; fee: string; how: string }) {
    return `
      <h3 class="text-lg font-bold text-gray-900">${wallet}</h3>
      <span class="mt-2 inline-block rounded-full border px-3 py-0.5 text-xs font-semibold ${statusColor(d.status)}">${d.status}</span>
      <dl class="mt-4 space-y-2 text-sm">
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Transaction unique</dt><dd class="font-medium text-gray-900">${d.single}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Limite quotidienne</dt><dd class="font-medium text-gray-900">${d.daily}</dd></div>
        <div class="flex justify-between gap-4"><dt class="text-gray-500">Frais de traitement</dt><dd class="font-medium text-gray-900">${d.fee}</dd></div>
        <div class="pt-2 text-gray-600"><dt class="text-gray-500">Comment configurer</dt><dd class="mt-1">${d.how}</dd></div>
      </dl>`;
  }

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const networkEl = document.getElementById('network') as HTMLSelectElement;
  const alipayCard = document.getElementById('alipay-card');
  const wechatCard = document.getElementById('wechat-card');

  btn?.addEventListener('click', () => {
    const net = networkEl.value as NetworkKey;
    const data = matrix[net];
    if (!data || !alipayCard || !wechatCard || !result) return;
    alipayCard.innerHTML = cardHtml('Alipay', data.alipay);
    wechatCard.innerHTML = cardHtml('WeChat Pay', data.wechat);
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>