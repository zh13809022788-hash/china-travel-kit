---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Vérificateur de prises et de tension pour la Chine';
const description =
  'Découvrez si vous avez besoin d’un adaptateur de prise ou d’un convertisseur de tension pour la Chine selon votre pays d’origine. La Chine utilise le 220 V et les prises de type A, C et I.';

const countries = [
  { value: 'États-Unis', label: 'États-Unis' },
  { value: 'Royaume-Uni', label: 'Royaume-Uni' },
  { value: 'Canada', label: 'Canada' },
  { value: 'Australie', label: 'Australie' },
  { value: 'Allemagne', label: 'Allemagne' },
  { value: 'France', label: 'France' },
  { value: 'Italie', label: 'Italie' },
  { value: 'Espagne', label: 'Espagne' },
  { value: 'Pays-Bas', label: 'Pays-Bas' },
  { value: 'Japon', label: 'Japon' },
  { value: 'Corée du Sud', label: 'Corée du Sud' },
  { value: 'Singapour', label: 'Singapour' },
  { value: 'Inde', label: 'Inde' },
  { value: 'Brésil', label: 'Brésil' },
  { value: 'Nouvelle-Zélande', label: 'Nouvelle-Zélande' },
  { value: 'Suisse', label: 'Suisse' },
  { value: 'Afrique du Sud', label: 'Afrique du Sud' },
  { value: 'Émirats arabes unis', label: 'Émirats arabes unis' },
  { value: 'Autre', label: 'Autre' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Outil</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Vérificateur de prises et de tension</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-6">
      <label class="flex flex-col text-sm sm:max-w-sm">
        <span class="mb-1 font-medium text-gray-700">Vous voyagez depuis</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c.value}>{c.label}</option>)}
        </select>
      </label>
      <button id="check-btn" class="btn-primary mt-4 w-full sm:w-auto">Vérifier ce qu’il me faut</button>
    </div>

    <!-- Référence : norme utilisée en Chine -->
    <div class="mt-6 grid gap-4 sm:grid-cols-3">
      <div class="card"><dt class="text-sm text-gray-500">Tension</dt><dd class="text-2xl font-bold text-gray-900">220 V</dd></div>
      <div class="card"><dt class="text-sm text-gray-500">Fréquence</dt><dd class="text-2xl font-bold text-gray-900">50 Hz</dd></div>
      <div class="card"><dt class="text-sm text-gray-500">Types de prises</dt><dd class="text-2xl font-bold text-gray-900">A · C · I</dd></div>
    </div>

    <!-- Résultat -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>

      <AffiliateCta
        title="Obtenir un adaptateur universel pour la Chine"
        description="Un adaptateur de voyage compact tout-en-un compatible avec les prises chinoises et capable de charger plusieurs appareils à la fois."
        buttonText="Voir l’adaptateur recommandé"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  // Tension domestique de chaque pays et types de prises utilisés.
  const data: Record<string, { volts: number; plugs: string[] }> = {
    'États-Unis': { volts: 120, plugs: ['A', 'B'] },
    'Canada': { volts: 120, plugs: ['A', 'B'] },
    'Japon': { volts: 100, plugs: ['A', 'B'] },
    'Brésil': { volts: 127, plugs: ['C', 'N'] },
    'Royaume-Uni': { volts: 230, plugs: ['G'] },
    'Australie': { volts: 230, plugs: ['I'] },
    'Nouvelle-Zélande': { volts: 230, plugs: ['I'] },
    'Allemagne': { volts: 230, plugs: ['C', 'F'] },
    'France': { volts: 230, plugs: ['C', 'E'] },
    'Italie': { volts: 230, plugs: ['C', 'F', 'L'] },
    'Espagne': { volts: 230, plugs: ['C', 'F'] },
    'Pays-Bas': { volts: 230, plugs: ['C', 'F'] },
    'Suisse': { volts: 230, plugs: ['C', 'J'] },
    'Corée du Sud': { volts: 220, plugs: ['C', 'F'] },
    'Singapour': { volts: 230, plugs: ['G'] },
    'Inde': { volts: 230, plugs: ['C', 'D', 'M'] },
    'Afrique du Sud': { volts: 230, plugs: ['C', 'D', 'M', 'N'] },
    'Émirats arabes unis': { volts: 230, plugs: ['C', 'D', 'G'] },
    'Autre': { volts: 0, plugs: [] },
  };

  // La Chine accepte les prises de type A, C et I.
  const CHINA_PLUGS = ['A', 'C', 'I'];
  const CHINA_VOLTS = 220;

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const country = countryEl.value;
    const countryLabel = countryEl.selectedOptions[0]?.textContent?.trim() || country;
    const info = data[country];

    let heading: string, body: string, tone: 'good' | 'warn' | 'info';
    const points: string[] = [];

    if (!info || info.volts === 0) {
      tone = 'info';
      heading = 'Vérifiez votre prise et votre tension exactes';
      body = 'Nous n’avons pas de données pour votre sélection. Regardez l’étiquette de votre chargeur : si elle indique « 100–240V », vous avez seulement besoin d’un adaptateur pour les prises chinoises de type A, C ou I.';
      points.push('La Chine utilise le 220 V, 50 Hz, avec des prises de type A, C et I.');
      points.push('La plupart des chargeurs de téléphone et d’ordinateur portable sont bitension (100–240V) et nécessitent seulement un adaptateur de prise.');
    } else {
      const plugMatch = info.plugs.some((p) => CHINA_PLUGS.includes(p));
      const voltMatch = Math.abs(info.volts - CHINA_VOLTS) <= 20;

      if (plugMatch && voltMatch) {
        tone = 'good';
        heading = 'Vous n’avez probablement pas besoin d’adaptateur';
        body = `${countryLabel} utilise des types de prises compatibles (${info.plugs.join(', ')}) et une tension similaire (${info.volts} V). Vos prises devraient entrer directement dans les prises chinoises.`;
        points.push('Vérifiez quand même chaque prise et emportez un adaptateur au cas où une prise murale serait difficile à utiliser.');
      } else if (!plugMatch && voltMatch) {
        tone = 'warn';
        heading = 'Vous avez besoin d’un adaptateur de prise, mais pas d’un convertisseur de tension';
        body = `${countryLabel} fonctionne avec une tension similaire (${info.volts} V), donc vos appareils ne risquent rien. Mais votre type de prise (${info.plugs.join(', ')}) n’entre pas dans les prises chinoises : prévoyez un adaptateur.`;
        points.push('Un simple adaptateur peu coûteux pour les types A/C/I suffit.');
        points.push('Aucun convertisseur de tension encombrant n’est nécessaire.');
      } else if (plugMatch && !voltMatch) {
        tone = 'warn';
        heading = 'Attention à la tension des appareils monotension';
        body = `Vos prises (${info.plugs.join(', ')}) peuvent entrer, mais la tension de ${countryLabel} (${info.volts} V) diffère du 220 V chinois.`;
        points.push('Les téléphones, ordinateurs portables et appareils photo indiquant 100–240V fonctionnent partout.');
        points.push('Les appareils monotension (certains sèche-cheveux ou lisseurs) nécessitent un convertisseur de tension ou doivent rester à la maison.');
      } else {
        tone = 'warn';
        heading = 'Vous avez besoin d’un adaptateur de prise et devez vérifier la tension';
        body = `${countryLabel} utilise des prises différentes (${info.plugs.join(', ')}) et une tension différente (${info.volts} V) du 220 V chinois. Emportez un adaptateur pour les types A/C/I.`;
        points.push('Les chargeurs bitension (100–240V) nécessitent seulement l’adaptateur de prise.');
        points.push('Les appareils monotension de forte puissance nécessitent aussi un convertisseur de tension, ou mieux, un équivalent acheté sur place.');
      }
    }

    const toneStyles = {
      good: 'border-green-200 bg-green-50',
      warn: 'border-amber-200 bg-amber-50',
      info: 'border-blue-200 bg-blue-50',
    } as const;
    const toneBadge = {
      good: 'bg-green-600 text-white',
      warn: 'bg-amber-500 text-white',
      info: 'bg-blue-600 text-white',
    } as const;
    const toneLabel = {
      good: 'Aucun adaptateur nécessaire',
      warn: 'Adaptateur nécessaire',
      info: 'Vérifiez votre chargeur',
    } as const;

    card.className = `card border ${toneStyles[tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[tone]}">${toneLabel[tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${heading}</h2>
      <p class="mt-2 text-gray-700">${body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>