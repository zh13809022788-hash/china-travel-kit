---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Vérificateur de prises et de tension pour la Chine';
const description =
  'Vérifiez si vous avez besoin d’un adaptateur de prise ou d’un convertisseur de tension pour la Chine selon votre pays de départ.';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Outil</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Vérificateur de prises et de tension</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>
    <AdSlot format="banner" />
    <div class="mt-6 rounded-lg border border-gray-200 bg-gray-50 p-5">
      <p class="text-sm leading-6 text-gray-600">
        La Chine fonctionne en 220 V / 50 Hz et utilise généralement des prises de type A, C et I.
        Vérifiez toujours l’étiquette de votre chargeur : s’il indique « 100-240V », un simple
        adaptateur suffit la plupart du temps.
      </p>
    </div>
    <AffiliateCta
      title="Prévoir le bon adaptateur"
      description="Un adaptateur universel compact suffit dans la plupart des cas pour la Chine."
      buttonText="Voir un adaptateur recommandé"
      placeholder={AFFILIATE_LINKS.transport}
    />
  </main>
  <Footer />
</BaseLayout>
