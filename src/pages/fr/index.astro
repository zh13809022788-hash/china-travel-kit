---
import { getCollection } from 'astro:content';
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import AdSlot from "../../components/AdSlot.astro";
import NewsletterSignup from "../../components/NewsletterSignup.astro";
import { Image } from 'astro:assets';
import heroImage from "../../assets/images/city-shanghai.jpg";

const posts = await getCollection('posts');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()).slice(0, 12);

import { getCategoryLabel } from "../../i18n/categories";
const locale = 'en';
---
<!-- Contenu genere avec assistance IA, revise par un redacteur natif -->


<BaseLayout
  title="ChinaTripBox - Guides des paiements, eSIM et transports pour voyager en Chine"
  description="Guides pratiques pour voyager en Chine a destination des visiteurs etrangers : paiements, eSIM, train a grande vitesse, DiDi, transit sans visa, et ce qu'il faut configurer avant d'atterrir."
  alternates={{ en: '/', 'zh-TW': '/zh-tw/', ja: '/ja/', ko: '/ko/', ru: '/ru/', fr: '/fr/', de: '/de/', es: '/es/' }}
>
  <Header />
  <main>
    <section class="border-b border-gray-200 bg-gray-50">
      <div class="container-page grid gap-8 py-12 lg:grid-cols-[1fr_360px] lg:items-center">
        <div>
          <p class="text-sm font-semibold uppercase tracking-wide text-brand-700">La boite a outils de voyage ChinaTripBox</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Reglez les paiements, internet, les visas et les transports avant d'atterrir en Chine
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Des guides et outils pratiques pour les visiteurs etrangers. Configurez Alipay, WeChat Pay, une eSIM, le train a grande vitesse, DiDi et le transit sans visa — reglez d'abord la logistique, puis profitez du voyage.
          </p>
          <div class="mt-6 flex flex-wrap gap-3">
            <a href="/posts/how-to-pay-in-china-tourist-guide/" class="btn-primary">Commencez par les paiements</a>
            <a href="/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-outline">Liste de verification avant le depart</a>
          </div>
        </div>

        <aside class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
          <Image
            src={heroImage}
            alt="Ligne d'horizon de Shanghai representant la planification d'un voyage urbain en Chine"
            widths={[360, 720]}
            sizes="(max-width: 1024px) 100vw, 360px"
            quality={65}
            loading="eager"
            class="h-52 w-full object-cover"
          />
          <div class="p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Ordre de lecture recommande</p>
            <h2 class="mt-2 text-lg font-bold text-gray-950">Resolvez d'abord les problemes du jour d'arrivee</h2>
            <p class="mt-2 text-sm leading-6 text-gray-600">
              Les paiements, internet, les VTC et les billets de train sont les quatre choses qu'il vaut la peine de configurer avant d'atterrir.
            </p>
          </div>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <AdSlot format="banner" />

      <section class="py-8">
        <div class="section-heading">
          <div>
            <p class="section-kicker">Derniers guides</p>
            <h2>Articles pratiques pour voyager en Chine</h2>
          </div>
        </div>

        <div class="mt-6 divide-y divide-gray-200 rounded-lg border border-gray-200 bg-white">
          {sortedPosts.map((post) => (
            <a href={`/posts/${post.slug}/`} class="group block p-5 hover:bg-gray-50 hover:no-underline">
              <div class="flex flex-wrap items-center gap-2 text-xs font-semibold uppercase tracking-wide text-brand-700">
                <span>{getCategoryLabel(post.data.category, locale)}</span>
                <span class="text-gray-300">/</span>
                <time datetime={post.data.pubDate.toISOString()}>
                  {post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
              </div>
              <h3 class="mt-2 text-lg font-bold text-gray-950 group-hover:text-brand-700">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </section>

      <AdSlot format="banner" />

      <section class="py-8">
        <NewsletterSignup locale="en" />
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>