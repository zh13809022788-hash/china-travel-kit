---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const CATEGORY = 'payment';
const posts = (await getCollection('posts-fr'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Paiement en Chine : Alipay, WeChat Pay et cartes étrangères';
const description =
  'Guides pas à pas pour payer en Chine : configurer Alipay et WeChat Pay, lier des cartes internationales et éviter les erreurs courantes.';

const prioritySteps = [
  'Installez Alipay et WeChat avant le départ, puis vérifiez votre identité tant que vous avez encore accès à votre banque dans votre pays et à votre numéro de téléphone.',
  'Ajoutez au moins une carte Visa ou Mastercard, puis gardez une deuxième carte d’un autre émetteur en solution de secours.',
  'Gardez un petit montant en RMB en espèces pour les taxis, les petites boutiques et les situations où la vérification du portefeuille ou l’autorisation de la carte échoue.',
];

const paymentTools = [
  { href: '/fr/tools/payment-checker/', title: 'Vérificateur de compatibilité des paiements', desc: 'Vérifiez la prise en charge des cartes, les plafonds habituels et les frais pour Alipay et WeChat Pay.' },
  { href: '/fr/tools/budget-cash-estimator/', title: 'Estimateur de budget et d’espèces', desc: 'Estimez vos dépenses de voyage et le montant d’espèces de secours à emporter.' },
  { href: '/fr/tools/currency-converter/', title: 'Convertisseur de devise RMB', desc: 'Convertissez les prix en yuans et comprenez les coûts du quotidien.' },
];
---
import { getCategoryLabel } from '../../../i18n/categories.ts';

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Paiement</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Guides de paiement en Chine</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-how-to-pay" alt="Configuration du paiement mobile sur un smartphone affichant des moyens de paiement pour un voyage en Chine" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-payment">
      <h2 id="featured-payment" class="sr-only">Guides de paiement à lire</h2>
      <a href="/fr/posts/alipay-foreign-credit-card-step-by-step/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Configuration d’Alipay</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Guide pas à pas pour installer Alipay et lier une carte bancaire étrangère</p>
      </a>
      <a href="/fr/posts/wechat-pay-foreign-visitors-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">WeChat Pay</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Guide complet de configuration et d’utilisation pour les visiteurs étrangers</p>
      </a>
      <a href="/fr/posts/alipay-vs-wechat-pay-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Alipay vs WeChat Pay</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Quelle application de paiement choisir en 2026 ?</p>
      </a>
      <a href="/fr/posts/how-to-pay-in-china-tourist-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Guide complet du paiement</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Tout ce qu’il faut savoir pour payer en Chine en tant que touriste</p>
      </a>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[1fr_340px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">Commencez avec une configuration de paiement fiable</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          En Chine, les paiements par QR code dominent largement. Une configuration pratique pour les touristes comprend généralement un portefeuille principal, un portefeuille de secours, deux options de carte et un peu d’argent liquide en yuan pour les cas exceptionnels.
        </p>
        <ol class="mt-5 space-y-3 text-sm leading-6 text-gray-600">
          {prioritySteps.map((step, index) => (
            <li class="flex gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand-50 text-xs font-bold text-brand-700">{index + 1}</span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">Outils de paiement</h2>
        <div class="mt-4 grid gap-3">
          {paymentTools.map((tool) => (
            <a href={tool.href} class="rounded-lg border border-brand-100 bg-white p-4 hover:border-brand-200 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-900 hover:text-brand-700">{tool.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{tool.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/fr/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{getCategoryLabel(post.data.category, locale)}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('fr-FR', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">Guides bientôt disponibles.</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>