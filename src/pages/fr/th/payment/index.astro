---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import AdSlot from '../../../../components/AdSlot.astro';
import CoverImage from '../../../../components/CoverImage.astro';

const CATEGORY = 'payment';
const posts = (await getCollection('posts-zh-tw'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = '中國付款指南：Alipay、WeChat Pay 與海外信用卡';
const description =
  '提供外國旅客在中國付款的實用指南，教你設定 Alipay 與 WeChat Pay、綁定國際信用卡，並避開常見問題。';

const prioritySteps = [
  '出發前先安裝 Alipay 和 WeChat Pay，並在仍可使用本國銀行帳戶與手機門號時完成身分驗證。',
  '至少綁定一張 Visa 或 Mastercard，並另外準備一張不同發卡銀行的卡片作為備用。',
  '隨身攜帶少量人民幣現金，以便在搭計程車、逛小店，或遇到錢包驗證與刷卡授權失敗時使用。',
];

const paymentTools = [
  { href: '/zh-tw/tools/payment-checker/', title: '付款相容性檢查工具', desc: '查看 Alipay 和 WeChat Pay 的卡片支援情況、常見額度與手續費。' },
  { href: '/zh-tw/tools/budget-cash-estimator/', title: '預算與現金估算工具', desc: '估算旅費支出，以及需要攜帶多少備用現金。' },
  { href: '/zh-tw/tools/currency-converter/', title: '人民幣匯率換算工具', desc: '換算成人民幣價格，快速了解日常花費。' },
];
import { getCategoryLabel } from '../../../i18n/categories';
const locale = 'th';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="th">
  <Header locale="th" />
  <main class="container-page py-10">
    <header>
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">付款</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">中國付款指南</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-how-to-pay" alt="以智慧型手機展示中國旅遊付款方式的行動支付設定畫面" loading="lazy" />


    <div class="mt-8 space-y-4 text-justify text-lg leading-8 text-gray-600">
      <p>
  การชำระเงินในจีนในฐานะนักท่องเที่ยวต่างชาติเคยหมายถึงการพกเงินสด RMB เป็นกองหนาและหวังว่าคนขับแท็กซี่จะมีเงินทอน ยุคสมัยนั้นสิ้นสุดลงแล้ว ทุกวันนี้ ร้านค้า รถไฟฟ้าใต้ดิน ร้านอาหาร และร้านสะดวกซื้อทุกแห่งในเมืองใหญ่ของจีนรับ Alipay และ WeChat Pay การตั้งค่าทั้งหมดตั้งแต่ติดตั้งแอปไปจนถึงเชื่อมบัตรต่างประเทศใช้เวลาประมาณ 15 นาที หากทำก่อนเดินทาง เคล็ดลับคือทำก่อนเดินทาง ไม่ใช่หลังจากมาถึง เพราะการยืนยันตัวตนในกระเป๋าเงินดิจิทัลบางครั้งอาจใช้เวลาหนึ่งถึงสองวัน
      </p>
      <p>
  คู่มือด้านล่างอธิบายวิธีการใช้กระเป๋าเงินหลักสองประเภท วิธีเชื่อมบัตร Visa หรือ Mastercard เมื่อใดควรใช้บัตรต่างประเทศโดยตรง และควรพกเงินสดสำรองเท่าใด เริ่มต้นด้วยคำแนะนำทีละขั้นตอนสำหรับ Alipay หากคุณไม่เคยใช้แอปจีนมาก่อน เพราะครอบคลุมขั้นตอนการยืนยันตัวตนที่เป็นอุปสรรค最常见ที่สุดสำหรับนักท่องเที่ยวต่างชาติ
      </p>
    </div>

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="精選付款">
      <h2 id="精選付款" class="sr-only">精選付款指南</h2>
      <a href="/zh-tw/posts/alipay-foreign-credit-card-step-by-step/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Alipay 設定教學</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">一步一步教你安裝 Alipay 並綁定海外信用卡</p>
      </a>
      <a href="/zh-tw/posts/wechat-pay-foreign-visitors-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">WeChat Pay</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">外國旅客適用的完整設定與使用指南</p>
      </a>
      <a href="/zh-tw/posts/alipay-vs-wechat-pay-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Alipay 與 WeChat Pay 比較</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">2026 年你應該使用哪一款付款應用程式？</p>
      </a>
      <a href="/zh-tw/posts/how-to-pay-in-china-tourist-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">完整付款指南</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">旅客在中國付款時需要知道的一切</p>
      </a>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[1fr_340px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">先建立穩妥可靠的付款配置</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          中國目前以 QR 碼付款為主。對旅客最友善的配置通常是：一個主要電子錢包、一個備用電子錢包、兩種卡片選項，以及少量現金來應付例外情況。
        </p>
        <ol class="mt-5 space-y-3 text-sm leading-6 text-gray-600">
          {prioritySteps.map((step, index) => (
            <li class="flex gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand-50 text-xs font-bold text-brand-700">{index + 1}</span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">付款工具</h2>
        <div class="mt-4 grid gap-3">
          {paymentTools.map((tool) => (
            <a href={tool.href} class="rounded-lg border border-brand-100 bg-white p-4 hover:border-brand-200 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-900 hover:text-brand-700">{tool.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{tool.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/zh-tw/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{getCategoryLabel(post.data.category, locale)}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('zh-TW', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">指南即將上線。</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>