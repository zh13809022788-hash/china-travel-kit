---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import AdSlot from '../../../../components/AdSlot.astro';

const seriesSlug = 'history-of-china';
const posts = (await getCollection('posts-zh-tw'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = '中國歷史 — 獻給旅人的古蹟與故事';
const description = '以外國旅人的視角探索中國的歷史景點：長城、兵馬俑、紫禁城、絲路、古都與水鄉，透過背後的故事理解眼前所見。';

const relatedTools = [
  { href: '/zh-tw/posts/china-visa-free-entry-transit-guide-2026/', title: '簽證與入境指南', desc: '免簽過境與入境規定' },
  { href: '/zh-tw/posts/china-high-speed-rail-guide-foreigners/', title: '高鐵指南', desc: '前往中國各地歷史景點的列車' },
  { href: '/zh-tw/posts/book-china-train-tickets-12306-foreigners/', title: '預訂火車票', desc: '外國護照持有人使用 12306 的指南' },
];

const relatedCities = [
  { href: '/zh-tw/posts/beijing-city-guide-for-foreigners/', title: '北京', desc: '紫禁城、長城、天壇' },
  { href: '/zh-tw/posts/hangzhou-city-guide-for-foreigners/', title: '杭州', desc: '南宋古都' },
  { href: '/zh-tw/posts/chengdu-city-guide-for-foreigners/', title: '成都', desc: '三國遺產與古街' },
];

const otherSeries = [
  { href: '/zh-tw/series/food-of-china/', title: '中國美食' },
  { href: '/zh-tw/series/culture-of-china/', title: '中國文化' },
  { href: '/zh-tw/series/nature-of-china/', title: '中國自然' },
];
import { getCategoryLabel } from '../../../../i18n/categories';
const locale = 'zh-tw';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="zh-TW">
  <Header locale="zh-TW" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">內容系列</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">文章</p>
            <h2>中國歷史系列</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/zh-tw/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">本系列文章正在準備中，請稍後再回來查看。</p>
        )}
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">實用工具</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">規劃你的行程</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">城市指南</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">歷史名城</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">更多系列</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>
