---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';

const title = 'Planificateur de voyage en Chine gratuit';
const description =
  'Préparez un plan concret pour un premier voyage en Chine avec des recommandations sur les paiements, l’eSIM, les transports, les applications, les espèces et la check-list du premier jour.';

const needOptions = [
  { value: 'payment', label: 'Configurer les paiements' },
  { value: 'esim', label: 'eSIM et Internet' },
  { value: 'transport', label: 'Aéroport et trains' },
  { value: 'hotel', label: 'Choisir le bon quartier pour l’hôtel' },
  { value: 'apps', label: 'Applications et traduction' },
  { value: 'cash', label: 'Prévoir des espèces' },
  { value: 'visa', label: 'Vérifier l’entrée sans visa' },
  { value: 'food', label: 'Repas et livraison' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main>
    <section class="border-b border-gray-200 bg-white">
      <div class="container-page grid gap-8 py-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <div>
          <p class="section-kicker">Outil gratuit</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Préparez un plan d’arrivée concret en Chine avant le départ
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Obtenez un premier plan pour les paiements, les données eSIM, le trajet depuis
            l’aéroport, la configuration des applications, la réserve d’espèces et le rythme des
            premiers jours. L’outil fonctionne dans votre navigateur et n’enregistre pas vos
            réponses.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#planner" class="btn-primary">Commencer</a>
            <a href="/fr/travel-help/" class="btn-outline">Demander de l’aide</a>
            <a href="/fr/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">Lire le guide du premier voyage</a>
          </div>
        </div>

        <aside class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="section-kicker">Pour qui ?</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Idéal pour un premier séjour</h2>
          <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
            <li>Préparer les paiements avant l’arrivée</li>
            <li>Choisir entre eSIM, itinérance et accès aux applications</li>
            <li>Anticiper le premier trajet entre l’aéroport et la ville</li>
            <li>Poser une base simple, ville par ville</li>
          </ul>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <AdSlot format="banner" />

      <section id="planner" class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <form id="trip-planner-form" class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm md:p-6">
          <div class="border-b border-gray-200 pb-5">
            <p class="section-kicker">Détails du voyage</p>
            <h2 class="mt-2 text-2xl font-bold text-gray-950">Indiquez ce que vous savez déjà</h2>
          </div>

          <div class="mt-6 grid gap-5 md:grid-cols-2">
            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Pays ou région de départ
              <input id="home-country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="États-Unis, Royaume-Uni, Singapour..." />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Ville d’arrivée
              <select id="arrival-city" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Shanghai</option>
                <option>Pékin</option>
                <option>Canton</option>
                <option>Shenzhen</option>
                <option>Chengdu</option>
                <option>Hangzhou</option>
                <option>Autre ville</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800 md:col-span-2">
              Villes prévues
              <input id="destination-cities" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="Shanghai, Hangzhou, Pékin" />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Durée du voyage
              <select id="trip-length" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option value="3">3 jours</option>
                <option value="5">5 jours</option>
                <option value="7" selected>7 jours</option>
                <option value="10">10 jours</option>
                <option value="14">14 jours</option>
                <option value="21">21 jours ou plus</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Motif du voyage
              <select id="trip-purpose" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Tourisme</option>
                <option>Affaires</option>
                <option>Séjour longue durée</option>
                <option>Nomade numérique</option>
                <option>Visite familiale</option>
                <option>Transit</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Niveau de budget
              <select id="budget-range" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Économique</option>
                <option selected>Confort</option>
                <option>Haut de gamme</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Style de voyage
              <select id="travel-style" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Efficace</option>
                <option>Économique</option>
                <option selected>Confort</option>
                <option>En famille</option>
                <option>Affaires</option>
                <option>Gastronomie</option>
              </select>
            </label>
          </div>

          <fieldset class="mt-6">
            <legend class="text-sm font-semibold text-gray-800">Sur quoi avez-vous besoin d’aide ?</legend>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              {needOptions.map((option) => (
                <label class="flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-700">
                  <input class="h-4 w-4 rounded border-gray-300 text-brand-600" type="checkbox" name="needs" value={option.value} checked={['payment', 'esim', 'transport', 'apps'].includes(option.value)} />
                  {option.label}
                </label>
              ))}
            </div>
          </fieldset>

          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p id="planner-status" class="text-sm text-gray-500">Aucun compte ni aucune donnée sensible ne sont nécessaires.</p>
            <button class="btn-primary" type="submit">Générer le plan</button>
          </div>
        </form>

        <aside class="space-y-6">
          <section class="rounded-lg border border-gray-200 bg-white p-5">
            <p class="section-kicker">Vérification humaine</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Besoin d’une relecture humaine ?</h2>
            <p class="mt-3 text-sm leading-6 text-gray-600">
              Si votre itinéraire, votre calendrier, votre configuration de paiement ou votre
              premier jour vous semblent fragiles, envoyez le plan généré par e-mail et demandez une
              liste de corrections relue par une personne.
            </p>
            <a id="planner-email-link" class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:border-brand-600 hover:text-brand-600 hover:no-underline" href="mailto:zh13809022788@gmail.com?subject=Demande%20de%20relecture%20de%20voyage%20ChinaTripBox">
              Préparer l’e-mail de relecture
            </a>
          </section>

          <section class="rounded-lg border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Limites</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">À utiliser comme aide à l’organisation</h2>
            <p class="mt-3 text-sm leading-6 text-gray-700">
              Cet outil ne remplace pas un conseil juridique, d’immigration, médical, bancaire ou
              d’urgence. Vérifiez toujours les règles importantes liées à l’entrée, à la compagnie
              aérienne, à l’hôtel, aux cartes, aux télécoms et aux applications auprès de sources
              officielles.
            </p>
          </section>
        </aside>
      </section>

      <section id="plan-output" class="mt-10 hidden rounded-lg border border-brand-100 bg-brand-50 p-5 md:p-6" aria-live="polite">
        <div class="border-b border-brand-100 pb-4">
          <p class="section-kicker">Plan généré</p>
          <h2 class="mt-2 text-2xl font-bold text-gray-950">Votre première trame de voyage en Chine</h2>
        </div>
        <div id="plan-content" class="mt-5 grid gap-5"></div>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <a href="/fr/payment/" class="card block hover:no-underline">
          <p class="section-kicker">Paiement</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Préparez Alipay et WeChat Pay</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Configurez au moins un portefeuille mobile et un moyen de secours avant l’arrivée.</p>
        </a>
        <a href="/fr/esim/" class="card block hover:no-underline">
          <p class="section-kicker">Internet</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Choisissez votre solution eSIM ou d’itinérance</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Assurez-vous de pouvoir ouvrir vos cartes, traduire, écrire et commander un VTC dès le premier jour.</p>
        </a>
        <a href="/fr/transport/" class="card block hover:no-underline">
          <p class="section-kicker">Transport</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Planifiez votre premier trajet</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Sachez comment aller de l’aéroport à l’hôtel et quand choisir métro, taxi, DiDi ou train.</p>
        </a>
      </section>

      <section class="mt-10 rounded-lg border border-gray-200 bg-white p-5 md:p-6">
        <p class="section-kicker">Avant d’utiliser le planificateur</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950">Lisez les guides de base si c’est votre premier voyage en Chine</h2>
        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <a href="/fr/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Planifier un premier voyage en Chine</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Suivez le même ordre que dans l’outil : Internet, paiements, trajet depuis l’aéroport, applications, ordre des villes et check-list du premier jour.</p>
          </a>
          <a href="/fr/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Ce qu’il faut configurer avant de partir en Chine</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Une check-list concrète pour Alipay, WeChat Pay, eSIM, DiDi, billets de train, cartes et réserve d’espèces.</p>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('trip-planner-form') as HTMLFormElement | null;
  const output = document.getElementById('plan-output');
  const content = document.getElementById('plan-content');
  const status = document.getElementById('planner-status');
  const emailLink = document.getElementById('planner-email-link') as HTMLAnchorElement | null;

  const getValue = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null)?.value.trim() || '';
  const selectedNeeds = () =>
    Array.from(document.querySelectorAll<HTMLInputElement>('input[name="needs"]:checked')).map((input) => input.value);
  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char] ?? char);

  const splitCities = (value: string, arrival: string) => {
    const typed = value
      .split(',')
      .map((city) => city.trim())
      .filter(Boolean);
    const cities = typed.length ? typed : [arrival];
    return Array.from(new Set(cities));
  };

  const list = (items: string[]) => `<ul class="mt-3 grid gap-2 text-sm leading-6 text-gray-700">${items.map((item) => `<li>${item}</li>`).join('')}</ul>`;
  const panel = (title: string, items: string[]) => `
    <section class="rounded-lg border border-gray-200 bg-white p-5">
      <h3 class="text-lg font-bold text-gray-950">${title}</h3>
      ${list(items)}
    </section>
  `;

  const buildPlan = () => {
    const home = getValue('home-country') || 'votre pays ou région de départ';
    const arrival = getValue('arrival-city') || 'Shanghai';
    const cities = splitCities(getValue('destination-cities'), arrival);
    const days = Number(getValue('trip-length') || '7');
    const purpose = getValue('trip-purpose') || 'Tourisme';
    const budget = getValue('budget-range') || 'Confort';
    const style = getValue('travel-style') || 'Confort';
    const needs = selectedNeeds();
    const perCity = Math.max(1, Math.floor(days / Math.max(1, cities.length)));

    const preDeparture = [
      `Installez Alipay, WeChat, DiDi, une application de traduction et une carte hors ligne avant de quitter ${escapeHtml(home)}.`,
      needs.includes('payment')
        ? 'Associez une carte Visa ou Mastercard étrangère à Alipay et vérifiez que la configuration fonctionne bien avant le départ.'
        : 'Gardez une configuration simple : un portefeuille mobile, une carte physique et un peu d’espèces en RMB.',
      needs.includes('esim')
        ? 'Achetez et activez une eSIM ou un forfait d’itinérance avant le vol, puis gardez le QR code d’activation accessible hors ligne.'
        : 'Vérifiez que votre téléphone aura bien des données à l’arrivée avant de compter sur les cartes ou le VTC.',
      'Enregistrez l’adresse de votre hôtel en anglais et en chinois, ainsi que la station de métro la plus proche.',
    ];

    const payment = [
      'Configuration principale : Alipay avec une carte étrangère, car c’est souvent le portefeuille le plus simple à utiliser pour un visiteur.',
      'Configuration de secours : WeChat Pay si votre carte s’y associe correctement, plus une carte Visa ou Mastercard physique.',
      budget === 'Économique'
        ? 'Réserve d’espèces : prévoyez une petite somme en RMB pour les stands, les cautions ou un problème temporaire de carte ou de portefeuille.'
        : 'Réserve d’espèces : gardez assez de RMB pour un taxi, quelques encas et un repas simple si le paiement mobile tombe en panne.',
      'Ne comptez pas sur Apple Pay ou Google Pay comme moyen de paiement principal en Chine continentale.',
    ];

    const internet = [
      'Pour un court séjour, une eSIM de voyage reste souvent la solution la plus simple si votre téléphone est compatible.',
      'Pour un séjour plus long ou une forte consommation de données, comparez l’itinérance, l’eSIM, le pocket WiFi et la SIM locale avant l’arrivée.',
      'Testez les données mobiles avant de quitter l’aéroport, car vos applications de paiement, de VTC, de traduction et de cartes en dépendent.',
      'Conservez hors ligne les informations de l’hôtel et les détails de transport au cas où votre première connexion serait instable.',
    ];

    const transport = [
      `Premier trajet : préparez le transfert entre l’aéroport ou la gare de ${escapeHtml(arrival)} et votre hôtel avant l’atterrissage.`,
      'Utilisez le métro pour les trajets urbains prévisibles, DiDi pour le porte-à-porte et le train à grande vitesse pour les déplacements entre villes.',
      needs.includes('transport')
        ? 'Pour les journées en train, réservez le plus tôt possible et vérifiez que les informations du passeport correspondent exactement à celles de la plateforme de billets.'
        : 'Évitez les correspondances trop serrées entre un vol international et un train longue distance le même jour.',
      'Gardez une fiche d’adresse en chinois prête à montrer à un taxi ou à la réception de l’hôtel.',
    ];

    const dayPlan = cities.map((city, index) => {
      const start = index * perCity + 1;
      const end = index === cities.length - 1 ? days : Math.min(days, start + perCity - 1);
      return `Jours ${start}-${end} : ${escapeHtml(city)} - allégez la première demi-journée, vérifiez paiements et données, puis regroupez les visites par quartier.`;
    });

    const mistakes = [
      'N’attendez pas l’arrivée pour configurer vos applications, vos cartes et votre forfait de données.',
      'Ne surchargez pas votre première journée de visites juste après un vol long-courrier.',
      'Ne dépendez jamais d’un seul moyen de paiement.',
      purpose === 'Affaires'
        ? 'Pour un voyage d’affaires, prévoyez plus de marge pour le trafic, les contrôles de sécurité, les factures et l’accès aux immeubles.'
        : 'Pour un voyage de loisirs, gardez un créneau souple tous les deux ou trois jours pour la météo, la foule ou la fatigue.',
      style === 'Gastronomie'
        ? 'Pour un voyage centré sur la gastronomie, enregistrez les noms des restaurants en chinois et vérifiez les horaires avant de traverser toute la ville.'
        : 'Gardez toujours un plan simple pour manger près de l’hôtel.',
    ];

    const html = [
      panel('Check-list avant le départ', preDeparture),
      panel('Paiements et espèces', payment),
      panel('Internet et applications', internet),
      panel('Transport et premier jour', transport),
      panel('Trame simple jour par jour', dayPlan),
      panel('Erreurs à éviter', mistakes),
    ].join('');

    const emailBody = [
      'Demande de relecture ChinaTripBox',
      '',
      `Pays ou région de départ : ${home}`,
      `Ville d’arrivée : ${arrival}`,
      `Villes prévues : ${cities.join(', ')}`,
      `Durée du voyage : ${days} jours`,
      `Motif : ${purpose}`,
      `Budget : ${budget}`,
      `Style : ${style}`,
      `Besoins : ${needs.join(', ') || 'non précisés'}`,
      '',
      'Merci de relire ma préparation de voyage en Chine : paiements, eSIM, transport, rythme et erreurs possibles du premier jour.',
    ].join('\n');

    if (emailLink) {
      emailLink.href = `mailto:zh13809022788@gmail.com?subject=${encodeURIComponent(
        'Demande de relecture de voyage ChinaTripBox',
      )}&body=${encodeURIComponent(emailBody)}`;
    }

    return html;
  };

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!content || !output) return;
    content.innerHTML = buildPlan();
    output.classList.remove('hidden');
    output.scrollIntoView({ behavior: 'smooth', block: 'start' });
    if (status) status.textContent = 'Plan généré. Vous pouvez modifier vos réponses et le régénérer à tout moment.';
  });
</script>
