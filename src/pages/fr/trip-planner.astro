---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';

const title = 'Planificateur de voyage en Chine gratuit';
const description =
  'Élaborez un plan pratique pour un premier voyage en Chine avec des recommandations de paiement, eSIM, transport, configuration d’applications, espèces et liste de vérification du premier jour.';

const needOptions = [
  { value: 'payment', label: 'Configuration des paiements' },
  { value: 'esim', label: 'eSIM et Internet' },
  { value: 'transport', label: 'Aéroport et trains' },
  { value: 'hotel', label: 'Choix du quartier d’hôtel' },
  { value: 'apps', label: 'Applications et traduction' },
  { value: 'cash', label: 'Réserve de liquide' },
  { value: 'visa', label: 'Entrée sans visa' },
  { value: 'food', label: 'Nourriture et livraison' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main>
    <section class="border-b border-gray-200 bg-white">
      <div class="container-page grid gap-8 py-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <div>
          <p class="section-kicker">Outil de planification gratuit</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Élaborez un plan d’arrivée pratique en Chine avant de voler
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Obtenez un premier plan pour les paiements, les données eSIM, le transport depuis
            l’aéroport, la configuration des applications, la réserve de liquide et le rythme
            quotidien. L’outil fonctionne dans votre navigateur et n’enregistre pas vos réponses.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#planner" class="btn-primary">Commencer la planification</a>
            <a href="/fr/travel-help/" class="btn-outline">Demander de l’aide voyage</a>
            <a href="/fr/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">Lire le guide pour premiers voyageurs</a>
          </div>
        </div>

        <aside class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="section-kicker">Idéal pour</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Configuration pour premier voyageur</h2>
          <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
            <li>Préparation des paiements avant l’arrivée</li>
            <li>Décisions eSIM, itinérance et accès aux applications</li>
            <li>Planification du premier trajet aéroport-ville</li>
            <li>Cadre simple de voyage ville par ville</li>
          </ul>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <AdSlot format="banner" />

      <section id="planner" class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <form id="trip-planner-form" class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm md:p-6">
          <div class="border-b border-gray-200 pb-5">
            <p class="section-kicker">Détails du voyage</p>
            <h2 class="mt-2 text-2xl font-bold text-gray-950">Dites-nous ce que vous savez</h2>
          </div>

          <div class="mt-6 grid gap-5 md:grid-cols-2">
            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Pays ou région d’origine
              <input id="home-country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="États-Unis, Royaume-Uni, Singapour..." />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Ville d’arrivée
              <select id="arrival-city" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Shanghai</option>
                <option>Pékin</option>
                <option>Canton</option>
                <option>Shenzhen</option>
                <option>Chengdu</option>
                <option>Hangzhou</option>
                <option>Autre ville</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800 md:col-span-2">
              Villes de destination
              <input id="destination-cities" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="Shanghai, Hangzhou, Pékin" />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Durée du voyage
              <select id="trip-length" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option value="3">3 jours</option>
                <option value="5">5 jours</option>
                <option value="7" selected>7 jours</option>
                <option value="10">10 jours</option>
                <option value="14">14 jours</option>
                <option value="21">21 jours ou plus</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Objet du voyage
              <select id="trip-purpose" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Tourisme</option>
                <option>Affaires</option>
                <option>Long séjour</option>
                <option>Nomade numérique</option>
                <option>Visite familiale</option>
                <option>Transit</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Niveau de budget
              <select id="budget-range" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Économique</option>
                <option selected>Confort</option>
                <option>Premium</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              Style de voyage
              <select id="travel-style" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>Efficace</option>
                <option>Économique</option>
                <option selected>Confort</option>
                <option>Familial</option>
                <option>Affaires</option>
                <option>Gastronomique</option>
              </select>
            </label>
          </div>

          <fieldset class="mt-6">
            <legend class="text-sm font-semibold text-gray-800">De quoi avez-vous besoin d’aide ?</legend>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              {needOptions.map((option) => (
                <label class="flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-700">
                  <input class="h-4 w-4 rounded border-gray-300 text-brand-600" type="checkbox" name="needs" value={option.value} checked={['payment', 'esim', 'transport', 'apps'].includes(option.value)} />
                  {option.label}
                </label>
              ))}
            </div>
          </fieldset>

          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p id="planner-status" class="text-sm text-gray-500">Aucun compte ni donnée sensible nécessaire.</p>
            <button class="btn-primary" type="submit">Générer le plan</button>
          </div>
        </form>

        <aside class="space-y-6">
          <section class="rounded-lg border border-gray-200 bg-white p-5">
            <p class="section-kicker">Validation humaine</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Besoin d’une révision humaine ?</h2>
            <p class="mt-3 text-sm leading-6 text-gray-600">
              Si votre itinéraire, votre calendrier, votre configuration de paiement ou votre
              premier jour vous semblent risqués, envoyez le plan généré par e-mail et demandez une
              liste de corrections revue par un humain.
            </p>
            <a id="planner-email-link" class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:border-brand-600 hover:text-brand-600 hover:no-underline" href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Trip%20Review%20Request">
              Préparer l’e-mail de révision
            </a>
          </section>

          <section class="rounded-lg border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Limites</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Utilisez-le comme aide à la planification</h2>
            <p class="mt-3 text-sm leading-6 text-gray-700">
              Cet outil ne constitue pas un conseil juridique, d’immigration, médical, bancaire ou
              d’urgence. Vérifiez les règles importantes d’entrée, de compagnie aérienne, d’hôtel,
              de carte, de télécom et d’application auprès de sources officielles.
            </p>
          </section>
        </aside>
      </section>

      <section id="plan-output" class="mt-10 hidden rounded-lg border border-brand-100 bg-brand-50 p-5 md:p-6" aria-live="polite">
        <div class="border-b border-brand-100 pb-4">
          <p class="section-kicker">Plan généré</p>
          <h2 class="mt-2 text-2xl font-bold text-gray-950">Votre brouillon de configuration de voyage en Chine</h2>
        </div>
        <div id="plan-content" class="mt-5 grid gap-5"></div>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <a href="/fr/payment/" class="card block hover:no-underline">
          <p class="section-kicker">Paiement</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Préparez Alipay et WeChat Pay</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Configurez au moins un portefeuille et un moyen de paiement de secours avant l’arrivée.</p>
        </a>
        <a href="/fr/esim/" class="card block hover:no-underline">
          <p class="section-kicker">Internet</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Choisissez une configuration eSIM ou itinérance</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Assurez-vous de pouvoir charger des cartes, traduire, envoyer des messages et commander un VTC dès le premier jour.</p>
        </a>
        <a href="/fr/transport/" class="card block hover:no-underline">
          <p class="section-kicker">Transport</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Planifiez votre premier itinéraire</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">Connaissez votre trajet aéroport-hôtel et quand utiliser le métro, le taxi, DiDi ou le train.</p>
        </a>
      </section>

      <section class="mt-10 rounded-lg border border-gray-200 bg-white p-5 md:p-6">
        <p class="section-kicker">Avant d’utiliser le planificateur</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950">Lisez les guides de configuration si c’est votre premier voyage en Chine</h2>
        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <a href="/fr/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Planificateur de voyage en Chine pour premiers voyageurs</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Utilisez le même ordre de planification que cet outil : Internet, paiement, trajet aéroport, applications, ordre des villes et liste de vérification du premier jour.</p>
          </a>
          <a href="/fr/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Ce qu’il faut configurer avant de voyager en Chine</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Une liste de vérification pratique avant le départ pour Alipay, WeChat Pay, eSIM, DiDi, billets de train, cartes et réserve de liquide.</p>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('trip-planner-form') as HTMLFormElement | null;
  const output = document.getElementById('plan-output');
  const content = document.getElementById('plan-content');
  const status = document.getElementById('planner-status');
  const emailLink = document.getElementById('planner-email-link') as HTMLAnchorElement | null;

  const getValue = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null)?.value.trim() || '';
  const selectedNeeds = () =>
    Array.from(document.querySelectorAll<HTMLInputElement>('input[name="needs"]:checked')).map((input) => input.value);
  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char] ?? char);

  const splitCities = (value: string, arrival: string) => {
    const typed = value
      .split(',')
      .map((city) => city.trim())
      .filter(Boolean);
    const cities = typed.length ? typed : [arrival];
    return Array.from(new Set(cities));
  };

  const list = (items: string[]) => `<ul class="mt-3 grid gap-2 text-sm leading-6 text-gray-700">${items.map((item) => `<li>${item}</li>`).join('')}</ul>`;
  const panel = (title: string, items: string[]) => `
    <section class="rounded-lg border border-gray-200 bg-white p-5">
      <h3 class="text-lg font-bold text-gray-950">${title}</h3>
      ${list(items)}
    </section>
  `;

  const buildPlan = () => {
    const home = getValue('home-country') || 'votre pays d’origine';
    const arrival = getValue('arrival-city') || 'Shanghai';
    const cities = splitCities(getValue('destination-cities'), arrival);
    const days = Number(getValue('trip-length') || '7');
    const purpose = getValue('trip-purpose') || 'Tourisme';
    const budget = getValue('budget-range') || 'Confort';
    const style = getValue('travel-style') || 'Confort';
    const needs = selectedNeeds();
    const perCity = Math.max(1, Math.floor(days / Math.max(1, cities.length)));

    const preDeparture = [
      `Installez Alipay, WeChat, DiDi, une application de traduction et une carte hors ligne avant de quitter ${escapeHtml(home)}.`,
      needs.includes('payment')
        ? 'Associez une carte Visa ou Mastercard étrangère à Alipay et faites un petit test de vérification avant le départ.'
        : 'Gardez la configuration de paiement simple : un portefeuille mobile, une carte physique et des espèces en RMB.',
      needs.includes('esim')
        ? 'Achetez et activez une eSIM ou un forfait d’itinérance avant le vol, puis gardez le QR code accessible hors ligne.'
        : 'Confirmez que votre téléphone aura des données à l’arrivée avant de dépendre des cartes ou du VTC.',
      'Enregistrez l’adresse de votre hôtel en anglais et en chinois, plus la station de métro la plus proche.',
    ];

    const payment = [
      'Configuration principale : Alipay avec une carte étrangère, car c’est généralement le premier portefeuille le plus pratique pour les visiteurs.',
      'Configuration de secours : WeChat Pay si votre carte s’associe avec succès, plus une carte Visa ou Mastercard physique.',
      budget === 'Économique'
        ? 'Réserve de liquide : emportez une petite somme en RMB pour les étals, les dépôts ou les problèmes de carte/portefeuille.'
        : 'Réserve de liquide : gardez assez de RMB pour le taxi, les collations et un repas simple au cas où le paiement mobile tomberait en panne.',
      'Ne comptez pas sur Apple Pay ou Google Pay comme principal moyen de paiement en Chine continentale.',
    ];

    const internet = [
      'Pour les courts séjours, une eSIM de voyage est généralement la configuration la plus simple si votre téléphone prend en charge l’eSIM.',
      'Pour les séjours plus longs ou un usage intensif de données, comparez itinérance, eSIM, pocket WiFi et SIM locale avant l’arrivée.',
      'Testez les données mobiles avant de quitter l’aéroport, car les applications de paiement, VTC, traduction et cartes en dépendent toutes.',
      'Enregistrez les informations d’hôtel et de transport hors ligne au cas où votre première connexion serait instable.',
    ];

    const transport = [
      `Premier itinéraire : planifiez le trajet de l’aéroport ou de la gare d’${escapeHtml(arrival)} à l’hôtel avant l’atterrissage.`,
      'Utilisez le métro pour les trajets urbains prévisibles, DiDi pour les déplacements porte à porte et le train à grande vitesse pour les voyages interurbains.',
      needs.includes('transport')
        ? 'Pour les jours de train, réservez le plus tôt possible et gardez les informations du passeport cohérentes avec la plateforme de billets.'
        : 'Évitez les correspondances serrées le même jour entre vols internationaux et trains longue distance.',
      'Gardez une carte d’adresse en chinois prête pour les taxis ou les réceptions d’hôtel.',
    ];

    const dayPlan = cities.map((city, index) => {
      const start = index * perCity + 1;
      const end = index === cities.length - 1 ? days : Math.min(days, start + perCity - 1);
      return `Jours ${start}-${end} : ${escapeHtml(city)} - gardez la première demi-journée plus légère, confirmez paiement/données, puis regroupez les visites par quartier.`;
    });

    const mistakes = [
      'N’attendez pas l’arrivée pour configurer chaque application, carte et forfait de données.',
      'Ne planifiez pas une journée chargée de visites immédiatement après un vol long-courrier.',
      'Ne dépendez pas d’un seul moyen de paiement.',
      purpose === 'Affaires'
        ? 'Pour les voyages d’affaires, prévoyez du temps supplémentaire pour le trafic, les contrôles de sécurité, les factures et l’accès aux bâtiments.'
        : 'Pour les voyages de loisirs, laissez un bloc flexible tous les deux ou trois jours pour la météo, les foules ou la fatigue.',
      style === 'Gastronomique'
        ? 'Pour les voyages gastronomiques, enregistrez les noms de restaurants en chinois et confirmez les horaires d’ouverture avant de traverser la ville.'
        : 'Gardez un simple plan de secours pour les repas près de votre hôtel.',
    ];

    const html = [
      panel('Liste de vérification avant départ', preDeparture),
      panel('Configuration des paiements et des espèces', payment),
      panel('Configuration Internet et applications', internet),
      panel('Transport et premier jour', transport),
      panel('Cadre jour par jour simple', dayPlan),
      panel('Avertissements sur les erreurs courantes', mistakes),
    ].join('');

    const emailBody = [
      'ChinaTripBox Trip Review Request',
      '',
      `Home country or region: ${home}`,
      `Arrival city: ${arrival}`,
      `Destination cities: ${cities.join(', ')}`,
      `Trip length: ${days} days`,
      `Purpose: ${purpose}`,
      `Budget: ${budget}`,
      `Style: ${style}`,
      `Needs: ${needs.join(', ') || 'not specified'}`,
      '',
      'Please review my China trip setup for payment, eSIM, transport, timing, and first-day mistakes.',
    ].join('\n');

    if (emailLink) {
      emailLink.href = `mailto:zh13809022788@gmail.com?subject=${encodeURIComponent(
        'ChinaTripBox Trip Review Request',
      )}&body=${encodeURIComponent(emailBody)}`;
    }

    return html;
  };

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!content || !output) return;
    content.innerHTML = buildPlan();
    output.classList.remove('hidden');
    output.scrollIntoView({ behavior: 'smooth', block: 'start' });
    if (status) status.textContent = 'Plan généré. Ajustez vos réponses et régénérez à tout moment.';
  });
</script>
