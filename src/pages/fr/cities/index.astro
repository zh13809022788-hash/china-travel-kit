---

import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CoverImage from '../../../components/CoverImage.astro';
import ChinaMap from '../../../components/ChinaMap.astro';
import AdSlot from '../../../components/AdSlot.astro';

const allPosts = await getCollection('posts-fr');
const cityNames = ['beijing', 'shanghai', 'chengdu', 'hangzhou', 'sanya', 'guangzhou', 'xian', 'chongqing', 'kunming', 'nanjing'];
const cityPosts = allPosts
  .filter((post) => cityNames.some((city) => post.slug.includes(city) || post.data.tags.includes(city)))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const title = 'Guides des villes chinoises pour visiteurs étrangers';
const description = 'Planifiez des étapes urbaines pratiques en Chine avec des guides pour Pékin, Shanghai, Canton, Chengdu, Xi’an, Hangzhou, Chongqing et Sanya, ainsi que les prochaines étapes pour l’aéroport, le métro, la nourriture et les transports.';

const mapCities = [
  { name: 'Beijing', x: 470, y: 80, href: '#beijing' },
  { name: 'Xi\'an', x: 340, y: 155, href: '#xian' },
  { name: 'Nanjing', x: 490, y: 180, href: '' },
  { name: 'Shanghai', x: 540, y: 200, href: '#shanghai' },
  { name: 'Chengdu', x: 250, y: 220, href: '#chengdu' },
  { name: 'Hangzhou', x: 520, y: 205, href: '#hangzhou' },
  { name: 'Chongqing', x: 310, y: 260, href: '#chongqing' },
  { name: 'Guilin', x: 370, y: 300, href: '' },
  { name: 'Kunming', x: 210, y: 335, href: '' },
  { name: 'Guangzhou', x: 400, y: 370, href: '#guangzhou' },
  { name: 'Shenzhen', x: 430, y: 390, href: '' },
  { name: 'Sanya', x: 360, y: 440, href: '#sanya' },
];

const cities = [
  {
    name: 'Beijing',
    href: '/fr/posts/beijing-city-guide-for-foreigners/',
    desc: 'Idéal pour l’histoire, les hutongs, la Grande Muraille et les visites classiques pour les premiers voyageurs.',
    days: '4-5 jours',
    bestSeason: 'Septembre-Octobre',
    difficulty: 'Moyen',
    whyGo: 'Histoire impériale, musées et l’accès le plus facile à la Grande Muraille.',
    next: '/fr/posts/beijing-daxing-airport-to-city-center-a-first-timer-s-guide/',
    nextLabel: 'Guide de transfert depuis l’aéroport de Daxing',
  },
  {
    name: 'Shanghai',
    href: '/fr/posts/shanghai-city-guide-for-foreigners/',
    desc: 'Idéal pour une arrivée en douceur, la cuisine internationale, les promenades de skyline et un bon réseau de métro.',
    days: '3-4 jours',
    bestSeason: 'Mars-Mai, Octobre-Novembre',
    difficulty: 'Facile',
    whyGo: 'La première étape la plus fluide pour le métro, les aéroports, la nourriture et les services en anglais.',
    next: '/fr/posts/shanghai-metro-for-foreigners-tickets-qr-codes-transfers/',
    nextLabel: 'Guide du métro de Shanghai',
  },
  {
    name: 'Chengdu',
    href: '/fr/posts/chengdu-city-guide-for-foreigners/',
    desc: 'Idéal pour la cuisine du Sichuan, le rythme des maisons de thé, les pandas et un rythme urbain plus doux.',
    days: '3-5 jours',
    bestSeason: 'Mars-Juin, Septembre-Novembre',
    difficulty: 'Moyen',
    whyGo: 'Pandas, cuisine du Sichuan, maisons de thé, coûts réduits et excursions dans l’ouest de la Chine.',
    next: '/fr/posts/chengdu-street-food-safety-spice-levels-what-to-order/',
    nextLabel: 'Guide de la street-food de Chengdu',
  },
  {
    name: 'Xi\'an',
    href: '/fr/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/',
    desc: 'Idéal pour l’histoire ancienne, l’armée en terre cuite, les anciens remparts et le patrimoine chinois palpable.',
    days: '3-4 jours',
    bestSeason: 'Mars-Mai, Septembre-Novembre',
    difficulty: 'Moyen',
    whyGo: 'Guerriers en terre cuite, ancien rempart de la ville, rue alimentaire du quartier musulman et un sens profond de l’histoire chinoise.',
    next: '/fr/posts/china-high-speed-rail-guide-foreigners/',
    nextLabel: 'Train à grande vitesse vers Xi’an',
  },
  {
    name: 'Guangzhou',
    href: '/fr/posts/airport-to-city-transport-beijing-shanghai-guangzhou/',
    desc: 'Idéal pour la cuisine cantonaise, l’énergie d’une ville commerciale, porte du sud et accès facile à Hong Kong.',
    days: '3-4 jours',
    bestSeason: 'Octobre-Décembre, Mars-Avril',
    difficulty: 'Moyen',
    whyGo: 'Dim sum cantonais, académie du clan Chen, tour de Canton et une alternative méridionale plus chaude à Pékin et Shanghai.',
    next: '/fr/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    nextLabel: 'Guide de la cuisine cantonaise',
  },
  {
    name: 'Chongqing',
    href: '/fr/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    desc: 'Idéal pour le hotpot du Sichuan, une skyline futuriste, un terrain de ville montagneuse et les croisières sur le Yangtsé.',
    days: '3-4 jours',
    bestSeason: 'Mars-Mai, Septembre-Novembre',
    difficulty: 'Difficile',
    whyGo: 'Hotpot de Chongqing, grotte de Hongya, skyline nocturne, téléphérique du Yangtsé et un plan de ville unique en verticalité.',
    next: '/fr/food/',
    nextLabel: 'Guide de la cuisine de Chongqing',
  },
  {
    name: 'Hangzhou',
    href: '/fr/posts/hangzhou-city-guide-for-foreigners/',
    desc: 'Idéal pour le lac de l’Ouest, les paysages verdoyants, un rythme de week-end et une escapade urbaine raffinée.',
    days: '2-3 jours',
    bestSeason: 'Mars-Mai, Septembre-Novembre',
    difficulty: 'Facile à moyen',
    whyGo: 'Lac de l’Ouest, villages de thé, temples et un prolongement calme en train à grande vitesse depuis Shanghai.',
    next: '/fr/transport/',
    nextLabel: 'Planifier trains et transports locaux',
  },
  {
    name: 'Sanya',
    href: '/fr/posts/sanya-city-guide-for-foreigners/',
    desc: 'Idéal pour un climat hivernal doux, les séjours en resort, le temps à la plage et les excursions à Hainan.',
    days: '3-7 jours',
    bestSeason: 'Novembre-Avril',
    difficulty: 'Moyen',
    whyGo: 'Temps à la plage en Chine, soleil d’hiver, fruits de mer, resorts et séjours saisonniers plus longs.',
    next: '/fr/posts/what-to-pack-for-china-a-season-by-season-checklist/',
    nextLabel: 'Guide de préparation saisonnière',
  },
];

const routes = [
  {
    name: 'Premier voyage en Chine, 8-10 jours',
    plan: 'Shanghai 3 jours, Hangzhou 2 jours, Pékin 4 jours',
    fit: 'Meilleur équilibre entre arrivée facile, paysages classiques et histoire incontournable.',
  },
  {
    name: 'Cuisine et rythme détendu, 7-9 jours',
    plan: 'Chengdu 4 jours, Pékin ou Shanghai 3-4 jours',
    fit: 'Idéal pour les voyageurs qui veulent des pandas, des maisons de thé, du hotpot et une grande ville porte d’entrée.',
  },
  {
    name: 'Évasion hivernale, 6-10 jours',
    plan: 'Sanya 4-6 jours, Shanghai 2-3 jours',
    fit: 'Idéal quand le nord de la Chine est froid et que vous voulez une simple combinaison plage et ville.',
  },
];

const faqItems = [
  {
    question: 'Quelle ville de Chine est la plus facile pour les premiers voyageurs étrangers ?',
    answer:
      'Shanghai est généralement la première ville la plus facile car les aéroports, les panneaux du métro, les hôtels, les restaurants et les services internationaux sont les plus adaptés aux étrangers. Pékin reste très gérable, mais nécessite plus de réservation à l’avance et une planification quotidienne plus soigneuse.',
  },
  {
    question: 'Combien de villes chinoises dois-je visiter en un seul voyage ?',
    answer:
      'Pour un premier voyage de 8-10 jours, deux ou trois villes suffisent. La Chine est vaste, et les transferts aéroportuaires, les gares, les contrôles de sécurité et les changements d’hôtel peuvent consommer plus de temps que prévu. Choisissez une ville porte d’entrée, une étape culturelle ou pittoresque, et une extension optionnelle.',
  },
  {
    question: 'Quelle ville est la meilleure pour un long séjour en Chine ?',
    answer:
      'Shanghai est la base de long séjour la plus facile pour les services et la couverture en anglais, Chengdu est plus avantageuse pour des coûts réduits et un mode de vie détendu, et Hangzhou offre un compromis avec ses paysages et une économie tech solide. Sanya convient bien aux séjours d’hiver plutôt qu’à une vie urbaine toute l’année.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---


<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Planification des villes</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="city-shanghai" alt="Skyline de Shanghai et le Bund au crépuscule représentant le voyage urbain en Chine" loading="eager" />

    <ChinaMap cities={mapCities} />

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3" aria-labelledby="city-shortcuts">
      <h2 id="city-shortcuts" class="sr-only">Raccourcis villes</h2>
      {cities.map((city) => (
        <article class="card" id={city.name.toLowerCase().replace(/[^a-z]/g, '')}>
          <h3 class="text-xl font-bold text-gray-950">{city.name}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{city.desc}</p>
          <dl class="mt-4 grid gap-2 text-sm text-gray-700">
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Durée conseillée</dt>
              <dd class="text-right">{city.days}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Meilleure saison</dt>
              <dd class="text-right">{city.bestSeason}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Accessibilité</dt>
              <dd class="text-right">{city.difficulty}</dd>
            </div>
          </dl>
          <div class="mt-5 grid gap-2 text-sm font-semibold">
            <a href={city.href} class="text-brand-700 hover:text-brand-800">Ouvrir le guide de la ville</a>
            <a href={city.next} class="text-gray-700 hover:text-brand-700">{city.nextLabel}</a>
          </div>
        </article>
      ))}
    </section>

    <section class="mt-12" aria-labelledby="compare-cities">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Comparaison des villes</p>
          <h2 id="compare-cities">Quelle ville de Chine devriez-vous choisir ?</h2>
        </div>
      </div>
      <div class="mt-6 overflow-hidden rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
          <thead class="bg-gray-50 text-xs font-semibold uppercase tracking-wide text-gray-600">
            <tr>
              <th class="px-4 py-3">Ville</th>
              <th class="px-4 py-3">Pourquoi y aller</th>
              <th class="px-4 py-3">Durée conseillée</th>
              <th class="px-4 py-3">Meilleure saison</th>
              <th class="px-4 py-3">Accessibilité</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {cities.map((city) => (
              <tr>
                <th class="px-4 py-4 font-bold text-gray-950">
                  <a href={city.href} class="text-brand-700 hover:text-brand-800">{city.name}</a>
                </th>
                <td class="px-4 py-4 leading-6 text-gray-700">{city.whyGo}</td>
                <td class="px-4 py-4 text-gray-700">{city.days}</td>
                <td class="px-4 py-4 text-gray-700">{city.bestSeason}</td>
                <td class="px-4 py-4 text-gray-700">{city.difficulty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-12 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]" aria-labelledby="route-ideas">
      <div>
        <p class="section-kicker">Planification d’itinéraire</p>
        <h2 id="route-ideas" class="mt-2 text-3xl font-bold text-gray-950">Combinaisons de villes pratiques</h2>
        <p class="mt-3 leading-7 text-gray-600">
          Un bon itinéraire en Chine fonctionne généralement mieux quand les villes ont des rôles différents. Utilisez Shanghai comme point d’arrivée facile, Pékin pour l’histoire, Hangzhou pour les paysages, Chengdu pour la cuisine et l’accès à l’ouest de la Chine, et Sanya pour une pause au chaud. Évitez d’ajouter trop de vols ou de transferts en gare à un court voyage.
        </p>
      </div>
      <div class="grid gap-4">
        {routes.map((route) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-lg font-bold text-gray-950">{route.name}</h3>
            <p class="mt-2 font-semibold text-brand-700">{route.plan}</p>
            <p class="mt-2 text-sm leading-6 text-gray-600">{route.fit}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Tous les guides liés aux villes</p>
            <h2>Articles sur les villes et transports locaux</h2>
          </div>
        </div>
        <div class="mt-6 grid gap-5 md:grid-cols-2">
          {cityPosts.map((post) => (
            <a href={`/fr/posts/${post.slug}/`} class="card block hover:no-underline">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{post.data.category}</span>
              <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <p class="section-kicker">Avant de choisir une ville</p>
        <h2 class="mt-1 text-xl font-bold text-gray-950">Vérifiez la logistique</h2>
        <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
          <li><a href="/fr/payment/" class="font-semibold text-brand-700">Paiements :</a> configurez Alipay, WeChat Pay et une réserve de liquide avant de voyager dans les petites villes.</li>
          <li><a href="/fr/esim/" class="font-semibold text-brand-700">Internet :</a> choisissez eSIM, itinérance ou SIM locale avant de dépendre des cartes et de la traduction.</li>
          <li><a href="/fr/transport/" class="font-semibold text-brand-700">Transport :</a> comparez trains, transferts aéroportuaires, DiDi et QR codes de métro.</li>
          <li><a href="/fr/tools/best-time-to-visit/" class="font-semibold text-brand-700">Calendrier :</a> vérifiez la météo, les jours fériés et la pression touristique par mois.</li>
        </ul>
      </aside>
    </section>

    <section class="mt-12" aria-labelledby="city-faq">
      <div class="section-heading">
        <div>
          <p class="section-kicker">FAQ des villes</p>
          <h2 id="city-faq">Questions courantes sur la planification urbaine en Chine</h2>
        </div>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {faqItems.map((item) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-base font-bold text-gray-950">{item.question}</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">{item.answer}</p>
          </article>
        ))}
      </div>
    </section>

    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  </main>
  <Footer />
</BaseLayout>
