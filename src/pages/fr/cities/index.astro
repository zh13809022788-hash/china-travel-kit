---
import { getCollection } from 'astro:content';
import { getCategoryLabel } from '../../i18n/categories';
import { CITY_GUIDES, type CityGuideEntry } from '../../data/cityGuideData';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CoverImage from '../../components/CoverImage.astro';
import ChinaMap from '../../components/ChinaMap.astro';
import AdSlot from '../../components/AdSlot.astro';

const allPosts = await getCollection('posts');

// Trouver quels guides de ville ont des articles publiés
const postMap = new Map<string, typeof allPosts[0]>();
for (const post of allPosts) {
  for (const guide of CITY_GUIDES) {
    if (post.slug === guide.slug || post.slug.includes(guide.slug)) {
      postMap.set(guide.slug, post);
    }
  }
}

// Afficher uniquement les villes qui ont un article de guide publié
const activeGuides = CITY_GUIDES.filter((g) => postMap.has(g.slug));
const activeSlugs = new Set(activeGuides.map((g) => g.slug));

// Coordonnées de la carte avec les liens href appropriés
const mapCities = CITY_GUIDES.map((g) => ({
  name: g.name,
  x: g.mapX,
  y: g.mapY,
  href: postMap.has(g.slug) ? `#${g.name.toLowerCase().replace(/[^a-z]/g, '')}` : '',
}));

// Cartes de villes triées par nom
const cities = [...activeGuides].sort((a, b) => a.name.localeCompare(b.name));

// Tous les articles liés aux villes (triés par titre)
const cityPosts = allPosts
  .filter((post) => activeSlugs.has(post.slug) || post.data.tags?.some((t: string) =>
    [...activeSlugs].some((s) => s.includes(t) || t.includes(s))
  ))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const title = 'Guides des villes de Chine pour les visiteurs étrangers';
const description = `Planifiez des étapes urbaines pratiques en Chine avec des guides pour ${activeGuides.map((g) => g.name).join(', ')}.`;

const routes = [
  {
    name: 'Premier voyage en Chine, 8-10 jours',
    plan: 'Shanghai 3 jours, Hangzhou 2 jours, Beijing 4 jours',
    fit: 'Le meilleur équilibre entre arrivée facile, paysages classiques et histoire incontournable.',
  },
  {
    name: 'Gastronomie et rythme détendu, 7-9 jours',
    plan: 'Chengdu 4 jours, Beijing ou Shanghai 3-4 jours',
    fit: 'Bien adapté aux voyageurs qui veulent voir des pandas, des maisons de thé, manger de la fondue chinoise et visiter une grande ville d\'entrée.',
  },
  {
    name: 'Escapade hivernale, 6-10 jours',
    plan: 'Sanya 4-6 jours, Shanghai 2-3 jours',
    fit: 'Le meilleur choix quand le nord de la Chine est froid et que vous voulez une combinaison simple entre plage et ville.',
  },
  {
    name: 'Découverte du Sud, 10-12 jours',
    plan: 'Guangzhou 3 jours, Guilin 3 jours, Shanghai 4 jours',
    fit: 'Parfait pour les amateurs de cuisine, de paysages pittoresques et d\'un rythme tranquille à travers le sud de la Chine.',
  },
  {
    name: 'Capitales anciennes, 10-12 jours',
    plan: 'Beijing 4 jours, Xi\'an 3 jours, Nanjing 2 jours, Shanghai 3 jours',
    fit: 'Itinéraire axé sur l\'histoire à travers les capitales impériales de la Chine avec des liaisons en train à grande vitesse.',
  },
];

const faqItems = [
  {
    question: 'Quelle ville de Chine est la plus facile pour les visiteurs étrangers venant pour la première fois ?',
    answer:
      'Shanghai est généralement la ville la plus facile pour commencer, car les aéroports, la signalétique du métro, les hôtels, les restaurants et les services internationaux y sont les plus adaptés aux étrangers. Beijing reste tout à fait gérable, mais demande plus de réservations à l\'avance et une organisation quotidienne plus soignée.',
  },
  {
    question: 'Combien de villes chinoises devrais-je visiter en un seul voyage ?',
    answer:
      'Pour un premier voyage de 8 à 10 jours, deux ou trois villes suffisent. La Chine est vaste, et les transferts aéroportuaires, les gares, les contrôles de sécurité et les changements d\'hôtel peuvent prendre plus de temps que prévu. Choisissez une ville d\'arrivée, une étape culturelle ou pittoresque, et une extension facultative.',
  },
  {
    question: 'Quelle ville convient le mieux pour un séjour plus long en Chine ?',
    answer:
      'Shanghai est la base la plus simple pour un long séjour en raison des services disponibles et de la présence de l\'anglais, Chengdu est plus avantageuse pour un coût de la vie plus bas et un mode de vie détendu, et Hangzhou offre un bon compromis avec ses paysages et sa forte économie technologique. Sanya convient bien pour les séjours d\'hiver plutôt que pour une vie urbaine toute l\'année.',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
const locale = 'en';
---
<!-- Contenu genere avec assistance IA, revise par un redacteur natif -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Planification des villes</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="city-shanghai" alt="Skyline de Shanghai et le Bund au crépuscule représentant les voyages urbains en Chine" loading="eager" />

    <ChinaMap cities={mapCities} />

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3" aria-labelledby="city-shortcuts">
      <h2 id="city-shortcuts" class="sr-only">Raccourcis vers les villes</h2>
      {cities.map((city) => (
        <a href={city.slug ? `/posts/${city.slug}/` : '#'} class="card block hover:no-underline scroll-mt-20" id={city.name.toLowerCase().replace(/[^a-z]/g, '')}>
          <h3 class="text-xl font-bold text-gray-950">{city.name}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{city.desc}</p>
          <dl class="mt-4 grid gap-2 text-sm text-gray-700">
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Séjour conseillé</dt>
              <dd class="text-right">{city.days}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Meilleure saison</dt>
              <dd class="text-right">{city.bestSeason}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">Facilité pour les visiteurs</dt>
              <dd class="text-right">{city.difficulty}</dd>
            </div>
          </dl>
          <span class="mt-3 inline-block text-sm font-semibold text-brand-700">Ouvrir le guide de la ville →</span>
        </a>
      ))}
    </section>

    <section class="mt-12" aria-labelledby="compare-cities">
      <div class="section-heading">
        <div>
          <p class="section-kicker">Comparaison des villes</p>
          <h2 id="compare-cities">Quelle ville de Chine devriez-vous choisir ?</h2>
        </div>
      </div>
      <div class="mt-6 overflow-hidden rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
          <thead class="bg-gray-50 text-xs font-semibold uppercase tracking-wide text-gray-600">
            <tr>
              <th class="px-4 py-3">Ville</th>
              <th class="px-4 py-3">Pourquoi y aller</th>
              <th class="px-4 py-3">Séjour conseillé</th>
              <th class="px-4 py-3">Meilleure saison</th>
              <th class="px-4 py-3">Facilité</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {cities.map((city) => (
              <tr>
                <th class="px-4 py-4 font-bold text-gray-950">
                  <a href={`/posts/${city.slug}/`} class="text-brand-700 hover:text-brand-800">{city.name}</a>
                </th>
                <td class="px-4 py-4 leading-6 text-gray-700">{city.whyGo}</td>
                <td class="px-4 py-4 text-gray-700">{city.days}</td>
                <td class="px-4 py-4 text-gray-700">{city.bestSeason}</td>
                <td class="px-4 py-4 text-gray-700">{city.difficulty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-12 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]" aria-labelledby="route-ideas">
      <div>
        <p class="section-kicker">Planification d'itinéraire</p>
        <h2 id="route-ideas" class="mt-2 text-3xl font-bold text-gray-950">Combinaisons de villes pratiques</h2>
        <p class="mt-3 leading-7 text-gray-600">
          Un bon itinéraire en Chine fonctionne généralement mieux lorsque les villes ont des rôles différents. Utilisez Shanghai comme
          point d'arrivée facile, Beijing pour l'histoire, Hangzhou pour les paysages, Chengdu pour la gastronomie et l'accès à l'ouest de la Chine, et
          Sanya pour une pause au climat chaud. Évitez d'ajouter trop de vols ou de transferts en gare à un voyage court.
        </p>
      </div>
      <div class="grid gap-4">
        {routes.map((route) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-lg font-bold text-gray-950">{route.name}</h3>
            <p class="mt-2 font-semibold text-brand-700">{route.plan}</p>
            <p class="mt-2 text-sm leading-6 text-gray-600">{route.fit}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Tous les guides liés aux villes</p>
            <h2>Articles de ville et transports locaux</h2>
          </div>
        </div>
        <div class="mt-6 grid gap-5 md:grid-cols-2">
          {cityPosts.map((post) => (
            <a href={`/posts/${post.slug}/`} class="card block hover:no-underline">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
              <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <p class="section-kicker">Avant de choisir une ville</p>
        <h2 class="mt-1 text-xl font-bold text-gray-950">Vérifiez l'ensemble de la logistique</h2>
        <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
          <li><a href="/payment/" class="font-semibold text-brand-700">Paiements :</a> configurez Alipay, WeChat Pay et une réserve en espèces avant de voyager dans de plus petites villes.</li>
          <li><a href="/esim/" class="font-semibold text-brand-700">Internet :</a> choisissez une eSIM, l'itinérance ou une carte SIM locale avant de dépendre des cartes et de la traduction.</li>
          <li><a href="/transport/" class="font-semibold text-brand-700">Transport :</a> comparez les trains, les transferts aéroportuaires, DiDi et les QR codes du métro.</li>
          <li><a href="/tools/best-time-to-visit/" class="font-semibold text-brand-700">Période :</a> vérifiez la météo, les jours fériés et l'affluence selon le mois.</li>
        </ul>
      </aside>
    </section>

    <section class="mt-12" aria-labelledby="city-faq">
      <div class="section-heading">
        <div>
          <p class="section-kicker">FAQ sur les villes</p>
          <h2 id="city-faq">Questions fréquentes sur la planification des villes en Chine</h2>
        </div>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {faqItems.map((item) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-base font-bold text-gray-950">{item.question}</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">{item.answer}</p>
          </article>
        ))}
      </div>
    </section>

    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  </main>
  <Footer />
</BaseLayout>