﻿---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const title = 'Équipe éditoriale ChinaTripBox';
const description =
  'À propos de l’équipe éditoriale ChinaTripBox, de notre méthode de recherche pour les guides pratiques sur la Chine et de la façon dont les lecteurs peuvent demander des corrections.';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': new URL('/authors/chinatripbox-editorial-team/#person', Astro.site).toString(),
  name: title,
  url: new URL('/authors/chinatripbox-editorial-team/', Astro.site).toString(),
  affiliation: {
    '@type': 'Organization',
    name: 'ChinaTripBox',
    url: new URL('/', Astro.site).toString(),
  },
  knowsAbout: [
    'préparation d’un voyage en Chine',
    'paiements mobiles en Chine',
    'eSIM et accès internet en Chine',
    'train à grande vitesse en Chine',
    'logistique des visiteurs étrangers en Chine',
  ],
};
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-12">
    <article class="prose-content article-body">
      <p class="section-kicker">Auteur</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-900">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>

      <h2>Priorités éditoriales</h2>
      <p>
        L’équipe éditoriale ChinaTripBox rédige des guides pratiques pour les visiteurs étrangers en
        Chine, avec un accent sur la configuration des paiements, les eSIM et l’accès internet, le
        train à grande vitesse, les VTC, les transferts aéroport, la planification des villes, les
        commandes de repas et les problèmes fréquents lors d’un premier voyage.
      </p>

      <h2>Comment nous élaborons nos guides</h2>
      <p>
        Nous croisons les sources officielles, la documentation des fournisseurs, les supports d’aide
        des applications, les questions des lecteurs, les retours de voyageurs et, lorsque c’est
        possible, des vérifications pratiques. Pour les sujets qui changent vite, comme l’entrée sans
        visa, les limites de paiement, la disponibilité des applications et les règles de transport,
        nous considérons les pages officielles des administrations ou des fournisseurs comme la source
        de référence.
      </p>

      <h2>Corrections</h2>
      <p>
        La logistique de voyage en Chine évolue rapidement. Si vous trouvez une étape obsolète, une
        règle modifiée, un lien cassé ou une réserve manquante, envoyez l’URL de la page via notre
        <a href="/fr/contact/">page de contact</a>. Nous examinons les corrections et mettons à jour
        les guides concernés lorsque les éléments sont clairs.
      </p>

      <h2>Politique éditoriale</h2>
      <p>
        Lisez notre <a href="/fr/editorial-policy/">politique éditoriale</a> pour en savoir plus sur
        la recherche, les mises à jour, la divulgation d’affiliation, l’indépendance et les limites.
      </p>

      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    </article>
  </main>
  <Footer />
</BaseLayout>

