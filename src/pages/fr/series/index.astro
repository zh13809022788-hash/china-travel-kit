---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const title = 'Séries de contenus sur le voyage en Chine';
const description = 'Explorez la Chine à travers cinq séries thématiques : cuisine, histoire, vie moderne, nature et culture, chacune conçue pour inspirer et informer les voyageurs étrangers.';

const seriesList = [
  {
    href: '/fr/series/food-of-china/',
    title: 'Cuisine de Chine',
    desc: 'Des stands de rue aux salles de banquet : un voyage culinaire pour visiteurs étrangers à travers les huit grandes cuisines, les petits-déjeuners régionaux, les styles de fondue et les plats qui valent de traverser la ville.',
    icon: 'Cuisine et boissons',
  },
  {
    href: '/fr/series/history-of-china/',
    title: 'Histoire de la Chine',
    desc: 'Les sites anciens expliqués aux voyageurs : Grande Muraille, armée de terre cuite, Cité interdite, route de la soie et récits derrière ce que vous avez réellement sous les yeux.',
    icon: 'Histoire',
  },
  {
    href: '/fr/series/modern-china/',
    title: 'Chine moderne',
    desc: 'Ce qui surprend le plus les étrangers : rues sans espèces, trains parmi les plus rapides du monde, mégapoles immenses, super apps et technologies du quotidien qui définissent la vie en Chine aujourd’hui.',
    icon: 'Vie moderne',
  },
  {
    href: '/fr/series/nature-of-china/',
    title: 'Nature de Chine',
    desc: 'Montagnes d’Avatar, lacs de conte de fées, paysages karstiques et plateau tibétain : les sites naturels les plus spectaculaires de Chine avec des guides pratiques pour visiteurs étrangers.',
    icon: 'Nature',
  },
  {
    href: '/fr/series/culture-of-china/',
    title: 'Culture chinoise',
    desc: 'Cérémonie du thé, fête du Printemps, face et guanxi, calligraphie, kung-fu et zodiaque : des traditions culturelles expliquées aux voyageurs qui veulent dépasser le tourisme de surface.',
    icon: 'Culture',
  },
];
---
import { getCategoryLabel } from '../../../i18n/categories.ts';

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Séries thématiques</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <section class="mt-10 grid gap-5 md:grid-cols-2">
      {seriesList.map((s) => (
        <a href={s.href} class="card block hover:no-underline">
          <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{s.icon}</span>
          <h2 class="mt-2 text-xl font-bold text-gray-950">{s.title}</h2>
          <p class="mt-2 text-sm leading-6 text-gray-600">{s.desc}</p>
          <span class="mt-4 inline-flex text-sm font-semibold text-brand-700">Explorer la série</span>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>
