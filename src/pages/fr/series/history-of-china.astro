---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';

const seriesSlug = 'history-of-china';
const posts = (await getCollection('posts-fr'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Histoire de Chine : grands sites et récits pour les voyageurs';
const description = 'Explorez les grands sites historiques chinois : Grande Muraille, armée de terre cuite, Cité interdite, Route de la soie, anciennes capitales et villes d’eau, avec le contexte utile pour mieux les comprendre.';

const relatedTools = [
  { href: '/fr/posts/china-visa-free-entry-transit-guide-2026/', title: 'Guide des visas et de l’entrée', desc: 'Comprendre le transit sans visa et les conditions d’entrée' },
  { href: '/fr/posts/china-high-speed-rail-guide-foreigners/', title: 'Guide du train à grande vitesse', desc: 'Rejoindre les grands sites historiques en train' },
  { href: '/fr/posts/book-china-train-tickets-12306-foreigners/', title: 'Réserver des billets de train', desc: 'Le guide 12306 pour les passeports étrangers' },
];

const relatedCities = [
  { href: '/fr/posts/beijing-city-guide-for-foreigners/', title: 'Pékin', desc: 'Cité interdite, Grande Muraille et Temple du Ciel' },
  { href: '/fr/posts/hangzhou-city-guide-for-foreigners/', title: 'Hangzhou', desc: 'Ancienne capitale des Song du Sud' },
  { href: '/fr/posts/chengdu-city-guide-for-foreigners/', title: 'Chengdu', desc: 'Patrimoine des Trois Royaumes et vieilles rues' },
];

const otherSeries = [
  { href: '/fr/series/food-of-china/', title: 'La cuisine de Chine' },
  { href: '/fr/series/culture-of-china/', title: 'Culture de Chine' },
  { href: '/fr/series/nature-of-china/', title: 'Nature de Chine' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Série thématique</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>
    <AdSlot format="banner" />
    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Articles</p>
            <h2>Série Histoire de Chine</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/fr/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{post.data.category}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">Les articles de cette série sont en préparation. Revenez bientôt.</p>
        )}
      </div>
      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Outils utiles</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Préparer ses visites</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Guides de villes</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Villes historiques</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Autres séries</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>
