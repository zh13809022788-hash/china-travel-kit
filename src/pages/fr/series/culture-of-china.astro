---
---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';

const seriesSlug = 'culture-of-china';
const posts = (await getCollection('posts-fr'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Culture de la Chine — traditions et coutumes pour les voyageurs';
const description = 'Explorez la culture chinoise en tant que voyageur étranger : cérémonie du thé, Fête du Printemps, notion de face et guanxi, calligraphie, kung-fu, zodiaque et traditions qui façonnent la vie quotidienne en Chine.';

const relatedTools = [
  { href: '/fr/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/', title: 'Pourboires et étiquette', desc: 'Quand laisser un pourboire, quand s’abstenir, et pourquoi' },
  { href: '/fr/posts/what-to-pack-for-china-a-season-by-season-checklist/', title: 'Préparer ses bagages pour les festivals', desc: 'Quoi emporter pendant les saisons de fêtes' },
  { href: '/fr/posts/how-to-pay-in-china-tourist-guide/', title: 'Comment payer en Chine', desc: 'Les paiements pendant la saison des festivals' },
];

const relatedCities = [
  { href: '/fr/posts/beijing-city-guide-for-foreigners/', title: 'Pékin', desc: 'Culture impériale et vie dans les hutongs' },
  { href: '/fr/posts/hangzhou-city-guide-for-foreigners/', title: 'Hangzhou', desc: 'Culture du thé et patrimoine du lac de l’Ouest' },
  { href: '/fr/posts/chengdu-city-guide-for-foreigners/', title: 'Chengdu', desc: 'Culture des maisons de thé et art de vivre' },
];

const otherSeries = [
  { href: '/fr/series/food-of-china/', title: 'La cuisine de Chine' },
  { href: '/fr/series/history-of-china/', title: 'Histoire de la Chine' },
  { href: '/fr/series/modern-china/', title: 'La Chine moderne' },
];
import { getCategoryLabel } from '../../../i18n/categories';
const locale = 'fr';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Série de contenus</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Articles</p>
            <h2>Série Culture de la Chine</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/fr/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">Les articles de cette série sont en préparation. Revenez bientôt.</p>
        )}
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Outils pratiques</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Voyager avec une sensibilité culturelle</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Guides de villes</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Villes culturelles</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Autres séries</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>

---