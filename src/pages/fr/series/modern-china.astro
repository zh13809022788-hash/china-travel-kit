---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';

const seriesSlug = 'modern-china';
const posts = (await getCollection('posts-fr'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'La Chine moderne — Ce qui surprend le plus les étrangers';
const description = 'Découvrez la Chine moderne en tant que voyageur étranger : société sans espèces, trains les plus rapides du monde, repérage dans les mégapoles, super-apps, trains de nuit et technologies qui façonnent la vie quotidienne.';

const relatedTools = [
  { href: '/fr/posts/how-to-pay-in-china-tourist-guide/', title: 'Comment payer en Chine', desc: 'Configurer les paiements mobiles pour les touristes' },
  { href: '/fr/posts/china-high-speed-rail-guide-foreigners/', title: 'Guide du train à grande vitesse', desc: 'Prendre les trains à grande vitesse en Chine' },
  { href: '/fr/posts/best-esim-for-china-travel-2026/', title: 'Meilleure eSIM pour la Chine', desc: 'Rester connecté dès l’arrivée' },
];

const relatedCities = [
  { href: '/fr/posts/shanghai-city-guide-for-foreigners/', title: 'Shanghai', desc: 'La mégapole financière de la Chine' },
  { href: '/fr/posts/beijing-city-guide-for-foreigners/', title: 'Pékin', desc: 'Capitale historique et centre moderne' },
  { href: '/fr/posts/shanghai-metro-for-foreigners-tickets-qr-codes-transfers/', title: 'Métro de Shanghai', desc: 'Se repérer dans un immense réseau de transport' },
];

const otherSeries = [
  { href: '/fr/series/food-of-china/', title: 'La cuisine chinoise' },
  { href: '/fr/series/history-of-china/', title: 'L’histoire de la Chine' },
  { href: '/fr/series/culture-of-china/', title: 'La culture chinoise' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Série de contenus</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Articles</p>
            <h2>Série sur la Chine moderne</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/fr/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{post.data.category}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">Les articles de cette série sont en cours de préparation. Revenez bientôt.</p>
        )}
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Outils pratiques</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Explorer la Chine moderne</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Guides des villes</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">Mégapoles</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">Autres séries</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>
