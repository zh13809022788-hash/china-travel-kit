---
import { getCollection } from 'astro:content';
import BlogPost from '../../../layouts/BlogPost.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts-fr');
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();
const { data } = post;

const affiliateByCategory: Record<string, { title: string; description: string; buttonText: string }> = {
  payment: {
    title: 'Configuration des paiements',
    description: 'Préparez une carte de voyage compatible avec Alipay et WeChat Pay avant le départ pour arriver plus sereinement.',
    buttonText: 'Commencer',
  },
  esim: {
    title: 'eSIM recommandée pour la Chine',
    description: 'Évitez les files d’attente à l’aéroport et activez votre connexion avant le décollage.',
    buttonText: 'Voir les forfaits',
  },
  transport: {
    title: 'Billets de train et transferts',
    description: 'Réservez vos trains à grande vitesse et vos transferts aéroport en anglais pour voyager plus sereinement.',
    buttonText: 'Réserver',
  },
};

const affiliate = affiliateByCategory[data.category];
const allPosts = await getCollection('posts-fr');
const related = allPosts
  .filter((candidate) => candidate.slug !== post.slug)
  .map((candidate) => {
    const sharedTags = candidate.data.tags.filter((tag) => data.tags.includes(tag)).length;
    const categoryMatch = candidate.data.category === data.category ? 2 : 0;
    const cityMatch =
      ['beijing', 'shanghai', 'chengdu', 'hangzhou', 'sanya'].some(
        (city) => post.slug.includes(city) && candidate.slug.includes(city)
      )
        ? 3
        : 0;
    return { candidate, score: sharedTags + categoryMatch + cityMatch };
  })
  .filter((item) => item.score > 0)
  .sort((a, b) => b.score - a.score || b.candidate.data.pubDate.valueOf() - a.candidate.data.pubDate.valueOf())
  .slice(0, 4)
  .map(({ candidate }) => ({
    title: candidate.data.title,
    description: candidate.data.description,
    href: `/fr/posts/${candidate.slug}/`,
  }));
---

<BlogPost
  title={data.title}
  description={data.description}
  pubDate={data.pubDate}
  category={data.category}
  tags={data.tags}
  faqs={data.faqs}
  cover={data.cover}
  coverAlt={data.coverAlt}
  related={related}
  locale="fr"
  alternates={{ en: `/posts/${post.slug}/`, fr: `/fr/posts/${post.slug}/` }}
  affiliate={affiliate}
>
  <Content />
</BlogPost>
