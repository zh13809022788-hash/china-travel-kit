---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const CATEGORY = 'transport';
const posts = (await getCollection('posts-fr'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'Transport en Chine : trains, VTC et déplacements urbains';
const description =
  'Apprenez à réserver les trains à grande vitesse, utiliser DiDi et vous déplacer facilement en transports publics en Chine.';

const transportPaths = [
  { href: '/fr/posts/china-high-speed-rail-guide-foreigners/', title: 'Trains longue distance', desc: 'À lire pour planifier vos trajets entre villes, choisir votre classe et gérer l’entrée en gare.' },
  { href: '/fr/posts/airport-to-city-transport-beijing-shanghai-guangzhou/', title: 'Depuis l’aéroport', desc: 'Comparez métro, taxi, VTC et train aéroportuaire pour le premier trajet.' },
  { href: '/fr/posts/didi-china-foreign-tourists-guide/', title: 'VTC', desc: 'Configurez DiDi, utilisez des points de prise en charge traduits et limitez les appels du chauffeur.' },
  { href: '/fr/posts/shanghai-metro-for-foreigners-tickets-qr-codes-transfers/', title: 'Métro', desc: 'Comprenez les billets QR, les correspondances et les habitudes locales à partir de l’exemple de Shanghai.' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">Transport</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">Guides transport en Chine</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="hub-transport" alt="Train à grande vitesse et réseau ferroviaire moderne en Chine" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-transport">
      <h2 id="featured-transport" class="sr-only">Guides transport à lire en priorité</h2>
      <a href="/fr/posts/china-high-speed-rail-guide-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Guide du train à grande vitesse</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Billets, classes, accès aux gares et repères utiles</p>
      </a>
      <a href="/fr/posts/book-china-train-tickets-12306-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Réserver sur 12306</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Le pas à pas avec un passeport étranger</p>
      </a>
      <a href="/fr/posts/didi-china-foreign-tourists-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Utiliser DiDi</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Le guide pratique du VTC en Chine</p>
      </a>
      <a href="/fr/posts/airport-to-city-transport-beijing-shanghai-guangzhou/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Transferts aéroport</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Pékin, Shanghai et Canton</p>
      </a>
    </section>

    <section class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4" aria-labelledby="transport-paths">
      <h2 id="transport-paths" class="sr-only">Parcours de préparation transport</h2>
      {transportPaths.map((path) => (
        <a href={path.href} class="card block hover:no-underline">
          <h3 class="text-lg font-bold text-gray-950">{path.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{path.desc}</p>
        </a>
      ))}
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/fr/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{post.data.category}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('fr-FR', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">Les guides seront bientôt disponibles.</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>
