const title = "Entreprise unipersonnelle IA en Chine : guide pour les étrangers (2026)";
const description =
  "Les étrangers peuvent-ils gérer une entreprise unipersonnelle d'IA tout en vivant en Chine ? Ce guide couvre les règles de visa, la conformité, l'infrastructure, les outils de paiement et les conseils de mise en place.";
const url = '/digital-nomads/ai-opc/';
const datePublished = '2026-07-09';

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Nomades numériques', href: '/digital-nomads/' },
