---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'Aide voyage Chine';
const description =
  'Posez vos questions pratiques sur la Chine : paiements, eSIM, transports, applications et organisation du premier jour, avec une première réponse assistée par AI et un relais humain si nécessaire.';

const quickPrompts = [
  'Ma carte ne s’ajoute ni à Alipay ni à WeChat Pay.',
  'J’ai besoin d’un plan eSIM et applications pour mon voyage.',
  'J’ai besoin d’aide pour aller de l’aéroport à mon hôtel.',
  'Je ne sais pas combien d’espèces emporter.',
];

const supportAreas = [
  'Paiements : Alipay, WeChat Pay, cartes, frais et espèces de secours',
  'Connexion : eSIM, itinérance, applis sensibles au VPN et arrivée à l’aéroport',
  'Transport : trajets depuis l’aéroport, métro, DiDi, taxis et bases du train rapide',
  'Applications : traduction, livraison de repas, cartes, VTC et captures d’écran',
  'Organisation du voyage : checklist du premier jour, préparation par ville et prochaines étapes',
  'Relais humain : cas complexes qui demandent davantage de contexte',
];

const safetyRules = [
  'N’envoyez jamais de photo de passeport, de numéro complet de carte, de mot de passe, de PIN ou de code temporaire.',
  'Ne demandez à personne de se connecter à vos comptes ou de faire une vérification d’identité à votre place.',
  'N’utilisez pas cette aide pour des questions juridiques, migratoires, médicales, bancaires ou d’urgence.',
  'Vérifiez les points importants auprès des sources officielles, compagnies aériennes, banques, opérateurs télécoms ou éditeurs d’applications.',
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="fr">
  <Header locale="fr" />
  <main>
    <section class="border-b border-gray-200 bg-white">
      <div class="container-page grid gap-8 py-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <div>
          <p class="section-kicker">Aide voyage personnalisée</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Posez votre question avant qu’un détail logistique ne vous bloque
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Commencez par une aide AI gratuite pour les problèmes pratiques de voyage en Chine. Si
            votre situation demande du contexte, des captures d’écran ou un échange plus poussé,
            transformez-la en demande par e-mail.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#travel-help-chat" class="btn-primary">Commencer</a>
            <a href="/fr/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-outline">Utiliser la checklist avant départ</a>
            <a href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Travel%20Help%20Request" class="btn-outline">
              Envoyer un e-mail
            </a>
          </div>
        </div>

        <aside class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Statut du service</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">AI d’abord, relecture humaine ensuite</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Les réponses gratuites sont générées par AI. L’aide relue par une personne passe encore
            par e-mail pendant cette phase de test.
          </p>
          <dl class="mt-5 grid gap-3 text-sm">
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">Idéal pour</dt>
              <dd class="font-semibold text-gray-900">Préparation pratique du voyage</dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">Mode de réponse</dt>
              <dd class="font-semibold text-gray-900">AI + suivi par e-mail</dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">Paiement</dt>
              <dd class="font-semibold text-gray-900">Inactif</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <section id="travel-help-chat" class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
          <div class="border-b border-gray-200 bg-gray-50 px-5 py-4">
          <p class="section-kicker">Aide voyage AI gratuite</p>
            <h2 class="mt-1 text-2xl font-bold text-gray-950">Guichet d’aide voyage</h2>
          </div>

          <div class="grid gap-0 md:grid-cols-[minmax(0,1fr)_280px]">
            <div class="flex min-h-[560px] flex-col">
              <div id="chat-log" class="flex-1 space-y-4 overflow-y-auto p-5" aria-live="polite">
                <div class="max-w-[88%] rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-700">
                  <strong class="block text-gray-950">Aide ChinaTripBox</strong>
                  Expliquez ce que vous essayez de faire, à quel moment du voyage vous vous trouvez
                  et ce qui s’est déjà passé. L’assistant AI vous proposera une suite logique et
                  signalera quand une relecture humaine est préférable.
                </div>
              </div>

              <div class="border-t border-gray-200 p-4">
                <div class="mb-3 flex flex-wrap gap-2">
                  {quickPrompts.map((prompt) => (
                    <button
                      type="button"
                      class="quick-prompt rounded-full border border-gray-200 bg-white px-3 py-1.5 text-left text-xs font-medium text-gray-700 hover:border-brand-300 hover:bg-brand-50"
                      data-prompt={prompt}
                    >
                      {prompt}
                    </button>
                  ))}
                </div>
                <form id="travel-help-form" class="grid gap-3">
                  <label class="sr-only" for="help-message">Votre question de voyage</label>
                  <textarea
                    id="help-message"
                    name="message"
                    rows="5"
                    class="w-full resize-y rounded-lg border border-gray-300 px-4 py-3 text-sm leading-6 text-gray-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
                    placeholder="Exemple : j’arrive à Shanghai demain. Ma Mastercard ne s’ajoute pas à WeChat Pay, mais Alipay fonctionne. Puis-je quand même utiliser le métro, DiDi et la livraison de repas ?"
                    required
                  ></textarea>
                  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <p id="form-status" class="text-sm text-gray-500">N’incluez aucune donnée personnelle sensible.</p>
                    <button id="help-submit" type="submit" class="btn-primary">Demander à l’AI</button>
                  </div>
                </form>
              </div>
            </div>

            <aside class="border-t border-gray-200 bg-gray-50 p-5 md:border-l md:border-t-0">
              <h3 class="text-lg font-bold text-gray-950">Détails de la demande</h3>
              <div class="mt-4 grid gap-4">
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  Étape du voyage
                  <select id="trip-stage" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                    <option>Avant le départ</option>
                    <option>À l’aéroport</option>
                    <option>Déjà en Chine</option>
                    <option>Préparation d’un séjour long</option>
                  </select>
                </label>
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  Sujet principal
                  <select id="help-topic" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                    <option>Applications de paiement</option>
                    <option>Internet et eSIM</option>
                    <option>Trajet ou transport</option>
                    <option>Repas, livraison ou applis locales</option>
                    <option>Préparation générale du voyage</option>
                  </select>
                </label>
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  Ville ou trajet
                  <input
                    id="help-location"
                    class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700"
                    placeholder="Shanghai, Pékin, aéroport vers l’hôtel…"
                  />
                </label>
              </div>

              <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-4">
                <p class="text-sm font-bold text-gray-950">Passage à l’humain</p>
                <p class="mt-2 text-sm leading-6 text-gray-700">
                  Utilisez cette option lorsqu’un simple guide ne suffit pas. L’e-mail préparé inclut
                  votre sujet, l’étape du voyage, le lieu et votre question pour permettre une
                  réponse plus contextualisée.
                </p>
              </div>

              <a
                id="email-request-link"
                href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Travel%20Help%20Request"
                class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:border-brand-600 hover:text-brand-600 hover:no-underline"
              >
                Préparer l’e-mail
              </a>
            </aside>
          </div>
        </div>

        <aside class="space-y-6">
          <section class="rounded-lg border border-gray-200 bg-white p-5">
            <p class="section-kicker">Périmètre</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Ce que cette aide couvre</h2>
            <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
              {supportAreas.map((area) => (
                <li class="border-b border-gray-100 pb-3 last:border-b-0 last:pb-0">{area}</li>
              ))}
            </ul>
          </section>

          <section class="rounded-lg border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Règles de sécurité</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">N’envoyez aucune donnée sensible</h2>
            <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
              {safetyRules.map((rule) => (
                <li>{rule}</li>
              ))}
            </ul>
          </section>
        </aside>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <div class="card">
          <p class="section-kicker">Étape 1</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Décrivez le problème</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Indiquez la ville, l’application, le trajet, l’échéance et ce que vous avez déjà essayé.
          </p>
        </div>
        <div class="card">
          <p class="section-kicker">Étape 2</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Recevez une première piste</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            La page fournit une première réponse concrète et vous renvoie vers les guides utiles.
          </p>
        </div>
        <div class="card">
          <p class="section-kicker">Étape 3</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Passez par e-mail si besoin</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Si vous avez besoin d’un échange plus poussé, envoyez l’e-mail préparé et poursuivez en privé.
          </p>
        </div>
      </section>

      <section class="mt-10 rounded-lg border border-gray-200 bg-white p-5 md:p-6">
        <p class="section-kicker">Commencer en autonomie</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950">Guides qui répondent aux questions les plus fréquentes</h2>
        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <a href="/fr/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Planificateur de premier voyage en Chine</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">À utiliser si vous préparez encore les paiements, la connexion, les transports et votre premier jour sur place.</p>
          </a>
          <a href="/fr/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Checklist de préparation avant le départ</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Vérifiez Alipay, WeChat Pay, eSIM, DiDi, les billets de train, la traduction, les adresses et les espèces de secours avant de partir.</p>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('travel-help-form') as HTMLFormElement | null;
  const message = document.getElementById('help-message') as HTMLTextAreaElement | null;
  const chatLog = document.getElementById('chat-log');
  const status = document.getElementById('form-status');
  const stage = document.getElementById('trip-stage') as HTMLSelectElement | null;
  const topic = document.getElementById('help-topic') as HTMLSelectElement | null;
  const locationInput = document.getElementById('help-location') as HTMLInputElement | null;
  const emailLink = document.getElementById('email-request-link') as HTMLAnchorElement | null;
  const submitButton = document.getElementById('help-submit') as HTMLButtonElement | null;

  const guideLinks: Record<string, { label: string; href: string }> = {
    'Applications de paiement': { label: 'guide des paiements', href: '/fr/payment/' },
    'Internet et eSIM': { label: 'guide eSIM', href: '/fr/esim/' },
    'Trajet ou transport': { label: 'guide transport', href: '/fr/transport/' },
    'Repas, livraison ou applis locales': {
      label: 'guide de livraison de repas',
      href: '/fr/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    },
    'Préparation générale du voyage': { label: 'page des outils', href: '/fr/tools/' },
  };

  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char] ?? char);

  const updateEmailLink = () => {
    if (!emailLink) return;
    const selectedStage = stage?.value ?? 'Avant le départ';
    const selectedTopic = topic?.value ?? 'Préparation générale du voyage';
    const place = locationInput?.value.trim() || 'Non précisé';
    const question = message?.value.trim() || '';
    const body = [
      'ChinaTripBox Travel Help Request',
      '',
      `Étape du voyage : ${selectedStage}`,
      `Sujet principal : ${selectedTopic}`,
      `Ville ou trajet : ${place}`,
      '',
      'Question :',
      question,
      '',
      'Je comprends que je ne dois pas inclure de photo de passeport, de numéro complet de carte bancaire, de mot de passe, de PIN ou de code temporaire.',
    ].join('\n');

    emailLink.href = `mailto:zh13809022788@gmail.com?subject=${encodeURIComponent(
      `Aide voyage : ${selectedTopic}`,
    )}&body=${encodeURIComponent(body)}`;
  };

  const addBubble = (content: string, fromUser = false) => {
    if (!chatLog) return null;
    const wrapper = document.createElement('div');
    wrapper.className = fromUser
      ? 'ml-auto max-w-[88%] rounded-lg bg-brand-600 p-4 text-sm leading-6 text-white'
      : 'max-w-[88%] rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-700';
    wrapper.innerHTML = content;
    chatLog.appendChild(wrapper);
    chatLog.scrollTop = chatLog.scrollHeight;
    return wrapper;
  };

  const formatAiAnswer = (value: string) =>
    escapeHtml(value)
      .replace(/\n{3,}/g, '\n\n')
      .replace(/\n/g, '<br>');

  const buildReply = (question: string) => {
    const selectedTopic = topic?.value ?? 'Préparation générale du voyage';
    const selectedStage = stage?.value ?? 'Avant le départ';
    const place = locationInput?.value.trim();
    const guide = guideLinks[selectedTopic] ?? guideLinks['Préparation générale du voyage'];
    const needsHuman =
      /screenshot|photo|declin|failed|stuck|urgent|tomorrow|today|passport|verification|identity|hotel|route/i.test(
        question,
      );

    const placeLine = place
      ? `Comme cela concerne <strong>${escapeHtml(place)}</strong>, indiquez dans votre e-mail l’aéroport, la gare, le quartier, le nom de l’application et la date concernée.`
      : 'Ajoutez votre ville, votre aéroport, votre gare, votre quartier d’hôtel ou le nom de l’application avant d’envoyer une demande plus détaillée.';

    const escalation = needsHuman
      ? 'Cette situation semble justifier un suivi humain, car elle demande probablement du contexte ou des vérifications supplémentaires.'
      : 'Le guide peut suffire dans un premier temps ; passez ensuite par l’e-mail si votre cas reste particulier.';

    return `
      <strong class="block text-gray-950">Prochaine étape conseillée</strong>
      <span class="block mt-1">Topic: ${escapeHtml(selectedTopic)}. Stage: ${escapeHtml(selectedStage)}.</span>
      <span class="block mt-2">${placeLine}</span>
      <span class="block mt-2">Commencez par le <a href="${guide.href}" class="font-semibold text-brand-700">${guide.label}</a>, puis utilisez le bouton d’e-mail préparé si vous avez encore besoin d’un échange plus poussé.</span>
      <span class="block mt-2">${escalation}</span>
    `;
  };

  document.querySelectorAll<HTMLButtonElement>('.quick-prompt').forEach((button) => {
    button.addEventListener('click', () => {
      if (!message) return;
      message.value = button.dataset.prompt ?? '';
      message.focus();
      updateEmailLink();
    });
  });

  [message, stage, topic, locationInput].forEach((element) => {
    element?.addEventListener('input', updateEmailLink);
    element?.addEventListener('change', updateEmailLink);
  });

  const requestAiAnswer = async (question: string) => {
    const response = await fetch('/api/travel-help', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({
        message: question,
        stage: stage?.value ?? 'Avant le départ',
        topic: topic?.value ?? 'Préparation générale du voyage',
        location: locationInput?.value.trim() ?? '',
      }),
    });

    const data = await response.json() as { answer?: string; error?: string };
    if (!response.ok || !data.answer) {
      throw new Error(data.error || 'Assistant AI indisponible.');
    }
    return data.answer;
  };

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const question = message?.value.trim() ?? '';
    if (!question) {
      if (status) status.textContent = 'Ajoutez d’abord votre question.';
      return;
    }
    addBubble(escapeHtml(question), true);
    const thinking = addBubble('L’AI analyse votre question de voyage…');
    if (status) status.textContent = 'Demande envoyée à l’AI…';
    if (submitButton) submitButton.disabled = true;

    try {
      const answer = await requestAiAnswer(question);
      if (thinking) {
        thinking.innerHTML = `
          <strong class="block text-gray-950">Réponse AI</strong>
          <span class="mt-2 block">${formatAiAnswer(answer)}</span>
          <span class="mt-3 block text-xs text-gray-500">Pour les problèmes complexes liés à un compte, à un paiement, à un visa, au droit, à la santé ou à une urgence, vérifiez toujours auprès du service officiel concerné.</span>
        `;
      }
      if (status) status.textContent = 'Réponse AI prête. Utilisez l’e-mail si vous souhaitez un suivi humain.';
    } catch {
      if (thinking) thinking.innerHTML = buildReply(question);
      if (status) status.textContent = 'L’AI est indisponible ; une réponse de secours a été préparée localement.';
    } finally {
      if (submitButton) submitButton.disabled = false;
    }
    updateEmailLink();
  });

  updateEmailLink();
</script>
