---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const CATEGORY = 'esim';
const posts = (await getCollection('posts-ja'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = '中国eSIM・通信ガイド｜到着後すぐにインターネットをご利用いただけます';
const description =
  '中国旅行に合ったeSIMデータプランを比較し、出発前に準備しておきましょう。到着後すぐにインターネットへ接続でき、物理SIMを入れ替える必要もありません。';

const connectionChoices = [
  {
    title: 'eSIM',
    desc: 'お使いのスマートフォンがeSIMに対応している場合は、出発前に通信環境を整えたい短期旅行の方に特におすすめです。',
  },
  {
    title: 'ローミング',
    desc: '銀行のSMS受信や到着直後の予備回線として便利ですが、大容量のデータ通信では割高になりやすいです。',
  },
  {
    title: 'ポケットWi-Fiまたは現地SIM',
    desc: '複数人での旅行、長期滞在、または旅行用eSIMに対応していない端末を使う場合に、有力な選択肢になります。',
  },
];

const internetTools = [
  { href: '/ja/tools/esim-comparison/', title: 'eSIMプラン比較', desc: '旅行向けのデータ容量、利用日数、想定シーンをまとめて比較できます。' },
  { href: '/ja/tools/app-availability-checker/', title: 'アプリ利用可否チェッカー', desc: '中国で使いたいアプリが利用できるか、代替手段があるかを確認できます。' },
  { href: '/ja/posts/internet-access-china-apps-that-work-2026/', title: 'インターネット接続ガイド', desc: '使えるアプリ、VPNの考え方、出発前に済ませておきたい設定を確認できます。' },
];
import { getCategoryLabel } from '../../../i18n/categories';
const locale = 'ja';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja"
  title="中国旅行eSIMおすすめ 2026 | 料金比較と選び方"
  description="中国旅行に最適なeSIMデータプランを比較：中国聯通・中国移動ネットワーク対応、3ドルから即時開通。">
  <Header locale="ja" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">eSIM通信</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">中国eSIM・データ通信ガイド</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="hub-esim" alt="中国旅行で使えるモバイル通信とデータ接続の選択肢" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-esim">
      <h2 id="featured-esim" class="sr-only">おすすめの通信ガイド</h2>
      <a href="/ja/posts/best-esim-for-china-travel-2026/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">2026年版 おすすめeSIM</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">中国旅行向けにAiralo、Holafly、Nomadを比較しています。</p>
      </a>
      <a href="/ja/posts/china-esim-vs-roaming-2026-the-real-10-day-cost/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">eSIMとローミングの比較</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">旅行者の視点で10日間の実費を比較しています。</p>
      </a>
      <a href="/ja/posts/do-you-need-a-vpn-in-china-2026/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">2026年版 VPNガイド</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">中国旅行でVPNが本当に必要かを解説しています。</p>
      </a>
      <a href="/ja/posts/pocket-wifi-vs-esim-vs-sim-china/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">ポケットWi-FiとeSIMの比較</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">主な通信手段をまとめて比較できます。</p>
      </a>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[1fr_340px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">中国で使う通信手段を選びましょう</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          旅行者の方にとって安心しやすいのは、メインの通信手段に加えて、銀行、地図、翻訳、配車アプリ用に予備の接続手段も1つ確保しておくことです。
        </p>
        <div class="mt-5 grid gap-3">
          {connectionChoices.map((choice) => (
            <div class="rounded-lg border border-gray-200 bg-gray-50 p-4">
              <h3 class="text-sm font-bold text-gray-900">{choice.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{choice.desc}</p>
            </div>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">通信関連ツール</h2>
        <div class="mt-4 grid gap-3">
          {internetTools.map((tool) => (
            <a href={tool.href} class="rounded-lg border border-brand-100 bg-white p-4 hover:border-brand-200 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-900 hover:text-brand-700">{tool.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{tool.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/ja/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{getCategoryLabel(post.data.category, locale)}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">ガイド記事は順次公開いたします。</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>
