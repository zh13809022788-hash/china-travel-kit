---
import GuideLayout from '../../../layouts/GuideLayout.astro';

const title = '外国人向け中国での支払い方法ガイド（2026年版）';
const description =
  '外国人でも Alipay と WeChat Pay を使えるのでしょうか。現金はまだ必要なのでしょうか。このガイドでは、中国で暮らす旅行者・駐在員・デジタルノマド向けに、利用しやすい支払い方法をまとめてわかりやすく解説します。';
const url = '/digital-nomads/payment/';
const datePublished = '2026-07-09';

const breadcrumbs = [
  { label: 'ホーム', href: '/' },
  { label: 'デジタルノマド', href: '/ja/digital-nomads/' },
  { label: '支払いガイド' },
];

const toc = [
  { id: 'why-mobile', label: 'モバイル決済が主流である理由' },
  { id: 'alipay', label: '外国人向け Alipay' },
  { id: 'wechat', label: '外国人向け WeChat Pay' },
  { id: 'cash', label: '現金はまだ必要か' },
  { id: 'cards', label: '海外発行クレジットカードの使い方' },
  { id: 'scenarios', label: '場面別の支払い方法' },
  { id: 'nomad', label: 'ノマド向け: 家賃と海外送金' },
  { id: 'pitfalls', label: 'よくある落とし穴を避ける方法' },
  { id: 'faq', label: 'よくある質問' },
];

const faqs = [
  {
    question: '外国人でも中国で Alipay と WeChat Pay を使えますか。',
    answer:
      'はい、使えます。現在はどちらのアプリでも、海外の電話番号で登録し、海外発行の Visa・Mastercard・American Express などを連携できます。多くの店舗で、現地の人と同じように QR コードを使って支払えます。設定は数分で終わることが多いため、できれば中国に到着する前に済ませておくのがおすすめです。',
  },
  {
    question: 'モバイル決済を使うには中国の銀行口座が必要ですか。',
    answer:
      'いいえ、必須ではありません。Alipay と WeChat Pay の国際利用向け機能は海外発行カードに対応しているため、中国の銀行口座がなくても使えます。ただし、中国国内で人民元を受け取る場合や、長期賃貸で家主に銀行振込をする場合には、現地口座があると便利です。',
  },
  {
    question: 'Alipay や WeChat Pay には外国人向けの利用上限がありますか。',
    answer:
      'はい、あります。海外発行カードを連携したアカウントには、1回あたりの上限額や累計上限額が設定されています。日常的な少額決済では追加手数料がかからないことが多い一方、高額決済や利用額が大きい場合には少額の処理手数料がかかることがあります。上限は変更されることがあるため、大きな支払いに使う前にアプリ内で確認してください。',
  },
  {
    question: '中国では今でも現金を使えますか。',
    answer:
      'はい、使えます。現金は今でも法定通貨であり、法律上は加盟店が受け取りを拒否できません。ただし、実際には現金対応に慣れておらず、お釣りの用意に困る店もあります。タクシー、地方、小規模店、アプリ障害時の備えとして、少額紙幣を中心に数百元持っておくと安心ですが、普段の支払いのほとんどはモバイル決済になると考えて差し支えありません。',
  },
  {
    question: '海外発行のクレジットカードは店舗でそのまま使えますか。',
    answer:
      '使える場所は限られています。国際系ホテル、空港内の店舗、高級モール、一部の大型チェーンでは Visa や Mastercard の端末が使えることがありますが、日常的な店舗、小さな飲食店、交通機関ではほとんど使えません。最も確実なのは、そのカードを Alipay または WeChat Pay に登録し、QR コードで支払う方法です。',
  },
  {
    question: '外国人はタクシーや配車サービスの料金をどう支払えばよいですか。',
    answer:
      'DiDi を使うのが便利です。DiDi は Alipay や WeChat Pay に組み込まれており、連携した海外発行カードに自動で請求できます。流しのタクシーでも QR 決済に対応していることが増えていますが、古い車両に備えて少額の現金を持っておくと安心です。',
  },
  {
    question: 'ノマドとして中国でお金を受け取ったり報酬を受け取ったりできますか。',
    answer:
      '海外からの収入については、現在使っている海外の銀行口座や決済サービスをそのまま利用するのが現実的です。中国の決済システムは、基本的に国内送金や居住者向けに設計されています。家賃などの現地支払いには、海外発行カードを通じて Alipay や WeChat Pay を使うか、現地口座を開設して銀行振込を使う方法があります。',
  },
];

const related = [
  {
    title: '中国ビザ完全ガイド（デジタルノマド向け・2026年版）',
    description: '観光ビザ、商用ビザ、トランジット、出入国を含めた滞在方法をまとめて解説します。',
    href: '/ja/digital-nomads/visa/',
  },
  {
    title: '中国デジタルノマド完全ガイド',
    description: 'インターネット事情、生活費、おすすめ都市、リモートワークの実情をまとめた総合ガイドです。',
    href: '/ja/digital-nomads/',
  },
  {
    title: '中国長期滞在ガイド: 外国人向け完全版',
    description: '住まい、月額予算、1か月から6か月滞在までの日常実務を解説します。',
    href: '/ja/long-stay/',
  },
];
---

<GuideLayout
  title={title}
  description={description}
  url={url}
  datePublished={datePublished}
  breadcrumbs={breadcrumbs}
  toc={toc}
  faqs={faqs}
  related={related}
  cover="cover-payment"
  coverAlt="中国でスマートフォンを使って QR コード決済をしている様子"
 locale="ja">
  <p>
    中国のお金まわりは、ほかの多くの国とはかなり異なります。そのため、初めて訪れる人は戸惑いやすいです。都市部では現金中心の生活はほぼ消えており、海外発行のクレジットカードは多くの店であまり役に立ちません。しかし、いったん準備が整えば、支払いそのものは驚くほど簡単です。屋台の軽食でも、高速鉄道の切符でも、月額のコワーキング料金でも、QR コードを1回読み取るだけで済みます。重要なのは、ほとんどの支払いが Alipay と WeChat Pay という2つのスーパーアプリを通じて行われていること、そして今ではどちらも外国人に対応していることです。このガイドでは、まず現地の人のように支払えるようになるための基本を説明し、そのうえで、一般的な観光ガイドではあまり触れられない家賃や海外送金など、デジタルノマド向けの実務も解説します。
  </p>

  <h2 id="why-mobile">モバイル決済が主流である理由</h2>
  <p>
    中国では、財布の役割を QR コードが置き換えました。高級ブティックから果物の屋台まで、店先には支払い用のコードが掲示されており、それを読み取って支払います。カード端末がそもそも置かれていないことも珍しくありません。外国人にとって、これ自体は準備さえ済ませれば、むしろ便利です。小銭を探す必要もなく、カードが使えるかどうか心配する必要もありません。ただし、そのためには最優先で Alipay か WeChat Pay を海外発行カードと連携させる必要があります。できれば中国に到着する前に済ませておくのが理想です。ここを押さえれば日常生活はかなりスムーズになりますが、準備せずに来ると、水を1本買うだけでも苦労することがあります。
  </p>

  <h2 id="alipay">外国人向け Alipay（Tour Pass とカード連携）</h2>
  <p>
    2つの中では、Alipay のほうが外国人にとって使いやすく、最初に設定する候補として向いています。最近のバージョンでは、海外ユーザーが直接アカウント登録をして海外発行カードを連携できるほか、Tour Pass のようなプリペイド型の選択肢も用意されています。
  </p>
  <ul>
    <li><strong>対応カード:</strong> 海外発行の Visa、Mastercard、American Express など、主要な国際ブランドに対応しています。</li>
    <li><strong>設定手順:</strong> Alipay をインストールし、海外の電話番号で登録し、パスポートで本人確認を行ったうえで、銀行カードの項目からカードを追加します。</li>
    <li><strong>利用上限:</strong> 少額決済では手数料がかからないことが多い一方、高額決済では一定割合の手数料がかかる場合があります。海外発行カードには、1回あたりや年間の利用上限もあります。</li>
    <li><strong>使える場所:</strong> QR 決済に対応している場所であれば、ほぼそのまま使えます。実際には、ほとんどの場所で利用できます。</li>
  </ul>

  <h2 id="wechat">外国人向け WeChat Pay</h2>
  <p>
    WeChat Pay は WeChat に組み込まれており、WeChat 自体が中国で最も広く使われているメッセージアプリです。そのため、支払い手段であると同時に、現地での連絡手段としても重要です。こちらも海外発行カードの連携に対応しています。
  </p>
  <ul>
    <li><strong>対応カード:</strong> 主に Visa と Mastercard など主要な国際ブランドに対応していますが、対応範囲は Alipay よりやや狭いことがあります。</li>
    <li><strong>設定方法:</strong> WeChat をインストールして登録し、「自分」→「サービス」→「ウォレット」→「カード」からカードを追加します。</li>
    <li><strong>Alipay と WeChat Pay の違い:</strong> 外国人にとっては、カード連携のしやすさや支払い専用ツールとしての使いやすさでは Alipay のほうがやや有利です。一方で、WeChat Pay は小規模店舗、グループチャット、ミニプログラム内で前提になっている場面が多いため、できれば両方入れておくことをおすすめします。</li>
  </ul>

  <h2 id="cash">現金はまだ必要ですか。</h2>
  <p>
    現金は都市部の日常生活ではほとんど使われなくなりましたが、完全になくなったわけではありません。モバイル決済では対応しづらい場面に備えて、少額紙幣を中心に数百元持っておく価値はあります。
  </p>
  <ul>
    <li><strong>現金がまだ役立つ場面:</strong> 地方や小都市、一部の古いタクシー、非常に小さな露店、寺院の賽銭箱、そしてスマートフォンの電池切れやアプリの不具合が起きたときの備えです。</li>
    <li><strong>現金の入手方法:</strong> 海外発行カードに対応した ATM で人民元を引き出せます。都市部では大手銀行の ATM が最も確実です。なお、母国側の銀行から海外引き出し手数料がかかることがあります。</li>
    <li><strong>目安:</strong> 高額紙幣よりも少額紙幣を持つほうが実用的です。小さな店では 100 元札のお釣りが出しにくいことがあります。</li>
  </ul>

  <h2 id="cards">海外発行クレジットカードを直接使う場合</h2>
  <p>
    多くの場所で、カードをそのまま提示して支払えるとは考えないほうがよいです。直接使える場所はありますが、あくまで例外です。
  </p>
  <ul>
    <li><strong>使える場所:</strong> 国際系ホテル、空港、高級百貨店や大型モール、一部の大手小売チェーンなどです。</li>
    <li><strong>使えない場所:</strong> 多くの飲食店、コンビニ、交通機関、市場、小規模店舗ではほとんど期待できません。</li>
    <li><strong>ブランドごとの差:</strong> 端末自体がある場所では Visa と Mastercard が比較的広く使えます。American Express はさらに限定的です。UnionPay は中国国内の標準ですが、外国人旅行者にとって実用的な答えはほぼ同じで、アプリにカードを登録して QR で支払う方法が最も確実です。</li>
  </ul>

  <h2 id="scenarios">場面別の支払い方法</h2>
  <p>よくある場面ごとの支払い方法は、概ね次のとおりです。</p>
  <ul>
    <li><strong>タクシー・配車サービス:</strong> DiDi なら連携カードに自動で請求されます。流しのタクシーでも QR 決済に対応していることが多いですが、備えとして現金もあると安心です。</li>
    <li><strong>フードデリバリー:</strong> Alipay や WeChat 内の Meituan または Ele.me のミニプログラムから注文し、アプリ内で支払います。詳しくは <a href="/ja/posts/ordering-food-in-china-without-chinese-meituan-ele-me/">中国語なしで料理を注文する方法</a> をご覧ください。</li>
    <li><strong>高速鉄道:</strong> 公式の Railway 12306 アプリまたはミニプログラムで、パスポートを使って予約し、そのままアプリ内で支払えます。詳しくは <a href="/ja/posts/book-china-train-tickets-12306-foreigners/">列車チケットの予約方法</a> をご覧ください。</li>
    <li><strong>シェア自転車:</strong> 各アプリのミニプログラムから解錠し、利用料金は残高または連携した支払い手段に請求されます。</li>
    <li><strong>病院の受付:</strong> 大きな病院では、受付料や診療関連費用をモバイル決済で支払えることが多いです。小さなクリニックに備えて、パスポートと多少の現金を持っておくと安心です。</li>
    <li><strong>携帯電話のチャージ:</strong> 現地 SIM へのチャージは、Alipay や WeChat から数秒で行えます。</li>
  </ul>

  <h2 id="nomad">ノマド向け: 家賃、コワーキング、海外送金</h2>
  <p>
    日常的な支払い以外にも、長めに滞在するリモートワーカーには、旅行者とは異なるお金まわりの課題があります。
  </p>
  <ul>
    <li><strong>家賃の支払い:</strong> サービスアパートメントやホテルでは、モバイル決済やカード払いに対応していることが多いです。一方、個人の家主は銀行振込を希望することがあり、その場合は現地口座があると便利です。あるいは、チャージ済みの Alipay 残高で対応できることもあります。</li>
    <li><strong>コワーキング料金:</strong> 多くのスペースでは、月額料金を Alipay、WeChat、またはカードで請求します。経理処理が必要な場合は、領収書を必ず保管してください。</li>
    <li><strong>海外からの収入:</strong> 収入の受け取りは、現在使っている海外の銀行口座や決済サービスをそのまま使うのが基本です。海外収入を中国国内向けの決済システムに無理に通そうとしないほうが安全です。</li>
    <li><strong>両替と為替コスト:</strong> 母国の銀行レート、ATM の引き出しコスト、アプリ内カード手数料を比較してください。まとまった金額では、手数料の低いマルチカレンシー口座のほうが空港の両替所より有利なことが多いです。</li>
  </ul>

  <h2 id="pitfalls">よくある落とし穴を避ける方法</h2>
  <ul>
    <li><strong>QR コード詐欺:</strong> 店側が掲示しているコードだけを読み取るか、自分のコードを店員に読み取ってもらってください。知らない人から渡されたコードや、別のコードの上に貼られた不審なコードは読み取らないでください。</li>
    <li><strong>利用上限:</strong> 高額な買い物の前に、海外発行カードの上限を確認しておくと、レジで決済に失敗するのを防げます。</li>
    <li><strong>両替手段:</strong> 非公式の両替業者は避け、銀行 ATM、正規の両替窓口、またはアプリに連携したカードを使ってください。</li>
    <li><strong>アプリの不具合:</strong> どちらか一方が使えなくても困らないように、両方のアプリを入れておき、あわせて少額の現金も持っておくと安心です。</li>
  </ul>

  <h2 id="next">次に考えたいこと: どの都市を拠点にするか</h2>
  <p>
    ビザと支払い方法の準備ができたら、次の大きな判断は、どの都市を生活拠点にするかです。生活費の比較や、リモートワーク向けのおすすめ都市については、<a href="/ja/digital-nomads/">中国デジタルノマド完全ガイド</a>をご覧ください。
  </p>
</GuideLayout>
