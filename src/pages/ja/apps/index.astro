---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CoverImage from '../../../components/CoverImage.astro';
import AdSlot from '../../../components/AdSlot.astro';

const title = '中国旅行で必要なアプリ完全ガイド：ダウンロード先とWeb版の代替手段';
const description = '中国旅行で必要になりやすいアプリをまとめてご紹介します。WeChat、Alipay、DiDi、Baidu Maps、Meituan、12306、VPN などを網羅し、各アプリの App Store / Google Play ダウンロードリンクと、インストール不要で使える H5 Web 版も掲載しています。';

const appGroups = [
  {
    category: '決済・ウォレット',
    apps: [
      {
        name: 'Alipay',
        desc: '中国で最も広く使われているモバイルウォレットです。海外発行の Visa や Mastercard を連携すれば、店舗、レストラン、タクシー、屋台などで QR コード決済ができます。',
        android: 'https://play.google.com/store/apps/details?id=com.eg.android.AlipayGphone',
        ios: 'https://apps.apple.com/app/alipay/id333206289',
        h5: null,
        note: '初期設定は10〜15分ほどで完了します。本人確認にはパスポートが必要です。',
        guide: '/ja/posts/alipay-foreign-credit-card-step-by-step/',
      },
      {
        name: 'WeChat',
        desc: '中国を代表するスーパーアプリです。メッセージ、通話、Moments（SNSフィード）、WeChat Pay まで、日常のさまざまな場面で使われています。',
        android: 'https://play.google.com/store/apps/details?id=com.tencent.mm',
        ios: 'https://apps.apple.com/app/wechat/id414478124',
        h5: 'https://web.wechat.com/',
        note: 'WeChat Pay を使うにはカード連携が必要です。WeChat 自体は設定しなくても、メッセージ用途で利用できます。',
        guide: '/ja/posts/link-a-foreign-visa-or-mastercard-to-wechat-pay-in-china/',
      },
    ],
  },
  {
    category: '移動・配車',
    apps: [
      {
        name: 'DiDi',
        desc: '中国版 Uber ともいえる配車アプリです。タクシーや専用車を手配でき、英語表示にも対応しています。支払いには Alipay または WeChat Pay を使えます。',
        android: 'https://play.google.com/store/apps/details?id=com.didi.sdk',
        ios: 'https://apps.apple.com/app/didi/id1164272094',
        h5: 'https://www.didiglobal.com/',
        note: 'H5 版はブラウザや WeChat のミニプログラムから利用できます。たまに乗る程度であれば、アプリを入れなくても十分です。',
        guide: '/ja/posts/didi-china-foreign-tourists-guide/',
      },
      {
        name: 'Alipay の交通ミニプログラム',
        desc: 'Alipay 内の交通ミニプログラムを使えば、主要都市の地下鉄やバスで QR コードを読み取って乗車できます。',
        android: null,
        ios: null,
        h5: null,
        note: 'Alipay を開いて「交通」アイコンを選んでください。別途インストールする必要はありません。',
        guide: '/ja/transport/',
      },
      {
        name: '12306',
        desc: '中国鉄路の公式列車予約アプリです。中国語表示のみで、利用には本人確認が必要です。代替手段としては Trip.com が便利です。',
        android: 'https://play.google.com/store/apps/details?id=com.cars.blaili',
        ios: 'https://apps.apple.com/app/12306/id564757494',
        h5: 'https://www.12306.cn/',
        note: '外国人旅行者にはやや使いにくいため、英語に対応していて本人確認の負担が少ない Trip.com の利用をおすすめします。',
        guide: '/ja/posts/book-china-train-tickets-12306-foreigners/',
      },
      {
        name: 'Trip.com (Ctrip)',
        desc: '英語で使いやすく、鉄道、航空券、ホテルをまとめて予約できるアプリです。海外発行のカードもそのまま利用できます。',
        android: 'https://play.google.com/store/apps/details?id=com.ctrip',
        ios: 'https://apps.apple.com/app/trip-com/id1612956441',
        h5: 'https://www.trip.com/',
        note: '列車予約では 12306 の最も使いやすい代替手段です。手数料はやや高めですが、その分手続きはかなり簡単です。',
        guide: null,
      },
    ],
  },
  {
    category: 'ナビ・地図',
    apps: [
      {
        name: 'Baidu Maps',
        desc: '中国国内では非常に詳細な地図アプリです。ターンバイターンの経路案内、公共交通の検索、飲食店探しまで対応しています。中国語のみですが、操作に慣れれば十分使えます。',
        android: 'https://play.google.com/store/apps/details?id=com.baidu.BaiduMap',
        ios: 'https://apps.apple.com/app/baidu-maps/id452186370',
        h5: 'https://map.baidu.com/',
        note: '中国では Google Maps が制限されるため、移動には Baidu Maps か Amap が必要です。',
        guide: null,
      },
      {
        name: 'Amap (Gaode)',
        desc: 'Baidu Maps の代替として人気の地図アプリです。現地ではこちらを好む人も多く、配車時の案内、渋滞情報、飲食店レビューに強みがあります。',
        android: 'https://play.google.com/store/apps/details?id=com.autonavi.minimap',
        ios: 'https://apps.apple.com/app/amap/id461703208',
        h5: 'https://ditu.amap.com/',
        note: 'Baidu Maps と Amap のどちらでも問題ありません。配車では Amap のほうが正確なことが多いです。',
        guide: null,
      },
      {
        name: 'Google Maps',
        desc: '中国でも地図の閲覧自体は一部可能ですが、ナビ機能やリアルタイム交通情報は安定しません。旅行前の下調べには便利です。',
        android: null,
        ios: null,
        h5: 'https://maps.google.com/',
        note: '中国国内でターンバイターンの案内を使うには VPN が必要で、実用性はあまり高くありません。',
        guide: '/ja/posts/do-you-need-a-vpn-in-china-2026/',
      },
    ],
  },
  {
    category: '食事・グルメ',
    apps: [
      {
        name: 'Meituan',
        desc: 'フードデリバリー、レストラン予約、映画チケット、ホテル予約まで対応する総合生活アプリです。中国語のみですが、Alipay のミニプログラム経由であれば比較的使いやすくなります。',
        android: 'https://play.google.com/store/apps/details?id=com.sankuai.meituan',
        ios: 'https://apps.apple.com/app/meituan/id423924287',
        h5: 'https://waimai.meituan.com/',
        note: 'フードデリバリーの H5 版はブラウザで使えます。支払いは受け取り時に Alipay でも対応できます。',
        guide: '/ja/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
      },
      {
        name: 'Ele.me',
        desc: 'Alibaba 傘下のフードデリバリーアプリです。Meituan に近いサービスで、Alipay を使って料理を注文できます。',
        android: 'https://play.google.com/store/apps/details?id=me.ele',
        ios: 'https://apps.apple.com/app/ele-me/id532785356',
        h5: 'https://www.ele.me/',
        note: 'Meituan と Ele.me はどちらも便利です。掲載されている店舗が異なるため、両方試すと選択肢が広がります。',
        guide: '/ja/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
      },
      {
        name: 'Dianping',
        desc: '中国版 Yelp のような口コミアプリです。レストランの評価、レビュー、写真を確認でき、現地で人気のお店探しに役立ちます。中国語のみです。',
        android: 'https://play.google.com/store/apps/details?id=com.dianping.v1',
        ios: 'https://apps.apple.com/app/dianping/id416896465',
        h5: 'https://www.dianping.com/',
        note: '写真検索機能が便利です。注文前に料理の見た目を確認できます。',
        guide: '/ja/food/',
      },
    ],
  },
  {
    category: '連絡・VPN',
    apps: [
      {
        name: 'VPN（出発前に1つ選んでおきましょう）',
        desc: 'VPN は必ず出発前にインストールしてください。中国では ExpressVPN、NordVPN、Astrill などが候補になります。無料 VPN の多くは利用できません。',
        android: null,
        ios: null,
        h5: null,
        note: '必須です。到着前にインストールと動作確認を済ませ、現地に着いたらすぐ使えるようにしておきましょう。',
        guide: '/ja/posts/do-you-need-a-vpn-in-china-2026/',
      },
      {
        name: 'Google Translate',
        desc: 'メニュー、看板、書類の翻訳に便利なカメラ翻訳が使えます。中国語（簡体字）のオフラインパックも事前に入れておくと安心です。',
        android: 'https://play.google.com/store/apps/details?id=com.google.android.apps.translate',
        ios: 'https://apps.apple.com/app/google-translate/id414706506',
        h5: 'https://translate.google.com/',
        note: '翻訳アプリとして非常に優秀です。旅行前にオフラインパックをダウンロードしておいてください。',
        guide: '/ja/tools/survival-kit/',
      },
    ],
  },
  {
    category: '旅行予約',
    apps: [
      {
        name: 'Trip.com（ホテル予約）',
        desc: '海外発行カードでホテルを予約するなら、最も使いやすい選択肢です。掲載数が多く、英語表示にも対応しています。',
        android: null,
        ios: null,
        h5: 'https://www.trip.com/hotels/',
        note: '航空券や鉄道の予約にも対応しており、旅行手配をまとめて済ませられます。',
        guide: null,
      },
      {
        name: 'Fliggy (Alitrip)',
        desc: 'Alibaba の旅行予約サービスです。Alipay アプリ内から利用でき、国内線の予約に向いています。',
        android: null,
        ios: null,
        h5: 'https://www.fliggy.com/',
        note: '支払いは Alipay でできます。別途ダウンロードする必要はありません。',
        guide: null,
      },
    ],
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">モバイルアプリ</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">中国旅行で入れておきたい必須アプリ</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-internet-apps" alt="中国旅行で役立つ必須アプリのアイコンが表示されたスマートフォン" loading="eager" />

    <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-5 text-sm leading-6 text-amber-900">
      <strong>出発前の準備：</strong>これらのアプリは、出発前に WiFi 環境で入れておくことをおすすめします。中国国内ではアプリストアの表示やダウンロードが遅かったり、使いにくかったりする場合があります。翻訳のオフラインパックや VPN アプリも、自宅で事前に準備しておきましょう。
    </div>

    <AdSlot format="banner" />

    {appGroups.map((group) => (
      <section class="mt-12" aria-labelledby={group.category.replace(/\s+/g, '-').toLowerCase()}>
        <h2 id={group.category.replace(/\s+/g, '-').toLowerCase()} class="text-2xl font-bold text-gray-950">{group.category}</h2>
        <div class="mt-5 grid gap-5 md:grid-cols-2">
          {group.apps.map((app) => (
            <article class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
              <h3 class="text-lg font-bold text-gray-950">{app.name}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{app.desc}</p>

              <div class="mt-4 flex flex-wrap gap-2">
                {app.ios && (
                  <a href={app.ios} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md bg-gray-900 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-gray-700">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M17.05 20.28c-.98.95-2.05.8-3.08.35-1.09-.46-2.09-.48-3.24 0-1.44.62-2.2.44-3.06-.35C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.54 4.09zM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25z"/></svg>
                    App Storeで開く
                  </a>
                )}
                {app.android && (
                  <a href={app.android} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md bg-green-700 px-3 py-1.5 text-xs font-medium text-white transition-colors hover:bg-green-600">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M18.33 8.7c-.55-.96-1.1-1.91-1.66-2.86l.32-.32c.18-.18.36-.36.54-.54.77-.77.77-1.53 0-2.3-.74-.74-1.52-.74-2.26 0-.36.36-.72.72-1.08 1.08l-.1.1A7.83 7.83 0 0 0 12 3.5c-1.1 0-2.15.2-3.12.61l-.1-.1c-.36-.36-.72-.72-1.08-1.08-.74-.74-1.52-.74-2.26 0-.77.77-.77 1.53 0 2.3.18.18.36.36.54.54l.32.32C5.2 6.8 4.64 7.75 4.08 8.7c-.55.95-1.09 1.9-1.64 2.86h15.53c-.55-.96-1.1-1.91-1.64-2.86M7.75 5.75c-.4 0-.72-.33-.72-.72s.32-.72.72-.72c.4 0 .72.33.72.72s-.32.72-.72.72m8.2 0c-.4 0-.72-.33-.72-.72s.32-.72.72-.72c.4 0 .72.33.72.72s-.32.72-.72.72M6.3 13.36v4.58c0 .66.53 1.2 1.2 1.2h.7c.66 0 1.2-.54 1.2-1.2v-4.58c0-.66-.54-1.2-1.2-1.2h-.7c-.67 0-1.2.54-1.2 1.2m8.72 0v4.58c0 .66.53 1.2 1.2 1.2h.7c.66 0 1.2-.54 1.2-1.2v-4.58c0-.66-.54-1.2-1.2-1.2h-.7c-.67 0-1.2.54-1.2 1.2"/></svg>
                    Google Playで開く
                  </a>
                )}
                {app.h5 && (
                  <a href={app.h5} target="_blank" rel="noopener" class="inline-flex items-center gap-1 rounded-md border border-gray-200 bg-white px-3 py-1.5 text-xs font-medium text-gray-700 transition-colors hover:bg-gray-50">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                    Web版で開く
                  </a>
                )}
              </div>

              {app.note && (
                <p class="mt-3 text-xs leading-5 text-gray-500"><span class="font-semibold">補足：</span> {app.note}</p>
              )}
              {app.guide && (
                <a href={app.guide} class="mt-2 inline-block text-xs font-semibold text-brand-700 hover:text-brand-800">設定ガイドを見る &rarr;</a>
              )}
            </article>
          ))}
        </div>
      </section>
    ))}

    <section class="mt-12 rounded-lg border border-gray-200 p-6">
      <h2 class="text-xl font-bold text-gray-950">H5 Web アプリはダウンロード不要で使えます</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        中国の多くのサービスには、<strong>ブラウザで使える Web 版（H5）</strong>があります。スマートフォンのブラウザや WeChat / Alipay のミニプログラム内で直接使えるため、10個以上のアプリを端末に入れたくない短期旅行の方には特に便利です。代表的なものは次のとおりです。
      </p>
      <div class="mt-4 grid gap-3 text-sm sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">DiDi</strong> — <span class="text-gray-600">www.didiglobal.com（英語表示に対応しています）</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Baidu Maps</strong> — <span class="text-gray-600">map.baidu.com（中国語のみです）</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">WeChat Web</strong> — <span class="text-gray-600">web.wechat.com（メッセージ機能のみ使えます）</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Meituan</strong> — <span class="text-gray-600">waimai.meituan.com（フードデリバリーに対応しています）</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Dianping</strong> — <span class="text-gray-600">dianping.com（レストランを探せます）</span></div>
        <div class="rounded-md bg-gray-50 p-3"><strong class="text-gray-900">Alipay のミニプログラム</strong> — <span class="text-gray-600">Alipay 内で完結します（追加インストールは不要です）</span></div>
      </div>
      <p class="mt-4 text-xs text-gray-500">
        <strong>多くの場合、Web 版は VPN なしでも利用できます。</strong>アプリ本体のダウンロードは、出発前に自宅の WiFi で済ませておくと安心です。
      </p>
    </section>

    <section class="mt-10 text-center">
      <p class="text-sm text-gray-500">アプリストアのリンクは公式ページを開きます。料金や提供状況は、地域ごとの制限によって異なる場合があります。</p>
    </section>
  </main>
  <Footer />
</BaseLayout>
