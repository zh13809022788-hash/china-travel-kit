---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';

const seriesSlug = 'history-of-china';
const posts = (await getCollection('posts-ja'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = '中国の歴史 旅行者のための古代遺跡と物語';
const description = '万里の長城、兵馬俑、紫禁城、シルクロード、古都、水郷の町々など、中国の歴史スポットを海外旅行者にもわかりやすくご案内します。目の前にある景色の背景にある物語まで読み解けます。';

const relatedTools = [
  { href: '/ja/posts/china-visa-free-entry-transit-guide-2026/', title: 'ビザ・入国ガイド', desc: 'ビザ免除乗り継ぎ制度と入国条件をご案内します' },
  { href: '/ja/posts/china-high-speed-rail-guide-foreigners/', title: '高速鉄道ガイド', desc: '中国各地の歴史スポットへ向かう列車情報をご案内します' },
  { href: '/ja/posts/book-china-train-tickets-12306-foreigners/', title: '列車チケット予約ガイド', desc: '外国籍パスポートをお持ちの方向けの12306利用ガイドです' },
];

const relatedCities = [
  { href: '/ja/posts/beijing-city-guide-for-foreigners/', title: '北京', desc: '紫禁城、万里の長城、天壇を巡れます' },
  { href: '/ja/posts/hangzhou-city-guide-for-foreigners/', title: '杭州', desc: '南宋の古都の歴史に触れられます' },
  { href: '/ja/posts/chengdu-city-guide-for-foreigners/', title: '成都', desc: '三国志ゆかりの史跡と古い街並みが楽しめます' },
];

const otherSeries = [
  { href: '/ja/series/food-of-china/', title: '中国の食' },
  { href: '/ja/series/culture-of-china/', title: '中国の文化' },
  { href: '/ja/series/nature-of-china/', title: '中国の自然' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">特集シリーズ</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">記事一覧</p>
            <h2>「中国の歴史」シリーズ</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/ja/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{post.data.category}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">このシリーズの記事は現在準備中です。しばらくしてからもう一度ご覧ください。</p>
        )}
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">旅行に役立つ情報</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">見学計画に役立つガイド</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">都市ガイド</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">歴史ある都市</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">ほかのシリーズ</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>
