---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';

const seriesSlug = 'food-of-china';
const posts = (await getCollection('posts-ja'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = '中国の食文化を楽しむ旅ガイド';
const description = '中国を訪れる旅行者の方向けに、中国の食文化をわかりやすくご案内します。八大料理、地域ごとの火鍋、屋台で気をつけたいこと、点心、朝食、ベジタリアン向けの選び方、そして遠回りしてでも食べたい名物料理まで幅広くご紹介します。';

const relatedTools = [
  { href: '/ja/posts/ordering-food-in-china-without-chinese-meituan-ele-me/', title: '中国語ができなくても料理を注文する方法', desc: '旅行者の方向けに、MeituanとEle.meの設定方法をわかりやすくご案内します。' },
  { href: '/ja/posts/how-to-pay-in-china-tourist-guide/', title: '中国での支払い方法', desc: '食事のときに使えるAlipay、WeChat Pay、現金の使い分けをご説明します。' },
  { href: '/ja/food/', title: '食事とグルメのガイド', desc: 'ChinaTripBoxの食に関する記事をまとめてご覧いただけます。' },
];

const relatedCities = [
  { href: '/ja/posts/chengdu-city-guide-for-foreigners/', title: '成都', desc: '四川料理の本場として知られています。' },
  { href: '/ja/posts/beijing-city-guide-for-foreigners/', title: '北京', desc: '北京ダックや北方料理を楽しめます。' },
  { href: '/ja/posts/shanghai-city-guide-for-foreigners/', title: '上海', desc: '小籠包や多彩な創作料理が味わえます。' },
];

const otherSeries = [
  { href: '/ja/series/history-of-china/', title: '中国の歴史' },
  { href: '/ja/series/culture-of-china/', title: '中国の文化' },
  { href: '/ja/series/modern-china/', title: '現代の中国' },
];
---
import { getCategoryLabel } from '../../../i18n/categories.ts';

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">連載シリーズ</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">記事一覧</p>
            <h2>「中国の食文化」シリーズの記事</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/ja/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">このシリーズの記事は現在準備中です。恐れ入りますが、しばらくしてからもう一度ご覧ください。</p>
        )}
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">便利なガイド</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">中国で食事をしっかり楽しむために</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">都市別グルメガイド</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">食べたい街を見つける</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">関連シリーズ</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>
