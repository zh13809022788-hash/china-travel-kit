---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';

const title = 'China旅行コンテンツシリーズ';
const description = '食、歴史、現代生活、自然、文化という5つのテーマ別シリーズを通じてChinaを探索。各シリーズは、外国人旅行者にひらめきと実用的な情報を届けるために作られています。';

const seriesList = [
  {
    href: '/ja/series/food-of-china/',
    title: 'Chinaの食',
    desc: '屋台から宴会場まで。八大料理、地域ごとの朝食、火鍋のスタイル、そして街を横断してでも食べに行く価値のある料理をめぐる、外国人のための美食の旅。',
    icon: '食べ物・飲み物',
  },
  {
    href: '/ja/series/history-of-china/',
    title: 'Chinaの歴史',
    desc: '旅行者のために古代遺跡を読み解く。万里の長城、兵馬俑、紫禁城、シルクロード、そして目の前の景色の背後にある物語。',
    icon: '歴史',
  },
  {
    href: '/ja/series/modern-china/',
    title: '現代のChina',
    desc: '外国人が最も驚くもの。キャッシュレスの街、世界最速クラスの鉄道、メガシティの規模、スーパーアプリ、そして今日のChinaの暮らしを形づくる日常のテクノロジー。',
    icon: '現代生活',
  },
  {
    href: '/ja/series/nature-of-china/',
    title: 'Chinaの自然',
    desc: 'Avatarのような山々、童話のような湖、カルスト地形、チベット高原。外国人旅行者向けの実用ガイドとともに巡る、China屈指の壮大な自然スポット。',
    icon: '自然',
  },
  {
    href: '/ja/series/culture-of-china/',
    title: 'Chinaの文化',
    desc: '茶道、春節、面子と関係、書道、カンフー、干支。表面的な観光を越えて理解したい旅行者のために、文化的伝統をわかりやすく解説します。',
    icon: '文化',
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">コンテンツシリーズ</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <section class="mt-10 grid gap-5 md:grid-cols-2">
      {seriesList.map((s) => (
        <a href={s.href} class="card block hover:no-underline">
          <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{s.icon}</span>
          <h2 class="mt-2 text-xl font-bold text-gray-950">{s.title}</h2>
          <p class="mt-2 text-sm leading-6 text-gray-600">{s.desc}</p>
          <span class="mt-4 inline-flex text-sm font-semibold text-brand-700">シリーズを見る</span>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>
