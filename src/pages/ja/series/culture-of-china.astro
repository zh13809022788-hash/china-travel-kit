---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';

const seriesSlug = 'culture-of-china';
const posts = (await getCollection('posts-ja'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = '中国文化：旅行者のための伝統と習慣をご案内します';
const description = '外国人旅行者の方向けに、中国文化をわかりやすくご案内するガイドです。茶文化、春節、面子と関係、書道、カンフー、十二支、そして中国の日常生活を形づくる伝統について丁寧に解説します。';

const relatedTools = [
  { href: '/ja/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/', title: 'チップとマナー', desc: 'チップが必要な場面と不要な場面、その背景も含めてわかりやすくご案内します。' },
  { href: '/ja/posts/what-to-pack-for-china-a-season-by-season-checklist/', title: 'お祭りシーズンの持ち物', desc: '祝日シーズンの旅行で持っていくと便利なものをご紹介します。' },
  { href: '/ja/posts/how-to-pay-in-china-tourist-guide/', title: '中国での支払い方法', desc: '祝日シーズンの旅行で役立つ支払い方法をご案内します。' },
];

const relatedCities = [
  { href: '/ja/posts/beijing-city-guide-for-foreigners/', title: '北京', desc: '皇城文化や胡同の暮らしを身近に感じていただけます。' },
  { href: '/ja/posts/hangzhou-city-guide-for-foreigners/', title: '杭州', desc: '茶文化と西湖の歴史遺産をお楽しみいただけます。' },
  { href: '/ja/posts/chengdu-city-guide-for-foreigners/', title: '成都', desc: '茶館文化とゆったりした暮らしを味わっていただけます。' },
];

const otherSeries = [
  { href: '/ja/series/food-of-china/', title: '中国の食文化' },
  { href: '/ja/series/history-of-china/', title: '中国の歴史' },
  { href: '/ja/series/modern-china/', title: '現代の中国' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">シリーズのご案内</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">記事一覧</p>
            <h2>中国文化シリーズの記事をご覧いただけます</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/ja/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{post.data.category}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">このシリーズの記事は現在準備中です。公開まで今しばらくお待ちください。</p>
        )}
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">お役立ち情報</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">文化を知って、旅をより深く楽しみましょう</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">都市ガイド</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">文化を身近に感じていただける都市です</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">関連シリーズ</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>
