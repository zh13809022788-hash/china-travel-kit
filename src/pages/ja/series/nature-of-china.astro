---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';

const seriesSlug = 'nature-of-china';
const posts = (await getCollection('posts-ja'))
  .filter((p) => p.data.series === seriesSlug)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = '中国の自然 | 絶景と手つかずの大地をご紹介します';
const description = '外国人旅行者の方向けに、中国の壮大な自然をご紹介します。張家界の「アバター」を思わせる奇峰群、九寨溝のおとぎ話のような湖、黄山の雲海、桂林のカルスト峰、そしてチベット高原まで、幅広くご案内します。';

const relatedTools = [
  { href: '/ja/posts/what-to-pack-for-china-a-season-by-season-checklist/', title: '持ち物チェックリスト', desc: '季節ごとのアウトドア旅行に必要な装備を確認していただけます。' },
  { href: '/ja/posts/china-visa-free-entry-transit-guide-2026/', title: 'ビザ・入国ガイド', desc: '遠隔地を訪れる際に必要な許可証や入域ルールを確認していただけます。' },
  { href: '/ja/trip-planner/', title: '旅行プランナー', desc: '中国の自然を巡る旅程を作成していただけます。' },
];

const relatedCities = [
  { href: '/ja/posts/sanya-city-guide-for-foreigners/', title: '三亜', desc: '南国のビーチと熱帯雨林を満喫していただけます。' },
  { href: '/ja/posts/hangzhou-city-guide-for-foreigners/', title: '杭州', desc: '西湖と茶畑が織りなす美しい風景を楽しんでいただけます。' },
  { href: '/ja/posts/chengdu-city-guide-for-foreigners/', title: '成都', desc: '西部の山岳地帯やパンダ観光へ向かう玄関口として便利です。' },
];

const otherSeries = [
  { href: '/ja/series/history-of-china/', title: '中国の歴史' },
  { href: '/ja/series/culture-of-china/', title: '中国の文化' },
  { href: '/ja/series/food-of-china/', title: '中国の食文化' },
];
import { getCategoryLabel } from '../../../i18n/categories';
const locale = 'ja';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">シリーズ案内</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">記事一覧</p>
            <h2>「中国の自然」シリーズの記事をご覧いただけます</h2>
          </div>
        </div>
        {posts.length > 0 ? (
          <div class="mt-6 grid gap-5 md:grid-cols-2">
            {posts.map((post) => (
              <a href={`/ja/posts/${post.slug}/`} class="card block hover:no-underline">
                <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
                <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
                <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
              </a>
            ))}
          </div>
        ) : (
          <p class="mt-6 text-gray-500">このシリーズの記事は現在準備中です。公開まで今しばらくお待ちください。</p>
        )}
      </div>

      <aside class="space-y-6">
        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">便利なツール</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">旅行計画に役立つページです</h2>
          <div class="mt-4 grid gap-3">
            {relatedTools.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">都市ガイド</p>
          <h2 class="mt-1 text-xl font-bold text-gray-950">自然観光の拠点となる都市をご紹介します</h2>
          <div class="mt-4 grid gap-3">
            {relatedCities.map((item) => (
              <a href={item.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
                <h3 class="text-sm font-semibold text-gray-950">{item.title}</h3>
                <p class="mt-1 text-sm leading-6 text-gray-600">{item.desc}</p>
              </a>
            ))}
          </div>
        </div>

        <div class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <p class="section-kicker">あわせて読みたいシリーズ</p>
          <div class="mt-3 grid gap-2">
            {otherSeries.map((s) => (
              <a href={s.href} class="text-sm font-semibold text-brand-700 hover:underline">{s.title}</a>
            ))}
          </div>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>
