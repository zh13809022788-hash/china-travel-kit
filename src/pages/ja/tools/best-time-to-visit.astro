---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'China旅行のベストシーズン - 都市・月別プランナー';
const description =
  '中国主要都市の天気、混雑状況、持ち物を月別に確認できます。北京、上海、西安、成都、広州、ハルビンを訪れるベストシーズンを計画しましょう。';

const cities = ['北京', '上海', '西安', '成都', '広州', 'ハルビン'];
const months = ['1月', '2月', '3月', '4月', '5月', '6月', '7月', '8月', '9月', '10月', '11月', '12月'];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">ツール</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">China旅行のベストシーズン</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">都市</span>
        <select id="city" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {cities.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">旅行月</span>
        <select id="month" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {months.map((m, i) => <option value={i}>{m}</option>)}
        </select>
      </label>
    </div>

    <div id="result" class="mt-6">
      <div class="card" id="result-card"></div>
    </div>

    <!-- 旅行シーズンの注意書き -->
    <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-4 text-sm text-amber-800">
      <strong>混雑を避ける:</strong> 中国の祝日、特に春節
      (1月下旬から2月)、労働節(5月上旬)、国慶節・ゴールデンウィーク(10月第1週)
      は国内旅行者が大きく増えます。列車やホテルは売り切れやすく、料金も急上昇します。早めに予約するか、
      これらの日程を避けて計画しましょう。
    </div>

    <AffiliateCta
      title="列車とホテルは早めに予約"
      description="ピークシーズンは人気路線がすぐに売り切れます。高速鉄道と宿泊先は早めに確保しましょう。"
      buttonText="予約オプションを見る"
      placeholder={AFFILIATE_LINKS.transport}
    />
  </main>
  <Footer />
</BaseLayout>

