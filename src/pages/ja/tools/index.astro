---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import { TOOLS as tools } from '../../../config';

const title = '無料で使える中国旅行ツール集｜ビザ・決済・eSIM・予算・運転手向けカード・会話フレーズ';
const description =
  '中国旅行の準備に役立つ無料のインタラクティブツールをまとめています。ビザなし入国の確認、使える決済カードのチェック、eSIMの比較、旅行予算の試算、現金の予備額、電源プラグ、中国語フレーズ、タクシー運転手に見せる住所カードまで、このページでまとめて確認していただけます。';

const toolUseCases = [
  {
    title: '航空券を予約する前に確認しておきましょう',
    text: '旅程や訪問都市を決める前に、ビザなし入国チェッカー、旅行に適した時期、予算見積もりを確認しておくと安心です。',
    links: [
      { href: '/ja/tools/visa-free-checker/', label: 'ビザなし入国チェッカー' },
      { href: '/ja/tools/best-time-to-visit/', label: '旅行に適した時期' },
      { href: '/ja/tools/budget-cash-estimator/', label: '予算見積もり' },
    ],
  },
  {
    title: '出発前にひと通り確認しておきましょう',
    text: 'まだ自宅で落ち着いて設定できるうちに、決済、eSIM、アプリ、電源プラグ、フレーズ関連のツールを確認しておくと安心です。',
    links: [
      { href: '/ja/tools/payment-checker/', label: '決済チェッカー' },
      { href: '/ja/tools/esim-comparison/', label: 'eSIM比較' },
      { href: '/ja/tools/app-availability-checker/', label: 'アプリ利用可否チェッカー' },
    ],
  },
  {
    title: '中国滞在中に役立ちます',
    text: 'アプリの操作、タクシーの利用、メニューの読み取り、ホテルのフロントでのやり取りに困ったときは、運転手に見せるカード、通貨換算、必須フレーズが役立ちます。',
    links: [
      { href: '/ja/tools/survival-kit/', label: 'サバイバルキット' },
      { href: '/ja/tools/show-to-driver/', label: '運転手に見せるカード' },
      { href: '/ja/tools/currency-converter/', label: '人民元換算' },
      { href: '/ja/tools/essential-phrases/', label: '必須フレーズ' },
    ],
  },
];

const toolsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  hasPart: tools.map((tool) => ({
    '@type': 'WebApplication',
    name: tool.title,
    description: tool.desc,
    applicationCategory: 'TravelApplication',
    url: new URL(tool.href, 'https://www.chinatripbox.com').toString(),
  })),
};
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(toolsJsonLd)} />
  <Header locale="ja" />
  <main class="container-page py-12">
    <header>
      <p class="section-kicker">ツール一覧</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">無料で使える中国旅行ツール集</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="/ja/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-primary">出発前のチェックリストを見る</a>
        <a href="/ja/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">初めての方向け旅行プランを見る</a>
      </div>
    </header>

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 lg:grid-cols-3" aria-labelledby="tool-use-cases-heading">
      <div class="lg:col-span-3">
        <h2 id="tool-use-cases-heading" class="text-2xl font-bold text-gray-950">どのツールから使えばよいですか？</h2>
      </div>
      {toolUseCases.map((useCase) => (
        <article class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <h3 class="text-lg font-bold text-gray-950">{useCase.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{useCase.text}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {useCase.links.map((link) => (
              <a href={link.href} class="rounded-full border border-gray-200 px-3 py-1.5 text-xs font-semibold text-brand-700 hover:border-brand-300 hover:bg-brand-50 hover:no-underline">{link.label}</a>
            ))}
          </div>
        </article>
      ))}
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {tools.map((tool) => (
        <a href={tool.href} class="card block hover:no-underline">
          <div class="text-3xl">{tool.icon}</div>
          <h2 class="mt-3 text-lg font-bold text-gray-900">{tool.title}</h2>
          <p class="mt-1.5 text-sm text-gray-600">{tool.desc}</p>
          <span class="mt-3 inline-block text-sm font-semibold text-brand-600">ツールを開く</span>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>
