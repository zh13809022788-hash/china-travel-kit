---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import { TOOLS as tools } from '../../../config';

const title = '無料の中国旅行ツール：ビザ、決済、eSIM、予算、運転手カード、会話フレーズ';
const description =
  '中国旅行の計画に役立つ無料のインタラクティブツール：ビザなし入国、決済カードの対応状況、eSIMの選択肢、旅行予算、現金の予備、電源プラグ、中国語フレーズ、タクシー運転手に見せる住所カードを確認できます。';

const toolUseCases = [
  {
    title: '航空券を予約する前',
    text: '日程と訪問都市を確定する前に、ビザなし入国チェッカー、ベストシーズンプランナー、予算見積もりを使いましょう。',
    links: [
      { href: '/ja/tools/visa-free-checker/', label: 'ビザなし入国チェッカー' },
      { href: '/ja/tools/best-time-to-visit/', label: '訪問に最適な時期' },
      { href: '/ja/tools/budget-cash-estimator/', label: '予算見積もり' },
    ],
  },
  {
    title: '出発前',
    text: '自宅で設定トラブルに対処できるうちに、決済、eSIM、アプリ、電源プラグ、フレーズの各ツールを確認しましょう。',
    links: [
      { href: '/ja/tools/payment-checker/', label: '決済チェッカー' },
      { href: '/ja/tools/esim-comparison/', label: 'eSIM比較' },
      { href: '/ja/tools/app-availability-checker/', label: 'アプリチェッカー' },
    ],
  },
  {
    title: 'China滞在中',
    text: 'アプリ、タクシー、メニュー、ホテルのフロントで困ったときは、運転手カード、通貨換算、必須フレーズを使いましょう。',
    links: [
      { href: '/ja/tools/survival-kit/', label: 'サバイバルキット' },
      { href: '/ja/tools/show-to-driver/', label: '運転手に見せる' },
      { href: '/ja/tools/currency-converter/', label: '人民元換算' },
      { href: '/ja/tools/essential-phrases/', label: '必須フレーズ' },
    ],
  },
];

const toolsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  hasPart: tools.map((tool) => ({
    '@type': 'WebApplication',
    name: tool.title,
    description: tool.desc,
    applicationCategory: 'TravelApplication',
    url: new URL(tool.href, 'https://www.chinatripbox.com').toString(),
  })),
};
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(toolsJsonLd)} />
  <Header locale="ja" />
  <main class="container-page py-12">
    <header class="max-w-2xl">
      <p class="section-kicker">ツールセンター</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">無料の中国旅行ツール</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="/ja/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-primary">出発前チェックリストを使う</a>
        <a href="/ja/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">初めての方向けプランナーを読む</a>
      </div>
    </header>

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 lg:grid-cols-3" aria-labelledby="tool-use-cases-heading">
      <div class="lg:col-span-3">
        <h2 id="tool-use-cases-heading" class="text-2xl font-bold text-gray-950">最初に使うべきツールは？</h2>
      </div>
      {toolUseCases.map((useCase) => (
        <article class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <h3 class="text-lg font-bold text-gray-950">{useCase.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{useCase.text}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {useCase.links.map((link) => (
              <a href={link.href} class="rounded-full border border-gray-200 px-3 py-1.5 text-xs font-semibold text-brand-700 hover:border-brand-300 hover:bg-brand-50 hover:no-underline">{link.label}</a>
            ))}
          </div>
        </article>
      ))}
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {tools.map((tool) => (
        <a href={tool.href} class="card block hover:no-underline">
          <div class="text-3xl">{tool.icon}</div>
          <h2 class="mt-3 text-lg font-bold text-gray-900">{tool.title}</h2>
          <p class="mt-1.5 text-sm text-gray-600">{tool.desc}</p>
          <span class="mt-3 inline-block text-sm font-semibold text-brand-600">ツールを開く →</span>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>
