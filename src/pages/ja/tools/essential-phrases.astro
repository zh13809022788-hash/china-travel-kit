---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = '旅行者のための必須中国語フレーズ';
const description =
  'Chinaを訪れる旅行者向けに、必須の中国語フレーズをピンインと日本語付きでまとめた、印刷しやすい便利な一覧です。あいさつ、決済、交通、食事、緊急時をカバーしています。';

interface Phrase {
  en: string;
  zh: string;
  pinyin: string;
}
interface Group {
  id: string;
  label: string;
  icon: string;
  phrases: Phrase[];
}

const groups: Group[] = [
  {
    id: 'basics', label: 'あいさつ・基本', icon: '👋',
    phrases: [
      { en: 'こんにちは', zh: '你好', pinyin: 'nǐ hǎo' },
      { en: 'ありがとうございます', zh: '谢谢', pinyin: 'xièxie' },
      { en: 'どういたしまして', zh: '不客气', pinyin: 'bú kèqi' },
      { en: 'すみません / 失礼します', zh: '对不起', pinyin: 'duìbuqǐ' },
      { en: 'はい / そのとおりです', zh: '对', pinyin: 'duì' },
      { en: 'いいえ / 違います', zh: '不是', pinyin: 'bú shì' },
      { en: 'わかりません', zh: '我不明白', pinyin: 'wǒ bù míngbái' },
      { en: '英語を話せますか？', zh: '你会说英语吗？', pinyin: 'nǐ huì shuō yīngyǔ ma?' },
    ],
  },
  {
    id: 'payment', label: 'お金・決済', icon: '💳',
    phrases: [
      { en: 'いくらですか？', zh: '多少钱？', pinyin: 'duōshao qián?' },
      { en: 'Alipayは使えますか？', zh: '可以用支付宝吗？', pinyin: 'kěyǐ yòng zhīfùbǎo ma?' },
      { en: 'WeChat Payは使えますか？', zh: '可以用微信支付吗？', pinyin: 'kěyǐ yòng wēixìn zhīfù ma?' },
      { en: '高すぎます', zh: '太贵了', pinyin: 'tài guì le' },
      { en: 'カードで支払えますか？', zh: '可以刷卡吗？', pinyin: 'kěyǐ shuākǎ ma?' },
      { en: 'あなたのコードをスキャンします', zh: '我扫你的码', pinyin: 'wǒ sǎo nǐ de mǎ' },
    ],
  },
  {
    id: 'transport', label: '移動', icon: '🚕',
    phrases: [
      { en: '地下鉄はどこですか？', zh: '地铁站在哪里？', pinyin: 'dìtiě zhàn zài nǎlǐ?' },
      { en: 'この住所までお願いします', zh: '请带我去这个地址', pinyin: 'qǐng dài wǒ qù zhège dìzhǐ' },
      { en: 'ここで止めてください', zh: '请在这里停', pinyin: 'qǐng zài zhèlǐ tíng' },
      { en: '駅', zh: '火车站', pinyin: 'huǒchē zhàn' },
      { en: '空港', zh: '机场', pinyin: 'jīchǎng' },
      { en: '...へはどう行けばいいですか？', zh: '怎么去...？', pinyin: 'zěnme qù...?' },
    ],
  },
  {
    id: 'food', label: '食事', icon: '🍜',
    phrases: [
      { en: 'メニューをください', zh: '请给我菜单', pinyin: 'qǐng gěi wǒ càidān' },
      { en: '私はベジタリアンです', zh: '我吃素', pinyin: 'wǒ chī sù' },
      { en: '辛くしないでください', zh: '请不要辣', pinyin: 'qǐng búyào là' },
      { en: '水をください', zh: '请给我水', pinyin: 'qǐng gěi wǒ shuǐ' },
      { en: 'お会計をお願いします', zh: '买单', pinyin: 'mǎidān' },
      { en: 'おいしいです', zh: '很好吃', pinyin: 'hěn hǎochī' },
    ],
  },
  {
    id: 'help', label: '助け・緊急時', icon: '🆘',
    phrases: [
      { en: '助けて！', zh: '救命！', pinyin: 'jiùmìng!' },
      { en: 'トイレはどこですか？', zh: '洗手间在哪里？', pinyin: 'xǐshǒujiān zài nǎlǐ?' },
      { en: '医者が必要です', zh: '我需要看医生', pinyin: 'wǒ xūyào kàn yīshēng' },
      { en: '警察を呼んでください', zh: '请报警', pinyin: 'qǐng bàojǐng' },
      { en: '道に迷いました', zh: '我迷路了', pinyin: 'wǒ mílù le' },
      { en: '書いてください', zh: '请写下来', pinyin: 'qǐng xiě xiàlái' },
    ],
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">ツール</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">必須中国語フレーズ</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <!-- コントロール -->
    <div class="mt-6 flex flex-wrap items-center gap-3 print:hidden">
      <button data-filter="all" class="phrase-filter btn-primary text-sm">すべて</button>
      {groups.map((g) => (
        <button data-filter={g.id} class="phrase-filter rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:border-brand-400">
          {g.icon} {g.label}
        </button>
      ))}
      <button id="print-btn" class="ml-auto rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:border-brand-400">
        🖨️ 印刷 / PDF保存
      </button>
    </div>

    <!-- フレーズグループ -->
    <div class="mt-6 space-y-8">
      {groups.map((g) => (
        <section class="phrase-group" data-group={g.id}>
          <h2 class="mb-3 text-xl font-bold text-gray-900">{g.icon} {g.label}</h2>
          <div class="grid gap-3 sm:grid-cols-2">
            {g.phrases.map((p) => (
              <div class="card flex flex-col">
                <span class="text-sm text-gray-500">{p.en}</span>
                <span class="mt-1 text-2xl font-bold text-gray-900">{p.zh}</span>
                <span class="mt-0.5 text-sm italic text-brand-600">{p.pinyin}</span>
              </div>
            ))}
          </div>
        </section>
      ))}
    </div>

    <AffiliateCta
      title="移動中もオンラインで翻訳"
      description="China旅行用eSIMがあれば、到着した瞬間から翻訳アプリと地図を使えます。"
      buttonText="接続を準備する"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>('.phrase-filter');
  const sections = document.querySelectorAll<HTMLElement>('.phrase-group');
  const printBtn = document.getElementById('print-btn');

  const activeCls = ['btn-primary'];
  const idleCls = ['rounded-lg', 'border', 'border-gray-300', 'px-3', 'py-1.5', 'text-sm', 'font-medium', 'text-gray-700', 'hover:border-brand-400'];

  buttons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const filter = btn.dataset.filter;
      sections.forEach((s) => {
        s.classList.toggle('hidden', filter !== 'all' && s.dataset.group !== filter);
      });
      buttons.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('btn-primary', on);
        idleCls.forEach((c) => b.classList.toggle(c, !on));
      });
    });
  });

  printBtn?.addEventListener('click', () => window.print());
</script>
