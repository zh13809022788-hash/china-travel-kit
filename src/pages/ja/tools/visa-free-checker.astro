---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = '中国ビザ免除・トランジット判定ツール';
const description =
  'パスポートの国籍と旅行タイプに応じて、中国へビザなしで入国できる可能性があるか、240時間のビザなしトランジットを利用できるか、またはビザ申請が必要かを確認できます。';

const lastReviewed = '2026年7月13日';

// 2026年時点の代表的な制度データです。一般的な目安であり、法的助言ではありません。
// 予約前に必ず大使館や領事館などの公式情報で確認してください。
const countries = [
  '米国', '英国', 'カナダ', 'オーストラリア', 'ドイツ',
  'フランス', 'イタリア', 'スペイン', 'オランダ', '日本', '韓国',
  'シンガポール', 'マレーシア', 'タイ', 'ブラジル', 'ニュージーランド',
  'スイス', 'アイルランド', 'ノルウェー', 'その他',
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">ツール</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">中国ビザ免除・トランジット判定ツール</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <p class="mt-3 text-sm text-gray-500">
        最終確認日: {lastReviewed}。このツールは旅行計画の参考情報であり、公式な入国可否を保証するものではありません。
      </p>
    </header>

    <AdSlot format="banner" />

    <!-- 入力項目 -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">パスポートの国籍</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">旅行タイプ</span>
        <select id="trip" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="tourism">観光・親族訪問</option>
          <option value="business">出張・商用</option>
          <option value="transit">第三国・地域への乗り継ぎのみ</option>
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="check-btn" class="btn-primary w-full sm:w-auto">対象かどうかを確認する</button>
      </div>
    </div>

    <!-- 判定結果 -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>
      <p class="mt-3 text-xs text-gray-400">
        制度は頻繁に変更され、個別の事情によって判断が異なる場合があります。旅行を予約する前に、必ず中国の大使館または領事館で最新情報をご確認ください。このツールは一般的な目安のみを示しています。
      </p>

      <AffiliateCta
        title="出発前の準備もまとめて進めましょう"
        description="中国到着前に、通信手段、支払い方法、移動手段をあらかじめ整えておくと安心です。"
        buttonText="旅行に必要なものを見る"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6" aria-labelledby="official-sources">
      <h2 id="official-sources" class="text-xl font-bold text-gray-950">予約前に確認したい公式情報</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        ビザ免除対象国、入国可能な港、移動できる範囲、航空会社による搭乗可否の確認基準は変更されることがあります。最終判断は、必ず政府機関と航空会社の公式案内に従ってください。
      </p>
      <ul class="mt-4 grid gap-2 text-sm leading-6 text-gray-700">
        <li><a href="https://en.nia.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">国家移民管理局</a>で、出入境審査やトランジット免除制度の最新情報を確認できます。</li>
        <li><a href="https://english.www.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">国務院情報ポータル</a>で、英語の政策発表を確認できます。</li>
        <li><a href="https://www.mfa.gov.cn/eng/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">外交部</a>および中国の大使館・領事館のサイトで、パスポート国籍ごとの要件を確認してください。</li>
      </ul>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">ビザ免除利用で失敗しないためのポイント</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          よくある間違いは、通常のビザ免除入国とビザなしトランジットを混同してしまうことです。単純な往復旅行と、第三国・地域へ向かう途中の乗り継ぎは同じ扱いではありません。航空会社は搭乗前に必要書類を確認するため、条件を誤解していると中国に到着する前の段階で搭乗を断られることがあります。
        </p>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-gray-600">
          <li><strong class="text-gray-900">最初に確認すべきなのはパスポートの国籍です。</strong>居住国やクレジットカードの請求先国では判断されません。</li>
          <li><strong class="text-gray-900">入国とトランジットは分けて考えてください。</strong>トランジットでは通常、第三国または地域への確定済みの移動予定が必要です。</li>
          <li><strong class="text-gray-900">利用する入国港も重要です。</strong>トランジット制度は、指定された港と認められた移動範囲に基づいて運用されます。</li>
          <li><strong class="text-gray-900">証明書類を事前にそろえておきましょう。</strong>航空会社や入国審査官から、次の目的地への航空券、ホテル予約、旅程表、招待状などの提示を求められる場合があります。</li>
        </ul>
      </div>
      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">到着後の準備も忘れずに</h2>
        <div class="mt-4 grid gap-3">
          <a href="/ja/posts/china-visa-free-entry-transit-guide-2026/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">ビザ免除の完全ガイドを読む</a>
          <a href="/ja/posts/first-24-hours-in-china-arrival-checklist/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">到着後チェックリストを確認する</a>
          <a href="/ja/posts/airport-to-city-transport-beijing-shanghai-guangzhou/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">空港から市内への移動を調べる</a>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  type TripKey = 'tourism' | 'business' | 'transit';

  // 30日間の一方的ビザ免除入国（2026年制度）の対象国籍です。
  const visaFree30 = new Set([
    'ドイツ', 'フランス', 'イタリア', 'スペイン', 'オランダ', 'スイス',
    'アイルランド', 'ノルウェー', '日本', '韓国', 'ブラジル', 'ニュージーランド',
    'マレーシア', 'タイ', 'オーストラリア',
  ]);

  // 第三国・地域へ向かう際に、指定港経由で240時間（10日間）のビザなしトランジットを利用できる主な国籍です。
  const transit240 = new Set([
    '米国', '英国', 'カナダ', 'オーストラリア', 'ドイツ',
    'フランス', 'イタリア', 'スペイン', 'オランダ', '日本', '韓国',
    'シンガポール', 'スイス', 'アイルランド', 'ノルウェー', 'ブラジル', 'ニュージーランド',
  ]);

  interface Verdict {
    tone: 'good' | 'warn' | 'info';
    heading: string;
    body: string;
    points: string[];
  }

  function evaluate(country: string, trip: TripKey): Verdict {
    const has30 = visaFree30.has(country);
    const hasTransit = transit240.has(country);

    if (trip === 'transit') {
      if (hasTransit) {
        return {
          tone: 'good',
          heading: '240時間のビザなしトランジットを利用できる可能性があります',
          body: `${country}のパスポートをお持ちで、中国を経由して第三国・地域へ向かう場合は、対象となる入国港を利用すれば、通常は最大240時間（10日間）までビザなしで滞在できる可能性があります。`,
          points: [
            '240時間以内に第三国または地域へ出発する、確定済みの航空券などが必要です。',
            '入国と出国は、制度の対象となっている指定港を利用する必要があります。',
            '通常は、滞在中に移動できる地域が制限されます。利用する港ごとの条件を必ず確認してください。',
          ],
        };
      }
      return {
        tone: 'warn',
        heading: 'この国籍ではトランジット免除の対象外となる可能性があります',
        body: `${country}は、当サイトのデータでは一般的な240時間トランジット対象国の一覧に含まれていません。条件によっては別のビザ免除制度が使える場合もありますが、トランジット（G）ビザの取得が必要になる可能性があります。`,
        points: [
          '通常のビザ免除入国の対象国かどうかもあわせて確認してください。',
          '対象外の場合は、出発前に適切なビザを申請してください。',
        ],
      };
    }

    // 観光または商用渡航の場合
    if (has30) {
      return {
        tone: 'good',
        heading: '30日以内のビザなし入国が可能な場合があります',
        body: `${country}のパスポートをお持ちの方は、現在の一方的ビザ免除制度により、観光、商用、親族訪問、トランジットなどの目的で、通常は最長30日まで中国へビザなしで入国できる可能性があります。`,
        points: [
          'パスポートの残存有効期間は通常6か月以上必要で、空白ページも必要です。',
          '入国審査に備えて、復路または次の目的地への移動手段、宿泊先の証明を準備しておきましょう。',
          '30日という日数は1回の入国ごとに適用されます。予約前に最新の運用を確認してください。',
        ],
      };
    }
    if (hasTransit) {
      return {
        tone: 'info',
        heading: '通常はビザが必要ですが、トランジット免除を利用できる場合があります',
        body: `${country}は、当サイトの30日間ビザ免除リストでは観光・商用目的の対象外です。そのため通常はビザが必要ですが、第三国・地域へ向かう途中で中国を経由する場合は、240時間のビザなしトランジットを利用できる可能性があります。`,
        points: [
          '中国への訪問自体が主目的であれば、事前にL（観光）またはM（商用）ビザを申請してください。',
          '第三国・地域への途中立ち寄りであれば、240時間トランジットの対象となる可能性があります。「旅行タイプ」をトランジットに切り替えて確認してください。',
        ],
      };
    }
    return {
      tone: 'warn',
      heading: 'ビザの取得が必要となる可能性が高いです',
      body: `当サイトのデータでは、${country}のパスポートをお持ちの方がこの旅行タイプで中国に入国する場合、通常はビザが必要です。旅行前に、中国の大使館、領事館、または認可されたビザ申請センターを通じて申請してください。`,
      points: [
        '旅行まで十分な余裕をもって、L（観光）またはM（商用）ビザを申請してください。',
        '通常は、招待状または旅程表、ホテル予約、復路または次の目的地への航空券などが必要です。',
      ],
    };
  }

  const toneStyles: Record<Verdict['tone'], string> = {
    good: 'border-green-200 bg-green-50',
    warn: 'border-amber-200 bg-amber-50',
    info: 'border-blue-200 bg-blue-50',
  };
  const toneBadge: Record<Verdict['tone'], string> = {
    good: 'bg-green-600 text-white',
    warn: 'bg-amber-500 text-white',
    info: 'bg-blue-600 text-white',
  };
  const toneLabel: Record<Verdict['tone'], string> = {
    good: '利用できる可能性があります',
    warn: 'ビザが必要な可能性があります',
    info: '旅程によって異なります',
  };

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;
  const tripEl = document.getElementById('trip') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const v = evaluate(countryEl.value, tripEl.value as TripKey);
    card.className = `card border ${toneStyles[v.tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[v.tone]}">${toneLabel[v.tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${v.heading}</h2>
      <p class="mt-2 text-gray-700">${v.body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${v.points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
