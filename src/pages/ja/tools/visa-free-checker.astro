---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'Chinaビザ免除・トランジットチェッカー';
const description =
  '国籍と旅行タイプに基づいて、Chinaにビザなしで入国できるか、240時間ビザなしトランジットを使えるか、またはビザ申請が必要かを確認できます。';

const lastReviewed = '2026年7月13日';

// 2026年の代表的な制度データ。これは一般的な目安であり、法的助言ではありません。
// 旅行者は予約前に大使館で確認する必要があります。
const countries = [
  '米国', '英国', 'カナダ', 'オーストラリア', 'ドイツ',
  'フランス', 'イタリア', 'スペイン', 'オランダ', '日本', '韓国',
  'シンガポール', 'マレーシア', 'タイ', 'ブラジル', 'ニュージーランド',
  'スイス', 'アイルランド', 'ノルウェー', 'その他',
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">ツール</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">ビザ免除・トランジットチェッカー</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <p class="mt-3 text-sm text-gray-500">
        最終確認日: {lastReviewed}。このチェッカーは計画の補助であり、公式な適格性判断ではありません。
      </p>
    </header>

    <AdSlot format="banner" />

    <!-- 入力コントロール -->
    <div class="mt-6 grid gap-4 rounded-xl border border-gray-200 bg-gray-50 p-6 sm:grid-cols-2">
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">パスポートの国籍</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <label class="flex flex-col text-sm">
        <span class="mb-1 font-medium text-gray-700">旅行タイプ</span>
        <select id="trip" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          <option value="tourism">観光・訪問</option>
          <option value="business">ビジネス</option>
          <option value="transit">第三国への乗り継ぎのみ</option>
        </select>
      </label>
      <div class="sm:col-span-2">
        <button id="check-btn" class="btn-primary w-full sm:w-auto">対象か確認する</button>
      </div>
    </div>

    <!-- 結果 -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>
      <p class="mt-3 text-xs text-gray-400">
        制度は頻繁に変更され、個別の状況によって異なります。旅行を予約する前に、必ずChinaの大使館または領事館で確認してください。このツールは一般的な目安のみを提供します。
      </p>

      <AffiliateCta
        title="残りの旅行準備を整える"
        description="China到着前に通信、決済、交通手段を整理しておきましょう。"
        buttonText="旅行必需品を見る"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>

    <section class="mt-10 rounded-lg border border-gray-200 bg-white p-6" aria-labelledby="official-sources">
      <h2 id="official-sources" class="text-xl font-bold text-gray-950">予約前に確認すべき公式情報源</h2>
      <p class="mt-2 text-sm leading-6 text-gray-600">
        ビザ免除対象国、入国港、許可される移動エリア、航空会社の搭乗確認は変更されることがあります。政府と航空会社の公式ルールを最終判断として扱ってください。
      </p>
      <ul class="mt-4 grid gap-2 text-sm leading-6 text-gray-700">
        <li><a href="https://en.nia.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">国家移民管理局</a>で国境検査とトランジット免除の更新を確認。</li>
        <li><a href="https://english.www.gov.cn/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">国務院情報ポータル</a>で英語の政策発表を確認。</li>
        <li><a href="https://www.mfa.gov.cn/eng/" rel="nofollow noopener" target="_blank" class="font-semibold text-brand-700">外交部</a>およびChinaの大使館・領事館サイトでパスポート別ルールを確認。</li>
      </ul>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">ビザ免除での失敗を避ける方法</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          最もよくある間違いは、通常のビザなし入国とビザなしトランジットを混同することです。通常の往復旅行と第三国への途中降機は同じ旅程ではありません。航空会社は搭乗前に書類を確認するため、誤解があるとChinaに到着する前に旅行が止まることがあります。
        </p>
        <ul class="mt-4 space-y-3 text-sm leading-6 text-gray-600">
          <li><strong class="text-gray-900">まずパスポート国籍を確認します。</strong>居住国やカード請求先の国では、ビザ免除の可否は決まりません。</li>
          <li><strong class="text-gray-900">入国とトランジットを分けて考えます。</strong>トランジットでは通常、第三国または地域への確定した次の目的地への移動が必要です。</li>
          <li><strong class="text-gray-900">入国港を確認します。</strong>トランジット制度は指定港と許可された移動エリアに左右されます。</li>
          <li><strong class="text-gray-900">証明書類を準備します。</strong>航空会社や国境審査官が、次の目的地への航空券、ホテル、旅程、招待状の詳細を求める場合があります。</li>
        </ul>
      </div>
      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">到着後の準備も計画する</h2>
        <div class="mt-4 grid gap-3">
          <a href="/ja/posts/china-visa-free-entry-transit-guide-2026/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">完全版ビザ免除ガイドを読む</a>
          <a href="/ja/posts/first-24-hours-in-china-arrival-checklist/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">到着チェックリストを使う</a>
          <a href="/ja/posts/airport-to-city-transport-beijing-shanghai-guangzhou/" class="rounded-lg border border-brand-100 bg-white p-3 text-sm font-semibold text-gray-900 hover:border-brand-200 hover:text-brand-700 hover:no-underline">空港から市内への移動を計画する</a>
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  type TripKey = 'tourism' | 'business' | 'transit';

  // 30日間の一方的ビザ免除入国（2026年制度）の対象国籍。
  const visaFree30 = new Set([
    'ドイツ', 'フランス', 'イタリア', 'スペイン', 'オランダ', 'スイス',
    'アイルランド', 'ノルウェー', '日本', '韓国', 'ブラジル', 'ニュージーランド',
    'マレーシア', 'タイ', 'オーストラリア',
  ]);

  // 第三国・地域へ向かう際、指定港経由で240時間（10日間）ビザなしトランジットの対象となる国籍。
  const transit240 = new Set([
    '米国', '英国', 'カナダ', 'オーストラリア', 'ドイツ',
    'フランス', 'イタリア', 'スペイン', 'オランダ', '日本', '韓国',
    'シンガポール', 'スイス', 'アイルランド', 'ノルウェー', 'ブラジル', 'ニュージーランド',
  ]);

  interface Verdict {
    tone: 'good' | 'warn' | 'info';
    heading: string;
    body: string;
    points: string[];
  }

  function evaluate(country: string, trip: TripKey): Verdict {
    const has30 = visaFree30.has(country);
    const hasTransit = transit240.has(country);

    if (trip === 'transit') {
      if (hasTransit) {
        return {
          tone: 'good',
          heading: '240時間ビザなしトランジットの対象となる可能性があります',
          body: `${country}のパスポート保持者としてChinaを経由して第三国へ向かう場合、対象港から入国すれば通常、ビザなしで最大240時間（10日間）滞在できます。`,
          points: [
            '240時間以内に第三国または地域へ向かう確定済みの次の目的地への航空券が必要です。',
            '入国・出国は指定されたトランジット港を利用する必要があります（主要な国際空港の多くが対象です）。',
            '通常、入国した省・地域内に移動が制限されます。具体的な港のルールを確認してください。',
          ],
        };
      }
      return {
        tone: 'warn',
        heading: 'この国籍ではトランジットビザ免除が適用されない可能性があります',
        body: `${country}は当サイトのデータでは標準的な240時間トランジット対象リストに含まれていません。条件を満たせばビザなし入国の対象となる場合もありますが、トランジット（G）ビザが必要な可能性もあります。`,
        points: [
          '代わりに通常のビザなし入国の対象国籍か確認してください。',
          '対象外の場合は、旅行前に適切なビザを申請してください。',
        ],
      };
    }

    // 観光またはビジネスの場合
    if (has30) {
      return {
        tone: 'good',
        heading: '30日間のビザなし入国の対象となる可能性があります',
        body: `${country}のパスポート保持者は、現在の一方的ビザ免除制度により、観光、ビジネス、親族訪問、トランジット目的で通常最大30日間Chinaにビザなし入国できます。`,
        points: [
          'パスポートは少なくとも6か月以上有効で、空白ページが必要です。',
          '入国審査に備えて、次の目的地または帰国の移動と宿泊先の証明を準備してください。',
          '30日は1回の入国ごとの日数です。予約前に最新の数え方を確認してください。',
        ],
      };
    }
    if (hasTransit) {
      return {
        tone: 'info',
        heading: 'ビザが必要な可能性が高いですが、トランジット免除が使える場合があります',
        body: `${country}は当サイトの30日間ビザ免除リストでは観光・ビジネス対象外のため、通常はビザが必要です。ただし、第三国へ向かう途中で通過する場合は、240時間ビザなしトランジットを利用できる可能性があります。`,
        points: [
          '訪問を主目的とする場合は、事前にL（観光）またはM（ビジネス）ビザを申請してください。',
          '別の目的地へ向かう途中の立ち寄りなら、240時間トランジット対象の可能性があります。「旅行タイプ」をトランジットに切り替えて確認してください。',
        ],
      };
    }
    return {
      tone: 'warn',
      heading: 'ビザが必要な可能性が高いです',
      body: `当サイトのデータでは、${country}のパスポート保持者がこの旅行タイプでChinaに入国するには通常ビザが必要です。旅行前にChinaの大使館、領事館、または認可されたビザセンターを通じて申請してください。`,
      points: [
        '旅行の十分前にL（観光）またはM（ビジネス）ビザを申請してください。',
        '通常、招待状または旅程、ホテル予約、帰国便チケットなどが必要です。',
      ],
    };
  }

  const toneStyles: Record<Verdict['tone'], string> = {
    good: 'border-green-200 bg-green-50',
    warn: 'border-amber-200 bg-amber-50',
    info: 'border-blue-200 bg-blue-50',
  };
  const toneBadge: Record<Verdict['tone'], string> = {
    good: 'bg-green-600 text-white',
    warn: 'bg-amber-500 text-white',
    info: 'bg-blue-600 text-white',
  };
  const toneLabel: Record<Verdict['tone'], string> = {
    good: '対象の可能性あり',
    warn: 'ビザが必要な可能性',
    info: '旅程によります',
  };

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;
  const tripEl = document.getElementById('trip') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const v = evaluate(countryEl.value, tripEl.value as TripKey);
    card.className = `card border ${toneStyles[v.tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[v.tone]}">${toneLabel[v.tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${v.heading}</h2>
      <p class="mt-2 text-gray-700">${v.body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${v.points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
