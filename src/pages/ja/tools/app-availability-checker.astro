---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = '中国で使えるアプリは？アプリ利用可否チェッカー';
const description =
  'Google、WhatsApp、Instagram などのアプリが中国でVPNなしで使えるかどうかを確認でき、使えないサービスについては現地で使われている代替アプリもあわせてチェックできます。';

interface AppInfo {
  name: string;
  category: string;
  status: 'works' | 'blocked' | 'partial';
  note: string;
  alt?: string;
}

const apps: AppInfo[] = [
  { name: 'Google Search', category: 'Google', status: 'blocked', note: 'VPNなしでは使えません。', alt: 'Bing（利用可能）または Baidu' },
  { name: 'Google Maps', category: 'Google', status: 'partial', note: '表示はできますが、中国本土では位置情報や地図データにずれが出ることがあります。', alt: 'Apple Maps、Amap、または Baidu Maps' },
  { name: 'Gmail', category: 'Google', status: 'blocked', note: 'VPNなしでは使えません。', alt: 'Outlook または Google以外のメールサービス' },
  { name: 'YouTube', category: 'Google', status: 'blocked', note: 'VPNなしでは使えません。', alt: 'Bilibili（現地サービス）' },
  { name: 'WhatsApp', category: 'メッセージ', status: 'blocked', note: 'VPNなしでは使えません。', alt: 'WeChat' },
  { name: 'Facebook', category: 'SNS', status: 'blocked', note: 'VPNなしでは使えません。', alt: 'WeChat Moments または RED' },
  { name: 'Instagram', category: 'SNS', status: 'blocked', note: 'VPNなしでは使えません。', alt: 'RED（Xiaohongshu）' },
  { name: 'X (Twitter)', category: 'SNS', status: 'blocked', note: 'VPNなしでは使えません。', alt: 'Weibo' },
  { name: 'Telegram', category: 'メッセージ', status: 'blocked', note: 'VPNなしでは使えません。', alt: 'WeChat' },
  { name: 'WeChat', category: 'メッセージ', status: 'works', note: '問題なく使えます。中国では定番のアプリです。' },
  { name: 'Appleのサービス（iMessage、App Store）', category: 'Apple', status: 'works', note: '通常どおり使えます。' },
  { name: 'Microsoft / Bing / Outlook', category: 'Microsoft', status: 'works', note: '通常どおり使えます。' },
  { name: 'Booking.com', category: '旅行', status: 'works', note: '通常どおり使えます。' },
  { name: 'Airbnb', category: '旅行', status: 'works', note: '通常どおり使えます。' },
  { name: 'Trip.com', category: '旅行', status: 'works', note: '問題なく使えます。列車やホテルの予約に便利です。' },
  { name: 'Alipay', category: '決済', status: 'works', note: '問題なく使えます。海外発行のカードにも対応しています。' },
  { name: 'Uber', category: '交通', status: 'blocked', note: '中国本土では使えません。', alt: 'DiDi' },
  { name: 'Netflix', category: 'メディア', status: 'blocked', note: '中国本土では使えません。', alt: '現地の動画配信サービス、または事前ダウンロード' },
  { name: 'Spotify', category: 'メディア', status: 'blocked', note: '中国本土では使えません。', alt: 'QQ Music または事前のオフライン保存' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">ツール</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">中国で使えるアプリは？</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-4">
      <label class="flex flex-col text-sm sm:max-w-sm">
        <span class="mb-1 font-medium text-gray-700">アプリ名で検索・絞り込み</span>
        <input id="search" type="text" placeholder="例：WhatsApp、Google、Netflix"
          class="rounded-lg border border-gray-300 px-3 py-2 text-sm" />
      </label>
      <div class="mt-3 flex flex-wrap gap-2 text-sm">
        <button data-status="all" class="status-filter btn-primary px-3 py-1">すべて表示</button>
        <button data-status="works" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">✅ 使えます</button>
        <button data-status="partial" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">⚠️ 一部のみ使えます</button>
        <button data-status="blocked" class="status-filter rounded-lg border border-gray-300 px-3 py-1 font-medium text-gray-700">🚫 使えません</button>
      </div>
    </div>

    <div id="app-list" class="mt-6 grid gap-3 sm:grid-cols-2"></div>
    <p id="no-results" class="hidden py-8 text-center text-gray-500">条件に合うアプリは見つかりませんでした。</p>

    <AffiliateCta
      title="旅行用eSIMで、いつものアプリを使いやすく"
      description="中国向けの旅行eSIMなら、現地の通信制限を回避しやすくなり、普段使っているアプリをオンラインのまま利用しやすくなります。別途VPNを設定する手間もかかりません。"
      buttonText="eSIMの選択肢を見る"
      placeholder={AFFILIATE_LINKS.esim}
    />
  </main>
  <Footer />
</BaseLayout>

<script define:vars={{ apps }}>
  const listEl = document.getElementById('app-list');
  const noResults = document.getElementById('no-results');
  const searchEl = document.getElementById('search');
  const filters = document.querySelectorAll('.status-filter');
  let activeStatus = 'all';

  const badge = {
    works: { cls: 'bg-green-100 text-green-800', label: '✅ 使えます' },
    partial: { cls: 'bg-amber-100 text-amber-800', label: '⚠️ 一部のみ使えます' },
    blocked: { cls: 'bg-red-100 text-red-800', label: '🚫 使えません' },
  };

  function render() {
    const q = searchEl.value.trim().toLowerCase();
    const list = apps.filter((a) => {
      const matchStatus = activeStatus === 'all' || a.status === activeStatus;
      const matchQuery = !q || a.name.toLowerCase().includes(q) || a.category.toLowerCase().includes(q);
      return matchStatus && matchQuery;
    });

    listEl.innerHTML = list
      .map((a) => `
        <div class="card">
          <div class="flex items-start justify-between gap-3">
            <div>
              <h3 class="font-bold text-gray-900">${a.name}</h3>
              <span class="text-xs text-gray-400">${a.category}</span>
            </div>
            <span class="whitespace-nowrap rounded-full px-2.5 py-0.5 text-xs font-semibold ${badge[a.status].cls}">${badge[a.status].label}</span>
          </div>
          <p class="mt-2 text-sm text-gray-600">${a.note}</p>
          ${a.alt ? `<p class="mt-1.5 text-sm"><span class="text-gray-500">代わりに使えるアプリ・サービス：</span> <span class="font-medium text-brand-600">${a.alt}</span></p>` : ''}
        </div>`)
      .join('');

    noResults.classList.toggle('hidden', list.length > 0);
  }

  searchEl.addEventListener('input', render);
  filters.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeStatus = btn.dataset.status;
      filters.forEach((b) => {
        const on = b === btn;
        b.classList.toggle('btn-primary', on);
        ['rounded-lg', 'border', 'border-gray-300', 'font-medium', 'text-gray-700'].forEach((c) => b.classList.toggle(c, !on));
      });
      render();
    });
  });

  render();
</script>
