---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Header from "../../../components/Header.astro";
import Footer from "../../../components/Footer.astro";
import ShowToLocal from "../../../components/ShowToLocal.astro";
import SurvivalChecklist from "../../../components/SurvivalChecklist.astro";
import survivalKits from "../../../data/survival-kits.json";

const title = 'China Survival Kit: 翻訳カードと旅行チェックリスト';
const description =
  '外国人旅行者向けのインタラクティブな China survival kits: 全画面の翻訳カード、到着後の設定チェックリスト、食物アレルギーカード、現地でのコミュニケーションツール。';
---
<!-- AI支援で生成されたコンテンツ、ネイティブスピーカーが確認済み -->


<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">Survival kit</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-950 md:text-4xl">China Survival Kit</h1>
<p class="mt-4 max-w-3xl text-lg leading-8 text-gray-600">
  China Survival Kit は、安心して旅行の準備ができるようサポートします。出発前準備のあらゆるステップを網羅したインタラクティブなチェックリストが含まれており、ビザ申請、旅行保険、支払い設定（Alipay/WeChat Pay）、eSIM または SIM カードの購入、宿泊先の予約、持ち物の必需品確認に対応しています。フレーズカードのセクションでは、料理の注文、道を尋ねる、タクシー料金の交渉といったよくある場面で、中国語のテキストを現地の人に見せることができます。自分用のフレーズを使ったカスタムカードを追加することもできます。すべてブラウザに保存されるため、アカウントを作成しなくても、旅行中いつでも再び利用できます。
</p>
      <p class="mt-3 text-lg leading-8 text-gray-600">
        長いガイドを読んでいる時間がない場面では、全画面の翻訳カードと保存されたチェックリストを活用してください。
        空港到着、ホテルのチェックイン、タクシー、レストラン、アレルギー対応、初日の設定に役立ちます。
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="#arrival" class="btn-primary">到着準備から始める</a>
        <a href="#food" class="btn-outline">食事カードを開く</a>
      </div>
    </header>

    <section class="mt-8 grid gap-4 md:grid-cols-3">
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">全画面カード</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">カードをタップすると、大きな中国語テキストをドライバー、ホテルの受付、またはレストランのスタッフに見せることができます。</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">保存されたチェックリスト</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">チェックリストの進捗はブラウザに保存されるため、閉じても後から再開できます。</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">Context AI entry</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">フローティングヘルパーを使って、トピックに応じたプロンプトで ChinaTripBox の旅行サポートを開けます。</p>
      </div>
    </section>

    <div class="mt-10 grid gap-8">
      {survivalKits.map((kit) => (
        <section id={kit.slug} class="grid gap-5 rounded-xl border border-gray-200 bg-gray-50 p-5">
          <div class="max-w-3xl">
            <p class="section-kicker">{kit.slug} kit</p>
            <h2 class="mt-1 text-2xl font-bold text-gray-950">{kit.title}</h2>
            <p class="mt-2 text-sm leading-6 text-gray-600">{kit.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {kit.related_paths.map((path) => (
                <a href={path} class="rounded-full border border-gray-200 bg-white px-3 py-1.5 text-xs font-semibold text-brand-700 hover:border-brand-300 hover:no-underline">
                  関連ガイド
                </a>
              ))}
            </div>
          </div>
          <div class="grid gap-5 lg:grid-cols-[1fr_0.85fr]">
            <ShowToLocal themeId={kit.theme_id} tools={kit.tools} />
            <SurvivalChecklist themeId={kit.theme_id} steps={kit.checklist_steps} />
          </div>
        </section>
      ))}
    </div>
  </main>
  <Footer />
</BaseLayout>