---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ShowToLocal from '../../../components/ShowToLocal.astro';
import SurvivalChecklist from '../../../components/SurvivalChecklist.astro';
import ContextAiBubble from '../../../components/ContextAiBubble.astro';
import survivalKits from '../../../data/survival-kits.json';

const title = 'Chinaサバイバルキット：翻訳カードと旅行チェックリスト';
const description =
  '外国人旅行者向けのインタラクティブなChinaサバイバルキット：全画面翻訳カード、到着時の設定チェックリスト、食物アレルギーカード、現地で使えるコミュニケーションツール。';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">サバイバルキット</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-950 md:text-4xl">Chinaサバイバルキット</h1>
      <p class="mt-3 text-lg leading-8 text-gray-600">
        長いガイドを読む時間がない場面では、全画面翻訳カードと保存済みチェックリストを活用しましょう。
        空港到着、ホテルのチェックイン、タクシー、レストラン、アレルギー、初日の設定に役立ちます。
      </p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="#arrival" class="btn-primary">到着準備から始める</a>
        <a href="#food" class="btn-outline">食事カードを開く</a>
      </div>
    </header>

    <section class="mt-8 grid gap-4 md:grid-cols-3">
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">全画面カード</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">カードをタップして、大きな中国語テキストを運転手、ホテルのフロント、レストランスタッフに見せられます。</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">保存済みチェックリスト</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">チェックリストの進捗はブラウザに保存されるため、閉じても後で続きから再開できます。</p>
      </div>
      <div class="rounded-lg border border-gray-200 bg-white p-5">
        <h2 class="text-lg font-bold text-gray-950">コンテキストAI入口</h2>
        <p class="mt-2 text-sm leading-6 text-gray-600">フローティングヘルパーから、トピックに応じたプロンプト付きでChinaTripBoxの旅行サポートを開けます。</p>
      </div>
    </section>

    <div class="mt-10 grid gap-8">
      {survivalKits.map((kit) => (
        <section id={kit.slug} class="grid gap-5 rounded-xl border border-gray-200 bg-gray-50 p-5">
          <div class="max-w-3xl">
            <p class="section-kicker">{kit.slug}キット</p>
            <h2 class="mt-1 text-2xl font-bold text-gray-950">{kit.title}</h2>
            <p class="mt-2 text-sm leading-6 text-gray-600">{kit.description}</p>
            <div class="mt-3 flex flex-wrap gap-2">
              {kit.related_paths.map((path) => (
                <a href={path} class="rounded-full border border-gray-200 bg-white px-3 py-1.5 text-xs font-semibold text-brand-700 hover:border-brand-300 hover:no-underline">
                  関連ガイド
                </a>
              ))}
            </div>
          </div>
          <div class="grid gap-5 lg:grid-cols-[1fr_0.85fr]">
            <ShowToLocal themeId={kit.theme_id} tools={kit.tools} />
            <SurvivalChecklist themeId={kit.theme_id} steps={kit.checklist_steps} />
          </div>
        </section>
      ))}
    </div>
  </main>
  <ContextAiBubble defaultPrompt="到着、レストラン、翻訳カード、チェックリスト準備にChinaサバイバルキットを使えるよう手伝ってください。" />
  <Footer />
</BaseLayout>
