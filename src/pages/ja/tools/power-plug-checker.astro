---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import AffiliateCta from '../../../components/AffiliateCta.astro';
import { AFFILIATE_LINKS } from '../../../config';

const title = 'China 電源プラグ・電圧チェッカー';
const description =
  '出発国をもとに、China 旅行で変換プラグや変圧器が必要か確認できます。China では 220V、プラグタイプ A、C、I が使われています。';

const countries = [
  'アメリカ', 'イギリス', 'カナダ', 'オーストラリア', 'ドイツ',
  'フランス', 'イタリア', 'スペイン', 'オランダ', '日本', '韓国',
  'シンガポール', 'インド', 'ブラジル', 'ニュージーランド', 'スイス',
  '南アフリカ', 'アラブ首長国連邦', 'その他',
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">ツール</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">電源プラグ・電圧チェッカー</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <AdSlot format="banner" />

    <div class="mt-6 rounded-xl border border-gray-200 bg-gray-50 p-6">
      <label class="flex flex-col text-sm sm:max-w-sm">
        <span class="mb-1 font-medium text-gray-700">出発国</span>
        <select id="country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm">
          {countries.map((c) => <option value={c}>{c}</option>)}
        </select>
      </label>
      <button id="check-btn" class="btn-primary mt-4 w-full sm:w-auto">必要なものを確認</button>
    </div>

    <!-- 参考: China の標準 -->
    <div class="mt-6 grid gap-4 sm:grid-cols-3">
      <div class="card"><dt class="text-sm text-gray-500">電圧</dt><dd class="text-2xl font-bold text-gray-900">220 V</dd></div>
      <div class="card"><dt class="text-sm text-gray-500">周波数</dt><dd class="text-2xl font-bold text-gray-900">50 Hz</dd></div>
      <div class="card"><dt class="text-sm text-gray-500">プラグタイプ</dt><dd class="text-2xl font-bold text-gray-900">A・C・I</dd></div>
    </div>

    <!-- 結果 -->
    <div id="result" class="mt-6 hidden">
      <div class="card" id="result-card"></div>

      <AffiliateCta
        title="China 対応のユニバーサル変換プラグを用意"
        description="China のコンセントに対応し、複数のデバイスを同時に充電できるコンパクトな一体型トラベルアダプターです。"
        buttonText="おすすめの変換プラグを見る"
        placeholder={AFFILIATE_LINKS.transport}
      />
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  // 各国の家庭用電圧と使用されているプラグタイプ。
  const data: Record<string, { volts: number; plugs: string[] }> = {
    'アメリカ': { volts: 120, plugs: ['A', 'B'] },
    'カナダ': { volts: 120, plugs: ['A', 'B'] },
    '日本': { volts: 100, plugs: ['A', 'B'] },
    'ブラジル': { volts: 127, plugs: ['C', 'N'] },
    'イギリス': { volts: 230, plugs: ['G'] },
    'オーストラリア': { volts: 230, plugs: ['I'] },
    'ニュージーランド': { volts: 230, plugs: ['I'] },
    'ドイツ': { volts: 230, plugs: ['C', 'F'] },
    'フランス': { volts: 230, plugs: ['C', 'E'] },
    'イタリア': { volts: 230, plugs: ['C', 'F', 'L'] },
    'スペイン': { volts: 230, plugs: ['C', 'F'] },
    'オランダ': { volts: 230, plugs: ['C', 'F'] },
    'スイス': { volts: 230, plugs: ['C', 'J'] },
    '韓国': { volts: 220, plugs: ['C', 'F'] },
    'シンガポール': { volts: 230, plugs: ['G'] },
    'インド': { volts: 230, plugs: ['C', 'D', 'M'] },
    '南アフリカ': { volts: 230, plugs: ['C', 'D', 'M', 'N'] },
    'アラブ首長国連邦': { volts: 230, plugs: ['C', 'D', 'G'] },
    'その他': { volts: 0, plugs: [] },
  };

  // China ではプラグタイプ A、C、I を使用できます。
  const CHINA_PLUGS = ['A', 'C', 'I'];
  const CHINA_VOLTS = 220;

  const btn = document.getElementById('check-btn');
  const result = document.getElementById('result');
  const card = document.getElementById('result-card');
  const countryEl = document.getElementById('country') as HTMLSelectElement;

  btn?.addEventListener('click', () => {
    if (!card || !result) return;
    const country = countryEl.value;
    const info = data[country];

    let heading: string, body: string, tone: 'good' | 'warn' | 'info';
    const points: string[] = [];

    if (!info || info.volts === 0) {
      tone = 'info';
      heading = 'お使いのプラグと電圧を確認してください';
      body = '選択された国のデータがありません。充電器のラベルを確認し、「100-240V」と記載されていれば、China のタイプ A、C、I コンセント向けの変換プラグだけで対応できます。';
      points.push('China では 220V、50Hz、プラグタイプ A、C、I が使われています。');
      points.push('ほとんどのスマートフォンやノートパソコンの充電器はデュアルボルテージ（100-240V）対応で、変換プラグだけで使えます。');
    } else {
      const plugMatch = info.plugs.some((p) => CHINA_PLUGS.includes(p));
      const voltMatch = Math.abs(info.volts - CHINA_VOLTS) <= 20;

      if (plugMatch && voltMatch) {
        tone = 'good';
        heading = '変換プラグはおそらく不要です';
        body = `${country} は互換性のあるプラグタイプ（${info.plugs.join(', ')}）と近い電圧（${info.volts}V）を使用しています。お使いのプラグは China のコンセントにそのまま差し込める可能性があります。`;
        points.push('念のため各プラグを確認し、コンセントの差し込みが固い場合に備えて変換プラグを 1 つ持参すると安心です。');
      } else if (!plugMatch && voltMatch) {
        tone = 'warn';
        heading = '変換プラグが必要です（変圧器は不要）';
        body = `${country} は近い電圧（${info.volts}V）なので、デバイスは安全に使えます。ただしプラグタイプ（${info.plugs.join(', ')}）は China のコンセントに合わないため、変換プラグを持参してください。`;
        points.push('タイプ A/C/I 対応のシンプルで安価な変換プラグがあれば十分です。');
        points.push('かさばる変圧器は必要ありません。');
      } else if (plugMatch && !voltMatch) {
        tone = 'warn';
        heading = '単一電圧の機器は電圧に注意してください';
        body = `プラグ（${info.plugs.join(', ')}）は合う可能性がありますが、${country} の電圧（${info.volts}V）は China の 220V と異なります。`;
        points.push('100-240V と表示されたスマートフォン、ノートパソコン、カメラはどこでも問題なく使えます。');
        points.push('単一電圧の製品（一部のヘアドライヤーやヘアアイロンなど）は、変圧器が必要です。持参しない選択も検討してください。');
      } else {
        tone = 'warn';
        heading = '変換プラグが必要です。電圧も確認してください';
        body = `${country} は China の 220V と異なるプラグ（${info.plugs.join(', ')}）および電圧（${info.volts}V）を使用しています。タイプ A/C/I 対応の変換プラグを持参してください。`;
        points.push('デュアルボルテージ対応充電器（100-240V）は変換プラグだけで使えます。');
        points.push('単一電圧の高ワット機器は変圧器も必要です。現地で同等品を購入する方法もあります。');
      }
    }

    const toneStyles = {
      good: 'border-green-200 bg-green-50',
      warn: 'border-amber-200 bg-amber-50',
      info: 'border-blue-200 bg-blue-50',
    } as const;
    const toneBadge = {
      good: 'bg-green-600 text-white',
      warn: 'bg-amber-500 text-white',
      info: 'bg-blue-600 text-white',
    } as const;
    const toneLabel = { good: '変換プラグ不要', warn: '変換プラグが必要', info: '充電器を確認' } as const;

    card.className = `card border ${toneStyles[tone]}`;
    card.innerHTML = `
      <span class="inline-block rounded-full px-3 py-0.5 text-xs font-semibold ${toneBadge[tone]}">${toneLabel[tone]}</span>
      <h2 class="mt-3 text-xl font-bold text-gray-900">${heading}</h2>
      <p class="mt-2 text-gray-700">${body}</p>
      <ul class="mt-4 list-disc space-y-1.5 pl-5 text-sm text-gray-600">
        ${points.map((p) => `<li>${p}</li>`).join('')}
      </ul>`;
    result.classList.remove('hidden');
    result.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
</script>
