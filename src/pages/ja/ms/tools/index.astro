---
import BaseLayout from '../../../../layouts/BaseLayout.astro';
import Header from '../../../../components/Header.astro';
import Footer from '../../../../components/Footer.astro';
import AdSlot from '../../../../components/AdSlot.astro';
import { TOOLS as tools } from '../../../../config';

const title = '免費中國旅行工具：簽證、付款、eSIM、預算、司機卡與常用語';
const description =
  '免費互動式中國旅行規劃工具：查詢免簽入境、付款卡相容性、eSIM 選項、旅行預算、現金備用、電源插頭、中文常用語與計程車司機地址卡。';

const toolUseCases = [
  {
    title: '訂機票前',
    text: '在確定日期與城市之前，先使用免簽檢查器、最佳旅遊時間規劃器與預算估算器。',
    links: [
      { href: '/zh-tw/tools/visa-free-checker/', label: '免簽檢查器' },
      { href: '/zh-tw/tools/best-time-to-visit/', label: '最佳旅遊時間' },
      { href: '/zh-tw/tools/budget-cash-estimator/', label: '預算估算器' },
    ],
  },
  {
    title: '出發前',
    text: '趁還在家、有時間排除設定問題時，先使用付款、eSIM、App、插頭與常用語工具。',
    links: [
      { href: '/zh-tw/tools/payment-checker/', label: '付款檢查器' },
      { href: '/zh-tw/tools/esim-comparison/', label: 'eSIM 比較器' },
      { href: '/zh-tw/tools/app-availability-checker/', label: 'App 檢查器' },
    ],
  },
  {
    title: '抵達中國後',
    text: '遇到 App、計程車、菜單或飯店櫃台溝通困難時，可使用司機卡、貨幣換算與必備常用語。',
    links: [
      { href: '/zh-tw/tools/survival-kit/', label: '旅行生存包' },
      { href: '/zh-tw/tools/show-to-driver/', label: '給司機看' },
      { href: '/zh-tw/tools/currency-converter/', label: 'RMB 換算器' },
      { href: '/zh-tw/tools/essential-phrases/', label: '必備常用語' },
    ],
  },
];

const toolsJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: title,
  description,
  hasPart: tools.map((tool) => ({
    '@type': 'WebApplication',
    name: tool.title,
    description: tool.desc,
    applicationCategory: 'TravelApplication',
    url: new URL(tool.href, 'https://www.chinatripbox.com').toString(),
  })),
};
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="zh-TW">
  <script slot="head" type="application/ld+json" set:html={JSON.stringify(toolsJsonLd)} />
  <Header locale="zh-TW" />
  <main class="container-page py-12">
    <header>
      <p class="section-kicker">工具中心</p>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">免費中國旅行工具</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
      <div class="mt-5 flex flex-wrap gap-3">
        <a href="/zh-tw/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-primary">使用行前檢查清單</a>
        <a href="/zh-tw/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">閱讀首次訪華規劃指南</a>
      </div>
    </header>

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 lg:grid-cols-3" aria-labelledby="tool-use-cases-heading">
      <div class="lg:col-span-3">
        <h2 id="tool-use-cases-heading" class="text-2xl font-bold text-gray-950">應該先使用哪個工具？</h2>
      </div>
      {toolUseCases.map((useCase) => (
        <article class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
          <h3 class="text-lg font-bold text-gray-950">{useCase.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{useCase.text}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {useCase.links.map((link) => (
              <a href={link.href} class="rounded-full border border-gray-200 px-3 py-1.5 text-xs font-semibold text-brand-700 hover:border-brand-300 hover:bg-brand-50 hover:no-underline">{link.label}</a>
            ))}
          </div>
        </article>
      ))}
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {tools.map((tool) => (
        <a href={tool.href} class="card block hover:no-underline">
          <div class="text-3xl">{tool.icon}</div>
          <h2 class="mt-3 text-lg font-bold text-gray-900">{tool.title}</h2>
          <p class="mt-1.5 text-sm text-gray-600">{tool.desc}</p>
          <span class="mt-3 inline-block text-sm font-semibold text-brand-600">開啟工具 →</span>
        </a>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>
