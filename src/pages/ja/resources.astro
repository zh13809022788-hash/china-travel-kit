---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = '外国人旅行者向け中国旅行リソース';
const description =
  'Chinaを訪れる外国人旅行者のための実用リソース集。決済、eSIM、鉄道、ビザ、都市ガイド、ツール、初めての旅行計画に役立つリンクをまとめています。';

const resourceGroups = [
  {
    title: '30分しかない場合',
    description: 'すぐに使えるChina旅行の準備を短時間で整えたい旅行者向けの最短読み進めルートです。',
    links: [
      { href: '/ja/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: '出発前準備チェックリスト' },
      { href: '/ja/tools/survival-kit/', title: 'China旅行サバイバルカードとチェックリスト' },
      { href: '/ja/tools/payment-checker/', title: '決済の代替プランを確認する' },
      { href: '/ja/tools/visa-free-checker/', title: 'ビザなし入国またはトランジットを確認する' },
      { href: '/ja/posts/china-high-speed-rail-guide-foreigners/', title: '鉄道予約と駅での入場方法を理解する' },
    ],
  },
  {
    title: 'まずはこちら：初めての旅行準備',
    description: '「Chinaへ行く」と決めてから、到着後に困らない計画を作るまでの最短ルートです。',
    links: [
      { href: '/ja/trip-planner/', title: '無料China旅行プランナー' },
      { href: '/ja/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/', title: '初めて訪れる人向けChina旅行プランナー' },
      { href: '/ja/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: 'China旅行前に準備すること' },
      { href: '/ja/posts/china-visa-free-entry-transit-guide-2026/', title: 'Chinaビザなし入国・トランジットガイド' },
      { href: '/ja/tools/best-time-to-visit/', title: 'China旅行のベストシーズン' },
      { href: '/ja/posts/what-to-pack-for-china-a-season-by-season-checklist/', title: 'China旅行の持ち物' },
    ],
  },
  {
    title: '決済とお金',
    description: 'モバイル決済、現金の備え、カード、日常の支払いで起こりやすい問題を扱います。',
    links: [
      { href: '/ja/posts/how-to-pay-in-china-tourist-guide/', title: '旅行者としてChinaで支払う方法' },
      { href: '/ja/posts/alipay-foreign-credit-card-step-by-step/', title: '海外カードでAlipayを設定する' },
      { href: '/ja/posts/wechat-pay-foreign-visitors-guide/', title: '外国人旅行者向けWeChat Payガイド' },
      { href: '/ja/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/', title: '出発前の決済・アプリチェックリスト' },
      { href: '/ja/tools/payment-checker/', title: '決済互換性チェッカー' },
    ],
  },
  {
    title: 'インターネットとアプリ',
    description: 'オンライン状態を保ち、eSIMを選び、到着前に使えるアプリを把握します。',
    links: [
      { href: '/ja/posts/best-esim-for-china-travel-2026/', title: 'China旅行に最適なeSIM' },
      { href: '/ja/posts/china-esim-vs-roaming-2026-the-real-10-day-cost/', title: 'China eSIMとローミング料金の比較' },
      { href: '/ja/posts/internet-access-china-apps-that-work-2026/', title: 'Chinaのインターネット接続とアプリ' },
      { href: '/ja/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/', title: 'eSIMとアプリを含む初めての旅行計画' },
      { href: '/ja/tools/app-availability-checker/', title: '自分のアプリはChinaで使える？' },
    ],
  },
  {
    title: '交通と都市ガイド',
    description: '鉄道、地下鉄、空港、配車サービス、実用的な都市別プランニングを扱います。',
    links: [
      { href: '/ja/cities/', title: 'China都市ガイド一覧' },
      { href: '/ja/posts/china-high-speed-rail-guide-foreigners/', title: '外国人向けChina高速鉄道ガイド' },
      { href: '/ja/posts/book-china-train-tickets-12306-foreigners/', title: '12306でChinaの鉄道チケットを予約する' },
      { href: '/ja/posts/didi-china-foreign-tourists-guide/', title: '外国人旅行者としてDiDiを使う' },
      { href: '/ja/posts/airport-to-city-transport-beijing-shanghai-guangzhou/', title: '空港から市内への交通ガイド' },
    ],
  },
  {
    title: '食事、マナー、日常生活',
    description: '食事、チップ、デリバリーアプリ、屋台グルメ、現地での不便を減らす実用的な習慣を扱います。',
    links: [
      { href: '/ja/food/', title: 'Chinaの食事・グルメガイド' },
      { href: '/ja/posts/ordering-food-in-china-without-chinese-meituan-ele-me/', title: '中国語なしで料理を注文する' },
      { href: '/ja/posts/chengdu-street-food-safety-spice-levels-what-to-order/', title: '成都の屋台グルメ安全性と辛さガイド' },
      { href: '/ja/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/', title: 'Chinaのチップ：必要な場面' },
    ],
  },
  {
    title: '長期滞在とリモートワーク',
    description: '数週間から数か月の滞在では、法的要件、住居、決済、仕事用ツールの信頼性から確認しましょう。',
    links: [
      { href: '/ja/long-stay/', title: 'China長期滞在ガイド' },
      { href: '/ja/digital-nomads/', title: 'Chinaデジタルノマドガイド' },
      { href: '/ja/digital-nomads/visa/', title: 'デジタルノマド向けChinaビザガイド' },
      { href: '/ja/digital-nomads/payment/', title: '長期滞在向け決済設定' },
    ],
  },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main class="container-page py-10">
    <section class="max-w-3xl">
      <p class="section-kicker">リソースセンター</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </section>

    <section class="mt-10 grid gap-5 md:grid-cols-2">
      {resourceGroups.map((group) => (
        <article class="card">
          <h2 class="text-xl font-bold text-gray-950">{group.title}</h2>
          <p class="mt-2 text-sm leading-6 text-gray-600">{group.description}</p>
          <ul class="mt-5 grid gap-3">
            {group.links.map((link) => (
              <li>
                <a href={link.href} class="font-semibold text-brand-700 hover:text-brand-800">
                  {link.title}
                </a>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </section>
  </main>
  <Footer />
</BaseLayout>
