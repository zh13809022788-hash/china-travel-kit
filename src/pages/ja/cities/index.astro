    nextLabel: '広東料理ガイド',
  },
  {
    id: 'chongqing',
    name: '重慶',
    href: '/ja/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    desc: '四川火鍋、近未来的な夜景、山城らしい地形、長江クルーズを楽しむ人に最適です。',
    days: '3〜4日',
    bestSeason: '3月〜5月、9月〜11月',
    difficulty: '難しい',
    whyGo: '重慶火鍋、洪崖洞、夜景、長江ロープウェイ、独特の立体的な都市構造が魅力です。',
    next: '/ja/food/',
    nextLabel: '重慶グルメガイド',
  },
  {
    id: 'hangzhou',
    name: '杭州',
    href: '/ja/posts/hangzhou-city-guide-for-foreigners/',
    desc: '西湖、緑豊かな景色、週末向きのペース、洗練された都市滞在に最適です。',
    days: '2〜3日',
    bestSeason: '3月〜5月、9月〜11月',
    difficulty: '簡単〜普通',
    whyGo: '西湖、茶村、寺院、上海から高速鉄道で追加しやすい落ち着いた滞在先です。',
    next: '/ja/transport/',
    nextLabel: '鉄道と市内交通を計画する',
  },
  {
    id: 'sanya',
    name: '三亜',
    href: '/ja/posts/sanya-city-guide-for-foreigners/',
    desc: '暖かい冬、リゾート滞在、ビーチ時間、海南島内の小旅行に最適です。',
    days: '3〜7日',
    bestSeason: '11月〜4月',
    difficulty: '普通',
    whyGo: 'China のビーチ、冬の日差し、海鮮、リゾート、季節限定の長めの滞在を楽しめます。',
    next: '/ja/posts/what-to-pack-for-china-a-season-by-season-checklist/',
    nextLabel: '季節別パッキングガイド',
  },
];

const routes = [
  {
    name: '初めての China 旅行、8〜10日',
    plan: '上海3日、杭州2日、北京4日',
    fit: '到着後の動きやすさ、定番の景色、代表的な歴史をバランスよく組み合わせられます。',
  },
  {
    name: '食事とゆったり旅、7〜9日',
    plan: '成都4日、北京または上海3〜4日',
    fit: 'パンダ、茶館、火鍋、主要な玄関口都市を組み合わせたい旅行者に向いています。',
  },
  {
    name: '冬の避寒旅、6〜10日',
    plan: '三亜4〜6日、上海2〜3日',
    fit: 'China 北部が寒い時期に、ビーチと都市をシンプルに組み合わせたい場合に最適です。',
  },
];

const faqItems = [
  {
    question: '初めての外国人旅行者にとって、最も行きやすい China の都市はどこですか？',
    answer:
      '上海は、空港、地下鉄の表示、ホテル、レストラン、国際的なサービスが外国人旅行者に最も使いやすいため、最初の都市として選びやすいです。北京も十分に旅行しやすいですが、事前予約と毎日の移動計画をより丁寧に立てる必要があります。',
  },
  {
    question: '1回の旅行で China の都市はいくつ回るべきですか？',
    answer:
      '初めての8〜10日間の旅行なら、2〜3都市で十分です。China は広く、空港移動、鉄道駅、保安検査、ホテル移動には予想以上に時間がかかります。玄関口となる都市を1つ、文化または景色を楽しむ滞在先を1つ、必要に応じて追加先を1つ選びましょう。',
  },
  {
    question: 'China で長めに滞在するなら、どの都市が向いていますか？',
    answer:
      'サービス面と英語対応では上海が長期滞在の拠点として最も使いやすく、成都は費用を抑えた落ち着いた生活に向いています。杭州は景色と強いテック経済を備えた中間的な選択肢です。三亜は通年の都市生活というより、冬の滞在に向いています。',
  },
];

const faqJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqItems.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: item.answer,
    },
  })),
};
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">都市計画</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="city-shanghai" alt="China の都市旅行を表す夕暮れの上海スカイラインと外灘" loading="eager" />

    <ChinaMap cities={mapCities} />

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 md:grid-cols-2 xl:grid-cols-3" aria-labelledby="city-shortcuts">
      <h2 id="city-shortcuts" class="sr-only">都市ショートカット</h2>
      {cities.map((city) => (
        <article class="card" id={city.id}>
          <h3 class="text-xl font-bold text-gray-950">{city.name}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{city.desc}</p>
          <dl class="mt-4 grid gap-2 text-sm text-gray-700">
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">おすすめ滞在日数</dt>
              <dd class="text-right">{city.days}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">ベストシーズン</dt>
              <dd class="text-right">{city.bestSeason}</dd>
            </div>
            <div class="flex justify-between gap-4">
              <dt class="font-semibold text-gray-900">旅行しやすさ</dt>
              <dd class="text-right">{city.difficulty}</dd>
            </div>
          </dl>
          <div class="mt-5 grid gap-2 text-sm font-semibold">
            <a href={city.href} class="text-brand-700 hover:text-brand-800">都市ガイドを開く</a>
            <a href={city.next} class="text-gray-700 hover:text-brand-700">{city.nextLabel}</a>
          </div>
        </article>
      ))}
    </section>

    <section class="mt-12" aria-labelledby="compare-cities">
      <div class="section-heading">
        <div>
          <p class="section-kicker">都市比較</p>
          <h2 id="compare-cities">どの China の都市を選ぶべき？</h2>
        </div>
      </div>
      <div class="mt-6 overflow-hidden rounded-lg border border-gray-200">
        <table class="min-w-full divide-y divide-gray-200 text-left text-sm">
          <thead class="bg-gray-50 text-xs font-semibold uppercase tracking-wide text-gray-600">
            <tr>
              <th class="px-4 py-3">都市</th>
              <th class="px-4 py-3">行く理由</th>
              <th class="px-4 py-3">おすすめ滞在日数</th>
              <th class="px-4 py-3">ベストシーズン</th>
              <th class="px-4 py-3">難易度</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100 bg-white">
            {cities.map((city) => (
              <tr>
                <th class="px-4 py-4 font-bold text-gray-950">
                  <a href={city.href} class="text-brand-700 hover:text-brand-800">{city.name}</a>
                </th>
                <td class="px-4 py-4 leading-6 text-gray-700">{city.whyGo}</td>
                <td class="px-4 py-4 text-gray-700">{city.days}</td>
                <td class="px-4 py-4 text-gray-700">{city.bestSeason}</td>
                <td class="px-4 py-4 text-gray-700">{city.difficulty}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mt-12 grid gap-6 lg:grid-cols-[0.9fr_1.1fr]" aria-labelledby="route-ideas">
      <div>
        <p class="section-kicker">ルート計画</p>
        <h2 id="route-ideas" class="mt-2 text-3xl font-bold text-gray-950">現実的な都市の組み合わせ</h2>
        <p class="mt-3 leading-7 text-gray-600">
          よい China 旅行の行程は、都市ごとに役割を分けると組みやすくなります。上海は到着しやすい玄関口、
          北京は歴史、杭州は景色、成都は食事と China 西部へのアクセス、三亜は暖かい休暇に向いています。
          短い旅行では、フライトや鉄道駅での乗り換えを詰め込みすぎないようにしましょう。
        </p>
      </div>
      <div class="grid gap-4">
        {routes.map((route) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-lg font-bold text-gray-950">{route.name}</h3>
            <p class="mt-2 font-semibold text-brand-700">{route.plan}</p>
            <p class="mt-2 text-sm leading-6 text-gray-600">{route.fit}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">都市関連ガイド一覧</p>
            <h2>都市記事と市内交通</h2>
          </div>
        </div>
        <div class="mt-6 grid gap-5 md:grid-cols-2">
          {cityPosts.map((post) => (
            <a href={`/ja/posts/${post.slug}/`} class="card block hover:no-underline">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{post.data.category}</span>
              <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <p class="section-kicker">都市を選ぶ前に</p>
        <h2 class="mt-1 text-xl font-bold text-gray-950">旅行インフラを確認</h2>
        <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
          <li><a href="/ja/payment/" class="font-semibold text-brand-700">決済:</a> 小都市へ行く前に Alipay、WeChat Pay、現金の予備を準備しましょう。</li>
          <li><a href="/ja/esim/" class="font-semibold text-brand-700">インターネット:</a> 地図や翻訳に頼る前に、eSIM、ローミング、現地SIMのどれを使うか選びましょう。</li>
          <li><a href="/ja/transport/" class="font-semibold text-brand-700">交通:</a> 鉄道、空港アクセス、DiDi、地下鉄QRコードを比較しましょう。</li>
          <li><a href="/ja/tools/best-time-to-visit/" class="font-semibold text-brand-700">時期:</a> 月ごとの天気、祝日、混雑度を確認しましょう。</li>
        </ul>
      </aside>
    </section>

    <section class="mt-12" aria-labelledby="city-faq">
      <div class="section-heading">
        <div>
          <p class="section-kicker">都市FAQ</p>
          <h2 id="city-faq">China の都市計画でよくある質問</h2>
        </div>
      </div>
      <div class="mt-6 grid gap-4 md:grid-cols-3">
        {faqItems.map((item) => (
          <article class="rounded-lg border border-gray-200 bg-white p-5">
            <h3 class="text-base font-bold text-gray-950">{item.question}</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">{item.answer}</p>
          </article>
        ))}
      </div>
    </section>

    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  </main>
  <Footer />
</BaseLayout>
