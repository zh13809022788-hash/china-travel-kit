---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import CoverImage from '../../../components/CoverImage.astro';
import ChinaMap from '../../../components/ChinaMap.astro';
import AdSlot from '../../../components/AdSlot.astro';

const allPosts = await getCollection('posts-ja');
const cityNames = ['beijing', 'shanghai', 'chengdu', 'hangzhou', 'sanya', 'guangzhou', 'xian', 'chongqing', 'kunming', 'nanjing'];
const cityPosts = allPosts
  .filter((post) => cityNames.some((city) => post.slug.includes(city) || post.data.tags.includes(city)))
  .sort((a, b) => a.data.title.localeCompare(b.data.title));

const title = '外国人旅行者向け中国都市ガイド';
const description =
  '北京、上海、広州、成都、西安、杭州、重慶、三亜のガイドを使って、China 旅行の現実的な都市滞在を計画しましょう。空港、地下鉄、食事、交通の次の準備も確認できます。';

const mapCities = [
  { name: '北京', x: 470, y: 80, href: '#beijing' },
  { name: '西安', x: 340, y: 155, href: '#xian' },
  { name: '南京', x: 490, y: 180, href: '' },
  { name: '上海', x: 540, y: 200, href: '#shanghai' },
  { name: '成都', x: 250, y: 220, href: '#chengdu' },
  { name: '杭州', x: 520, y: 205, href: '#hangzhou' },
  { name: '重慶', x: 310, y: 260, href: '#chongqing' },
  { name: '桂林', x: 370, y: 300, href: '' },
  { name: '昆明', x: 210, y: 335, href: '' },
  { name: '広州', x: 400, y: 370, href: '#guangzhou' },
  { name: '深圳', x: 430, y: 390, href: '' },
  { name: '三亜', x: 360, y: 440, href: '#sanya' },
];

const cities = [
  {
    id: 'beijing',
    name: '北京',
    href: '/ja/posts/beijing-city-guide-for-foreigners/',
    desc: '歴史、胡同、万里の長城、初めての定番観光に最適です。',
    days: '4〜5日',
    bestSeason: '9月〜10月',
    difficulty: '普通',
    whyGo: '皇帝時代の歴史、博物館、そして万里の長城へ最も行きやすい拠点です。',
    next: '/ja/posts/beijing-daxing-airport-to-city-center-a-first-timer-s-guide/',
    nextLabel: '大興空港アクセスガイド',
  },
  {
    id: 'shanghai',
    name: '上海',
    href: '/ja/posts/shanghai-city-guide-for-foreigners/',
    desc: '到着後の動きやすさ、多国籍な食事、スカイライン散策、地下鉄の使いやすさを重視する人に最適です。',
    days: '3〜4日',
    bestSeason: '3月〜5月、10月〜11月',
    difficulty: '簡単',
    whyGo: '地下鉄、空港、食事、英語対応サービスの面で、最初の滞在地として最もスムーズです。',
    next: '/ja/posts/shanghai-metro-for-foreigners-tickets-qr-codes-transfers/',
    nextLabel: '上海地下鉄ガイド',
  },
  {
    id: 'chengdu',
    name: '成都',
    href: '/ja/posts/chengdu-city-guide-for-foreigners/',
    desc: '四川料理、茶館のゆったりした空気、パンダ、穏やかな大都市のリズムを楽しむ人に最適です。',
    days: '3〜5日',
    bestSeason: '3月〜6月、9月〜11月',
    difficulty: '普通',
    whyGo: 'パンダ、四川料理、茶館、比較的低い費用、China 西部への小旅行が魅力です。',
    next: '/ja/posts/chengdu-street-food-safety-spice-levels-what-to-order/',
    nextLabel: '成都屋台グルメガイド',
  },
  {
    id: 'xian',
    name: '西安',
    href: '/ja/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/',
    desc: '古代史、兵馬俑、古い城壁、中国文化を体感する旅に最適です。',
    days: '3〜4日',
    bestSeason: '3月〜5月、9月〜11月',
    difficulty: '普通',
    whyGo: '兵馬俑、古城壁、回民街のグルメ、そして中国史の奥深さを感じられます。',
    next: '/ja/posts/china-high-speed-rail-guide-foreigners/',
    nextLabel: '西安行き高速鉄道',
  },
  {
    id: 'guangzhou',
    name: '広州',
    href: '/ja/posts/airport-to-city-transport-beijing-shanghai-guangzhou/',
    desc: '広東料理、商業都市の活気、南部への玄関口、香港へのアクセスを重視する人に最適です。',
