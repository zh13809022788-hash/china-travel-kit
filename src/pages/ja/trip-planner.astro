---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';

const title = '無料で使える中国旅行プランナーです';
const description =
  'お支払い、eSIM、移動手段、アプリ設定、現金の備え、初日のチェックリストまで含めて、初めての中国旅行を実用的に組み立てられます。';

const needOptions = [
  { value: 'payment', label: '支払いの準備を進めたいです' },
  { value: 'esim', label: 'eSIMと通信環境を整えたいです' },
  { value: 'transport', label: '空港や鉄道の移動を考えたいです' },
  { value: 'hotel', label: 'ホテル選びの考え方を知りたいです' },
  { value: 'apps', label: 'アプリと翻訳の準備をしたいです' },
  { value: 'cash', label: '現金の予備を考えたいです' },
  { value: 'visa', label: 'ビザ免除での入国条件を確認したいです' },
  { value: 'food', label: '食事やデリバリー事情を把握したいです' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main>
    <section class="border-b border-gray-200 bg-white">
      <div class="container-page grid gap-8 py-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <div>
          <p class="section-kicker">無料で使える計画ツールです</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            出発前に、中国到着後の行動計画を作っておきませんか
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            お支払い、eSIMの通信、空港からの移動、アプリ設定、現金の備え、日ごとの回り方まで、最初のたたき台を作れます。ブラウザ内で動作し、回答内容は保存されません。
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#planner" class="btn-primary">計画を始めます</a>
            <a href="/ja/travel-help/" class="btn-outline">旅行相談をします</a>
            <a href="/ja/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="btn-outline">初めての方向けガイドを読みます</a>
          </div>
        </div>

        <aside class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="section-kicker">このような方に向いています</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">初めての渡航準備に役立ちます</h2>
          <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
            <li>到着前に支払いの準備を整えたい方です</li>
            <li>eSIM、ローミング、アプリ利用を考えたい方です</li>
            <li>空港から市内までの最初の移動を決めたい方です</li>
            <li>都市ごとの回り方をシンプルに整理したい方です</li>
          </ul>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <AdSlot format="banner" />

      <section id="planner" class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <form id="trip-planner-form" class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm md:p-6">
          <div class="border-b border-gray-200 pb-5">
            <p class="section-kicker">旅行情報です</p>
            <h2 class="mt-2 text-2xl font-bold text-gray-950">分かっていることを教えてください</h2>
          </div>

          <div class="mt-6 grid gap-5 md:grid-cols-2">
            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              出発国・地域
              <input id="home-country" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="アメリカ、イギリス、シンガポールなどをご入力ください" />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              到着都市
              <select id="arrival-city" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>上海</option>
                <option>北京</option>
                <option>広州</option>
                <option>深圳</option>
                <option>成都</option>
                <option>杭州</option>
                <option>その他の都市</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800 md:col-span-2">
              訪問予定の都市
              <input id="destination-cities" class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700" placeholder="上海、杭州、北京のようにご入力ください" />
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              旅行日数
              <select id="trip-length" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option value="3">3日間</option>
                <option value="5">5日間</option>
                <option value="7" selected>7日間</option>
                <option value="10">10日間</option>
                <option value="14">14日間</option>
                <option value="21">21日間以上</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              旅行の目的
              <select id="trip-purpose" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>観光</option>
                <option>出張</option>
                <option>長期滞在</option>
                <option>デジタルノマド</option>
                <option>家族訪問</option>
                <option>乗り継ぎ</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              ご予算の目安
              <select id="budget-range" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>節約重視です</option>
                <option selected>標準的です</option>
                <option>ゆとりがあります</option>
              </select>
            </label>

            <label class="grid gap-1 text-sm font-semibold text-gray-800">
              旅行スタイル
              <select id="travel-style" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                <option>効率重視です</option>
                <option>節約重視です</option>
                <option selected>標準的です</option>
                <option>家族向けです</option>
                <option>ビジネス向けです</option>
                <option>食事重視です</option>
              </select>
            </label>
          </div>

          <fieldset class="mt-6">
            <legend class="text-sm font-semibold text-gray-800">どのようなお手伝いが必要ですか？</legend>
            <div class="mt-3 grid gap-3 sm:grid-cols-2">
              {needOptions.map((option) => (
                <label class="flex items-center gap-3 rounded-lg border border-gray-200 bg-gray-50 px-3 py-2 text-sm text-gray-700">
                  <input class="h-4 w-4 rounded border-gray-300 text-brand-600" type="checkbox" name="needs" value={option.value} checked={['payment', 'esim', 'transport', 'apps'].includes(option.value)} />
                  {option.label}
                </label>
              ))}
            </div>
          </fieldset>

          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            <p id="planner-status" class="text-sm text-gray-500">アカウント登録や機微な情報の入力は不要です。</p>
            <button class="btn-primary" type="submit">プランを作成します</button>
          </div>
        </form>

        <aside class="space-y-6">
          <section class="rounded-lg border border-gray-200 bg-white p-5">
            <p class="section-kicker">次の段階です</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">人の目で確認してほしいですか？</h2>
            <p class="mt-3 text-sm leading-6 text-gray-600">
              ルート、日程、支払い設定、初日の動きに不安がある場合は、作成したプランをメールで送り、人による修正案の確認を依頼できます。
            </p>
            <a id="planner-email-link" class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:border-brand-600 hover:text-brand-600 hover:no-underline" href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20旅行確認依頼">
              確認依頼のメールを準備します
            </a>
          </section>

          <section class="rounded-lg border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">ご注意ください</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">計画補助としてご利用ください</h2>
            <p class="mt-3 text-sm leading-6 text-gray-700">
              このツールは、法律、入国、医療、銀行、緊急時の助言を行うものではありません。入国条件、航空会社、ホテル、カード、通信、アプリに関する重要なルールは、必ず公式情報でご確認ください。
            </p>
          </section>
        </aside>
      </section>

      <section id="plan-output" class="mt-10 hidden rounded-lg border border-brand-100 bg-brand-50 p-5 md:p-6" aria-live="polite">
        <div class="border-b border-brand-100 pb-4">
          <p class="section-kicker">作成したプランです</p>
          <h2 class="mt-2 text-2xl font-bold text-gray-950">中国旅行の準備案です</h2>
        </div>
        <div id="plan-content" class="mt-5 grid gap-5"></div>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <a href="/ja/payment/" class="card block hover:no-underline">
          <p class="section-kicker">支払いです</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Alipay と WeChat Pay を整えましょう</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">到着前に、少なくとも1つのウォレットと1つの予備の支払い手段を用意しておきましょう。</p>
        </a>
        <a href="/ja/esim/" class="card block hover:no-underline">
          <p class="section-kicker">通信です</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">eSIM かローミングを選びましょう</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">初日から地図、翻訳、メッセージ、配車を使える状態にしておきましょう。</p>
        </a>
        <a href="/ja/transport/" class="card block hover:no-underline">
          <p class="section-kicker">交通です</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">最初の移動を決めておきましょう</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">空港からホテルまでの経路と、地下鉄、タクシー、DiDi、鉄道の使い分けを確認しておきましょう。</p>
        </a>
      </section>

      <section class="mt-10 rounded-lg border border-gray-200 bg-white p-5 md:p-6">
        <p class="section-kicker">プランナーを使う前にご確認ください</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950">初めての中国旅行なら、先に準備ガイドをお読みください</h2>
        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <a href="/ja/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">初めての方向けの中国旅行プランナーです</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">このツールと同じ順番で、通信、支払い、空港移動、アプリ、都市の回り方、初日のチェックリストを整理できます。</p>
          </a>
          <a href="/ja/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">中国旅行前に設定しておきたいことです</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Alipay、WeChat Pay、eSIM、DiDi、鉄道券、地図、現金の備えまで含めた、実用的な出発前チェックリストです。</p>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('trip-planner-form') as HTMLFormElement | null;
  const output = document.getElementById('plan-output');
  const content = document.getElementById('plan-content');
  const status = document.getElementById('planner-status');
  const emailLink = document.getElementById('planner-email-link') as HTMLAnchorElement | null;

  const getValue = (id: string) => (document.getElementById(id) as HTMLInputElement | HTMLSelectElement | null)?.value.trim() || '';
  const selectedNeeds = () =>
    Array.from(document.querySelectorAll<HTMLInputElement>('input[name="needs"]:checked')).map((input) => input.value);
  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char] ?? char);

  const splitCities = (value: string, arrival: string) => {
    const typed = value
      .split(',')
      .map((city) => city.trim())
      .filter(Boolean);
    const cities = typed.length ? typed : [arrival];
    return Array.from(new Set(cities));
  };

  const list = (items: string[]) => `<ul class="mt-3 grid gap-2 text-sm leading-6 text-gray-700">${items.map((item) => `<li>${item}</li>`).join('')}</ul>`;
  const panel = (title: string, items: string[]) => `
    <section class="rounded-lg border border-gray-200 bg-white p-5">
      <h3 class="text-lg font-bold text-gray-950">${title}</h3>
      ${list(items)}
    </section>
  `;

  const buildPlan = () => {
    const home = getValue('home-country') || '出発国・地域';
    const arrival = getValue('arrival-city') || '上海';
    const cities = splitCities(getValue('destination-cities'), arrival);
    const days = Number(getValue('trip-length') || '7');
    const purpose = getValue('trip-purpose') || '観光';
    const budget = getValue('budget-range') || '標準的です';
    const style = getValue('travel-style') || '標準的です';
    const needs = selectedNeeds();
    const perCity = Math.max(1, Math.floor(days / Math.max(1, cities.length)));

    const preDeparture = [
      `${escapeHtml(home)} を出発する前に、Alipay、WeChat、DiDi、翻訳アプリ、オフライン地図を入れておきましょう。`,
      needs.includes('payment')
        ? '外国発行の Visa または Mastercard を Alipay に1枚だけ連携し、出発前に少額決済で確認しておきましょう。'
        : '支払い手段はシンプルにまとめて、モバイルウォレット1つ、物理カード1枚、少額の人民元を準備しておくと安心です。',
      needs.includes('esim')
        ? 'フライト前に eSIM かローミングを購入して有効化し、QRコードはオフラインでも見られるようにしておきましょう。'
        : '地図や配車に頼る前に、到着時に通信が使えるかどうかだけは必ず確認しておきましょう。',
      'ホテルの住所は英語と中国語の両方で保存し、最寄りの地下鉄駅も控えておきましょう。',
    ];

    const payment = [
      '基本は、外国発行カードを連携した Alipay です。旅行者にとって、最も実用的な最初のウォレットになりやすいです。',
      '予備として、カードが通れば WeChat Pay、さらに物理の Visa または Mastercard を1枚持っておくと安心です。',
      budget === '節約重視です'
        ? '現金の予備として、屋台、デポジット、カードやウォレットの不具合に備えて、少額の人民元を持っておきましょう。'
        : '現金の予備として、タクシー、軽食、モバイル決済が使えないときの簡単な食事代は確保しておきましょう。',
      '中国本土では、Apple Pay や Google Pay を主な支払い手段にしないほうが安全です。',
    ];

    const internet = [
      '短期旅行なら、端末が eSIM に対応していれば、旅行用 eSIM が最も手軽です。',
      '長期滞在や大容量通信が必要なら、出発前にローミング、eSIM、ポケットWiFi、現地SIMを比べておきましょう。',
      '支払いアプリ、配車、翻訳、地図は通信に依存するため、空港を出る前に必ずモバイル通信を確認してください。',
      '最初の接続が不安定な場合に備えて、ホテル情報と移動情報はオフラインでも見られるようにしておきましょう。',
    ];

    const transport = [
      `${escapeHtml(arrival)} の空港または駅からホテルまでの最初の移動は、到着前に決めておきましょう。`,
      '市内の移動は、予測しやすい区間なら地下鉄、ドアツードアなら DiDi、都市間移動なら高速鉄道と考えると分かりやすいです。',
      needs.includes('transport')
        ? '鉄道移動がある日は、できるだけ早めに予約し、パスポート情報を予約サイトと一致させてください。'
        : '国際線の到着日と長距離鉄道の移動日を同じ日に詰め込みすぎないようにしましょう。',
      'タクシーやホテルのフロントで見せられるように、中国語の住所カードを用意しておくと便利です。',
    ];

    const dayPlan = cities.map((city, index) => {
      const start = index * perCity + 1;
      const end = index === cities.length - 1 ? days : Math.min(days, start + perCity - 1);
      return `${start}日目〜${end}日目: ${escapeHtml(city)}では、最初の半日は軽めに過ごし、支払いと通信を確認してから、観光地はエリアごとにまとめて回るのがおすすめです。`;
    });

    const mistakes = [
      '到着してから、アプリ、カード、通信をまとめて設定しようとしないでください。',
      '長距離移動の直後に、観光を詰め込んだ一日を入れないようにしましょう。',
      '支払い手段を1つだけに頼らないでください。',
      purpose === '出張'
        ? '出張であれば、渋滞、保安検査、請求書、建物の入館手続きに備えて、余裕時間を多めに見ておきましょう。'
        : '観光であれば、2〜3日に1回は天気、混雑、疲れに対応できる予備枠を残しておきましょう。',
      style === '食事重視です'
        ? '食事重視の旅では、店名を中国語で保存し、移動前に営業時間を確認しておきましょう。'
        : 'ホテル周辺で食事ができる簡単な予備案を1つ持っておきましょう。',
    ];

    const html = [
      panel('出発前のチェックリストです', preDeparture),
      panel('支払いと現金の準備です', payment),
      panel('通信とアプリの準備です', internet),
      panel('交通と初日の動きです', transport),
      panel('日ごとの大まかな組み立て方です', dayPlan),
      panel('よくある失敗への注意点です', mistakes),
    ].join('');

    const emailBody = [
      'ChinaTripBox 旅行確認依頼です',
      '',
      `出発国・地域: ${home}`,
      `到着都市: ${arrival}`,
      `訪問予定の都市: ${cities.join(', ')}`,
      `旅行日数: ${days}日間`,
      `旅行の目的: ${purpose}`,
      `ご予算の目安: ${budget}`,
      `旅行スタイル: ${style}`,
      `必要な支援: ${needs.join(', ') || '未指定です'}`,
      '',
      '支払い、eSIM、交通、所要時間、初日の失敗ポイントについて、中国旅行の準備内容をご確認ください。',
    ].join('\n');

    if (emailLink) {
      emailLink.href = `mailto:zh13809022788@gmail.com?subject=${encodeURIComponent(
        'ChinaTripBox 旅行確認依頼です',
      )}&body=${encodeURIComponent(emailBody)}`;
    }

    return html;
  };

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!content || !output) return;
    content.innerHTML = buildPlan();
    output.classList.remove('hidden');
    output.scrollIntoView({ behavior: 'smooth', block: 'start' });
    if (status) status.textContent = 'プランを作成しました。回答を変更すれば、いつでも作り直せます。';
  });
</script>
