---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const CATEGORY = 'payment';
const posts = (await getCollection('posts-ja'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = '中国決済ガイド：Alipay、WeChat Pay、海外カード';
const description =
  '外国人旅行者向けに、中国での支払い方法、Alipay と WeChat Pay の設定、海外カード連携、よくある失敗の避け方を解説します。';

const prioritySteps = [
  '出発前に Alipay と WeChat をインストールし、自国の銀行と電話番号をまだ使えるうちに本人確認を済ませておきましょう。',
  'Visa または Mastercard を少なくとも1枚登録し、別の発行会社のカードを予備として用意しておきましょう。',
  'タクシー、小さな店舗、ウォレット認証やカード承認が失敗した場合に備えて、少額の人民元現金を持っておきましょう。',
];

const paymentTools = [
  { href: '/ja/tools/payment-checker/', title: '決済互換性チェッカー', desc: 'Alipay と WeChat Pay のカード対応状況、一般的な上限、手数料を確認できます。' },
  { href: '/ja/tools/budget-cash-estimator/', title: '予算・現金見積もりツール', desc: '旅行中の支出と、持っておくべき予備現金の目安を見積もれます。' },
  { href: '/ja/tools/currency-converter/', title: '人民元通貨換算ツール', desc: '価格を人民元に換算し、日常的な費用感を把握できます。' },
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">決済</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">中国決済ガイド</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-how-to-pay" alt="China旅行の支払い方法を表示したスマートフォンでのモバイル決済設定" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-payment">
      <h2 id="featured-payment" class="sr-only">注目の決済ガイド</h2>
      <a href="/ja/posts/alipay-foreign-credit-card-step-by-step/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Alipay 設定</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Alipay のインストールと海外クレジットカード登録を順番に解説</p>
      </a>
      <a href="/ja/posts/wechat-pay-foreign-visitors-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">WeChat Pay</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">外国人旅行者向けの完全な設定・利用ガイド</p>
      </a>
      <a href="/ja/posts/alipay-vs-wechat-pay-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Alipay と WeChat Pay の比較</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">2026年に使うべき決済アプリはどちら？</p>
      </a>
      <a href="/ja/posts/how-to-pay-in-china-tourist-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">完全版決済ガイド</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">旅行者が China で支払うために知っておきたいことを網羅</p>
      </a>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[1fr_340px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">信頼できる決済設定から始める</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          China ではQR決済が主流です。旅行者にとって使いやすい準備とは、メインのウォレット1つ、予備のウォレット1つ、カード2枚、そして例外時に使える少額の現金を用意しておくことです。
        </p>
        <ol class="mt-5 space-y-3 text-sm leading-6 text-gray-600">
          {prioritySteps.map((step, index) => (
            <li class="flex gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand-50 text-xs font-bold text-brand-700">{index + 1}</span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">決済ツール</h2>
        <div class="mt-4 grid gap-3">
          {paymentTools.map((tool) => (
            <a href={tool.href} class="rounded-lg border border-brand-100 bg-white p-4 hover:border-brand-200 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-900 hover:text-brand-700">{tool.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{tool.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/ja/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">決済</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">ガイドは近日公開予定です。</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>
