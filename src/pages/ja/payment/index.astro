---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const CATEGORY = 'payment';
const posts = (await getCollection('posts-ja'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = '中国でのお支払い方法ガイド：Alipay・WeChat Pay・海外発行カードの使い方をご案内します';
const description =
  '中国を訪れる旅行者の方向けに、現地で利用しやすいお支払い方法、Alipay と WeChat Pay の設定手順、海外発行カードの連携方法、よくある失敗を避けるコツをわかりやすくご案内します。';

const prioritySteps = [
  '出発前に Alipay と WeChat をインストールし、ご自身の国の銀行口座や電話番号が使えるうちに、本人確認まで済ませておきましょう。',
  'Visa または Mastercard を少なくとも1枚登録し、できれば異なる発行会社のカードも予備としてご用意ください。',
  'タクシーや小規模な店舗、ウォレット認証やカード承認がうまくいかない場面に備えて、少額の人民元現金もお持ちいただくと安心です。',
];

const paymentTools = [
  { href: '/ja/tools/payment-checker/', title: 'お支払い対応チェッカー', desc: 'Alipay と WeChat Pay で使えるカードの種類、一般的な利用上限、手数料の目安をご確認いただけます。' },
  { href: '/ja/tools/budget-cash-estimator/', title: '予算・現金見積もりツール', desc: 'ご旅行中に想定される支出と、予備として持っておきたい現金額の目安を見積もっていただけます。' },
  { href: '/ja/tools/currency-converter/', title: '人民元換算ツール', desc: '価格を人民元に換算して、日常的な支出感覚をつかんでいただけます。' },
];
---
import { getCategoryLabel } from '../../../i18n/categories.ts';

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main class="container-page py-10">
    <header class="max-w-2xl">
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">お支払い</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">中国でのお支払い方法をご案内します</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-how-to-pay" alt="中国旅行中のお支払い方法を確認するスマートフォンのモバイル決済設定画面です" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="osusume-payment">
      <h2 id="osusume-payment" class="sr-only">おすすめのお支払いガイドをご紹介します</h2>
      <a href="/ja/posts/alipay-foreign-credit-card-step-by-step/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Alipay の設定方法をご案内します</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">Alipay のインストールから海外発行クレジットカードの登録まで、順を追ってわかりやすくご案内します。</p>
      </a>
      <a href="/ja/posts/wechat-pay-foreign-visitors-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">WeChat Pay の使い方をご案内します</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">旅行者の方向けに、設定方法から実際の使い方までまとめてご案内します。</p>
      </a>
      <a href="/ja/posts/alipay-vs-wechat-pay-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">Alipay と WeChat Pay を比較してご案内します</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">2026年のご旅行で使いやすい決済アプリがどちらかを比較してご紹介します。</p>
      </a>
      <a href="/ja/posts/how-to-pay-in-china-tourist-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">総合お支払いガイドをご覧いただけます</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">旅行者の方が中国でお支払いをする際に知っておきたいポイントをひと通りご確認いただけます。</p>
      </a>
    </section>

    <section class="mt-8 grid gap-6 lg:grid-cols-[1fr_340px]">
      <div class="rounded-lg border border-gray-200 bg-white p-6">
        <h2 class="text-2xl font-bold text-gray-900">まずは確実に使えるお支払い環境を整えましょう</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          中国ではQRコード決済が広く使われています。旅行者の方は、主に使うウォレットを1つ、予備のウォレットを1つ、カードを2枚、さらに例外時に備えた少額の現金を準備しておくと安心です。
        </p>
        <ol class="mt-5 space-y-3 text-sm leading-6 text-gray-600">
          {prioritySteps.map((step, index) => (
            <li class="flex gap-3">
              <span class="flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-brand-50 text-xs font-bold text-brand-700">{index + 1}</span>
              <span>{step}</span>
            </li>
          ))}
        </ol>
      </div>

      <aside class="rounded-lg border border-brand-100 bg-brand-50 p-6">
        <h2 class="text-lg font-bold text-gray-900">便利なお支払いツールをご利用ください</h2>
        <div class="mt-4 grid gap-3">
          {paymentTools.map((tool) => (
            <a href={tool.href} class="rounded-lg border border-brand-100 bg-white p-4 hover:border-brand-200 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-900 hover:text-brand-700">{tool.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{tool.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/ja/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">お支払い</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">ガイドは現在準備中です。公開まで今しばらくお待ちください。</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>
