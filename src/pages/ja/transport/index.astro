---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const CATEGORY = 'transport';
const posts = (await getCollection('posts-ja'))
  .filter((p) => p.data.category === CATEGORY)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = '中国の交通ガイド：高速鉄道、DiDi、市内移動をご案内します';
const description =
  '中国を旅行される外国人の方向けに、高速鉄道の予約方法、DiDiの使い方、公共交通機関の利用方法をわかりやすくご案内します。';

const transportPaths = [
  { href: '/ja/posts/china-high-speed-rail-guide-foreigners/', title: '都市間の鉄道移動をご案内します', desc: '都市間の移動計画、座席クラス、パスポート情報の入力方法、駅へ到着する目安の時間をご確認いただけます。' },
  { href: '/ja/posts/airport-to-city-transport-beijing-shanghai-guangzhou/', title: '空港到着後の移動方法をご案内します', desc: '空港から市内へ向かう最初の移動手段として、地下鉄、タクシー、配車アプリ、空港連絡鉄道を比較しながらご覧いただけます。' },
  { href: '/ja/posts/didi-china-foreign-tourists-guide/', title: '配車サービスの使い方をご案内します', desc: 'DiDiの設定方法、翻訳付きの乗車位置ピンの使い方、運転手からの連絡を減らすコツをご紹介します。' },
  { href: '/ja/posts/shanghai-metro-for-foreigners-tickets-qr-codes-transfers/', title: '地下鉄の利用方法をご案内します', desc: '上海を例に、QR乗車券の使い方、乗り換え方法、ラッシュ時の利用の流れを学んでいただけます。' },
];
import { getCategoryLabel } from '../../../i18n/categories';
const locale = 'ja';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja"
  title="中国交通ガイド | 高速鉄道・地下鉄・タクシー完全攻略"
  description="中国の交通機関完全ガイド：高速鉄道網、都市の地下鉄、DiDi配車、国内線、バスの利用方法。">
  <Header locale="ja" />
  <main class="container-page py-10">
    <header>
      <span class="text-sm font-semibold uppercase tracking-wide text-brand-600">交通案内</span>
      <h1 class="mt-2 text-3xl font-bold text-gray-900 md:text-4xl">中国の交通情報をご案内します</h1>
      <p class="mt-3 text-lg text-gray-600">{description}</p>
    </header>

    

    <div class="mt-8 space-y-4 text-justify text-lg leading-8 text-gray-600">
      <p>中国は世界で最も高度で広範な交通ネットワークを誇り、都市間や都市内の移動が驚くほど簡単です。その中心となるのが、世界最大の高速鉄道網であり、時速350kmで主要都市を結んでいます。北京から上海まではわずか4.5時間、北京から西安までは約4時間です。列車はG（高速）、D（準高速）、K/T（一般）に分類され、G列車が長距離移動に最も快適で人気があります。チケットは公式アプリ12306または英語対応のTrip.comで予約できます。</p>
      <p>都市内では、地下鉄システムが効率的で手頃な料金であり、北京、上海、広州、深圳などの主要都市では英語表記も充実しています。DiDi（中国のUber）は外国人でも簡単に利用できます。タクシーは広く利用可能ですが、英語のコミュニケーションが難しい場合があるため、目的地を中国語で書いておくと便利です。長距離には国内線も良い選択肢で、中国南方航空、中国国際航空、中国東方航空などの主要航空会社が競争力のある料金を提供しています。最良の体験を得るには、地域間の移動に高速鉄道、都市内の移動に地下鉄とDiDiを組み合わせることをお勧めします。</p>
    </div>

    <AdSlot format="banner" />

    <section class="mt-6 grid gap-4 sm:grid-cols-2 lg:grid-cols-4" aria-labelledby="featured-transport">
      <h2 id="featured-transport" class="sr-only">おすすめの交通ガイドをご案内します</h2>
      <a href="/ja/posts/china-high-speed-rail-guide-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">高速鉄道の利用方法をご案内します</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">切符の予約方法、座席クラスの選び方、駅での移動方法をわかりやすくご案内します。</p>
      </a>
      <a href="/ja/posts/book-china-train-tickets-12306-foreigners/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">12306での切符予約方法をご案内します</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">外国のパスポートを使った予約手順を、順を追ってご説明します。</p>
      </a>
      <a href="/ja/posts/didi-china-foreign-tourists-guide/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">DiDiの使い方をご案内します</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">中国の配車アプリの使い方をわかりやすくご案内します。</p>
      </a>
      <a href="/ja/posts/airport-to-city-transport-beijing-shanghai-guangzhou/" class="rounded-lg border border-gray-200 bg-white p-4 text-sm shadow-sm transition-colors hover:border-brand-300 hover:bg-brand-50 hover:no-underline">
        <span class="font-semibold text-gray-950">空港から市内への移動方法をご案内します</span>
        <p class="mt-1 text-xs leading-5 text-gray-600">北京、上海、広州での移動方法をわかりやすくご案内します。</p>
      </a>
    </section>

    <section class="mt-8 grid gap-4 md:grid-cols-2 xl:grid-cols-4" aria-labelledby="transport-paths">
      <h2 id="transport-paths" class="sr-only">交通計画に役立つガイド一覧です</h2>
      {transportPaths.map((path) => (
        <a href={path.href} class="card block hover:no-underline">
          <h3 class="text-lg font-bold text-gray-950">{path.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{path.desc}</p>
        </a>
      ))}
    </section>

    <section class="mt-8 grid gap-6 md:grid-cols-2">
      {posts.map((post, i) => (
        <>
          <a href={`/ja/posts/${post.slug}/`} class="card block hover:no-underline">
            <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{getCategoryLabel(post.data.category, locale)}</span>
            <h2 class="mt-1.5 text-lg font-bold text-gray-900">{post.data.title}</h2>
            <p class="mt-1.5 text-sm text-gray-600">{post.data.description}</p>
            <time datetime={post.data.pubDate.toISOString()} class="mt-3 block text-xs text-gray-400">
              {post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'short', day: 'numeric' })}
            </time>
          </a>
          {(i + 1) % 3 === 0 && <div class="md:col-span-2"><AdSlot format="in-article" /></div>}
        </>
      ))}
      {posts.length === 0 && <p class="text-gray-500">ガイドは近日中に公開予定です。しばらくお待ちください。</p>}
    </section>
  </main>
  <Footer />
</BaseLayout>
