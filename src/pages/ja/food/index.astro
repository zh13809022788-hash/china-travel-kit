---

import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import AdSlot from '../../../components/AdSlot.astro';
import CoverImage from '../../../components/CoverImage.astro';

const posts = (await getCollection('posts-ja'))
  .filter((p) => p.data.category === 'food' || p.data.tags.includes('tipping') || p.data.tags.includes('restaurants'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = '中国のグルメ・食事マナーガイドです';
const description = '外国人旅行者の方向けに、中国の食事を安心して楽しむための実用的な情報をご案内します。デリバリーの頼み方、屋台料理の安全性、辛さの目安、チップ、レストランでのマナー、食文化まで幅広く解説します。';

const pathways = [
  {
    title: '中国語がわからなくても注文できます',
    desc: 'デリバリーアプリの設定方法、ホテル住所の保存方法、配達員からの電話に落ち着いて対応するコツをご案内します。',
    href: '/ja/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
  },
  {
    title: '屋台料理を安心して楽しめます',
    desc: '回転の良さ、十分に加熱されているか、水の扱い、辛さを伝える表現を目安に、比較的安心して利用しやすいお店の選び方をご紹介します。',
    href: '/ja/posts/chengdu-street-food-safety-spice-levels-what-to-order/',
  },
  {
    title: '食事のマナーを確認できます',
    desc: 'チップが不要な場面、サービス料を確認したい場面、現地のレストランでの基本的なふるまいについて、わかりやすくご説明します。',
    href: '/ja/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/',
  },
];

const cultureLinks = [
  {
    href: 'https://baijiu365.com/baijiu-101/',
    title: '白酒の基本を知っておきましょう',
    desc: '会食や招待された夕食で、中国を代表する蒸留酒に触れる場面に備えて、押さえておきたい基礎知識をご紹介しています。',
  },
  {
    href: 'https://baijiu365.com/how-to-drink-baijiu/',
    title: '白酒を失礼なく楽しむ方法です',
    desc: '乾杯の作法、少量ずつ注がれるお酒への対応、フォーマルな食事の場で無理なく付き合うコツを詳しく知りたい方におすすめです。',
  },
];
---


<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main class="container-page py-10">
    <header class="max-w-3xl">
      <p class="section-kicker">食事とグルメ</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <CoverImage name="topic-chengdu-food" alt="中国のナイトマーケットに並ぶ、辛みのある四川の屋台料理" loading="lazy" />

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 md:grid-cols-3" aria-labelledby="food-pathways">
      <h2 id="food-pathways" class="sr-only">食事の計画に役立つガイド一覧をご案内します</h2>
      {pathways.map((item) => (
        <a href={item.href} class="card block hover:no-underline">
          <h3 class="text-lg font-bold text-gray-950">{item.title}</h3>
          <p class="mt-2 text-sm leading-6 text-gray-600">{item.desc}</p>
          <span class="mt-4 inline-flex text-sm font-semibold text-brand-700">詳しく見る</span>
        </a>
      ))}
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">関連ガイド</p>
            <h2>食事とマナーに関する記事をご案内します</h2>
          </div>
        </div>
        <div class="mt-6 grid gap-5 md:grid-cols-2">
          {posts.map((post) => (
            <a href={`/ja/posts/${post.slug}/`} class="card block hover:no-underline">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{post.data.category}</span>
              <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
        <p class="section-kicker">食文化を知るための参考情報です</p>
        <h2 class="mt-1 text-xl font-bold text-gray-950">白酒が出てきても戸惑わないようにしましょう</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          観光中の食事では、お酒の知識が必須になることはほとんどありません。ですが、招待された宴席や接待を伴う会食、
          地方の家庭での食事では、白酒で乾杯する場面が出てくることがあります。以下の参考資料ではその点をより詳しく扱っており、
          ChinaTripBoxでは旅行中に役立つ実務的な情報を中心にご案内しています。
        </p>
        <div class="mt-5 grid gap-3">
          {cultureLinks.map((link) => (
            <a href={link.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-950">{link.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{link.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>
  </main>
  <Footer />
</BaseLayout>
