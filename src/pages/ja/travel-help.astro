---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const title = 'China Travel Help';
const description =
  'Ask one-on-one China travel questions about payments, eSIMs, transport, apps, and first-day setup with AI-assisted triage and optional human help.';

const quickPrompts = [
  'My Alipay or WeChat Pay card will not link.',
  'I need an eSIM and app access plan for my trip.',
  'I need help getting from the airport to my hotel.',
  'I am not sure how much cash to bring.',
];

const supportAreas = [
  '決済 setup: Alipay, WeChat Pay, cards, fees, and cash backup',
  'Connectivity: eSIMs, roaming, VPN-sensitive apps, and airport arrival data',
  '交通: airport routes, metro, DiDi, taxis, and high-speed rail basics',
  'App use: translation, food delivery, maps, ride-hailing, and screenshots',
  'Trip setup: first-day checklist, city-specific prep, and practical next steps',
  'Human escalation: complex cases that need back-and-forth context',
];

const safetyRules = [
  'Do not send passport photos, full card numbers, passwords, PINs, or one-time codes.',
  'Do not ask anyone to log in to your accounts or complete identity checks for you.',
  'Do not use this for legal, immigration, medical, banking, or emergency advice.',
  'Check important rules with official sources, airlines, banks, telecoms, or app operators.',
];
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description} locale="ja">
  <Header locale="ja" />
  <main>
    <section class="border-b border-gray-200 bg-white">
      <div class="container-page grid gap-8 py-10 lg:grid-cols-[minmax(0,1fr)_360px] lg:items-start">
        <div>
          <p class="section-kicker">One-on-one travel support</p>
          <h1 class="mt-3 max-w-3xl text-4xl font-bold leading-tight text-gray-950 md:text-5xl">
            Ask a China travel question before it slows you down
          </h1>
          <p class="mt-5 max-w-2xl text-lg leading-8 text-gray-600">
            Start with free AI help for practical China travel problems. If your question needs
            human judgment, screenshots, or back-and-forth context, turn it into a review request.
          </p>
          <div class="mt-7 flex flex-wrap gap-3">
            <a href="#travel-help-chat" class="btn-primary">Start a request</a>
            <a href="/ja/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="btn-outline">Use pre-trip checklist</a>
            <a href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Travel%20Help%20Request" class="btn-outline">
              Email directly
            </a>
          </div>
        </div>

        <aside class="rounded-lg border border-gray-200 bg-gray-50 p-5">
          <p class="text-xs font-semibold uppercase tracking-wide text-brand-700">Pilot status</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">AI first, human review later</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Free answers are generated by AI. Human-reviewed trip help is still routed by email
            while we test the workflow.
          </p>
          <dl class="mt-5 grid gap-3 text-sm">
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">Best for</dt>
              <dd class="font-semibold text-gray-900">Practical trip setup</dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">Response path</dt>
              <dd class="font-semibold text-gray-900">AI + email follow-up</dd>
            </div>
            <div class="flex items-center justify-between gap-4">
              <dt class="text-gray-500">決済</dt>
              <dd class="font-semibold text-gray-900">Not active</dd>
            </div>
          </dl>
        </aside>
      </div>
    </section>

    <div class="container-page py-10">
      <section id="travel-help-chat" class="grid gap-8 lg:grid-cols-[minmax(0,1fr)_360px]">
        <div class="overflow-hidden rounded-lg border border-gray-200 bg-white shadow-sm">
          <div class="border-b border-gray-200 bg-gray-50 px-5 py-4">
          <p class="section-kicker">Free AI travel help</p>
            <h2 class="mt-1 text-2xl font-bold text-gray-950">Travel help desk</h2>
          </div>

          <div class="grid gap-0 md:grid-cols-[minmax(0,1fr)_280px]">
            <div class="flex min-h-[560px] flex-col">
              <div id="chat-log" class="flex-1 space-y-4 overflow-y-auto p-5" aria-live="polite">
                <div class="max-w-[88%] rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-700">
                  <strong class="block text-gray-950">ChinaTripBox Help</strong>
                  Tell us what you are trying to do, where you are in the trip, and what already
                  happened. The AI helper will suggest next steps and flag when human review is better.
                </div>
              </div>

              <div class="border-t border-gray-200 p-4">
                <div class="mb-3 flex flex-wrap gap-2">
                  {quickPrompts.map((prompt) => (
                    <button
                      type="button"
                      class="quick-prompt rounded-full border border-gray-200 bg-white px-3 py-1.5 text-left text-xs font-medium text-gray-700 hover:border-brand-300 hover:bg-brand-50"
                      data-prompt={prompt}
                    >
                      {prompt}
                    </button>
                  ))}
                </div>
                <form id="travel-help-form" class="grid gap-3">
                  <label class="sr-only" for="help-message">Your travel question</label>
                  <textarea
                    id="help-message"
                    name="message"
                    rows="5"
                    class="w-full resize-y rounded-lg border border-gray-300 px-4 py-3 text-sm leading-6 text-gray-900 outline-none transition focus:border-brand-500 focus:ring-2 focus:ring-brand-100"
                    placeholder="Example: I arrive in Shanghai tomorrow. My Mastercard will not link in WeChat Pay, but Alipay works. Can I still use metro, DiDi, and food delivery?"
                    required
                  ></textarea>
                  <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                    <p id="form-status" class="text-sm text-gray-500">Avoid sensitive personal data.</p>
                    <button id="help-submit" type="submit" class="btn-primary">Ask AI</button>
                  </div>
                </form>
              </div>
            </div>

            <aside class="border-t border-gray-200 bg-gray-50 p-5 md:border-l md:border-t-0">
              <h3 class="text-lg font-bold text-gray-950">Request details</h3>
              <div class="mt-4 grid gap-4">
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  Trip stage
                  <select id="trip-stage" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                    <option>Before departure</option>
                    <option>At the airport</option>
                    <option>Already in China</option>
                    <option>Long-stay planning</option>
                  </select>
                </label>
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  Main topic
                  <select id="help-topic" class="rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm font-normal text-gray-700">
                    <option>決済 apps</option>
                    <option>Internet and eSIM</option>
                    <option>交通 route</option>
                    <option>Food, delivery, or local apps</option>
                    <option>General trip setup</option>
                  </select>
                </label>
                <label class="grid gap-1 text-sm font-semibold text-gray-800">
                  City or route
                  <input
                    id="help-location"
                    class="rounded-lg border border-gray-300 px-3 py-2 text-sm font-normal text-gray-700"
                    placeholder="Shanghai, Beijing, airport to hotel..."
                  />
                </label>
              </div>

              <div class="mt-6 rounded-lg border border-amber-200 bg-amber-50 p-4">
                <p class="text-sm font-bold text-gray-950">Human upgrade</p>
                <p class="mt-2 text-sm leading-6 text-gray-700">
                  Use this when a simple guide is not enough. The prepared email includes your topic,
                  stage, location, and question so a person can reply with context.
                </p>
              </div>

              <a
                id="email-request-link"
                href="mailto:zh13809022788@gmail.com?subject=ChinaTripBox%20Travel%20Help%20Request"
                class="mt-5 inline-flex w-full items-center justify-center rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm font-semibold text-gray-800 hover:border-brand-600 hover:text-brand-600 hover:no-underline"
              >
                Prepare email request
              </a>
            </aside>
          </div>
        </div>

        <aside class="space-y-6">
          <section class="rounded-lg border border-gray-200 bg-white p-5">
            <p class="section-kicker">Scope</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">What this can help with</h2>
            <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
              {supportAreas.map((area) => (
                <li class="border-b border-gray-100 pb-3 last:border-b-0 last:pb-0">{area}</li>
              ))}
            </ul>
          </section>

          <section class="rounded-lg border border-amber-200 bg-amber-50 p-5">
            <p class="text-xs font-semibold uppercase tracking-wide text-amber-700">Safety rules</p>
            <h2 class="mt-2 text-xl font-bold text-gray-950">Keep sensitive data out</h2>
            <ul class="mt-4 grid gap-3 text-sm leading-6 text-gray-700">
              {safetyRules.map((rule) => (
                <li>{rule}</li>
              ))}
            </ul>
          </section>
        </aside>
      </section>

      <section class="mt-12 grid gap-5 md:grid-cols-3">
        <div class="card">
          <p class="section-kicker">Step 1</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Describe the issue</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            Share the city, app, route, deadline, and what you have already tried.
          </p>
        </div>
        <div class="card">
          <p class="section-kicker">Step 2</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Get a next step</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            The page gives a practical first response and points you toward relevant guides.
          </p>
        </div>
        <div class="card">
          <p class="section-kicker">Step 3</p>
          <h2 class="mt-2 text-xl font-bold text-gray-950">Escalate by email</h2>
          <p class="mt-3 text-sm leading-6 text-gray-600">
            For one-on-one help, send the prepared email and continue the conversation privately.
          </p>
        </div>
      </section>

      <section class="mt-10 rounded-lg border border-gray-200 bg-white p-5 md:p-6">
        <p class="section-kicker">Self-service first</p>
        <h2 class="mt-2 text-2xl font-bold text-gray-950">Guides that answer common first-trip questions</h2>
        <div class="mt-5 grid gap-4 md:grid-cols-2">
          <a href="/ja/posts/china-trip-planner-first-time-visitors-payment-esim-transport-apps/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">First-time China trip planner</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Use this when you are still arranging payment, data, transport, and your first arrival day.</p>
          </a>
          <a href="/ja/posts/what-to-set-up-before-traveling-to-china-alipay-esim-didi-train-tickets/" class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
            <h3 class="font-bold text-gray-950">Pre-departure setup checklist</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">Check Alipay, WeChat Pay, eSIM, DiDi, train tickets, translation, addresses, and cash backup before you fly.</p>
          </a>
        </div>
      </section>
    </div>
  </main>
  <Footer />
</BaseLayout>

<script>
  const form = document.getElementById('travel-help-form') as HTMLFormElement | null;
  const message = document.getElementById('help-message') as HTMLTextAreaElement | null;
  const chatLog = document.getElementById('chat-log');
  const status = document.getElementById('form-status');
  const stage = document.getElementById('trip-stage') as HTMLSelectElement | null;
  const topic = document.getElementById('help-topic') as HTMLSelectElement | null;
  const locationInput = document.getElementById('help-location') as HTMLInputElement | null;
  const emailLink = document.getElementById('email-request-link') as HTMLAnchorElement | null;
  const submitButton = document.getElementById('help-submit') as HTMLButtonElement | null;

  const guideLinks: Record<string, { label: string; href: string }> = {
    '決済 apps': { label: 'payment setup guide', href: '/ja/payment/' },
    'Internet and eSIM': { label: 'eSIM guide', href: '/ja/esim/' },
    '交通 route': { label: 'transport guide', href: '/ja/transport/' },
    'Food, delivery, or local apps': {
      label: 'food delivery guide',
      href: '/ja/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
    },
    'General trip setup': { label: 'tools page', href: '/ja/tools/' },
  };

  const escapeHtml = (value: string) =>
    value.replace(/[&<>"']/g, (char) => ({
      '&': '&amp;',
      '<': '&lt;',
      '>': '&gt;',
      '"': '&quot;',
      "'": '&#39;',
    })[char] ?? char);

  const updateEmailLink = () => {
    if (!emailLink) return;
    const selectedStage = stage?.value ?? 'Before departure';
    const selectedTopic = topic?.value ?? 'General trip setup';
    const place = locationInput?.value.trim() || 'Not specified';
    const question = message?.value.trim() || '';
    const body = [
      'ChinaTripBox Travel Help Request',
      '',
      `Trip stage: ${selectedStage}`,
      `Main topic: ${selectedTopic}`,
      `City or route: ${place}`,
      '',
      'Question:',
      question,
      '',
      'I understand I should not include passport photos, full bank card numbers, passwords, PINs, or one-time codes.',
    ].join('\n');

    emailLink.href = `mailto:zh13809022788@gmail.com?subject=${encodeURIComponent(
      `Travel help: ${selectedTopic}`,
    )}&body=${encodeURIComponent(body)}`;
  };

  const addBubble = (content: string, fromUser = false) => {
    if (!chatLog) return null;
    const wrapper = document.createElement('div');
    wrapper.className = fromUser
      ? 'ml-auto max-w-[88%] rounded-lg bg-brand-600 p-4 text-sm leading-6 text-white'
      : 'max-w-[88%] rounded-lg border border-gray-200 bg-gray-50 p-4 text-sm leading-6 text-gray-700';
    wrapper.innerHTML = content;
    chatLog.appendChild(wrapper);
    chatLog.scrollTop = chatLog.scrollHeight;
    return wrapper;
  };

  const formatAiAnswer = (value: string) =>
    escapeHtml(value)
      .replace(/\n{3,}/g, '\n\n')
      .replace(/\n/g, '<br>');

  const buildReply = (question: string) => {
    const selectedTopic = topic?.value ?? 'General trip setup';
    const selectedStage = stage?.value ?? 'Before departure';
    const place = locationInput?.value.trim();
    const guide = guideLinks[selectedTopic] ?? guideLinks['General trip setup'];
    const needsHuman =
      /screenshot|photo|declin|failed|stuck|urgent|tomorrow|today|passport|verification|identity|hotel|route/i.test(
        question,
      );

    const placeLine = place
      ? `Because this involves <strong>${escapeHtml(place)}</strong>, include the exact airport, station, hotel area, app name, and date when you email.`
      : 'Add your city, airport, station, hotel area, or app name before sending this for one-on-one help.';

    const escalation = needsHuman
      ? 'This looks like a good candidate for human follow-up because it may need context or back-and-forth checks.'
      : 'This may be answerable from the guide first; use human follow-up if the guide does not match your exact situation.';

    return `
      <strong class="block text-gray-950">Suggested next step</strong>
      <span class="block mt-1">Topic: ${escapeHtml(selectedTopic)}. Stage: ${escapeHtml(selectedStage)}.</span>
      <span class="block mt-2">${placeLine}</span>
      <span class="block mt-2">Start with the <a href="${guide.href}" class="font-semibold text-brand-700">${guide.label}</a>, then use the prepared email button if you still need one-on-one help.</span>
      <span class="block mt-2">${escalation}</span>
    `;
  };

  document.querySelectorAll<HTMLButtonElement>('.quick-prompt').forEach((button) => {
    button.addEventListener('click', () => {
      if (!message) return;
      message.value = button.dataset.prompt ?? '';
      message.focus();
      updateEmailLink();
    });
  });

  [message, stage, topic, locationInput].forEach((element) => {
    element?.addEventListener('input', updateEmailLink);
    element?.addEventListener('change', updateEmailLink);
  });

  const requestAiAnswer = async (question: string) => {
    const response = await fetch('/api/travel-help', {
      method: 'POST',
      headers: { 'content-type': 'application/json' },
      body: JSON.stringify({
        message: question,
        stage: stage?.value ?? 'Before departure',
        topic: topic?.value ?? 'General trip setup',
        location: locationInput?.value.trim() ?? '',
      }),
    });

    const data = await response.json() as { answer?: string; error?: string };
    if (!response.ok || !data.answer) {
      throw new Error(data.error || 'AI helper unavailable.');
    }
    return data.answer;
  };

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();
    const question = message?.value.trim() ?? '';
    if (!question) {
      if (status) status.textContent = 'Add your question first.';
      return;
    }
    addBubble(escapeHtml(question), true);
    const thinking = addBubble('AI is checking your travel question...');
    if (status) status.textContent = 'Asking AI travel help...';
    if (submitButton) submitButton.disabled = true;

    try {
      const answer = await requestAiAnswer(question);
      if (thinking) {
        thinking.innerHTML = `
          <strong class="block text-gray-950">AI travel help</strong>
          <span class="mt-2 block">${formatAiAnswer(answer)}</span>
          <span class="mt-3 block text-xs text-gray-500">For complex account, payment, visa, legal, medical, or emergency issues, verify with the official provider or request human review.</span>
        `;
      }
      if (status) status.textContent = 'AI answer ready. Use email if you want human review.';
    } catch {
      if (thinking) thinking.innerHTML = buildReply(question);
      if (status) status.textContent = 'AI is unavailable, so a local fallback answer was prepared.';
    } finally {
      if (submitButton) submitButton.disabled = false;
    }
    updateEmailLink();
  });

  updateEmailLink();
</script>
