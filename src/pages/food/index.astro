---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import AdSlot from '../../components/AdSlot.astro';
import CoverImage from '../../components/CoverImage.astro';

const posts = (await getCollection('posts'))
  .filter((p) => p.data.category === 'food' || p.data.tags.includes('tipping') || p.data.tags.includes('restaurants'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const title = 'China Food, Dining & Etiquette Guides';
const description =
  'Practical China food guides for foreign visitors: ordering delivery, street-food safety, spice levels, tipping, restaurant etiquette, and dining culture.';

const pathways = [
  {
    title: 'Order without Chinese',
    desc: 'Set up delivery apps, save hotel addresses, and avoid courier-call confusion.',
    href: '/posts/ordering-food-in-china-without-chinese-meituan-ele-me/',
  },
  {
    title: 'Eat street food safely',
    desc: 'Use turnover, visible heat, water habits, and spice phrases to choose better stalls.',
    href: '/posts/chengdu-street-food-safety-spice-levels-what-to-order/',
  },
  {
    title: 'Handle dining etiquette',
    desc: 'Know when not to tip, when service charges matter, and how local restaurant norms work.',
    href: '/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/',
  },
];

const cultureLinks = [
  {
    href: 'https://baijiu365.com/baijiu-101/',
    title: 'Baijiu 101',
    desc: 'Useful background if a banquet or hosted dinner includes China\'s national spirit.',
  },
  {
    href: 'https://baijiu365.com/how-to-drink-baijiu/',
    title: 'How to drink baijiu politely',
    desc: 'A deeper companion guide for toasts, small pours, and pacing yourself at formal meals.',
  },
];
import { getCategoryLabel } from '../../i18n/categories';
const locale = 'en';
---

<BaseLayout title={`${title} | ChinaTripBox`} description={description}>
  <Header />
  <main class="container-page py-10">
    <header>
      <p class="section-kicker">Food & dining</p>
      <h1 class="mt-2 text-4xl font-bold leading-tight text-gray-950">{title}</h1>
      <p class="mt-4 max-w-3xl text-justify text-lg leading-8 text-gray-600">{description}</p>
    </header>

    <div class="mt-6">
      <CoverImage name="topic-chinese-cuisine" alt="Spicy Sichuan street food dishes at a night market in China" loading="lazy" />
    </div>

    <div class="mt-8 space-y-4 text-justify text-lg leading-8 text-gray-600">
      <p>
  Chinese cuisine is one of the world’s great culinary traditions, with eight major regional styles. From fiery Sichuan hotpot to delicate Cantonese dim sum, from Beijing’s legendary Peking duck to Xi’an’s hand-pulled noodles — each region offers unique flavors and experiences. As a foreign visitor, you’ll find an incredible range of dining options, from street stalls and noodle shops to high-end restaurants and food courts in every mall. Modern China also offers food delivery apps like Meituan and Ele.me, making it easy to order meals to your hotel. Most cities have international food options too, though the real adventure is diving into local Chinese cuisine.
      </p>
      <p>
  When eating out in China, a few practical tips help: major cities accept Alipay and WeChat Pay everywhere, but cash is useful for small street vendors. English menus are common in tourist areas but having a translation app handy helps at local restaurants. Tipping is not expected in China. Food safety is generally good in popular restaurants, though sticking to busy places with high turnover is wise. For those with dietary restrictions, note that Chinese cooking uses MSG widely, and many dishes contain soybean oil. Vegetarian options exist but communicating clearly helps avoid misunderstandings.
      </p>
    </div>

    <AdSlot format="banner" />

    <section class="mt-8 grid gap-5 md:grid-cols-3 auto-rows-fr" aria-labelledby="food-pathways">
      <h2 id="food-pathways" class="sr-only">Food planning pathways</h2>
      {pathways.map((item) => (
        <a href={item.href} class="card flex flex-col justify-between rounded-xl border border-gray-200 bg-white p-5 shadow-sm hover:border-brand-200 hover:bg-brand-50 hover:no-underline h-full">
          <div>
            <h3 class="text-lg font-bold text-gray-950">{item.title}</h3>
            <p class="mt-2 text-sm leading-6 text-gray-600">{item.desc}</p>
          </div>
          <span class="mt-4 inline-flex text-sm font-semibold text-brand-700">Read guide</span>
        </a>
      ))}
    </section>

    <section class="mt-10 grid gap-8 lg:grid-cols-[1fr_320px]">
      <div>
        <div class="section-heading">
          <div>
            <p class="section-kicker">Guides</p>
            <h2>Food and etiquette articles</h2>
          </div>
        </div>
        <div class="mt-6 grid gap-5 md:grid-cols-2 auto-rows-fr">
          {posts.map((post) => (
            <a href={`/posts/${post.slug}/`} class="card flex flex-col p-5 rounded-xl border border-gray-200 bg-white shadow-sm hover:border-brand-200 hover:bg-brand-50 hover:no-underline h-full">
              <span class="text-xs font-semibold uppercase tracking-wide text-brand-700">{getCategoryLabel(post.data.category, locale)}</span>
              <h3 class="mt-2 text-lg font-bold text-gray-950">{post.data.title}</h3>
              <p class="mt-2 text-sm leading-6 text-gray-600 flex-1">{post.data.description}</p>
            </a>
          ))}
        </div>
      </div>

      <aside class="rounded-lg border border-gray-200 bg-white p-5 shadow-sm">
        <p class="section-kicker">Culture companion</p>
        <h2 class="mt-1 text-xl font-bold text-gray-950">When baijiu appears</h2>
        <p class="mt-3 text-sm leading-6 text-gray-600">
          Most tourist meals do not require alcohol knowledge, but hosted banquets, business dinners,
          and rural family meals sometimes include baijiu toasts. These companion resources go deeper
          while ChinaTripBox stays focused on travel logistics.
        </p>
        <div class="mt-5 grid gap-3">
          {cultureLinks.map((link) => (
            <a href={link.href} class="rounded-lg border border-gray-200 p-4 hover:border-brand-200 hover:bg-brand-50 hover:no-underline">
              <h3 class="text-sm font-semibold text-gray-950">{link.title}</h3>
              <p class="mt-1 text-sm leading-6 text-gray-600">{link.desc}</p>
            </a>
          ))}
        </div>
      </aside>
    </section>
  
    <section class="mt-12 rounded-lg border border-gray-200 bg-gray-50 p-6">
      <h2 class="text-xl font-bold text-gray-950">More Food & Dining Tips</h2>
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <a href="/posts/china-food-guide-regional-foreigners/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Regional Food Guide</p>
          <p class="mt-1 text-sm text-gray-600">What to eat by region: Sichuan, Cantonese, Beijing and more</p>
        </a>
        <a href="/posts/ordering-food-in-china-without-chinese-meituan-ele-me/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Order Food Without Chinese</p>
          <p class="mt-1 text-sm text-gray-600">Use Meituan and Ele.me as a foreign visitor</p>
        </a>
        <a href="/posts/chengdu-street-food-safety-spice-levels-what-to-order/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Chengdu Street Food</p>
          <p class="mt-1 text-sm text-gray-600">Safety tips, spice levels, and must-try dishes</p>
        </a>
        <a href="/posts/tipping-in-china-when-it-s-expected-and-when-it-s-not/" class="rounded-lg bg-white p-4 shadow-sm hover:shadow transition">
          <p class="font-semibold text-brand-600">Tipping Etiquette</p>
          <p class="mt-1 text-sm text-gray-600">When to tip and when not to in China</p>
        </a>
      </div>
    </section>
</main>
  <Footer />
</BaseLayout>
